<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add
          name="aspNetCore"
          path="*"
          verb="*"
          modules="AspNetCoreModuleV2"
          resourceType="Unspecified"
        />
      </handlers>
      <aspNetCore
        processPath="dotnet"
        arguments=".\ShopInventory.dll"
        stdoutLogEnabled="true"
        stdoutLogFile=".\logs\stdout"
        hostingModel="InProcess"
        requestTimeout="00:05:00"
      >
        <environmentVariables>
          <!-- Core Settings -->
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <!-- Database Connection -->
          <environmentVariable
            name="ConnectionStrings__DefaultConnection"
            value="Host=localhost;Port=5432;Database=shopinventory;Username=shopinventory;Password=YOUR_DB_PASSWORD;Maximum Pool Size=100;Minimum Pool Size=10"
          />
          <!-- JWT Configuration -->
          <environmentVariable
            name="Jwt__SecretKey"
            value="YOUR_JWT_SECRET_KEY_AT_LEAST_64_CHARACTERS_LONG_FOR_SECURITY"
          />
          <!-- SAP Business One -->
          <environmentVariable
            name="SAP__ServiceLayerUrl"
            value="https://10.10.10.6:50000/b1s/v1/"
          />
          <environmentVariable name="SAP__CompanyDB" value="KEFALOS_USD_NEW2" />
          <environmentVariable name="SAP__Username" value="manager" />
          <environmentVariable name="SAP__Password" value="%$JmePle17" />
          <environmentVariable name="SAP__SkipCertificateValidation" value="true" />
          <!-- Security -->
          <environmentVariable
            name="Security__ApiKeys__0__Key"
            value="YOUR_API_KEY_FOR_SERVICE_COMMUNICATION"
          />
          <environmentVariable name="Security__AllowedOrigins__0" value="https://your-domain.com" />
          <!-- Email (Optional) -->
          <environmentVariable name="Email__SmtpHost" value="smtp.your-provider.com" />
          <environmentVariable name="Email__SmtpUsername" value="your-email@domain.com" />
          <environmentVariable name="Email__SmtpPassword" value="YOUR_SMTP_PASSWORD" />
          <environmentVariable name="Email__FromEmail" value="noreply@your-domain.com" />
          <!-- Payment Gateways (Optional - uncomment if needed) -->
          <!--
          <environmentVariable name="PaymentGateways__PayNow__IntegrationId" value="" />
          <environmentVariable name="PaymentGateways__PayNow__IntegrationKey" value="" />
          <environmentVariable name="PaymentGateways__Innbucks__ApiKey" value="" />
          <environmentVariable name="PaymentGateways__Innbucks__ApiSecret" value="" />
          <environmentVariable name="PaymentGateways__Innbucks__MerchantId" value="" />
          <environmentVariable name="PaymentGateways__Ecocash__ApiKey" value="" />
          <environmentVariable name="PaymentGateways__Ecocash__ApiSecret" value="" />
          <environmentVariable name="PaymentGateways__Ecocash__MerchantCode" value="" />
          <environmentVariable name="PaymentGateways__Ecocash__MerchantPin" value="" />
          -->
          <!-- Revmax Fiscal (Optional - uncomment if needed) -->
          <!--
          <environmentVariable name="Revmax__BaseUrl" value="" />
          <environmentVariable name="Revmax__DeviceId" value="" />
          <environmentVariable name="Revmax__OperatorId" value="" />
          -->
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
