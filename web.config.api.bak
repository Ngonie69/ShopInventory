<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\ShopInventory.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="InProcess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <environmentVariable name="ConnectionStrings__DefaultConnection" value="Host=localhost;Port=5432;Database=ShopInventory;Username=postgres;Password=YOUR_DB_PASSWORD" />
          <environmentVariable name="Jwt__SecretKey" value="YOUR_JWT_SECRET_KEY_AT_LEAST_64_CHARACTERS_LONG_FOR_SECURITY" />
          <environmentVariable name="SAP__ServiceLayerUrl" value="https://10.10.10.6:50000/b1s/v1/" />
          <environmentVariable name="SAP__CompanyDB" value="KEFALOS_USD_NEW2" />
          <environmentVariable name="SAP__Username" value="manager" />
          <environmentVariable name="SAP__Password" value="YOUR_SAP_PASSWORD" />
          <environmentVariable name="SAP__AllowedServerCertificateThumbprints__0" value="YOUR_SAP_SERVER_CERTIFICATE_THUMBPRINT_WITHOUT_SPACES" />
          <environmentVariable name="SAP__SkipCertificateValidation" value="false" />
          <environmentVariable name="Security__ApiKeys__0__Key" value="YOUR_API_KEY_FOR_SERVICE_COMMUNICATION" />
          <environmentVariable name="Security__AllowedOrigins__0" value="https://your-domain.com" />
          <environmentVariable name="Email__SmtpServer" value="mail.kefaloscheese.com" />
          <environmentVariable name="Email__SmtpPort" value="587" />
          <environmentVariable name="Email__Username" value="alerts@kefaloscheese.com" />
          <environmentVariable name="Email__Password" value="YOUR_SMTP_PASSWORD" />
          <environmentVariable name="Email__FromEmail" value="alerts@kefaloscheese.com" />
          <environmentVariable name="Email__FromName" value="Shop Inventory System" />
          <environmentVariable name="Email__UseSsl" value="true" />
          <environmentVariable name="FileStorage__UploadPath" value="C:\inetpub\ShopInventory-API\uploads" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
