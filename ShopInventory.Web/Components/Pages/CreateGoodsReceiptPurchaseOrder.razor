@page "/goods-receipt-pos/create"
@attribute [Authorize(Roles = "Admin,Manager")]
@rendermode InteractiveServer

<PageTitle>Create Goods Receipt PO</PageTitle>

<datalist id="goods-receipt-products">
    @foreach (var product in products)
    {
        <option value="@product.ItemCode">@product.ItemName</option>
    }
</datalist>

<datalist id="goods-receipt-warehouses">
    @foreach (var warehouse in warehouses)
    {
        <option value="@warehouse.WarehouseCode">@warehouse.WarehouseName</option>
    }
</datalist>

<div class="pdoc-create-page is-receipt">
    <div class="container-fluid pdoc-create-container">
        <div class="pdoc-create-breadcrumb">
            <a href="/goods-receipt-pos">Goods Receipt POs</a>
            <span class="sep">/</span>
            <span>Create New</span>
        </div>

        <div class="pdoc-create-header">
            <div class="pdoc-create-header-left">
                <div class="pdoc-create-header-icon"><i class="bi bi-box-arrow-in-down"></i></div>
                <div>
                    <h2>Create Goods Receipt PO</h2>
                    <p>Post a real SAP goods receipt purchase order and optionally link each received line back to the source purchase order line using base document fields.</p>
                </div>
            </div>
            <div class="pdoc-create-header-actions">
                <button type="button" class="btn-doc-back" @onclick="GoBack" disabled="@isSubmitting">
                    <i class="bi bi-arrow-left"></i>
                    <span>Back</span>
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="pdoc-create-alert error">@errorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="pdoc-create-alert success">@successMessage</div>
        }

        <div class="pdoc-create-card">
            <div class="pdoc-create-card-title"><i class="bi bi-building"></i> Supplier</div>
            @if (isLoadingLookups)
            {
                <div class="pdoc-create-loading">
                    <span class="spinner-border spinner-border-sm"></span>
                    <span>Loading suppliers, products, and warehouses...</span>
                </div>
            }
            <div class="pdoc-create-field">
                <label>Supplier <span class="req">*</span></label>
                @if (selectedSupplier is not null)
                {
                    <div class="pdoc-create-selected-card">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="pdoc-create-selected-code">
                                    <i class="bi bi-check-circle-fill me-1"></i>@selectedSupplier.CardCode
                                </div>
                                <div class="pdoc-create-selected-name">@selectedSupplier.CardName</div>
                                @if (!string.IsNullOrWhiteSpace(selectedSupplier.Currency) && !string.Equals(selectedSupplier.Currency, "##", StringComparison.OrdinalIgnoreCase))
                                {
                                    <div class="pdoc-create-selected-meta"><i class="bi bi-cash-coin me-1"></i>@selectedSupplier.Currency</div>
                                }
                            </div>
                            <button type="button" class="pdoc-create-clear-button" @onclick="ClearSupplier">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="pdoc-create-search-wrapper">
                        <input class="@(HasError("CardCode") ? "has-error" : string.Empty)"
                               value="@supplierSearchTerm"
                               @oninput="OnSupplierInput"
                               @onfocus="ShowSupplierResults"
                               @onblur="HandleSupplierBlur"
                               placeholder="Search supplier code or name" />
                        @if (showSupplierResults && FilteredSuppliers.Any())
                        {
                            <div class="pdoc-create-search-results" @onmousedown:preventDefault>
                                @foreach (var supplier in FilteredSuppliers)
                                {
                                    <button class="pdoc-create-search-option" type="button" @onmousedown="() => SelectSupplier(supplier)">
                                        <strong>@supplier.CardCode - @supplier.CardName</strong>
                                        <span class="pdoc-create-search-meta">@supplier.Currency</span>
                                    </button>
                                }
                            </div>
                        }
                        else if (showSupplierResults && !string.IsNullOrWhiteSpace(supplierSearchTerm))
                        {
                            <div class="pdoc-create-search-results">
                                <div class="pdoc-create-search-empty">
                                    <i class="bi bi-search me-1"></i>No suppliers found
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (HasError("CardCode"))
                {
                    <div class="pdoc-create-inline-error">@GetError("CardCode")</div>
                }
            </div>
        </div>

        <div class="pdoc-create-card">
            <div class="pdoc-create-card-title"><i class="bi bi-info-circle"></i> Receipt Details</div>
            <div class="pdoc-create-form-grid three-cols">
                <div class="pdoc-create-field">
                    <label>Posting Date</label>
                    <input type="date" @bind-value="goodsReceipt.DocDate" @bind-value:format="yyyy-MM-dd" />
                </div>
                <div class="pdoc-create-field">
                    <label>Due Date</label>
                    <input type="date" @bind-value="goodsReceipt.DocDueDate" @bind-value:format="yyyy-MM-dd" />
                </div>
                <div class="pdoc-create-field">
                    <label>Currency</label>
                    <input @bind="goodsReceipt.DocCurrency" placeholder="e.g. USD" />
                </div>
                <div class="pdoc-create-field">
                    <label>Supplier Reference</label>
                    <input @bind="goodsReceipt.NumAtCard" placeholder="Optional supplier ref" />
                </div>
                <div class="pdoc-create-field">
                    <label>Header Discount %</label>
                    <input type="number" step="0.01" @bind-value="goodsReceipt.DiscountPercent" />
                </div>
                <div class="pdoc-create-field full">
                    <label>Comments</label>
                    <textarea rows="3" @bind="goodsReceipt.Comments" placeholder="Optional receipt notes"></textarea>
                </div>
            </div>
        </div>

        <div class="pdoc-create-card">
            <div class="pdoc-create-section-header">
                <div class="pdoc-create-section-title"><i class="bi bi-list-ul"></i> Received Lines</div>
                <button type="button" class="btn-doc-add" @onclick="AddLine">
                    <i class="bi bi-plus-lg"></i>
                    <span>Add Line</span>
                </button>
            </div>

            @if (HasError("Lines"))
            {
                <div class="pdoc-create-inline-error" style="margin-bottom:.75rem;">@GetError("Lines")</div>
            }

            <div class="pdoc-create-table-wrap">
                <table class="pdoc-create-table">
                    <thead>
                        <tr>
                            <th>Item Code</th>
                            <th>Description</th>
                            <th class="cell-compact">Qty</th>
                            <th class="cell-compact">Unit Price</th>
                            <th>Warehouse</th>
                            <th class="cell-compact">Tax Code</th>
                            <th class="cell-mini">PO Entry</th>
                            <th class="cell-mini">PO Line</th>
                            <th class="cell-total">Total</th>
                            <th class="cell-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var index = 0; index < goodsReceipt.Lines.Count; index++)
                        {
                            var lineIndex = index;
                            var line = goodsReceipt.Lines[lineIndex];
                            <tr>
                                <td>
                                    <input class="@(HasError($"Lines[{lineIndex}].ItemCode") ? "has-error" : string.Empty)"
                                           list="goods-receipt-products"
                                           @bind="line.ItemCode"
                                           @onblur="() => SyncProduct(lineIndex)"
                                           placeholder="Item code" />
                                    @if (HasError($"Lines[{lineIndex}].ItemCode"))
                                    {
                                        <div class="pdoc-create-inline-error">@GetError($"Lines[{lineIndex}].ItemCode")</div>
                                    }
                                </td>
                                <td>
                                    <input @bind="line.ItemDescription" placeholder="Description" />
                                </td>
                                <td class="cell-compact">
                                    <input class="@(HasError($"Lines[{lineIndex}].Quantity") ? "has-error" : string.Empty)"
                                           type="number"
                                           step="0.01"
                                           @bind-value="line.Quantity" />
                                    @if (HasError($"Lines[{lineIndex}].Quantity"))
                                    {
                                        <div class="pdoc-create-inline-error">@GetError($"Lines[{lineIndex}].Quantity")</div>
                                    }
                                </td>
                                <td class="cell-compact">
                                    <input type="number" step="0.01" @bind-value="line.UnitPrice" />
                                </td>
                                <td>
                                    <input list="goods-receipt-warehouses" @bind="line.WarehouseCode" placeholder="Warehouse" />
                                </td>
                                <td class="cell-compact">
                                    <input @bind="line.TaxCode" placeholder="Tax code" />
                                </td>
                                <td class="cell-mini">
                                    <input type="number" @bind-value="line.BaseEntry" />
                                </td>
                                <td class="cell-mini">
                                    <input type="number" @bind-value="line.BaseLine" />
                                </td>
                                <td class="cell-total">@CalculateLineTotal(line).ToString("N2")</td>
                                <td class="cell-actions">
                                    <button type="button"
                                            class="btn-doc-remove"
                                            @onclick="() => RemoveLine(lineIndex)"
                                            disabled="@(goodsReceipt.Lines.Count == 1)">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="pdoc-create-total-banner">
                <div class="pdoc-create-total-item">
                    <span>Subtotal</span>
                    <strong>@SubTotal.ToString("N2") @goodsReceipt.DocCurrency</strong>
                </div>
                <div class="pdoc-create-total-item">
                    <span>Header Discount</span>
                    <strong>@HeaderDiscountAmount.ToString("N2")</strong>
                </div>
                <div class="pdoc-create-total-item">
                    <span>Estimated Total</span>
                    <strong>@EstimatedTotal.ToString("N2")</strong>
                </div>
            </div>
            <p class="pdoc-create-summary-note" style="margin: .85rem 0 0;">
                Use the optional base entry and base line columns when this receipt should close specific purchase-order lines in SAP. Base document type is fixed to purchase order.
            </p>
        </div>

        <div class="pdoc-create-footer">
            <button type="button" class="btn-doc-secondary" @onclick="GoBack">Cancel</button>
            <button type="button" class="btn-doc-submit" @onclick="SubmitAsync" disabled="@(isSubmitting || isLoadingLookups)">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                }
                <span>Create GRPO</span>
            </button>
        </div>
    </div>
</div>