"Driver",
"Merchandiser", "SalesRep", "MerchandiserPurchaseOrderViewer", "Lab" };
    private List<string> availableSections = new() { "Cheeseman", "Factory", "Graniteside", "Machipisa", "Bulawayo" };
    private List<WarehouseDto> availableWarehouses = new();
    private bool isLoadingWarehouses = false;
    private List<BusinessPartnerDto> availableCustomers = new();
    private bool isLoadingCustomers = false;
    private string customerSearchTerm = string.Empty;
    private static readonly Dictionary<string, string> allPaymentMethods = new()
    {
        { "cash", "Cash" },
        { "transfer", "Transfer" },
        { "check", "Check" },
        { "credit", "Credit Card" }
    };
    private Dictionary<string, List<PermissionModel>>? permissionCategories;

    // Payment settings data (for Cashier/DepotController roles)
    private List<GLAccountDto> availableGLAccounts = new();
    private bool isLoadingGLAccounts = false;
    private string glAccountSearchTerm = string.Empty;
    private List<BusinessPartnerDto> availablePaymentBPs = new();
    private bool isLoadingPaymentBPs = false;
    private string paymentBPSearchTerm = string.Empty;

    private static readonly HashSet<string> _excludedAccountTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        "at_Expenses", "at_Revenues"
    };

    private IEnumerable<GLAccountDto> FilteredGLAccounts
    {
        get
        {
            var eligible = availableGLAccounts.Where(gl => string.IsNullOrEmpty(gl.AccountType) ||
!_excludedAccountTypes.Contains(gl.AccountType));
            if (string.IsNullOrWhiteSpace(glAccountSearchTerm))
                return eligible;
            return eligible.Where(gl =>
                (gl.Code?.Contains(glAccountSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (gl.Name?.Contains(glAccountSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
        }
    }

    private IEnumerable<BusinessPartnerDto> FilteredPaymentBPs
    {
        get
        {
            var source = string.IsNullOrWhiteSpace(paymentBPSearchTerm)
                ? availablePaymentBPs
                : availablePaymentBPs.Where(bp =>
                    (bp.CardCode?.Contains(paymentBPSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (bp.CardName?.Contains(paymentBPSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
            return source.OrderByDescending(bp => userModel.AllowedPaymentBusinessPartners.Contains(bp.CardCode!))
                         .ThenBy(bp => bp.CardCode);
        }
    }

