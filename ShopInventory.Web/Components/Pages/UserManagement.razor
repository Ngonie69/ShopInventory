@page "/user-management"
@using ShopInventory.Web.Models
@using ShopInventory.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject IUserManagementService UserService
@inject IAuditService AuditService
@inject AuthenticationStateProvider AuthStateProvider
@inject IMasterDataCacheService MasterDataCache
@inject IJSRuntime JS
@inject IAppSettingsProvider AppSettings
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>User Management - Shop Inventory</PageTitle>

<div class="um-page">
    <!-- Page Header -->
    <div class="um-header">
        <div class="um-header-left">
            <div class="um-header-icon">
                <i class="bi bi-people-fill"></i>
            </div>
            <div>
                <h1 class="um-title">User Management</h1>
                <p class="um-subtitle">Manage accounts, permissions, and security</p>
            </div>
        </div>
        <div class="um-header-actions">
            <button class="um-btn um-btn-primary" @onclick="ShowCreateMobileUserModal"
                    title="Create a PodOperator user for mobile POD uploads">
                <i class="bi bi-phone"></i>
                <span>Add Mobile User</span>
            </button>
            <button class="um-btn um-btn-primary" @onclick="ShowCreateModal">
                <i class="bi bi-plus-lg"></i>
                <span>Add User</span>
            </button>
        </div>
    </div>

    <!-- Tabs -->
    <div class="um-tabs">
        <button class="um-tab @(activeTab == "users" ? "active" : "")" @onclick="@(() => SetTab("users"))">
            <i class="bi bi-people"></i> Users
            <span class="um-tab-count">@users.Count</span>
        </button>
        <button class="um-tab @(activeTab == "permissions" ? "active" : "")" @onclick="@(() => SetTab("permissions"))">
            <i class="bi bi-shield-lock"></i> Permissions
        </button>
        <button class="um-tab @(activeTab == "security" ? "active" : "")" @onclick="@(() => SetTab("security"))">
            <i class="bi bi-fingerprint"></i> Security
        </button>
    </div>

    @if (activeTab == "users")
    {
        <!-- Filter Bar -->
        <div class="um-filter-bar">
            <div class="um-search-box">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search by name or email..." @bind="searchTerm" @bind:event="oninput"
                       @onkeyup="OnSearchKeyUp" />
            </div>
            <select class="um-select" @bind="roleFilter" @bind:after="LoadUsers">
                <option value="">All Roles</option>
                @foreach (var role in availableRoles)
                {
                    <option value="@role">@role</option>
                }
            </select>
            <select class="um-select" @bind="statusFilter" @bind:after="LoadUsers">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="locked">Locked</option>
            </select>
            @if (!string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(roleFilter) ||
                                                                                                                                                                                            !string.IsNullOrEmpty(statusFilter))
            {
                <button class="um-btn um-btn-ghost" @onclick="ResetFilters">
                    <i class="bi bi-x-lg"></i> Clear
                </button>
            }
        </div>

        <!-- Users List -->
        @if (isLoading)
        {
            <div class="um-loading">
                <div class="um-spinner"></div>
                <p>Loading users...</p>
            </div>
        }
        else if (users.Any())
        {
            <div class="um-user-list">
                @foreach (var user in users)
                {
                    <div class="um-user-card @(!user.IsActive ? "inactive" : "") @(user.IsLocked ? "locked" : "")">
                        <div class="um-user-main">
                            <div class="um-avatar @GetAvatarClass(user)">
                                @user.Username[0].ToString().ToUpper()
                            </div>
                            <div class="um-user-info">
                                <div class="um-user-name">@user.Username</div>
                                <div class="um-user-email">@(user.Email ?? "No email")</div>
                            </div>
                            <div class="um-user-meta">
                                <span class="um-badge @GetRoleBadgeClass(user.Role)">@user.Role</span>
                                @if (user.IsLocked)
                                {
                                    <span class="um-badge um-badge-locked"><i class="bi bi-lock-fill"></i> Locked</span>
                                }
                                else if (user.IsActive)
                                {
                                    <span class="um-badge um-badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="um-badge um-badge-inactive">Inactive</span>
                                }
                                @if (user.TwoFactorEnabled)
                                {
                                    <span class="um-badge um-badge-2fa"><i class="bi bi-shield-fill-check"></i> 2FA</span>
                                }
                            </div>
                            <div class="um-user-login">
                                <span class="um-login-label">Last login</span>
                                <span class="um-login-time @(user.LastLoginAt.HasValue ? string.Empty : "um-login-never")"
                                      title="@GetLastLoginTitle(user.LastLoginAt)">
                                    @GetLastLoginDisplay(user.LastLoginAt)
                                </span>
                            </div>
                        </div>
                        <div class="um-user-actions">
                            <button class="um-action-btn" @onclick="@(() => ShowEditModal(user))" title="Edit user">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <button class="um-action-btn" @onclick="@(() => ShowPermissionsModal(user))" title="Manage permissions">
                                <i class="bi bi-shield-lock"></i>
                            </button>
                            <div class="um-action-more">
                                <button class="um-action-btn" @onclick="() => ToggleActionMenu(user.Id)" title="More actions">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                @if (openMenuUserId == user.Id)
                                {
                                    <div class="um-dropdown-menu" @onclick:stopPropagation="true">
                                        @if (user.IsLocked)
                                        {
                                            <button class="um-dropdown-item"
                                                    @onclick="@(async () => { CloseActionMenu(); await UnlockUser(user); })">
                                                <i class="bi bi-unlock-fill text-warning"></i> Unlock Account
                                            </button>
                                        }
                                        @if (user.TwoFactorEnabled)
                                        {
                                            <button class="um-dropdown-item"
                                                    @onclick="@(async () => { CloseActionMenu(); await ResetTwoFactor(user); })">
                                                <i class="bi bi-shield-x text-secondary"></i> Reset 2FA
                                            </button>
                                        }
                                        <button class="um-dropdown-item"
                                                @onclick="@(() => { CloseActionMenu(); ShowResetPasswordModal(user); })">
                                            <i class="bi bi-key-fill text-warning"></i> Reset Password
                                        </button>
                                        @if (user.IsActive)
                                        {
                                            <button class="um-dropdown-item um-dropdown-danger"
                                                    @onclick="@(async () => { CloseActionMenu(); await ConfirmDeactivate(user); })">
                                                <i class="bi bi-person-dash-fill"></i> Deactivate User
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="um-dropdown-item um-dropdown-success"
                                                    @onclick="@(async () => { CloseActionMenu(); await ActivateUser(user); })">
                                                <i class="bi bi-person-check-fill"></i> Activate User
                                            </button>
                                        }
                                        <div class="um-dropdown-divider"></div>
                                        <button class="um-dropdown-item um-dropdown-danger"
                                                @onclick="@(() => { CloseActionMenu(); ConfirmDeleteUser(user); })">
                                            <i class="bi bi-trash-fill"></i> Delete User
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="um-pagination">
                    <span class="um-page-info">Showing @((currentPage - 1) * pageSize + 1)–@Math.Min(currentPage * pageSize,
                                                                                                                                                                                                                                                                                                                                                                                    users.Count + (currentPage - 1) * pageSize) of page @currentPage</span>
                        <div class="um-page-buttons">
                            <button class="um-page-btn" disabled="@(currentPage <= 1)" @onclick="() => GoToPage(currentPage - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                var pg = i;
                                <button class="um-page-btn @(pg == currentPage ? "active" : "")" @onclick="() => GoToPage(pg)">@pg</button>
                            }
                            <button class="um-page-btn" disabled="@(currentPage >= totalPages)"
                                    @onclick="() => GoToPage(currentPage + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                        <select class="um-select um-select-sm" @bind="pageSize" @bind:after="OnPageSizeChanged">
                            <option value="10">10 / page</option>
                            <option value="20">20 / page</option>
                            <option value="50">50 / page</option>
                        </select>
                    </div>
                }
            }
            else
            {
                <div class="um-empty">
                    <i class="bi bi-people"></i>
                    <h3>No users found</h3>
                    <p>Try adjusting your search or filters</p>
                </div>
            }
        }
        else if (activeTab == "permissions")
        {
            <div class="um-section-card">
                <div class="um-section-header">
                    <h3><i class="bi bi-list-check me-2"></i>Available Permissions</h3>
                </div>
                @if (permissionCategories != null)
                {
                    @foreach (var category in permissionCategories)
                    {
                        <details class="um-perm-group">
                            <summary class="um-perm-summary">
                                <span>@category.Key</span>
                                <span class="um-perm-count">@category.Value.Count</span>
                            </summary>
                            <div class="um-perm-list">
                                @foreach (var perm in category.Value)
                                {
                                    <div class="um-perm-item">
                                        <code class="um-perm-code">@perm.Code</code>
                                        <span class="um-perm-name">@perm.Name</span>
                                        <span class="um-perm-desc">@perm.Description</span>
                                    </div>
                                }
                            </div>
                        </details>
                    }
                }
            </div>

            <div class="um-section-card" style="margin-top: 1.5rem;">
                <div class="um-section-header">
                    <h3><i class="bi bi-diagram-3 me-2"></i>Default Role Permissions</h3>
                </div>
                <div class="um-role-grid">
                    @foreach (var role in new[] { "Admin", "Cashier", "StockController", "DepotController", "PodOperator" })
                    {
                        <div class="um-role-card">
                            <div class="um-role-name">
                                <span class="um-badge @GetRoleBadgeClass(role)">@role</span>
                            </div>
                            <p class="um-role-desc">
                                @if (role == "Admin")
                                {
                                    <text>Full system access including user management and all permissions</text>
                                }
                                else if (role == "Cashier")
                                {
                                    <text>Access to payments, invoicing, sales orders, and credit notes</text>
                                }
                                else if (role == "StockController")
                                {
                                    <text>Access to inventory transfers only</text>
                                }
                                else if (role == "DepotController")
                                {
                                    <text>Access to payments and inventory transfers</text>
                                }
                                else if (role == "PodOperator")
                                {
                                    <text>Access to Proof of Delivery (POD) flows scoped to an assigned section</text>
                                }
                            </p>
                        </div>
                    }
                </div>
            </div>
        }
        else if (activeTab == "security")
        {
            <!-- Security Stats -->
            <div class="um-stats-grid">
                <div class="um-stat-card um-stat-success">
                    <div class="um-stat-icon"><i class="bi bi-shield-fill-check"></i></div>
                    <div class="um-stat-value">@usersWithTwoFactor</div>
                    <div class="um-stat-label">2FA Enabled</div>
                </div>
                <div class="um-stat-card um-stat-warning">
                    <div class="um-stat-icon"><i class="bi bi-shield-fill-exclamation"></i></div>
                    <div class="um-stat-value">@usersWithoutTwoFactor</div>
                    <div class="um-stat-label">2FA Disabled</div>
                </div>
                <div class="um-stat-card um-stat-danger">
                    <div class="um-stat-icon"><i class="bi bi-lock-fill"></i></div>
                    <div class="um-stat-value">@lockedUsers</div>
                    <div class="um-stat-label">Locked Accounts</div>
                </div>
            </div>

            <div class="um-section-card">
                <div class="um-section-header">
                    <h3><i class="bi bi-clock-history me-2"></i>Recent Security Events</h3>
                </div>
                @if (securityEvents.Any())
                {
                    <div class="um-event-list">
                        @foreach (var evt in securityEvents)
                        {
                            <div class="um-event-item">
                                <div class="um-event-icon">
                                    <i class="bi @GetSecurityEventIcon(evt.EventType)"></i>
                                </div>
                                <div class="um-event-info">
                                    <span class="um-event-user">@evt.Username</span>
                                    <span class="um-event-desc">@evt.Description</span>
                                </div>
                                <span class="um-event-time">@evt.Timestamp.ToString("dd MMM yyyy HH:mm")</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="um-empty" style="padding: 2rem;">
                        <i class="bi bi-shield-check" style="font-size: 2.5rem;"></i>
                        <p>No recent security events</p>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Create/Edit User Modal -->
    @if (showUserModal)
    {
        <div class="um-overlay" @onclick="CloseModal">
            <div class="um-modal" @onclick:stopPropagation="true">
                <div class="um-modal-header">
                    <h2>@(editingUser == null ? "Create New User" : $"Edit {editingUser.Username}")</h2>
                    <button class="um-modal-close" @onclick="CloseModal"><i class="bi bi-x-lg"></i></button>
                </div>
                <EditForm Model="userModel" OnValidSubmit="SaveUser">
                    <DataAnnotationsValidator />
                    <div class="um-modal-body">
                        <ValidationSummary class="text-danger" style="font-size: .82rem; margin-bottom: .75rem;" />
                        <div class="um-form-grid">
                            <div class="um-form-field">
                                <label>Username <span class="required">*</span></label>
                                <InputText class="um-input" @bind-Value="userModel.Username" placeholder="e.g. john.doe" />
                                <ValidationMessage For="@(() => userModel.Username)" />
                            </div>
                            <div class="um-form-field">
                                <label>Email</label>
                                <InputText class="um-input" @bind-Value="userModel.Email" placeholder="user@company.com" />
                                <ValidationMessage For="@(() => userModel.Email)" />
                            </div>
                            @if (editingUser == null)
                            {
                                <div class="um-form-field">
                                    <label>Password <span class="required">*</span></label>
                                    <InputText type="password" class="um-input" @bind-Value="userModel.Password"
                                               placeholder="Min. 6 characters" />
                                    <ValidationMessage For="@(() => userModel.Password)" />
                                </div>
                                <div class="um-form-field">
                                    <label>Confirm Password <span class="required">*</span></label>
                                    <InputText type="password" class="um-input" @bind-Value="userModel.ConfirmPassword"
                                               placeholder="Re-enter password" />
                                    <ValidationMessage For="@(() => userModel.ConfirmPassword)" />
                                </div>
                            }
                            <div class="um-form-field">
                                <label>First Name</label>
                                <InputText class="um-input" @bind-Value="userModel.FirstName" />
                            </div>
                            <div class="um-form-field">
                                <label>Last Name</label>
                                <InputText class="um-input" @bind-Value="userModel.LastName" />
                            </div>
                            <div class="um-form-field">
                                <label>Role <span class="required">*</span></label>
                                <InputSelect class="um-input" @bind-Value="userModel.Role">
                                    @foreach (var role in availableRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="um-form-field">
                                <label>Status</label>
                                <label class="um-toggle">
                                    <InputCheckbox @bind-Value="userModel.IsActive" />
                                    <span class="um-toggle-slider"></span>
                                    <span class="um-toggle-label">@(userModel.IsActive ? "Active" : "Inactive")</span>
                                </label>
                            </div>
                            @if (userModel.Role == "StockController" || userModel.Role == "DepotController")
                            {
                                <div class="um-form-field um-form-full">
                                    <label>Assigned Warehouses <span class="required">*</span></label>
                                    @if (isLoadingWarehouses)
                                    {
                                        <div class="um-spinner-sm"></div>
                                    }
                                    else
                                    {
                                        <div class="um-checklist-wrap">
                                            @foreach (var wh in availableWarehouses)
                                            {
                                                var whCode = wh.WarehouseCode ?? "";
                                                var isChecked = userModel.AssignedWarehouseCodes.Contains(whCode);
                                                <label class="um-checklist-item @(isChecked ? "checked" : "")" @onmouseover:stopPropagation>
                                                    <input type="checkbox" checked="@isChecked"
                                                           @onchange="(e) => ToggleWarehouse(whCode, (bool)(e.Value ?? false))" />
                                                    <span class="um-checklist-label">@wh.WarehouseCode</span>
                                                    <span class="um-checklist-hint">- @wh.WarehouseName</span>
                                                </label>
                                            }
                                        </div>
                                        @if (userModel.AssignedWarehouseCodes.Count > 0)
                                        {
                                            <div class="um-chip-wrap">
                                                @foreach (var whCode in userModel.AssignedWarehouseCodes)
                                                {
                                                    <span class="um-chip um-chip-blue">
                                                        @whCode
                                                        <button type="button" class="um-chip-remove"
                                                                @onclick="() => ToggleWarehouse(whCode, false)">x</button>
                                                    </span>
                                                }
                                            </div>
                                        }
                                    }
                                    <small class="um-form-hint">User will have access to all selected warehouses
                                        (@userModel.AssignedWarehouseCodes.Count selected)</small>
                                    </div>
                                }
                                @if (userModel.Role == "Driver" || userModel.Role == "PodOperator")
                                {
                                    <div class="um-form-field">
                                        <label>Assigned Section <span class="required">*</span></label>
                                        <InputSelect class="um-input" @bind-Value="userModel.AssignedSection">
                                            <option value="">-- Select Section --</option>
                                            @foreach (var sec in availableSections)
                                            {
                                                <option value="@sec">@sec</option>
                                            }
                                        </InputSelect>
                                    </div>
                                }

                                @if (userModel.Role == "Merchandiser")
                                {
                                    <div class="um-form-field um-form-full">
                                        <label>Assigned Customers <span class="required">*</span></label>
                                        @if (isLoadingCustomers)
                                        {
                                            <div class="um-spinner-sm"></div>
                                        }
                                        else
                                        {
                                            <div style="margin-bottom:.4rem;">
                                                <input type="text" class="um-input" placeholder="Search customers..."
                                                       @bind="customerSearchTerm" @bind:event="oninput" />
                                            </div>
                                            <div class="um-customer-list">
                                                @foreach (var bp in FilteredCustomers)
                                                {
                                                    var code = bp.CardCode!;
                                                    var isChecked = userModel.AssignedCustomerCodes.Contains(code);
                                                    <label class="um-customer-item @(isChecked ? "checked" : "")" @onmouseover:stopPropagation>
                                                        <input type="checkbox" checked="@isChecked"
                                                               @onchange="(e) => ToggleCustomer(code, (bool)(e.Value ?? false))"
                                                               style="accent-color:#16a34a;" />
                                                        <span class="um-customer-code">@bp.CardCode</span>
                                                        <span class="um-customer-name">– @GetBusinessPartnerDisplayName(bp)</span>
                                                    </label>
                                                }
                                                @if (!FilteredCustomers.Any())
                                                {
                                                    <div class="um-empty" style="padding: .5rem;">
                                                        <p>No customers found</p>
                                                    </div>
                                                }
                                            </div>
                                            @if (userModel.AssignedCustomerCodes.Count > 0)
                                            {
                                                <div style="margin-top:.4rem; display:flex; flex-wrap:wrap; gap:.3rem;">
                                                    @foreach (var custCode in userModel.AssignedCustomerCodes)
                                                    {
                                                        var customer = availableCustomers.FirstOrDefault(c => string.Equals(c.CardCode, custCode,
                            StringComparison.OrdinalIgnoreCase));
                                                        var custName = customer is null ? custCode : GetBusinessPartnerDisplayName(customer);
                                                        <span class="um-customer-tag">
                                                            @custCode – @custName
                                                            <button type="button" class="um-customer-tag-remove"
                                                                    @onclick="() => ToggleCustomer(custCode, false)">×</button>
                                                        </span>
                                                    }
                                                </div>
                                            }
                                        }
                                        <small class="um-form-hint">Assign business partners this merchandiser will attend to
                                            (@userModel.AssignedCustomerCodes.Count selected)</small>
                                        </div>

                                        <div class="um-form-field">
                                            <label>Default Warehouse <span class="required">*</span></label>
                                            @if (isLoadingWarehouses)
                                            {
                                                <div class="um-spinner-sm"></div>
                                            }
                                            else
                                            {
                                                <select class="um-input" @bind="MerchandiserDefaultWarehouse">
                                                    <option value="">-- Select Warehouse --</option>
                                                    @foreach (var wh in MerchandiserWarehouseOptions)
                                                    {
                                                        <option value="@wh.WarehouseCode">@wh.WarehouseCode - @wh.WarehouseName</option>
                                                    }
                                                </select>
                                            }
                                            <small class="um-form-hint">The warehouse used when this merchandiser submits sales orders from
                                                the mobile app</small>
                                            </div>
                                        }

                                        <!-- Allowed Payment Methods (hidden for Admin, SalesRep, Merchandiser, PodOperator, Driver, MerchandiserPurchaseOrderViewer, Lab) -->
                                        @if (userModel.Role != "Admin" && userModel.Role != "SalesRep" && userModel.Role != "Merchandiser" && userModel.Role != "PodOperator" && userModel.Role != "Driver" && userModel.Role != "MerchandiserPurchaseOrderViewer" && userModel.Role != "Lab")
                                        {
                                            <div class="um-form-field um-form-full">
                                                <label>Allowed Payment Methods</label>
                                                <div class="um-pm-wrap">
                                                    @foreach (var pm in allPaymentMethods)
                                                    {
                                                        var isChecked = userModel.AllowedPaymentMethods.Contains(pm.Key);
                                                        <label class="um-pm-item @(isChecked ? "checked" : "")">
                                                            <input type="checkbox" checked="@isChecked"
                                                                   @onchange="(e) => TogglePaymentMethod(pm.Key, (bool)(e.Value ?? false))" />
                                                            <span class="um-pm-label">@pm.Value</span>
                                                        </label>
                                                    }
                                                </div>
                                                @if (userModel.AllowedPaymentMethods.Count > 0)
                                                {
                                                    <div class="um-chip-wrap">
                                                        @foreach (var pm in userModel.AllowedPaymentMethods)
                                                        {
                                                            var label = allPaymentMethods.GetValueOrDefault(pm, pm);
                                                            <span class="um-chip um-chip-amber">
                                                                @label
                                                                <button type="button" class="um-chip-remove"
                                                                        @onclick="() => TogglePaymentMethod(pm, false)">x</button>
                                                            </span>
                                                        }
                                                    </div>
                                                }
                                                <small class="um-form-hint">
                                                    Select which payment methods this user can use. If none are selected, only the system
                                                    default will be available.
                                                    (@userModel.AllowedPaymentMethods.Count selected)
                                                </small>
                                            </div>
                                        }
                                        else if (userModel.Role == "Admin")
                                        {
                                            <div class="um-form-field um-form-full">
                                                <label>Allowed Payment Methods</label>
                                                <small style="color:#059669; font-size:.82rem;">
                                                    <i class="bi bi-shield-check me-1"></i>Admin users automatically have access to all payment
                                                    methods.
                                                </small>
                                            </div>
                                        }

                                        <!-- Incoming Payment Settings (Cashier & DepotController only) -->
                                        @if (userModel.Role == "Cashier" || userModel.Role == "DepotController")
                                        {
                                            <div class="um-form-field um-form-full" style="margin-top: 0.5rem;">
                                                <div style="border-top: 1px solid #e5e7eb; padding-top: 1rem; margin-bottom: 0.5rem;">
                                                    <label
                                                        style="font-weight: 600; font-size: 0.95rem; color: #374151; display: flex; align-items: center; gap: 0.5rem;">
                                                        <i class="bi bi-wallet2" style="color: #059669;"></i>
                                                        Incoming Payment Settings
                                                    </label>
                                                    <small class="um-form-hint" style="margin-top: 0; margin-bottom: 0.75rem;">
                                                        Configure the G/L account and business partners this user can use when posting incoming
                                                        payments.
                                                        If not set, the system-wide defaults from Settings will be used.
                                                    </small>
                                                </div>
                                            </div>

                                            <div class="um-form-field">
                                                <label>Default G/L Account</label>
                                                @if (isLoadingGLAccounts)
                                                {
                                                    <div class="um-spinner-sm"></div>
                                                }
                                                else
                                                {
                                                    <input type="text" class="um-input" placeholder="Search G/L accounts..."
                                                           @bind="glAccountSearchTerm" @bind:event="oninput" />
                                                    @if (!string.IsNullOrEmpty(userModel.DefaultGLAccount))
                                                    {
                                                        var gl = availableGLAccounts.FirstOrDefault(a => a.Code == userModel.DefaultGLAccount);
                                                        <div class="um-chip-wrap" style="margin-top: 0.35rem;">
                                                            <span class="um-chip um-chip-amber">
                                                                @(gl != null ? $"{gl.Code} – {gl.Name}" : userModel.DefaultGLAccount)
                                                                <button type="button" class="um-chip-remove"
                                                                        @onclick="() => { userModel.DefaultGLAccount = null; }">×</button>
                                                            </span>
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(glAccountSearchTerm))
                                                    {
                                                        <div
                                                            style="max-height: 180px; overflow-y: auto; border: 1px solid #e5e7eb; border-radius: 0.5rem; margin-top: 0.25rem;">
                                                            @foreach (var gl in FilteredGLAccounts.Take(20))
                                                            {
                                                                <div class="um-list-item @(userModel.DefaultGLAccount == gl.Code ? "selected" : "")"
                                                                     style="padding: 0.4rem 0.75rem; cursor: pointer; font-size: 0.85rem;"
                                                                     @onclick="() => { userModel.DefaultGLAccount = gl.Code; glAccountSearchTerm = string.Empty; }">
                                                                    <strong>@gl.Code</strong> – @gl.Name
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                }
                                                <small class="um-form-hint">The cash/bank account used for incoming payments</small>
                                            </div>

                                            <div class="um-form-field um-form-full">
                                                <label>Allowed Business Partners</label>
                                                @if (isLoadingPaymentBPs)
                                                {
                                                    <div class="um-spinner-sm"></div>
                                                }
                                                else
                                                {
                                                    <input type="text" class="um-input" placeholder="Search business partners..."
                                                           @bind="paymentBPSearchTerm" @bind:event="oninput" />
                                                    @if (userModel.AllowedPaymentBusinessPartners.Count > 0)
                                                    {
                                                        <div class="um-chip-wrap" style="margin-top: 0.35rem;">
                                                            @foreach (var bpCode in userModel.AllowedPaymentBusinessPartners)
                                                            {
                                                                var bp = availablePaymentBPs.FirstOrDefault(b => b.CardCode == bpCode);
                                                                <span class="um-chip um-chip-amber">
                                                                    @(bp != null ? $"{bp.CardCode} – {bp.CardName}" : bpCode)
                                                                    <button type="button" class="um-chip-remove"
                                                                            @onclick="() => TogglePaymentBP(bpCode, false)">×</button>
                                                                </span>
                                                            }
                                                        </div>
                                                    }
                                                    <div
                                                        style="max-height: 200px; overflow-y: auto; border: 1px solid #e5e7eb; border-radius: 0.5rem; margin-top: 0.25rem;">
                                                        @foreach (var bp in FilteredPaymentBPs.Take(50))
                                                        {
                                                            var isChecked = userModel.AllowedPaymentBusinessPartners.Contains(bp.CardCode!);
                                                            <label class="um-list-item"
                                                                   style="display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.75rem; cursor: pointer; font-size: 0.85rem;">
                                                                <input type="checkbox" checked="@isChecked"
                                                                       @onchange="(e) => TogglePaymentBP(bp.CardCode!, (bool)(e.Value ?? false))" />
                                                                <span>
                                                                    <strong>@bp.CardCode</strong> – @bp.CardName
                                                                    @if (bp.Balance.HasValue && bp.Balance.Value != 0)
                                                                    {
                                                                        <span style="font-size: 0.75rem; color: #b45309; margin-left: 0.5rem;">
                                                                            Bal: @bp.Balance.Value.ToString("N2")
                                                                        </span>
                                                                    }
                                                                </span>
                                                            </label>
                                                        }
                                                    </div>
                                                }
                                                <small class="um-form-hint">
                                                    Select which business partners this user can choose when creating incoming payments.
                                                    If none are selected, the system default will be used.
                                                    (@userModel.AllowedPaymentBusinessPartners.Count selected)
                                                </small>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="um-modal-footer">
                                    <button type="button" class="um-btn um-btn-ghost" @onclick="CloseModal">Cancel</button>
                                    <button type="submit" class="um-btn um-btn-primary" disabled="@isSaving">
                                        @if (isSaving)
                                        {
                                            <span class="um-spinner-sm"></span>
                                        }
                                        @(editingUser == null ? "Create User" : "Save Changes")
                                    </button>
                                </div>
                            </EditForm>
                        </div>
                    </div>
                }

                <!-- Permissions Modal -->
                @if (showPermissionsModal && selectedUserForPermissions != null)
                {
                    <div class="um-overlay" @onclick="ClosePermissionsModal">
                        <div class="um-modal um-modal-wide" @onclick:stopPropagation="true">
                            <div class="um-modal-header">
                                <h2>Permissions for @selectedUserForPermissions.Username</h2>
                                <button class="um-modal-close" @onclick="ClosePermissionsModal"><i class="bi bi-x-lg"></i></button>
                            </div>
                            <div class="um-modal-body" style="max-height: 65vh; overflow-y: auto;">
                                <label class="um-toggle" style="margin-bottom: 1.25rem;">
                                    <input type="checkbox" @bind="useRoleDefaults" />
                                    <span class="um-toggle-slider"></span>
                                    <span class="um-toggle-label">Use default permissions for
                                        <strong>@selectedUserForPermissions.Role</strong></span>
                                    </label>

                                    @if (!useRoleDefaults && permissionCategories != null)
                                    {
                                        @foreach (var category in permissionCategories)
                                        {
                                            <div class="um-perm-modal-group">
                                                <div class="um-perm-modal-header">
                                                    <strong>@category.Key</strong>
                                                    <div class="um-perm-modal-actions">
                                                        <button type="button" class="um-btn-link"
                                                                @onclick="() => SelectAllInCategory(category.Key)">Select All</button>
                                                        <button type="button" class="um-btn-link um-btn-link-muted"
                                                                @onclick="() => DeselectAllInCategory(category.Key)">Clear</button>
                                                    </div>
                                                </div>
                                                <div class="um-perm-modal-body">
                                                    @foreach (var perm in category.Value)
                                                    {
                                                        <label class="um-perm-check @(selectedPermissions.Contains(perm.Code) ? "checked" : "")">
                                                            <input type="checkbox" checked="@selectedPermissions.Contains(perm.Code)"
                                                                   @onchange="(e) => TogglePermission(perm.Code, (bool)e.Value!)" />
                                                            <div>
                                                                <span class="um-perm-check-name">@perm.Name</span>
                                                                <span class="um-perm-check-desc">@perm.Description</span>
                                                            </div>
                                                        </label>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                                <div class="um-modal-footer">
                                    <button type="button" class="um-btn um-btn-ghost" @onclick="ClosePermissionsModal">Cancel</button>
                                    <button type="button" class="um-btn um-btn-primary" @onclick="SavePermissions" disabled="@isSaving">
                                        @if (isSaving)
                                        {
                                            <span class="um-spinner-sm"></span>
                                        }
                                        Save Permissions
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Reset Password Modal -->
                    @if (showResetPasswordModal && resetPasswordUser != null)
                    {
                        <div class="um-overlay" @onclick="CloseResetPasswordModal">
                            <div class="um-modal" style="max-width: 480px;" @onclick:stopPropagation="true">
                                <div class="um-modal-header">
                                    <h2>Reset Password for @resetPasswordUser.Username</h2>
                                    <button class="um-modal-close" @onclick="CloseResetPasswordModal"><i class="bi bi-x-lg"></i></button>
                                </div>
                                <EditForm Model="resetPasswordModel" OnValidSubmit="ResetPassword">
                                    <DataAnnotationsValidator />
                                    <div class="um-modal-body">
                                        <div class="um-form-field">
                                            <label>New Password <span class="required">*</span></label>
                                            <InputText type="password" class="um-input" @bind-Value="resetPasswordModel.NewPassword"
                                                       placeholder="Min. 8 characters" />
                                            <ValidationMessage For="@(() => resetPasswordModel.NewPassword)" />
                                        </div>
                                        <div class="um-form-field" style="margin-top: 1rem;">
                                            <label>Confirm Password <span class="required">*</span></label>
                                            <InputText type="password" class="um-input" @bind-Value="resetPasswordModel.ConfirmPassword"
                                                       placeholder="Re-enter password" />
                                            <ValidationMessage For="@(() => resetPasswordModel.ConfirmPassword)" />
                                        </div>
                                    </div>
                                    <div class="um-modal-footer">
                                        <button type="button" class="um-btn um-btn-ghost" @onclick="CloseResetPasswordModal">Cancel</button>
                                        <button type="submit" class="um-btn um-btn-primary" disabled="@isSaving">
                                            @if (isSaving)
                                            {
                                                <span class="um-spinner-sm"></span>
                                            }
                                            Reset Password
                                        </button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    }

                    <!-- Delete User Confirmation Modal -->
                    @if (showDeleteConfirmModal && deleteTargetUser != null)
                    {
                        <div class="um-overlay" @onclick="CloseDeleteConfirmModal">
                            <div class="um-modal" style="max-width: 480px;" @onclick:stopPropagation="true">
                                <div class="um-modal-header um-delete-header">
                                    <h2><i class="bi bi-exclamation-triangle-fill"></i> Delete User</h2>
                                    <button class="um-modal-close" @onclick="CloseDeleteConfirmModal"><i class="bi bi-x-lg"></i></button>
                                </div>
                                <div class="um-modal-body">
                                    <p style="margin-bottom: 1rem;">Are you sure you want to <strong>permanently delete</strong> the user
                                        <strong>@deleteTargetUser.Username</strong>?
                                    </p>
                                    <div class="um-delete-warning">
                                        <i class="bi bi-exclamation-triangle-fill"></i> This action cannot be undone. All user data will be
                                        permanently removed.
                                    </div>
                                </div>
                                <div class="um-modal-footer">
                                    <button type="button" class="um-btn um-btn-ghost" @onclick="CloseDeleteConfirmModal">Cancel</button>
                                    <button type="button" class="um-btn um-btn-danger" @onclick="DeleteUser" disabled="@isSaving">
                                        @if (isSaving)
                                        {
                                            <span class="um-spinner-sm"></span>
                                        }
                                        <i class="bi bi-trash-fill"></i> Delete Permanently
                                    </button>
                                </div>
                            </div>
                        </div>
                    }


                    <style>
                        /* ── Base ─────────────────────────────── */
                        .um-page {
                            max-width: 1280px;
                            margin: 0 auto;
                            padding: 1.25rem 1.5rem 2rem;
                        }

                        /* ── Header ──────────────────────────── */
                        .um-header {
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            margin-bottom: 1.75rem;
                        }

                        .um-header-left {
                            display: flex;
                            align-items: center;
                            gap: 1rem;
                        }

                        .um-header-icon {
                            width: 48px;
                            height: 48px;
                            border-radius: 14px;
                            background: linear-gradient(135deg, #6366f1, #8b5cf6);
                            color: white;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            font-size: 1.4rem;
                        }

                        .um-title {
                            font-size: 1.6rem;
                            font-weight: 700;
                            color: #1a1a2e;
                            margin: 0;
                            line-height: 1.2;
                        }

                        .um-subtitle {
                            font-size: .85rem;
                            color: #6b7280;
                            margin: .15rem 0 0;
                        }

                        .um-header-actions {
                            display: flex;
                            gap: 8px;
                        }

                        /* ── Buttons ──────────────────────────── */
                        .um-btn {
                            display: inline-flex;
                            align-items: center;
                            gap: .5rem;
                            padding: .6rem 1.25rem;
                            border-radius: 10px;
                            font-weight: 600;
                            font-size: .85rem;
                            border: none;
                            cursor: pointer;
                            transition: all .2s;
                        }

                        .um-btn-primary {
                            background: linear-gradient(135deg, #6366f1, #8b5cf6);
                            color: white;
                            box-shadow: 0 2px 8px rgba(99, 102, 241, .3);
                        }

                        .um-btn-primary:hover {
                            box-shadow: 0 4px 15px rgba(99, 102, 241, .45);
                            transform: translateY(-1px);
                        }

                        .um-btn-ghost {
                            background: transparent;
                            color: #6b7280;
                            border: 1px solid #e5e7eb;
                        }

                        .um-btn-ghost:hover {
                            background: #f9fafb;
                            color: #374151;
                        }

                        .um-btn-link {
                            background: none;
                            border: none;
                            color: #6366f1;
                            font-size: .8rem;
                            font-weight: 600;
                            cursor: pointer;
                            padding: .2rem .5rem;
                            border-radius: 6px;
                        }

                        .um-btn-link:hover {
                            background: #eef2ff;
                        }

                        .um-btn-link-muted {
                            color: #9ca3af;
                        }

                        .um-btn-link-muted:hover {
                            color: #6b7280;
                            background: #f3f4f6;
                        }

                        /* ── Tabs ─────────────────────────────── */
                        .um-tabs {
                            display: flex;
                            gap: .25rem;
                            background: #f3f4f6;
                            border: 1px solid #e5e7eb;
                            border-radius: 8px;
                            padding: .3rem;
                            margin-bottom: 1rem;
                        }

                        .um-tab {
                            flex: 1;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            gap: .5rem;
                            padding: .65rem 1rem;
                            border-radius: 6px;
                            border: none;
                            background: transparent;
                            color: #6b7280;
                            font-weight: 500;
                            font-size: .85rem;
                            cursor: pointer;
                            transition: all .2s;
                        }

                        .um-tab:hover {
                            color: #374151;
                            background: rgba(255, 255, 255, .5);
                        }

                        .um-tab.active {
                            background: white;
                            color: #6366f1;
                            font-weight: 600;
                            box-shadow: 0 1px 4px rgba(0, 0, 0, .08);
                        }

                        .um-tab-count {
                            background: #e5e7eb;
                            color: #6b7280;
                            font-size: .7rem;
                            padding: .1rem .5rem;
                            border-radius: 20px;
                            font-weight: 600;
                        }

                        .um-tab.active .um-tab-count {
                            background: #eef2ff;
                            color: #6366f1;
                        }

                        /* ── Filter Bar ───────────────────────── */
                        .um-filter-bar {
                            display: flex;
                            gap: .75rem;
                            margin-bottom: 1rem;
                            flex-wrap: wrap;
                            align-items: center;
                        }

                        .um-search-box {
                            flex: 1;
                            min-width: 220px;
                            display: flex;
                            align-items: center;
                            gap: .6rem;
                            background: white;
                            border: 1.5px solid #e5e7eb;
                            border-radius: 8px;
                            padding: .55rem .9rem;
                            transition: border-color .2s;
                        }

                        .um-search-box:focus-within {
                            border-color: #6366f1;
                            box-shadow: 0 0 0 3px rgba(99, 102, 241, .1);
                        }

                        .um-search-box i {
                            color: #9ca3af;
                            font-size: .9rem;
                        }

                        .um-search-box input {
                            border: none;
                            outline: none;
                            width: 100%;
                            font-size: .85rem;
                            color: #374151;
                            background: transparent;
                        }

                        .um-select {
                            padding: .55rem .9rem;
                            border: 1.5px solid #e5e7eb;
                            border-radius: 8px;
                            font-size: .85rem;
                            color: #374151;
                            background: white;
                            min-width: 140px;
                            cursor: pointer;
                            outline: none;
                            transition: border-color .2s;
                        }

                        .um-select:focus {
                            border-color: #6366f1;
                        }

                        .um-select-sm {
                            min-width: 100px;
                            padding: .4rem .6rem;
                            font-size: .8rem;
                        }

                        /* ── User Cards ───────────────────────── */
                        .um-user-list {
                            display: flex;
                            flex-direction: column;
                            gap: .45rem;
                        }

                        .um-user-card {
                            display: flex;
                            align-items: center;
                            justify-content: space-between;
                            gap: .85rem;
                            background: white;
                            border: 1px solid #e5e7eb;
                            border-radius: 8px;
                            padding: .7rem .95rem;
                            transition: all .2s;
                        }

                        .um-user-card:hover {
                            border-color: #c7d2fe;
                            box-shadow: 0 2px 12px rgba(99, 102, 241, .08);
                        }

                        .um-user-card.inactive {
                            opacity: .6;
                        }

                        .um-user-card.locked {
                            border-left: 3px solid #ef4444;
                        }

                        .um-user-main {
                            display: grid;
                            grid-template-columns: 42px minmax(220px, 1.4fr) minmax(180px, 1fr) minmax(130px, auto);
                            align-items: center;
                            gap: .85rem;
                            flex: 1;
                            min-width: 0;
                        }

                        .um-avatar {
                            width: 42px;
                            height: 42px;
                            border-radius: 8px;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            color: white;
                            font-weight: 700;
                            font-size: 1rem;
                            flex-shrink: 0;
                        }

                        .um-avatar-admin {
                            background: linear-gradient(135deg, #ef4444, #dc2626);
                        }

                        .um-avatar-cashier {
                            background: linear-gradient(135deg, #3b82f6, #2563eb);
                        }

                        .um-avatar-stock {
                            background: linear-gradient(135deg, #06b6d4, #0891b2);
                        }

                        .um-avatar-depot {
                            background: linear-gradient(135deg, #f59e0b, #d97706);
                        }

                        .um-avatar-default {
                            background: linear-gradient(135deg, #6b7280, #4b5563);
                        }

                        .um-user-info {
                            min-width: 0;
                        }

                        .um-user-name {
                            font-weight: 600;
                            font-size: .9rem;
                            color: #1f2937;
                            white-space: nowrap;
                            overflow: hidden;
                            text-overflow: ellipsis;
                        }

                        .um-user-email {
                            font-size: .78rem;
                            color: #9ca3af;
                            white-space: nowrap;
                            overflow: hidden;
                            text-overflow: ellipsis;
                        }

                        .um-user-meta {
                            display: flex;
                            gap: .4rem;
                            flex-wrap: wrap;
                            align-items: center;
                            min-width: 0;
                        }

                        .um-user-login {
                            text-align: right;
                            min-width: 130px;
                        }

                        .um-login-label {
                            display: block;
                            font-size: .68rem;
                            color: #9ca3af;
                            text-transform: uppercase;
                            letter-spacing: 0;
                        }

                        .um-login-time {
                            font-size: .82rem;
                            color: #374151;
                            font-weight: 600;
                            white-space: nowrap;
                        }

                        .um-login-never {
                            color: #9ca3af;
                            font-weight: 500;
                        }

                        /* ── Badges ───────────────────────────── */
                        .um-badge {
                            display: inline-flex;
                            align-items: center;
                            gap: .3rem;
                            padding: .2rem .6rem;
                            border-radius: 6px;
                            font-size: .72rem;
                            font-weight: 600;
                            white-space: nowrap;
                        }

                        .um-badge-admin {
                            background: #fef2f2;
                            color: #dc2626;
                        }

                        .um-badge-cashier {
                            background: #eff6ff;
                            color: #2563eb;
                        }

                        .um-badge-stockcontroller {
                            background: #ecfeff;
                            color: #0891b2;
                        }

                        .um-badge-depotcontroller {
                            background: #fffbeb;
                            color: #d97706;
                        }

                        .um-badge-podoperator {
                            background: #fdf2f8;
                            color: #db2777;
                        }

                        .um-badge-apiuser {
                            background: #f3f4f6;
                            color: #4b5563;
                        }

                        .um-badge-user {
                            background: #f3f4f6;
                            color: #6b7280;
                        }

                        .um-badge-active {
                            background: #ecfdf5;
                            color: #059669;
                        }

                        .um-badge-inactive {
                            background: #f3f4f6;
                            color: #9ca3af;
                        }

                        .um-badge-locked {
                            background: #fef2f2;
                            color: #dc2626;
                        }

                        .um-badge-2fa {
                            background: #ecfdf5;
                            color: #059669;
                        }

                        /* ── Actions ──────────────────────────── */
                        .um-user-actions {
                            display: flex;
                            align-items: center;
                            gap: .25rem;
                            flex-shrink: 0;
                            padding-left: .65rem;
                            border-left: 1px solid #f3f4f6;
                        }

                        .um-action-btn {
                            width: 36px;
                            height: 36px;
                            border-radius: 8px;
                            border: 1px solid transparent;
                            background: transparent;
                            color: #6b7280;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            cursor: pointer;
                            transition: all .15s;
                            font-size: .9rem;
                        }

                        .um-action-btn:hover {
                            background: #f3f4f6;
                            color: #374151;
                            border-color: #e5e7eb;
                        }

                        .um-action-more {
                            position: relative;
                        }

                        .um-dropdown-menu {
                            position: absolute;
                            right: 0;
                            top: 100%;
                            margin-top: .35rem;
                            background: white;
                            border: 1px solid #e5e7eb;
                            border-radius: 12px;
                            box-shadow: 0 10px 40px rgba(0, 0, 0, .12);
                            min-width: 200px;
                            z-index: 50;
                            padding: .4rem;
                            overflow: hidden;
                        }

                        .um-dropdown-item {
                            display: flex;
                            align-items: center;
                            gap: .6rem;
                            width: 100%;
                            padding: .55rem .75rem;
                            border: none;
                            background: transparent;
                            font-size: .83rem;
                            color: #374151;
                            cursor: pointer;
                            border-radius: 8px;
                            transition: background .15s;
                        }

                        .um-dropdown-item:hover {
                            background: #f3f4f6;
                        }

                        .um-dropdown-danger {
                            color: #dc2626;
                        }

                        .um-dropdown-danger:hover {
                            background: #fef2f2;
                        }

                        .um-dropdown-divider {
                            height: 1px;
                            background: #e5e7eb;
                            margin: 0.25rem 0;
                        }

                        .um-dropdown-success {
                            color: #059669;
                        }

                        .um-dropdown-success:hover {
                            background: #ecfdf5;
                        }

                        .um-btn-danger {
                            background: #dc2626;
                            color: #fff;
                            border: none;
                            padding: .6rem 1.25rem;
                            border-radius: 8px;
                            font-weight: 600;
                            cursor: pointer;
                            display: inline-flex;
                            align-items: center;
                            gap: .4rem;
                            font-size: .875rem;
                            transition: background .2s;
                        }

                        .um-btn-danger:hover {
                            background: #b91c1c;
                        }

                        .um-btn-danger:disabled {
                            opacity: .6;
                            cursor: not-allowed;
                        }

                        /* ── Pagination ───────────────────────── */
                        .um-pagination {
                            display: flex;
                            align-items: center;
                            justify-content: space-between;
                            margin-top: 1.25rem;
                            padding: .75rem 0;
                        }

                        .um-page-info {
                            font-size: .82rem;
                            color: #6b7280;
                        }

                        .um-page-buttons {
                            display: flex;
                            gap: .25rem;
                        }

                        .um-page-btn {
                            width: 34px;
                            height: 34px;
                            border-radius: 8px;
                            border: 1px solid #e5e7eb;
                            background: white;
                            color: #374151;
                            font-size: .82rem;
                            font-weight: 500;
                            cursor: pointer;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            transition: all .15s;
                        }

                        .um-page-btn:hover:not(:disabled) {
                            border-color: #6366f1;
                            color: #6366f1;
                        }

                        .um-page-btn.active {
                            background: #6366f1;
                            color: white;
                            border-color: #6366f1;
                        }

                        .um-page-btn:disabled {
                            opacity: .4;
                            cursor: default;
                        }

                        /* ── Stats ────────────────────────────── */
                        .um-stats-grid {
                            display: grid;
                            grid-template-columns: repeat(3, 1fr);
                            gap: 1rem;
                            margin-bottom: 1.5rem;
                        }

                        .um-stat-card {
                            background: white;
                            border-radius: 14px;
                            padding: 1.5rem;
                            border: 1px solid #e5e7eb;
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                            text-align: center;
                        }

                        .um-stat-icon {
                            font-size: 1.8rem;
                            margin-bottom: .5rem;
                        }

                        .um-stat-value {
                            font-size: 2rem;
                            font-weight: 800;
                            line-height: 1;
                        }

                        .um-stat-label {
                            font-size: .82rem;
                            color: #6b7280;
                            margin-top: .25rem;
                        }

                        .um-stat-success .um-stat-icon {
                            color: #059669;
                        }

                        .um-stat-success .um-stat-value {
                            color: #059669;
                        }

                        .um-stat-warning .um-stat-icon {
                            color: #d97706;
                        }

                        .um-stat-warning .um-stat-value {
                            color: #d97706;
                        }

                        .um-stat-danger .um-stat-icon {
                            color: #dc2626;
                        }

                        .um-stat-danger .um-stat-value {
                            color: #dc2626;
                        }

                        /* ── Section Cards ────────────────────── */
                        .um-section-card {
                            background: white;
                            border: 1px solid #e5e7eb;
                            border-radius: 14px;
                            overflow: hidden;
                        }

                        .um-section-header {
                            padding: 1.25rem 1.5rem;
                            border-bottom: 1px solid #f3f4f6;
                        }

                        .um-section-header h3 {
                            font-size: 1rem;
                            font-weight: 600;
                            color: #1f2937;
                            margin: 0;
                        }

                        /* ── Permission Groups ────────────────── */
                        .um-perm-group {
                            border-bottom: 1px solid #f3f4f6;
                        }

                        .um-perm-group:last-child {
                            border-bottom: none;
                        }

                        .um-perm-summary {
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            padding: .85rem 1.5rem;
                            cursor: pointer;
                            font-weight: 600;
                            font-size: .88rem;
                            color: #374151;
                            list-style: none;
                        }

                        .um-perm-summary::-webkit-details-marker {
                            display: none;
                        }

                        .um-perm-summary::before {
                            content: '\F285';
                            font-family: 'bootstrap-icons';
                            margin-right: .6rem;
                            font-size: .7rem;
                            transition: transform .2s;
                        }

                        details[open] .um-perm-summary::before {
                            transform: rotate(90deg);
                        }

                        .um-perm-count {
                            background: #eef2ff;
                            color: #6366f1;
                            font-size: .72rem;
                            padding: .15rem .5rem;
                            border-radius: 20px;
                        }

                        .um-perm-list {
                            padding: 0 1.5rem 1rem;
                        }

                        .um-perm-item {
                            display: grid;
                            grid-template-columns: 160px 1fr 2fr;
                            gap: .75rem;
                            padding: .5rem 0;
                            border-bottom: 1px solid #f9fafb;
                            font-size: .82rem;
                            align-items: center;
                        }

                        .um-perm-item:last-child {
                            border-bottom: none;
                        }

                        .um-perm-code {
                            font-family: monospace;
                            font-size: .75rem;
                            background: #f3f4f6;
                            padding: .15rem .4rem;
                            border-radius: 4px;
                            color: #6366f1;
                        }

                        .um-perm-name {
                            font-weight: 500;
                            color: #374151;
                        }

                        .um-perm-desc {
                            color: #9ca3af;
                        }

                        /* ── Role Grid ────────────────────────── */
                        .um-role-grid {
                            display: grid;
                            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                            gap: 1rem;
                            padding: 1.25rem 1.5rem;
                        }

                        .um-role-card {
                            background: #f9fafb;
                            border-radius: 10px;
                            padding: 1rem;
                            border: 1px solid #f3f4f6;
                        }

                        .um-role-name {
                            margin-bottom: .5rem;
                        }

                        .um-role-desc {
                            font-size: .82rem;
                            color: #6b7280;
                            margin: 0;
                            line-height: 1.5;
                        }

                        /* ── Security Events ──────────────────── */
                        .um-event-list {
                            padding: .5rem 0;
                        }

                        .um-event-item {
                            display: flex;
                            align-items: center;
                            gap: .85rem;
                            padding: .65rem 1.5rem;
                            border-bottom: 1px solid #f9fafb;
                        }

                        .um-event-item:last-child {
                            border-bottom: none;
                        }

                        .um-event-icon {
                            width: 32px;
                            height: 32px;
                            border-radius: 8px;
                            background: #f3f4f6;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            flex-shrink: 0;
                        }

                        .um-event-info {
                            flex: 1;
                        }

                        .um-event-user {
                            font-weight: 600;
                            font-size: .85rem;
                            color: #1f2937;
                            margin-right: .4rem;
                        }

                        .um-event-desc {
                            font-size: .82rem;
                            color: #6b7280;
                        }

                        .um-event-time {
                            font-size: .78rem;
                            color: #9ca3af;
                            white-space: nowrap;
                        }

                        /* ── Modal ────────────────────────────── */
                        .um-overlay {
                            position: fixed;
                            inset: 0;
                            background: rgba(0, 0, 0, .4);
                            backdrop-filter: blur(4px);
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            z-index: 1050;
                            padding: 1rem;
                        }

                        .um-modal {
                            background: white;
                            border-radius: 16px;
                            width: 100%;
                            max-width: 600px;
                            max-height: calc(100vh - 2rem);
                            box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
                            overflow: hidden;
                            display: flex;
                            flex-direction: column;
                        }

                        .um-modal>form,
                        .um-modal>editform {
                            display: flex;
                            flex-direction: column;
                            flex: 1;
                            min-height: 0;
                            overflow: hidden;
                        }

                        .um-modal-wide {
                            max-width: 850px;
                        }

                        .um-modal-header {
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            padding: 1.25rem 1.5rem;
                            border-bottom: 1px solid #f3f4f6;
                            flex-shrink: 0;
                        }

                        .um-modal-header h2 {
                            font-size: 1.1rem;
                            font-weight: 700;
                            color: #1f2937;
                            margin: 0;
                        }

                        .um-modal-close {
                            width: 32px;
                            height: 32px;
                            border-radius: 8px;
                            border: none;
                            background: #f3f4f6;
                            color: #6b7280;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            cursor: pointer;
                            transition: all .15s;
                        }

                        .um-modal-close:hover {
                            background: #e5e7eb;
                            color: #374151;
                        }

                        .um-modal-body {
                            padding: 1.5rem;
                            overflow-y: auto;
                            flex: 1;
                            min-height: 0;
                        }

                        .um-modal-footer {
                            display: flex;
                            justify-content: flex-end;
                            gap: .75rem;
                            padding: 1rem 1.5rem;
                            border-top: 1px solid #f3f4f6;
                            background: #f9fafb;
                            flex-shrink: 0;
                        }

                        /* ── Form ─────────────────────────────── */
                        .um-form-grid {
                            display: grid;
                            grid-template-columns: 1fr 1fr;
                            gap: 1rem;
                        }

                        .um-form-full {
                            grid-column: 1 / -1;
                        }

                        .um-form-field label {
                            display: block;
                            font-size: .78rem;
                            font-weight: 600;
                            color: #374151;
                            margin-bottom: .3rem;
                            text-transform: uppercase;
                            letter-spacing: .3px;
                        }

                        .um-form-field .required {
                            color: #ef4444;
                        }

                        .um-form-hint {
                            display: block;
                            font-size: .75rem;
                            color: #9ca3af;
                            margin-top: .3rem;
                        }

                        .um-input {
                            width: 100%;
                            padding: .6rem .85rem;
                            border: 1.5px solid #e5e7eb;
                            border-radius: 10px;
                            font-size: .85rem;
                            color: #374151;
                            outline: none;
                            transition: border-color .2s;
                            background: white;
                        }

                        .um-input:focus {
                            border-color: #6366f1;
                            box-shadow: 0 0 0 3px rgba(99, 102, 241, .1);
                        }

                        .um-input:disabled {
                            background: #f9fafb;
                            color: #9ca3af;
                        }

                        /* ── Toggle ───────────────────────────── */
                        label.um-toggle {
                            display: flex;
                            align-items: center;
                            gap: .7rem;
                            cursor: pointer;
                            padding-top: .4rem;
                            font-weight: 400;
                            text-transform: none;
                            letter-spacing: 0;
                            margin-bottom: 0;
                        }

                        label.um-toggle input {
                            display: none;
                        }

                        .um-toggle-slider {
                            position: relative;
                            width: 44px;
                            height: 24px;
                            background: #d1d5db;
                            border-radius: 24px;
                            transition: background .2s;
                            flex-shrink: 0;
                        }

                        .um-toggle-slider::after {
                            content: '';
                            position: absolute;
                            top: 2px;
                            left: 2px;
                            width: 20px;
                            height: 20px;
                            background: white;
                            border-radius: 50%;
                            transition: transform .2s;
                            box-shadow: 0 1px 3px rgba(0, 0, 0, .15);
                        }

                        .um-toggle input:checked+.um-toggle-slider {
                            background: #6366f1;
                        }

                        .um-toggle input:checked+.um-toggle-slider::after {
                            transform: translateX(20px);
                        }

                        .um-toggle-label {
                            font-size: .85rem;
                            color: #374151;
                        }

                        /* ── Permission Modal Groups ──────────── */
                        .um-perm-modal-group {
                            border: 1px solid #e5e7eb;
                            border-radius: 10px;
                            margin-bottom: .75rem;
                            overflow: hidden;
                        }

                        .um-perm-modal-header {
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            padding: .7rem 1rem;
                            background: #f9fafb;
                            border-bottom: 1px solid #f3f4f6;
                        }

                        .um-perm-modal-actions {
                            display: flex;
                            gap: .5rem;
                        }

                        .um-perm-modal-body {
                            display: grid;
                            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
                            gap: .5rem;
                            padding: .75rem;
                        }

                        .um-perm-check {
                            display: flex;
                            align-items: flex-start;
                            gap: .5rem;
                            padding: .5rem .6rem;
                            border-radius: 8px;
                            cursor: pointer;
                            transition: background .15s;
                            border: 1px solid transparent;
                        }

                        .um-perm-check:hover {
                            background: #f9fafb;
                        }

                        .um-perm-check.checked {
                            background: #eef2ff;
                            border-color: #c7d2fe;
                        }

                        .um-perm-check input {
                            margin-top: .15rem;
                            accent-color: #6366f1;
                        }

                        .um-perm-check-name {
                            display: block;
                            font-size: .82rem;
                            font-weight: 500;
                            color: #374151;
                        }

                        .um-perm-check-desc {
                            display: block;
                            font-size: .72rem;
                            color: #9ca3af;
                        }

                        /* ── Loading / Empty ──────────────────── */
                        .um-loading {
                            text-align: center;
                            padding: 4rem 1rem;
                        }

                        .um-loading p {
                            color: #9ca3af;
                            margin-top: .75rem;
                            font-size: .85rem;
                        }

                        .um-spinner {
                            width: 36px;
                            height: 36px;
                            border: 3px solid #e5e7eb;
                            border-top-color: #6366f1;
                            border-radius: 50%;
                            animation: um-spin .6s linear infinite;
                            margin: 0 auto;
                        }

                        .um-spinner-sm {
                            display: inline-block;
                            width: 16px;
                            height: 16px;
                            border: 2px solid rgba(255, 255, 255, .3);
                            border-top-color: white;
                            border-radius: 50%;
                            animation: um-spin .6s linear infinite;
                        }

                        @@keyframes um-spin {
                            to {
                                transform: rotate(360deg);
                            }
                        }

                        .um-empty {
                            text-align: center;
                            padding: 4rem 1rem;
                            color: #9ca3af;
                        }

                        .um-empty i {
                            font-size: 3rem;
                            opacity: .4;
                        }

                        .um-empty h3 {
                            font-size: 1.1rem;
                            color: #6b7280;
                            margin: .75rem 0 .25rem;
                        }

                        .um-empty p {
                            font-size: .85rem;
                        }



                        /* ── Responsive ───────────────────────── */
                        @@media (max-width: 768px) {
                            .um-header {
                                flex-direction: column;
                                align-items: flex-start;
                                gap: 1rem;
                            }

                            .um-filter-bar {
                                flex-direction: column;
                            }

                            .um-user-card {
                                flex-direction: column;
                                align-items: stretch;
                            }

                            .um-user-main {
                                grid-template-columns: 42px minmax(0, 1fr);
                            }

                            .um-user-meta {
                                grid-column: 1 / -1;
                                margin-top: .5rem;
                            }

                            .um-user-login {
                                grid-column: 2;
                                min-width: 0;
                                text-align: left;
                            }

                            .um-user-actions {
                                justify-content: flex-end;
                                padding-left: 0;
                                padding-top: .5rem;
                                border-left: 0;
                                border-top: 1px solid #f3f4f6;
                            }

                            .um-stats-grid {
                                grid-template-columns: 1fr;
                            }

                            .um-form-grid {
                                grid-template-columns: 1fr;
                            }

                            .um-perm-item {
                                grid-template-columns: 1fr;
                            }

                            .um-pagination {
                                flex-direction: column;
                                gap: .75rem;
                            }
                        }

                        /* ── Customer List ────────────────────── */
                        .um-customer-list {
                            max-height: 200px;
                            overflow-y: auto;
                            border: 1px solid #e5e7eb;
                            border-radius: 8px;
                            padding: .5rem;
                        }

                        .um-customer-item {
                            display: flex;
                            align-items: center;
                            gap: .5rem;
                            padding: .3rem .5rem;
                            cursor: pointer;
                            border-radius: 6px;
                            font-size: .85rem;
                        }

                        .um-customer-item.checked {
                            background: #dcfce7;
                        }

                        .um-customer-code {
                            font-weight: 400;
                            color: #1a1a2e;
                        }

                        .um-customer-item.checked .um-customer-code {
                            font-weight: 600;
                        }

                        .um-customer-name {
                            color: #6b7280;
                            font-size: .8rem;
                        }

                        .um-customer-tag {
                            background: #dcfce7;
                            color: #166534;
                            padding: .15rem .5rem;
                            border-radius: 12px;
                            font-size: .78rem;
                            font-weight: 500;
                            display: inline-flex;
                            align-items: center;
                            gap: .3rem;
                        }

                        .um-customer-tag-remove {
                            background: none;
                            border: none;
                            color: #166534;
                            cursor: pointer;
                            padding: 0;
                            font-size: .85rem;
                            line-height: 1;
                        }

                        /* ── Warehouse / Payment Lists ────────── */
                        .um-checklist-wrap {
                            max-height: 200px;
                            overflow-y: auto;
                            border: 1px solid #e5e7eb;
                            border-radius: 8px;
                            padding: .5rem;
                        }

                        .um-checklist-item {
                            display: flex;
                            align-items: center;
                            gap: .5rem;
                            padding: .3rem .5rem;
                            cursor: pointer;
                            border-radius: 6px;
                            font-size: .85rem;
                        }

                        .um-checklist-item.checked {
                            background: #dbeafe;
                        }

                        .um-checklist-item input[type="checkbox"] {
                            accent-color: #2563eb;
                        }

                        .um-checklist-label {
                            font-weight: 400;
                            color: #1a1a2e;
                        }

                        .um-checklist-item.checked .um-checklist-label {
                            font-weight: 600;
                        }

                        .um-checklist-hint {
                            color: #6b7280;
                            font-size: .8rem;
                        }

                        .um-chip-wrap {
                            margin-top: .4rem;
                            display: flex;
                            flex-wrap: wrap;
                            gap: .3rem;
                        }

                        .um-chip {
                            padding: .15rem .5rem;
                            border-radius: 12px;
                            font-size: .78rem;
                            font-weight: 500;
                            display: inline-flex;
                            align-items: center;
                            gap: .3rem;
                        }

                        .um-chip-blue {
                            background: #dbeafe;
                            color: #1e40af;
                        }

                        .um-chip-amber {
                            background: #fef3c7;
                            color: #92400e;
                        }

                        .um-chip-remove {
                            background: none;
                            border: none;
                            color: inherit;
                            cursor: pointer;
                            padding: 0;
                            font-size: .7rem;
                        }

                        .um-pm-wrap {
                            border: 1px solid #e5e7eb;
                            border-radius: 8px;
                            padding: .5rem;
                        }

                        .um-pm-item {
                            display: flex;
                            align-items: center;
                            gap: .5rem;
                            padding: .3rem .5rem;
                            cursor: pointer;
                            border-radius: 6px;
                            font-size: .85rem;
                        }

                        .um-pm-item.checked {
                            background: #fef3c7;
                        }

                        .um-pm-item input[type="checkbox"] {
                            accent-color: #d97706;
                        }

                        .um-pm-label {
                            font-weight: 400;
                            color: #1a1a2e;
                        }

                        .um-pm-item.checked .um-pm-label {
                            font-weight: 600;
                        }

                        /* ── Delete Warning ───────────────────── */
                        .um-delete-warning {
                            background: #fef2f2;
                            border: 1px solid #fecaca;
                            border-radius: 8px;
                            padding: 0.75rem 1rem;
                            font-size: 0.85rem;
                            color: #991b1b;
                        }

                        .um-delete-header h2 {
                            color: #dc2626;
                        }

                        .um-delete-header {
                            border-bottom-color: #fee2e2;
                        }

                        /* ══════════════════════════════════════ */
                        /* ── Dark Mode ────────────────────────── */
                        /* ══════════════════════════════════════ */

                        /* ── Dark: Page Core ──────────────────── */
                        :global(.dark-theme) .um-title {
                            color: #f1f5f9;
                        }

                        :global(.dark-theme) .um-subtitle {
                            color: #94a3b8;
                        }

                        /* ── Dark: Tabs ───────────────────────── */
                        :global(.dark-theme) .um-tabs {
                            background: #0f172a;
                        }

                        :global(.dark-theme) .um-tab {
                            color: #94a3b8;
                        }

                        :global(.dark-theme) .um-tab:hover {
                            color: #e2e8f0;
                            background: rgba(255, 255, 255, .05);
                        }

                        :global(.dark-theme) .um-tab.active {
                            background: #1e293b;
                            color: #818cf8;
                        }

                        :global(.dark-theme) .um-tab-count {
                            background: #334155;
                            color: #94a3b8;
                        }

                        :global(.dark-theme) .um-tab.active .um-tab-count {
                            background: rgba(99, 102, 241, .2);
                            color: #818cf8;
                        }

                        /* ── Dark: Filter Bar ────────────────── */
                        :global(.dark-theme) .um-search-box {
                            background: #0f172a;
                            border-color: #475569;
                        }

                        :global(.dark-theme) .um-search-box:focus-within {
                            border-color: #818cf8;
