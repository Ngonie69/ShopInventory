    private static string GetLastLoginDisplay(DateTime? utcDateTime)
    {
        if (!utcDateTime.HasValue)
        {
            return "Never";
        }

        var catDateTime = IAuditService.ToCAT(DateTime.SpecifyKind(utcDateTime.Value, DateTimeKind.Utc));
        var catToday = IAuditService.ToCAT(DateTime.UtcNow).Date;

        if (catDateTime.Date == catToday)
        {
            return $"Today {catDateTime:HH:mm}";
        }

        if (catDateTime.Date == catToday.AddDays(-1))
        {
            return $"Yesterday {catDateTime:HH:mm}";
        }

        return catDateTime.Year == catToday.Year
            ? catDateTime.ToString("dd MMM HH:mm")
            : catDateTime.ToString("dd MMM yyyy HH:mm");
    }

    private static string GetLastLoginTitle(DateTime? utcDateTime)
    {
        if (!utcDateTime.HasValue)
        {
            return "No successful login recorded";
        }

        return $"{IAuditService.ToCAT(DateTime.SpecifyKind(utcDateTime.Value, DateTimeKind.Utc)):dd MMM yyyy HH:mm:ss} CAT";
    }

    private string GetRelativeTime(DateTime dateTime)
    {
        var diff = DateTime.UtcNow - dateTime;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return dateTime.ToString("dd MMM");
    }

