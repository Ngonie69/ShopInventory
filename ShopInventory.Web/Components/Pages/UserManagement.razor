@page "/user-management"
@using ShopInventory.Web.Models
@using ShopInventory.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject IUserManagementService UserService
@inject IAuditService AuditService
@inject AuthenticationStateProvider AuthStateProvider
@inject IMasterDataCacheService MasterDataCache
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>User Management - Shop Inventory</PageTitle>

<div class="um-page">
    <!-- Page Header -->
    <div class="um-header">
        <div class="um-header-left">
            <div class="um-header-icon">
                <i class="bi bi-people-fill"></i>
            </div>
            <div>
                <h1 class="um-title">User Management</h1>
                <p class="um-subtitle">Manage accounts, permissions, and security</p>
            </div>
        </div>
        <button class="um-btn um-btn-primary" @onclick="ShowCreateModal">
            <i class="bi bi-plus-lg"></i>
            <span>Add User</span>
        </button>
    </div>

    <!-- Tabs -->
    <div class="um-tabs">
        <button class="um-tab @(activeTab == "users" ? "active" : "")" @onclick="@(() => SetTab("users"))">
            <i class="bi bi-people"></i> Users
            <span class="um-tab-count">@users.Count</span>
        </button>
        <button class="um-tab @(activeTab == "permissions" ? "active" : "")" @onclick="@(() => SetTab("permissions"))">
            <i class="bi bi-shield-lock"></i> Permissions
        </button>
        <button class="um-tab @(activeTab == "security" ? "active" : "")" @onclick="@(() => SetTab("security"))">
            <i class="bi bi-fingerprint"></i> Security
        </button>
    </div>

    @if (activeTab == "users")
    {
        <!-- Filter Bar -->
        <div class="um-filter-bar">
            <div class="um-search-box">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search by name or email..." @bind="searchTerm"
                       @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
            </div>
            <select class="um-select" @bind="roleFilter" @bind:after="LoadUsers">
                <option value="">All Roles</option>
                @foreach (var role in availableRoles)
                {
                    <option value="@role">@role</option>
                }
            </select>
            <select class="um-select" @bind="statusFilter" @bind:after="LoadUsers">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="locked">Locked</option>
            </select>
            @if (!string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(roleFilter) || !string.IsNullOrEmpty(statusFilter))
            {
                <button class="um-btn um-btn-ghost" @onclick="ResetFilters">
                    <i class="bi bi-x-lg"></i> Clear
                </button>
            }
        </div>

        <!-- Users List -->
        @if (isLoading)
        {
            <div class="um-loading">
                <div class="um-spinner"></div>
                <p>Loading users...</p>
            </div>
        }
        else if (users.Any())
        {
            <div class="um-user-list">
                @foreach (var user in users)
                {
                    <div class="um-user-card @(!user.IsActive ? "inactive" : "") @(user.IsLocked ? "locked" : "")">
                        <div class="um-user-main">
                            <div class="um-avatar @GetAvatarClass(user)">
                                @user.Username[0].ToString().ToUpper()
                            </div>
                            <div class="um-user-info">
                                <div class="um-user-name">@user.Username</div>
                                <div class="um-user-email">@(user.Email ?? "No email")</div>
                            </div>
                            <div class="um-user-meta">
                                <span class="um-badge @GetRoleBadgeClass(user.Role)">@user.Role</span>
                                @if (user.IsLocked)
                                {
                                    <span class="um-badge um-badge-locked"><i class="bi bi-lock-fill"></i> Locked</span>
                                }
                                else if (user.IsActive)
                                {
                                    <span class="um-badge um-badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="um-badge um-badge-inactive">Inactive</span>
                                }
                                @if (user.TwoFactorEnabled)
                                {
                                    <span class="um-badge um-badge-2fa"><i class="bi bi-shield-fill-check"></i> 2FA</span>
                                }
                            </div>
                            <div class="um-user-login">
                                <span class="um-login-label">Last login</span>
                                <span class="um-login-time">
                                    @if (user.LastLoginAt.HasValue)
                                    {
                                        @GetRelativeTime(user.LastLoginAt.Value)
                                    }
                                    else
                                    {
                                        <text>Never</text>
                                    }
                                </span>
                            </div>
                        </div>
                        <div class="um-user-actions">
                            <button class="um-action-btn" @onclick="@(() => ShowEditModal(user))" title="Edit user">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <button class="um-action-btn" @onclick="@(() => ShowPermissionsModal(user))" title="Manage permissions">
                                <i class="bi bi-shield-lock"></i>
                            </button>
                            <div class="um-action-more">
                                <button class="um-action-btn" @onclick="() => ToggleActionMenu(user.Id)" title="More actions">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                @if (openMenuUserId == user.Id)
                                {
                                    <div class="um-dropdown-menu" @onclick:stopPropagation="true">
                                        @if (user.IsLocked)
                                        {
                                            <button class="um-dropdown-item" @onclick="@(() => { CloseActionMenu(); UnlockUser(user); })">
                                                <i class="bi bi-unlock-fill text-warning"></i> Unlock Account
                                            </button>
                                        }
                                        @if (user.TwoFactorEnabled)
                                        {
                                            <button class="um-dropdown-item" @onclick="@(() => { CloseActionMenu(); ResetTwoFactor(user); })">
                                                <i class="bi bi-shield-x text-secondary"></i> Reset 2FA
                                            </button>
                                        }
                                        @if (user.IsActive)
                                        {
                                            <button class="um-dropdown-item um-dropdown-danger" @onclick="@(() => { CloseActionMenu(); ConfirmDelete(user); })">
                                                <i class="bi bi-person-dash-fill"></i> Deactivate User
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="um-dropdown-item um-dropdown-success" @onclick="@(() => { CloseActionMenu(); ActivateUser(user); })">
                                                <i class="bi bi-person-check-fill"></i> Activate User
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="um-pagination">
                    <span class="um-page-info">Showing @((currentPage - 1) * pageSize + 1)–@Math.Min(currentPage * pageSize, users.Count + (currentPage - 1) * pageSize) of page @currentPage</span>
                    <div class="um-page-buttons">
                        <button class="um-page-btn" disabled="@(currentPage <= 1)" @onclick="() => GoToPage(currentPage - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            var pg = i;
                            <button class="um-page-btn @(pg == currentPage ? "active" : "")" @onclick="() => GoToPage(pg)">@pg</button>
                        }
                        <button class="um-page-btn" disabled="@(currentPage >= totalPages)" @onclick="() => GoToPage(currentPage + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                    <select class="um-select um-select-sm" @bind="pageSize" @bind:after="OnPageSizeChanged">
                        <option value="10">10 / page</option>
                        <option value="20">20 / page</option>
                        <option value="50">50 / page</option>
                    </select>
                </div>
            }
        }
        else
        {
            <div class="um-empty">
                <i class="bi bi-people"></i>
                <h3>No users found</h3>
                <p>Try adjusting your search or filters</p>
            </div>
        }
    }
    else if (activeTab == "permissions")
    {
        <div class="um-section-card">
            <div class="um-section-header">
                <h3><i class="bi bi-list-check me-2"></i>Available Permissions</h3>
            </div>
            @if (permissionCategories != null)
            {
                @foreach (var category in permissionCategories)
                {
                    <details class="um-perm-group">
                        <summary class="um-perm-summary">
                            <span>@category.Key</span>
                            <span class="um-perm-count">@category.Value.Count</span>
                        </summary>
                        <div class="um-perm-list">
                            @foreach (var perm in category.Value)
                            {
                                <div class="um-perm-item">
                                    <code class="um-perm-code">@perm.Code</code>
                                    <span class="um-perm-name">@perm.Name</span>
                                    <span class="um-perm-desc">@perm.Description</span>
                                </div>
                            }
                        </div>
                    </details>
                }
            }
        </div>

        <div class="um-section-card" style="margin-top: 1.5rem;">
            <div class="um-section-header">
                <h3><i class="bi bi-diagram-3 me-2"></i>Default Role Permissions</h3>
            </div>
            <div class="um-role-grid">
                @foreach (var role in new[] { "Admin", "Cashier", "StockController", "DepotController" })
                {
                    <div class="um-role-card">
                        <div class="um-role-name">
                            <span class="um-badge @GetRoleBadgeClass(role)">@role</span>
                        </div>
                        <p class="um-role-desc">
                            @if (role == "Admin")
                            {
                                <text>Full system access including user management and all permissions</text>
                            }
                            else if (role == "Cashier")
                            {
                                <text>Access to payments, invoicing, sales orders, and credit notes</text>
                            }
                            else if (role == "StockController")
                            {
                                <text>Access to inventory transfers only</text>
                            }
                            else
                            {
                                <text>Access to payments and inventory transfers</text>
                            }
                        </p>
                    </div>
                }
            </div>
        </div>
    }
    else if (activeTab == "security")
    {
        <!-- Security Stats -->
        <div class="um-stats-grid">
            <div class="um-stat-card um-stat-success">
                <div class="um-stat-icon"><i class="bi bi-shield-fill-check"></i></div>
                <div class="um-stat-value">@usersWithTwoFactor</div>
                <div class="um-stat-label">2FA Enabled</div>
            </div>
            <div class="um-stat-card um-stat-warning">
                <div class="um-stat-icon"><i class="bi bi-shield-fill-exclamation"></i></div>
                <div class="um-stat-value">@usersWithoutTwoFactor</div>
                <div class="um-stat-label">2FA Disabled</div>
            </div>
            <div class="um-stat-card um-stat-danger">
                <div class="um-stat-icon"><i class="bi bi-lock-fill"></i></div>
                <div class="um-stat-value">@lockedUsers</div>
                <div class="um-stat-label">Locked Accounts</div>
            </div>
        </div>

        <div class="um-section-card">
            <div class="um-section-header">
                <h3><i class="bi bi-clock-history me-2"></i>Recent Security Events</h3>
            </div>
            @if (securityEvents.Any())
            {
                <div class="um-event-list">
                    @foreach (var evt in securityEvents)
                    {
                        <div class="um-event-item">
                            <div class="um-event-icon">
                                <i class="bi @GetSecurityEventIcon(evt.EventType)"></i>
                            </div>
                            <div class="um-event-info">
                                <span class="um-event-user">@evt.Username</span>
                                <span class="um-event-desc">@evt.Description</span>
                            </div>
                            <span class="um-event-time">@evt.Timestamp.ToString("dd MMM yyyy HH:mm")</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="um-empty" style="padding: 2rem;">
                    <i class="bi bi-shield-check" style="font-size: 2.5rem;"></i>
                    <p>No recent security events</p>
                </div>
            }
        </div>
    }
</div>

<!-- Create/Edit User Modal -->
@if (showUserModal)
{
    <div class="um-overlay" @onclick="CloseModal">
        <div class="um-modal" @onclick:stopPropagation="true">
            <div class="um-modal-header">
                <h2>@(editingUser == null ? "Create New User" : $"Edit {editingUser.Username}")</h2>
                <button class="um-modal-close" @onclick="CloseModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <EditForm Model="userModel" OnValidSubmit="SaveUser">
                <DataAnnotationsValidator />
                <div class="um-modal-body">
                    <div class="um-form-grid">
                        <div class="um-form-field">
                            <label>Username <span class="required">*</span></label>
                            <InputText class="um-input" @bind-Value="userModel.Username" disabled="@(editingUser != null)"
                                       placeholder="e.g. john.doe" />
                            <ValidationMessage For="@(() => userModel.Username)" />
                        </div>
                        <div class="um-form-field">
                            <label>Email</label>
                            <InputText class="um-input" @bind-Value="userModel.Email" placeholder="user@company.com" />
                            <ValidationMessage For="@(() => userModel.Email)" />
                        </div>
                        @if (editingUser == null)
                        {
                            <div class="um-form-field">
                                <label>Password <span class="required">*</span></label>
                                <InputText type="password" class="um-input" @bind-Value="userModel.Password"
                                           placeholder="Min. 6 characters" />
                                <ValidationMessage For="@(() => userModel.Password)" />
                            </div>
                            <div class="um-form-field">
                                <label>Confirm Password <span class="required">*</span></label>
                                <InputText type="password" class="um-input" @bind-Value="userModel.ConfirmPassword"
                                           placeholder="Re-enter password" />
                                <ValidationMessage For="@(() => userModel.ConfirmPassword)" />
                            </div>
                        }
                        <div class="um-form-field">
                            <label>First Name</label>
                            <InputText class="um-input" @bind-Value="userModel.FirstName" />
                        </div>
                        <div class="um-form-field">
                            <label>Last Name</label>
                            <InputText class="um-input" @bind-Value="userModel.LastName" />
                        </div>
                        <div class="um-form-field">
                            <label>Role <span class="required">*</span></label>
                            <InputSelect class="um-input" @bind-Value="userModel.Role">
                                @foreach (var role in availableRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="um-form-field">
                            <label>Status</label>
                            <label class="um-toggle">
                                <InputCheckbox @bind-Value="userModel.IsActive" />
                                <span class="um-toggle-slider"></span>
                                <span class="um-toggle-label">@(userModel.IsActive ? "Active" : "Inactive")</span>
                            </label>
                        </div>
                        @if (userModel.Role == "StockController" || userModel.Role == "DepotController")
                        {
                            <div class="um-form-field um-form-full">
                                <label>Assigned Warehouse <span class="required">*</span></label>
                                @if (isLoadingWarehouses)
                                {
                                    <div class="um-spinner-sm"></div>
                                }
                                else
                                {
                                    <InputSelect class="um-input" @bind-Value="userModel.AssignedWarehouseCode">
                                        <option value="">-- Select Warehouse --</option>
                                        @foreach (var wh in availableWarehouses)
                                        {
                                            <option value="@wh.WarehouseCode">@wh.WarehouseCode - @wh.WarehouseName</option>
                                        }
                                    </InputSelect>
                                }
                                <small class="um-form-hint">User will only have access to the selected warehouse</small>
                            </div>
                        }
                    </div>
                </div>
                <div class="um-modal-footer">
                    <button type="button" class="um-btn um-btn-ghost" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="um-btn um-btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="um-spinner-sm"></span>
                        }
                        @(editingUser == null ? "Create User" : "Save Changes")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

<!-- Permissions Modal -->
@if (showPermissionsModal && selectedUserForPermissions != null)
{
    <div class="um-overlay" @onclick="ClosePermissionsModal">
        <div class="um-modal um-modal-wide" @onclick:stopPropagation="true">
            <div class="um-modal-header">
                <h2>Permissions for @selectedUserForPermissions.Username</h2>
                <button class="um-modal-close" @onclick="ClosePermissionsModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="um-modal-body" style="max-height: 65vh; overflow-y: auto;">
                <label class="um-toggle" style="margin-bottom: 1.25rem;">
                    <input type="checkbox" @bind="useRoleDefaults" />
                    <span class="um-toggle-slider"></span>
                    <span class="um-toggle-label">Use default permissions for <strong>@selectedUserForPermissions.Role</strong></span>
                </label>

                @if (!useRoleDefaults && permissionCategories != null)
                {
                    @foreach (var category in permissionCategories)
                    {
                        <div class="um-perm-modal-group">
                            <div class="um-perm-modal-header">
                                <strong>@category.Key</strong>
                                <div class="um-perm-modal-actions">
                                    <button type="button" class="um-btn-link" @onclick="() => SelectAllInCategory(category.Key)">Select All</button>
                                    <button type="button" class="um-btn-link um-btn-link-muted" @onclick="() => DeselectAllInCategory(category.Key)">Clear</button>
                                </div>
                            </div>
                            <div class="um-perm-modal-body">
                                @foreach (var perm in category.Value)
                                {
                                    <label class="um-perm-check @(selectedPermissions.Contains(perm.Code) ? "checked" : "")">
                                        <input type="checkbox" checked="@selectedPermissions.Contains(perm.Code)"
                                               @onchange="(e) => TogglePermission(perm.Code, (bool)e.Value!)" />
                                        <div>
                                            <span class="um-perm-check-name">@perm.Name</span>
                                            <span class="um-perm-check-desc">@perm.Description</span>
                                        </div>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="um-modal-footer">
                <button type="button" class="um-btn um-btn-ghost" @onclick="ClosePermissionsModal">Cancel</button>
                <button type="button" class="um-btn um-btn-primary" @onclick="SavePermissions" disabled="@isSaving">
                    @if (isSaving) { <span class="um-spinner-sm"></span> }
                    Save Permissions
                </button>
            </div>
        </div>
    </div>
}

<!-- Toast -->
@if (!string.IsNullOrEmpty(toastMessage))
{
    <div class="um-toast @(toastIsError ? "um-toast-error" : "um-toast-success")">
        <i class="bi @(toastIsError ? "bi-exclamation-circle-fill" : "bi-check-circle-fill")"></i>
        <span>@toastMessage</span>
        <button @onclick="() => toastMessage = string.Empty"><i class="bi bi-x"></i></button>
    </div>
}

<style>
    /* ── Base ─────────────────────────────── */
    .um-page { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }

    /* ── Header ──────────────────────────── */
    .um-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.75rem; }
    .um-header-left { display: flex; align-items: center; gap: 1rem; }
    .um-header-icon { width: 48px; height: 48px; border-radius: 14px; background: linear-gradient(135deg, #667eea, #764ba2); color: white; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; }
    .um-title { font-size: 1.6rem; font-weight: 700; color: #1a1a2e; margin: 0; line-height: 1.2; }
    .um-subtitle { font-size: .85rem; color: #6b7280; margin: .15rem 0 0; }

    /* ── Buttons ──────────────────────────── */
    .um-btn { display: inline-flex; align-items: center; gap: .5rem; padding: .6rem 1.25rem; border-radius: 10px; font-weight: 600; font-size: .85rem; border: none; cursor: pointer; transition: all .2s; }
    .um-btn-primary { background: linear-gradient(135deg, #667eea, #764ba2); color: white; box-shadow: 0 2px 8px rgba(102,126,234,.3); }
    .um-btn-primary:hover { box-shadow: 0 4px 15px rgba(102,126,234,.45); transform: translateY(-1px); }
    .um-btn-ghost { background: transparent; color: #6b7280; border: 1px solid #e5e7eb; }
    .um-btn-ghost:hover { background: #f9fafb; color: #374151; }
    .um-btn-link { background: none; border: none; color: #667eea; font-size: .8rem; font-weight: 600; cursor: pointer; padding: .2rem .5rem; border-radius: 6px; }
    .um-btn-link:hover { background: #eef2ff; }
    .um-btn-link-muted { color: #9ca3af; }
    .um-btn-link-muted:hover { color: #6b7280; background: #f3f4f6; }

    /* ── Tabs ─────────────────────────────── */
    .um-tabs { display: flex; gap: .25rem; background: #f3f4f6; border-radius: 12px; padding: .3rem; margin-bottom: 1.5rem; }
    .um-tab { flex: 1; display: flex; align-items: center; justify-content: center; gap: .5rem; padding: .65rem 1rem; border-radius: 10px; border: none; background: transparent; color: #6b7280; font-weight: 500; font-size: .85rem; cursor: pointer; transition: all .2s; }
    .um-tab:hover { color: #374151; background: rgba(255,255,255,.5); }
    .um-tab.active { background: white; color: #667eea; font-weight: 600; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .um-tab-count { background: #e5e7eb; color: #6b7280; font-size: .7rem; padding: .1rem .5rem; border-radius: 20px; font-weight: 600; }
    .um-tab.active .um-tab-count { background: #eef2ff; color: #667eea; }

    /* ── Filter Bar ───────────────────────── */
    .um-filter-bar { display: flex; gap: .75rem; margin-bottom: 1.25rem; flex-wrap: wrap; align-items: center; }
    .um-search-box { flex: 1; min-width: 220px; display: flex; align-items: center; gap: .6rem; background: white; border: 1.5px solid #e5e7eb; border-radius: 10px; padding: .55rem .9rem; transition: border-color .2s; }
    .um-search-box:focus-within { border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,.1); }
    .um-search-box i { color: #9ca3af; font-size: .9rem; }
    .um-search-box input { border: none; outline: none; width: 100%; font-size: .85rem; color: #374151; background: transparent; }
    .um-select { padding: .55rem .9rem; border: 1.5px solid #e5e7eb; border-radius: 10px; font-size: .85rem; color: #374151; background: white; min-width: 140px; cursor: pointer; outline: none; transition: border-color .2s; }
    .um-select:focus { border-color: #667eea; }
    .um-select-sm { min-width: 100px; padding: .4rem .6rem; font-size: .8rem; }

    /* ── User Cards ───────────────────────── */
    .um-user-list { display: flex; flex-direction: column; gap: .5rem; }
    .um-user-card { display: flex; align-items: center; justify-content: space-between; background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: .85rem 1.25rem; transition: all .2s; }
    .um-user-card:hover { border-color: #c7d2fe; box-shadow: 0 2px 12px rgba(102,126,234,.08); }
    .um-user-card.inactive { opacity: .6; }
    .um-user-card.locked { border-left: 3px solid #ef4444; }
    .um-user-main { display: flex; align-items: center; gap: 1rem; flex: 1; min-width: 0; }
    .um-avatar { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 1rem; flex-shrink: 0; }
