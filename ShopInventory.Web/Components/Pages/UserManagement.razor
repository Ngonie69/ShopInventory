    private async Task SaveUser()
    {
        isSaving = true;
        var isEditing = editingUser != null;
        var originalUsername = editingUser?.Username;
        var originalEmail = editingUser?.Email;
        try
        {
            if (!isEditing)
            {
                await UserService.CreateUserAsync(userModel);
                Snackbar.Add("User created successfully", Severity.Success);
            }
            else
            {
                var userToEdit = editingUser;
                if (userToEdit is null)
                {
                    Snackbar.Add("No user selected for editing.", Severity.Error);
                    return;
                }

                await UserService.UpdateUserAsync(userToEdit.Id, userModel);
                Snackbar.Add("User updated successfully", Severity.Success);

                var usernameChanged = !string.Equals(originalUsername, userModel.Username, StringComparison.OrdinalIgnoreCase);
                var emailChanged = !string.Equals(originalEmail, userModel.Email, StringComparison.OrdinalIgnoreCase);
                if ((usernameChanged || emailChanged) && AuthStateProvider is CustomAuthStateProvider customAuthStateProvider)
                {
                    var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                    var currentUsername = authState.User.Identity?.Name;
                    if (!string.IsNullOrWhiteSpace(currentUsername) &&
                        string.Equals(currentUsername, originalUsername, StringComparison.OrdinalIgnoreCase))
                    {
                        await customAuthStateProvider.UpdateUserProfileAsync(userModel.Username, userModel.Email);
                    }
                }
            }

            await AuditService.LogAsync(isEditing ? "UpdateUser" : "CreateUser", "User", userModel.Username);
            CloseModal();
            await LoadUsers();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

