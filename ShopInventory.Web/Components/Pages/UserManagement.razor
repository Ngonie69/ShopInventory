    private IEnumerable<WarehouseDto> MerchandiserWarehouseOptions
    {
        get
        {
            var selectedWarehouseCode = MerchandiserDefaultWarehouse;

            if (string.IsNullOrWhiteSpace(selectedWarehouseCode) ||
                availableWarehouses.Any(wh => string.Equals(wh.WarehouseCode, selectedWarehouseCode,
StringComparison.OrdinalIgnoreCase)))
            {
                return availableWarehouses;
            }

            return new[]
            {
                new WarehouseDto
                {
                    WarehouseCode = selectedWarehouseCode,
                    WarehouseName = "Currently assigned"
                }
            }.Concat(availableWarehouses);
        }
    }

