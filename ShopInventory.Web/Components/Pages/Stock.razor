@page "/stock"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ShopInventory.Web.Services
@using ShopInventory.Web.Models
@attribute [Authorize]
@inject IMasterDataCacheService MasterDataCache
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject IAppSettingsProvider AppSettings
@inject IAuditService AuditService
@rendermode InteractiveServer

<PageTitle>Stock Monitoring - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .stk-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Header ──────────────────────────────────────── */
    .stk-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .stk-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .stk-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .stk-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .stk-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .stk-header-actions {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .btn-stk-gradient {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 2px 8px rgba(102, 126, 234, .25);
        cursor: pointer;
    }

    .btn-stk-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .4);
        color: #fff;
    }

    .btn-stk-gradient:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .btn-stk-outline {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-stk-outline:hover {
        background: #f9fafb;
        border-color: #9ca3af;
    }

    .btn-stk-outline:disabled {
        opacity: .5;
        cursor: not-allowed;
    }

    .btn-stk-warning {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 2px 8px rgba(217, 119, 6, .25);
    }

    .btn-stk-warning:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(217, 119, 6, .4);
        color: #fff;
    }

    .btn-stk-warning:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    /* ── Stat Cards ──────────────────────────────────── */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: .85rem;
        border: 1px solid #e5e7eb;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        transition: all .25s ease;
    }

    .stat-card:hover {
        box-shadow: 0 4px 14px rgba(0, 0, 0, .08);
        transform: translateY(-2px);
    }

    .stat-card.warning-pulse {
        border-color: #fde68a;
    }

    .stat-card.danger-pulse {
        border-color: #fecaca;
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .stat-icon.purple {
        background: #ede9fe;
        color: #7c3aed;
    }

    .stat-icon.green {
        background: #d1fae5;
        color: #059669;
    }

    .stat-icon.amber {
        background: #fef3c7;
        color: #d97706;
    }

    .stat-icon.red {
        background: #fee2e2;
        color: #dc2626;
    }

    .stat-info .stat-value {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1.2;
    }

    .stat-info .stat-label {
        font-size: .78rem;
        color: #6b7280;
        font-weight: 500;
    }

    .stat-info .stat-hint {
        font-size: .72rem;
        font-weight: 500;
        margin-top: .15rem;
    }

    /* ── Filter Bar ──────────────────────────────────── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        align-items: flex-end;
        padding: 1rem 1.25rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .filter-bar .filter-field {
        flex: 1;
        min-width: 160px;
    }

    .filter-bar .filter-field label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .3rem;
    }

    .filter-bar .filter-field select,
    .filter-bar .filter-field input {
        width: 100%;
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        background: #fff;
        transition: all .15s;
    }

    .filter-bar .filter-field select:focus,
    .filter-bar .filter-field input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .filter-actions-row {
        display: flex;
        gap: .5rem;
        align-items: flex-end;
    }

    .btn-search {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-search:hover {
        opacity: .92;
        transform: translateY(-1px);
    }

    .btn-search:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    .btn-clear {
        background: #fff;
        color: #6b7280;
        border: 1px solid #d1d5db;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-clear:hover {
        background: #f3f4f6;
    }

    /* ── Table ───────────────────────────────────────── */
    .stk-table-wrap {
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #fff;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .stk-table-header {
        padding: .85rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
    }

    .stk-table-header h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .92rem;
    }

    .stk-count-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #374151;
    }

    .stk-table {
        width: 100%;
        font-size: .85rem;
        border-collapse: separate;
        border-spacing: 0;
    }

    .stk-table th {
        background: #f8fafc;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6b7280;
        font-weight: 600;
        padding: .6rem .75rem;
        border-bottom: 2px solid #e5e7eb;
        white-space: nowrap;
    }

    .stk-table td {
        padding: .55rem .75rem;
        border-bottom: 1px solid #f3f4f6;
        color: #374151;
        vertical-align: middle;
    }

    .stk-table tr:last-child td {
        border-bottom: none;
    }

    .stk-table tbody tr {
        transition: background .15s;
    }

    .stk-table tbody tr:hover {
        background: #f8fafc;
    }

    .stk-table tbody tr.row-danger {
        background: #fef2f2;
    }

    .stk-table tbody tr.row-danger:hover {
        background: #fee2e2;
    }

    .stk-table tbody tr.row-warning {
        background: #fffbeb;
    }

    .stk-table tbody tr.row-warning:hover {
        background: #fef3c7;
    }

    .item-code {
        font-weight: 700;
        color: #667eea;
        font-size: .88rem;
        font-family: 'Space Grotesk', monospace;
    }

    .item-name {
        font-weight: 500;
        color: #1a1a2e;
    }

    .qty-cell {
        font-family: 'Space Grotesk', monospace;
        font-weight: 600;
        font-size: .88rem;
    }

    .qty-warning {
        color: #d97706;
    }

    .qty-info {
        color: #2563eb;
    }

    .qty-danger {
        color: #dc2626;
    }

    .qty-success {
        color: #059669;
    }

    .uom-label {
        font-size: .82rem;
        color: #6b7280;
    }

    /* Health Bar */
    .health-bar {
        width: 56px;
        height: 6px;
        border-radius: 3px;
        background: #e5e7eb;
        overflow: hidden;
    }

    .health-bar-fill {
        height: 100%;
        border-radius: 3px;
        transition: width .3s ease;
    }

    .health-bar-fill.green {
        background: linear-gradient(90deg, #34d399, #059669);
    }

    .health-bar-fill.amber {
        background: linear-gradient(90deg, #fbbf24, #d97706);
    }

    .health-bar-fill.red {
        background: linear-gradient(90deg, #f87171, #dc2626);
    }

    /* Status Indicator */
    .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }

    .status-dot.green {
        background: #059669;
        box-shadow: 0 0 0 3px rgba(5, 150, 105, .2);
    }

    .status-dot.amber {
        background: #d97706;
        box-shadow: 0 0 0 3px rgba(217, 119, 6, .2);
    }

    .status-dot.red {
        background: #dc2626;
        box-shadow: 0 0 0 3px rgba(220, 38, 38, .2);
    }

    /* ── Pagination ──────────────────────────────────── */
    .stk-pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: .5rem;
        margin-top: 1.25rem;
    }

    .stk-pagination button {
        padding: .45rem 1rem;
        border-radius: 8px;
        border: 1px solid #d1d5db;
        background: #fff;
        color: #374151;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
    }

    .stk-pagination button:hover:not(:disabled) {
        background: #f3f4f6;
        border-color: #9ca3af;
    }

    .stk-pagination button:disabled {
        opacity: .4;
        cursor: not-allowed;
    }

    .stk-pagination .page-indicator {
        padding: .45rem .85rem;
        border-radius: 8px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        font-weight: 600;
        font-size: .85rem;
    }

    /* ── Empty & Loading States ──────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 1.8rem;
        color: #9ca3af;
    }

    .empty-state h6 {
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
    }

    .empty-state p {
        color: #9ca3af;
        font-size: .88rem;
        margin-bottom: 1rem;
    }

    .loading-state {
        text-align: center;
        padding: 3rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    /* ── Alert ───────────────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    /* ── Drawer Modal ────────────────────────────────── */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        z-index: 9998;
        animation: fadeIn .2s ease;
    }

    .detail-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(520px, 95vw);
        height: 100vh;
        background: #fff;
        z-index: 9999;
        box-shadow: -8px 0 30px rgba(0, 0, 0, .12);
        display: flex;
        flex-direction: column;
        animation: slideInRight .25s ease;
    }

    .drawer-header {
        padding: 1.15rem 1.5rem;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }

    .drawer-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .drawer-header .btn-close-drawer {
        background: rgba(255, 255, 255, .15);
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s;
        font-size: 1rem;
    }

    .drawer-header .btn-close-drawer:hover {
        background: rgba(255, 255, 255, .25);
    }

    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .drawer-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    .detail-item .detail-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
        margin-bottom: .15rem;
    }

    .detail-item .detail-value {
        font-size: .92rem;
        font-weight: 600;
        color: #1a1a2e;
    }

    /* ── Animations ──────────────────────────────────── */
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }

        to {
            transform: translateX(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ── Responsive ──────────────────────────────────── */
    @@media (max-width:768px) {
        .stat-row {
            grid-template-columns: 1fr 1fr;
        }

        .filter-bar {
            flex-direction: column;
        }

        .filter-bar .filter-field {
            min-width: 100%;
        }

        .stk-header {
            flex-direction: column;
        }

        .detail-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="stk-page">
    <div class="container-fluid">

        <!-- ━━━ Header ━━━ -->
        <div class="stk-header">
            <div class="stk-header-left">
                <div class="stk-header-icon"><i class="bi bi-clipboard-data"></i></div>
                <div>
                    <h2>Stock Monitoring</h2>
                    <p>Monitor inventory levels, alerts & stock status</p>
                </div>
            </div>
            <div class="stk-header-actions">
                <MudButton Class="btn-stk-warning" OnClick="ShowLowStockAlerts" Disabled="@(stockItems.Count == 0)">
                    <i class="bi bi-exclamation-triangle"></i>
                    Low Stock (@lowStockCount)
                </MudButton>
                <MudButton Class="btn-stk-outline" OnClick="RefreshStock" Disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-clockwise"></i>
                    }
                    Refresh
                </MudButton>
            </div>
        </div>

        <!-- ━━━ Alerts ━━━ -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner error-alert">
                <i class="bi bi-exclamation-octagon-fill"></i>
                <div style="flex:1;">@errorMessage</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Style="background:none;border:none;color:inherit;opacity:.45;cursor:pointer;font-size:1rem;"
                               OnClick="() => errorMessage = null" />
            </div>
        }

        <!-- ━━━ Stat Cards ━━━ -->
        @if (stockItems.Any())
        {
            <div class="stat-row">
                <div class="stat-card">
                    <div class="stat-icon purple"><i class="bi bi-box-seam"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@totalItems</div>
                        <div class="stat-label">Total SKUs</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon green"><i class="bi bi-check-circle-fill"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@inStockCount</div>
                        <div class="stat-label">Healthy Stock</div>
                    </div>
                </div>
                <div class="stat-card @(lowStockCount > 0 ? "warning-pulse" : "")">
                    <div class="stat-icon amber"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@lowStockCount</div>
                        <div class="stat-label">Low Stock</div>
                        @if (lowStockCount > 0)
                        {
                            <div class="stat-hint" style="color:#d97706;">Needs reorder</div>
                        }
                    </div>
                </div>
                <div class="stat-card @(outOfStockCount > 0 ? "danger-pulse" : "")">
                    <div class="stat-icon red"><i class="bi bi-x-circle-fill"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@outOfStockCount</div>
                        <div class="stat-label">Out of Stock</div>
                        @if (outOfStockCount > 0)
                        {
                            <div class="stat-hint" style="color:#dc2626;">Critical</div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- ━━━ Filter Bar ━━━ -->
        <div class="filter-bar">
            <div class="filter-field">
                <label>Warehouse *</label>
                @if (isLoadingWarehouses)
                {
                    <div style="display:flex;align-items:center;gap:.4rem;padding:.5rem 0;">
                        <span class="spinner-border spinner-border-sm" style="color:#667eea;"></span>
                        <span style="font-size:.85rem;color:#6b7280;">Loading warehouses...</span>
                    </div>
                }
                else
                {
                    <select @bind="selectedWarehouseCode" disabled="@isWarehouseLocked">
                        <option value="">-- Select Warehouse --</option>
                        @foreach (var warehouse in warehouses)
                        {
                            <option value="@warehouse.WarehouseCode">@warehouse.WarehouseCode - @warehouse.WarehouseName
                            </option>
                        }
                    </select>
                    @if (isWarehouseLocked)
                    {
                        <small style="font-size:.75rem;color:#6b7280;">Warehouse assigned to your account</small>
                    }
                }
            </div>
            <div class="filter-field" style="max-width:180px;">
                <label>Stock Status</label>
                <select @bind="stockFilter">
                    <option value="all">All Items</option>
                    <option value="instock">Healthy Stock</option>
                    <option value="lowstock">Low Stock</option>
                    <option value="outofstock">Out of Stock</option>
                </select>
            </div>
            <div class="filter-field" style="max-width:150px;">
                <label>Low Threshold</label>
                <input type="number" @bind="lowStockThreshold" min="1" max="1000" />
            </div>
            <div class="filter-field">
                <label>Search Item</label>
                <input type="text" @bind="searchTerm" @bind:event="oninput" placeholder="Code, name or barcode..."
                       @onkeypress="OnSearchKeyPress" />
            </div>
            <div class="filter-actions-row">
                <MudButton Class="btn-search" OnClick="LoadStock"
                           Disabled="@(string.IsNullOrEmpty(selectedWarehouseCode))">
                    <i class="bi bi-search"></i> Load
                </MudButton>
                <MudButton Class="btn-clear" OnClick="ClearFilters">
                    <i class="bi bi-x-circle"></i> Clear
                </MudButton>
            </div>
        </div>

        <!-- ━━━ Content States ━━━ -->
        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner-border" style="color:#667eea;width:2.5rem;height:2.5rem;" role="status"></div>
                <p style="margin-top:.75rem;color:#6b7280;font-weight:500;">Loading stock data...</p>
            </div>
        }
        else if (string.IsNullOrEmpty(selectedWarehouseCode) && !stockItems.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="bi bi-building"></i></div>
                <h6>Select a Warehouse</h6>
                <p>Choose a warehouse above to view its stock levels</p>
            </div>
        }
        else if (!stockItems.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="bi bi-inbox"></i></div>
                <h6>No stock items found</h6>
                <p>No items match your search criteria</p>
                <MudButton Class="btn-search" OnClick="RefreshStock"><i class="bi bi-arrow-clockwise"></i> Retry</MudButton>
            </div>
        }
        else
        {
            <!-- ━━━ Stock Table ━━━ -->
            <div class="stk-table-wrap">
                <div class="stk-table-header">
                    <h6><i class="bi bi-table"></i> Stock Status — @selectedWarehouseCode</h6>
                    <span class="stk-count-badge">
                        <i class="bi bi-funnel"></i> @filteredItems.Count() of @stockItems.Count items
                    </span>
                </div>
                <div style="overflow-x:auto;">
                    <table class="stk-table">
                        <thead>
                            <tr>
                                <th style="width:40px;text-align:center;">Status</th>
                                <th>Item Code</th>
                                <th>Item Name</th>
                                <th style="text-align:right;">On Hand</th>
                                <th style="text-align:right;">Committed</th>
                                <th style="text-align:right;">On Order</th>
                                <th style="text-align:right;">Available</th>
                                <th>UoM</th>
                                <th style="text-align:center;">Health</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in filteredItems)
                            {
                                var rowClass = item.Available <= 0 ? "row-danger" : item.Available < lowStockThreshold ?
                                "row-warning" : "";
                                <tr class="@rowClass">
                                    <td style="text-align:center;">
                                        @if (item.Available <= 0)
                                        {
                                            <span class="status-dot red" title="Out of stock"></span>
                                        }
                                        else if (item.Available < lowStockThreshold)
                                        {
                                            <span class="status-dot amber" title="Low stock"></span>
                                        }
                                        else
                                        {
                                            <span class="status-dot green" title="Healthy"></span>
                                        }
                                    </td>
                                    <td><span class="item-code">@item.ItemCode</span></td>
                                    <td><span class="item-name">@item.ItemName</span></td>
                                    <td style="text-align:right;"><span class="qty-cell">@item.InStock.ToString("N0")</span>
                                    </td>
                                    <td style="text-align:right;"><span
                                        class="qty-cell qty-warning">@item.Committed.ToString("N0")</span></td>
                                        <td style="text-align:right;"><span
                                            class="qty-cell qty-info">@item.Ordered.ToString("N0")</span></td>
                                            <td style="text-align:right;">
                                                <span
                                                    class="qty-cell @(item.Available <= 0 ? "qty-danger" : item.Available < lowStockThreshold ? "qty-warning" : "qty-success")">
                                                    @item.Available.ToString("N0")
                                                </span>
                                            </td>
                                            <td><span class="uom-label">@item.UoM</span></td>
                                            <td style="text-align:center;">
                                                @{
                                                    var healthPercent = item.InStock > 0 ? Math.Min(100, (item.Available /
                                                    lowStockThreshold) * 100) : 0;
                                                    var healthFill = healthPercent >= 100 ? "green" : healthPercent >= 50 ? "amber" : "red";
                                                }
                                                <div class="health-bar" title="@healthPercent.ToString("N0")% healthy">
                                                    <div class="health-bar-fill @healthFill" style="width:@healthPercent%"></div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- ━━━ Pagination ━━━ -->
                    @if (hasMore || currentPage > 1)
                    {
                        <div class="stk-pagination">
                            <MudButton OnClick="PreviousPage" Disabled="@(currentPage == 1)" Variant="Variant.Text">
                                <i class="bi bi-chevron-left"></i> Previous
                            </MudButton>
                            <span class="page-indicator">Page @currentPage</span>
                            <MudButton OnClick="NextPage" Disabled="@(!hasMore)" Variant="Variant.Text">
                                Next <i class="bi bi-chevron-right"></i>
                            </MudButton>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- ━━━ Warehouse Details Drawer ━━━ -->
        @if (showWarehouseDetails && selectedWarehouse != null)
        {
            <div class="modal-backdrop-custom" @onclick="() => showWarehouseDetails = false"></div>
            <div class="detail-drawer">
                <div class="drawer-header">
                    <h5><i class="bi bi-building me-2"></i>Warehouse Details</h5>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Class="btn-close-drawer"
                                   OnClick="() => showWarehouseDetails = false" />
                </div>
                <div class="drawer-body">
                    <div class="detail-grid">
                        <div class="detail-item">
                            <div class="detail-label">Code</div>
                            <div class="detail-value">@selectedWarehouse.WarehouseCode</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Name</div>
                            <div class="detail-value">@selectedWarehouse.WarehouseName</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Location</div>
                            <div class="detail-value">@(selectedWarehouse.Location ?? "—")</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">City</div>
                            <div class="detail-value">@(selectedWarehouse.City ?? "—")</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Country</div>
                            <div class="detail-value">@(selectedWarehouse.Country ?? "—")</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Status</div>
                            <div class="detail-value">
                                @if (selectedWarehouse.IsActive)
                                {
                                    <span
                                        style="display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .6rem;border-radius:6px;font-size:.78rem;font-weight:600;background:#d1fae5;color:#065f46;">
                                        <i class="bi bi-check-circle-fill"></i> Active
                                    </span>
                                }
                                else
                                {
                                    <span
                                        style="display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .6rem;border-radius:6px;font-size:.78rem;font-weight:600;background:#f3f4f6;color:#6b7280;">
                                        Inactive
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="drawer-footer">
                    <MudButton Class="btn-stk-outline" OnClick="() => showWarehouseDetails = false">Close</MudButton>
                </div>
            </div>
        }

@code {
    private List<WarehouseDto> warehouses = new();
    private List<StockQuantityDto> stockItems = new();
    private WarehouseDto? selectedWarehouse;
    private string selectedWarehouseCode = "";
    private string searchTerm = "";
    private string stockFilter = "all";
    private bool isLoading = false;
    private bool isLoadingWarehouses = true;
    private bool showWarehouseDetails = false;
    private string? errorMessage;
    private int currentPage = 1;
    private int pageSize = 50;
    private bool hasMore = false;
    private int lowStockThreshold = 10;

    private int totalItems => stockItems.Count;
    private int inStockCount => stockItems.Count(i => i.Available > lowStockThreshold);
    private int lowStockCount => stockItems.Count(i => i.Available > 0 && i.Available <= lowStockThreshold);
    private int outOfStockCount => stockItems.Count(i => i.Available <= 0);

    private IEnumerable<StockQuantityDto> filteredItems
    {
        get
        {
            var items = stockItems.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var term = searchTerm.ToLowerInvariant();
                items = items.Where(i =>
                (i.ItemCode?.ToLowerInvariant().Contains(term) ?? false) ||
                (i.ItemName?.ToLowerInvariant().Contains(term) ?? false) ||
                (i.BarCode?.ToLowerInvariant().Contains(term) ?? false));
            }

            return stockFilter switch
            {
                "instock" => items.Where(i => i.Available > lowStockThreshold),
                "lowstock" => items.Where(i => i.Available > 0 && i.Available <= lowStockThreshold),
                "outofstock" => items.Where(i => i.Available <= 0),
                _ => items
            };
        }
    }

    private string? userAssignedWarehouse;
    private bool isWarehouseLocked = false;

    protected override async Task OnInitializedAsync()
    {
        pageSize = AppSettings.PageSize;
        // Check if user has an assigned warehouse (StockController/DepotController)
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        userAssignedWarehouse = user.FindFirst("warehouse")?.Value;
        var role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;

        await LoadWarehouses();

        // Auto-select and lock warehouse for StockController/DepotController
        if (!string.IsNullOrEmpty(userAssignedWarehouse) && (role == "StockController" || role == "DepotController"))
        {
            selectedWarehouseCode = userAssignedWarehouse;
            isWarehouseLocked = true;
            await LoadStock();
        }
        await AuditService.LogAsync(AuditActions.ViewStock, "Stock", null);
    }

    private async Task LoadWarehouses()
    {
        isLoadingWarehouses = true;
        try
        {
            var warehouseList = await MasterDataCache.GetWarehousesAsync();
            warehouses = warehouseList?.Where(w => w.IsActive).ToList() ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load warehouses: {ex.Message}";
        }
        finally
        {
            isLoadingWarehouses = false;
        }
    }

    private async Task LoadStock()
    {
        if (string.IsNullOrEmpty(selectedWarehouseCode)) return;

        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var response = await Http.GetFromJsonAsync<WarehouseStockPagedResponseDto>(
            $"/api/stock/warehouse/{selectedWarehouseCode}/paged?page={currentPage}&pageSize={pageSize}");

            if (response != null)
            {
                stockItems = response.Items ?? new();
                hasMore = response.HasMore;
            }

            selectedWarehouse = warehouses.FirstOrDefault(w => w.WarehouseCode == selectedWarehouseCode);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load stock: {ex.Message}";
            stockItems = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshStock()
    {
        currentPage = 1;
        await LoadStock();
    }

    private async Task NextPage()
    {
        if (hasMore)
        {
            currentPage++;
            await LoadStock();
        }
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadStock();
        }
    }

    private async Task OnSearchKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(selectedWarehouseCode))
        {
            await LoadStock();
        }
    }

    private void ClearFilters()
    {
        searchTerm = "";
        stockFilter = "all";
        selectedWarehouseCode = "";
        stockItems = new();
        currentPage = 1;
    }

    private void ShowLowStockAlerts()
    {
        stockFilter = "lowstock";
        StateHasChanged();
    }

    private string GetStockStatusClass(StockQuantityDto item)
    {
        if (item.Available <= 0) return "danger";
        if (item.Available < lowStockThreshold) return "warning";
        return "success";
    }

    private string GetAvailableClass(decimal available) => available switch
    {
        <= 0 => "text-danger",
        < 10 => "text-warning",
        _ => "text-success"
    };

    // DTOs for API responses (Stock-specific models not in shared models)
    public class StockQuantityDto
    {
        public string? ItemCode { get; set; }
        public string? ItemName { get; set; }
        public string? BarCode { get; set; }
        public string? WarehouseCode { get; set; }
        public decimal InStock { get; set; }
        public decimal Committed { get; set; }
        public decimal Ordered { get; set; }
        public decimal Available { get; set; }
        public string? UoM { get; set; }
    }

    public class WarehouseStockPagedResponseDto
    {
        public string? WarehouseCode { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
        public int Count { get; set; }
        public bool HasMore { get; set; }
        public DateTime QueryDate { get; set; }
        public List<StockQuantityDto>? Items { get; set; }
    }
}