@page "/purchase-orders/create"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Manager")]
@inject IPurchaseOrderService PurchaseOrderService
@inject IMasterDataCacheService CacheService
@inject NavigationManager NavigationManager
@using ShopInventory.Web.Data
@using ShopInventory.Web.Services
@inject ILogger<CreatePurchaseOrder> Logger
@inject IAppSettingsProvider AppSettings
@inject IAuditService AuditService
@rendermode InteractiveServer

<PageTitle>Create Purchase Order - Shop Inventory</PageTitle>

<style>
    .cpo-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    .cpo-breadcrumb {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .85rem;
        color: #6b7280;
        margin-bottom: 1.25rem;
    }

    .cpo-breadcrumb a {
        color: #667eea;
        text-decoration: none;
        font-weight: 500;
    }

    .cpo-breadcrumb a:hover {
        text-decoration: underline;
    }

    .cpo-breadcrumb .sep {
        color: #d1d5db;
    }

    .cpo-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .cpo-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .cpo-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .cpo-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .cpo-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .cpo-header-actions {
        display: flex;
        gap: .5rem;
        align-items: center;
    }

    .btn-back {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .55rem 1.1rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .85rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: all .15s;
    }

    .btn-back:hover {
        background: #f9fafb;
        border-color: #9ca3af;
        color: #374151;
    }

    .cpo-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .cpo-card-title {
        font-weight: 600;
        font-size: .95rem;
        color: #1a1a2e;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .cpo-grid {
        display: grid;
        gap: .85rem;
    }

    .cpo-grid.cpo-grid-three {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .cpo-field {
        display: flex;
        flex-direction: column;
    }

    .cpo-field.full {
        grid-column: 1 / -1;
    }

    .cpo-field.compact label {
        font-size: .68rem;
        margin-bottom: .2rem;
    }

    .cpo-field label {
        font-size: .75rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: .25rem;
    }

    .cpo-field label .req {
        color: #ef4444;
    }

    .cpo-field input,
    .cpo-field select,
    .cpo-field textarea {
        width: 100%;
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        background: #fff;
        transition: all .15s;
    }

    .cpo-field textarea {
        min-height: 88px;
        resize: vertical;
    }

    .cpo-field input:focus,
    .cpo-field select:focus,
    .cpo-field textarea:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .cpo-field input.has-error,
    .cpo-field select.has-error,
    .cpo-field textarea.has-error {
        border-color: #ef4444;
        box-shadow: 0 0 0 1px rgba(239, 68, 68, .12);
    }

    .cpo-inline-error {
        color: #ef4444;
        font-size: .78rem;
        margin-top: .25rem;
    }

    .cpo-helper,
    .cpo-loading-inline,
    .cpo-empty-text {
        color: #6b7280;
        font-size: .82rem;
    }

    .cpo-loading-inline {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .75rem;
    }

    .cpo-alert {
        border-radius: 12px;
        border: 1px solid transparent;
        padding: .85rem 1rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        font-weight: 500;
    }

    .cpo-alert.success {
        background: #ecfdf5;
        border-color: #bbf7d0;
        color: #065f46;
    }

    .cpo-alert.error {
        background: #fef2f2;
        border-color: #fecaca;
        color: #991b1b;
    }

    .cpo-search-wrapper {
        position: relative;
    }

    .cpo-dropdown {
        position: absolute;
        z-index: 100;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        max-height: 250px;
        overflow-y: auto;
        width: 100%;
        box-shadow: 0 8px 25px rgba(0, 0, 0, .12);
        margin-top: 2px;
    }

    .cpo-dropdown-item {
        padding: .5rem .75rem;
        cursor: pointer;
        font-size: .85rem;
        border-bottom: 1px solid #f3f4f6;
        transition: background .12s;
    }

    .cpo-dropdown-item:hover {
        background: #f0f4ff;
    }

    .cpo-dropdown-note {
        padding: .65rem .75rem;
        color: #9ca3af;
        font-size: .82rem;
        text-align: center;
    }

    .cpo-selected-card {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 10px;
        padding: .75rem 1rem;
    }

    .cpo-selected-code {
        font-weight: 700;
        color: #065f46;
    }

    .cpo-selected-name {
        font-size: .85rem;
        color: #065f46;
        opacity: .85;
    }

    .cpo-selected-meta {
        font-size: .82rem;
        color: #065f46;
        opacity: .75;
        margin-top: .25rem;
    }

    .cpo-clear-button,
    .cpo-line-remove {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
    }

    .cpo-clear-button {
        width: 28px;
        height: 28px;
        border-radius: 7px;
        font-size: .8rem;
    }

    .cpo-line-remove {
        width: 24px;
        height: 24px;
        border-radius: 6px;
        font-size: .75rem;
    }

    .cpo-clear-button:hover,
    .cpo-line-remove:hover {
        background: #fee2e2;
    }

    .cpo-line-remove:disabled {
        opacity: .55;
        cursor: not-allowed;
    }

    .cpo-section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: .75rem;
    }

    .cpo-section-title {
        font-weight: 600;
        font-size: .92rem;
        color: #1a1a2e;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-po-gradient {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 2px 8px rgba(102, 126, 234, .25);
        cursor: pointer;
    }

    .btn-po-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .4);
        color: #fff;
    }

    .btn-create {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-create:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
    }

    .btn-create:disabled,
    .btn-secondary-action:disabled,
    .btn-outline-action:disabled {
        opacity: .55;
        cursor: not-allowed;
        transform: none;
    }

    .btn-secondary-action,
    .btn-outline-action {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-outline-action {
        background: #f8fafc;
    }

    .btn-secondary-action:hover,
    .btn-outline-action:hover {
        background: #f9fafb;
        border-color: #9ca3af;
    }

    .cpo-line-card {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: .85rem;
        margin-bottom: .65rem;
    }

    .cpo-line-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .75rem;
        margin-bottom: .6rem;
        flex-wrap: wrap;
    }

    .cpo-line-heading {
        display: flex;
        align-items: center;
        gap: .45rem;
        flex-wrap: wrap;
    }

    .cpo-line-badge {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: .75rem;
    }

    .cpo-line-code {
        font-weight: 600;
        font-size: .85rem;
        color: #1a1a2e;
    }

    .cpo-line-sep {
        color: #d1d5db;
    }

    .cpo-line-desc,
    .cpo-line-placeholder {
        color: #6b7280;
        font-size: .82rem;
    }

    .cpo-line-total {
        font-weight: 700;
        color: #059669;
        font-size: .92rem;
    }

    .cpo-line-grid {
        display: grid;
        gap: .65rem;
    }

    .cpo-line-grid.cpo-line-grid-top {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
        margin-bottom: .65rem;
    }

    .cpo-line-grid.cpo-line-grid-bottom {
        grid-template-columns: repeat(5, minmax(0, 1fr));
    }

    .cpo-add-another {
        background: none;
        border: 1px dashed #d1d5db;
        color: #6b7280;
        padding: .4rem 1rem;
        border-radius: 8px;
        font-size: .82rem;
        cursor: pointer;
        transition: all .15s;
    }

    .cpo-add-another:hover {
        border-color: #9ca3af;
        color: #374151;
        background: #f8fafc;
    }

    .cpo-empty-state {
        text-align: center;
        padding: 2rem 1rem;
        background: #f9fafb;
        border-radius: 10px;
        border: 2px dashed #e5e7eb;
    }

    .cpo-empty-state i {
        font-size: 1.5rem;
        color: #9ca3af;
        margin-bottom: .5rem;
    }

    .cpo-empty-title {
        color: #6b7280;
        font-size: .85rem;
        margin-bottom: .25rem;
    }

    .cpo-summary {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border-radius: 10px;
        padding: .95rem 1.15rem;
        margin-top: 1rem;
        color: #fff;
    }

    .cpo-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
    }

    .cpo-summary-item span {
        display: block;
        font-size: .76rem;
        opacity: .8;
        text-transform: uppercase;
        letter-spacing: .35px;
        margin-bottom: .15rem;
    }

    .cpo-summary-item strong {
        display: block;
        font-size: 1.08rem;
        font-weight: 700;
    }

    .cpo-footer {
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        padding-top: 1rem;
        flex-wrap: wrap;
    }

    @@media (max-width: 992px) {

        .cpo-grid.cpo-grid-three,
        .cpo-line-grid.cpo-line-grid-bottom,
        .cpo-summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .cpo-page {
            padding: 1rem;
        }

        .cpo-header,
        .cpo-footer,
        .cpo-section-header {
            flex-direction: column;
            align-items: stretch;
        }

        .cpo-header-left {
            align-items: flex-start;
        }

        .cpo-header-actions,
        .cpo-header-actions>*,
        .cpo-footer>* {
            width: 100%;
        }

        .cpo-grid.cpo-grid-three,
        .cpo-line-grid.cpo-line-grid-top,
        .cpo-line-grid.cpo-line-grid-bottom,
        .cpo-summary-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="cpo-page">
    <div class="container-fluid">
        <div class="cpo-breadcrumb">
            <a href="/purchase-orders">Purchase Orders</a>
            <span class="sep">/</span>
            <span>Create New</span>
        </div>

        <div class="cpo-header">
            <div class="cpo-header-left">
                <div class="cpo-header-icon"><i class="bi bi-bag-plus"></i></div>
                <div>
                    <h2>Create Purchase Order</h2>
                    <p>Create a new purchase order with the same guided layout as the sales-order flow.</p>
                </div>
            </div>
            <div class="cpo-header-actions">
                <button type="button" class="btn-back" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i>
                    <span>Back</span>
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="cpo-alert success">@successMessage</div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="cpo-alert error">@errorMessage</div>
        }

        <div class="cpo-card">
            <div class="cpo-card-title"><i class="bi bi-building"></i> Supplier</div>
            <div class="cpo-field">
                <label>Supplier <span class="req">*</span></label>
                @if (isLoadingLookups)
                {
                    <div class="cpo-loading-inline">
                        <span class="spinner-border spinner-border-sm text-primary"></span>
                        <span>Loading suppliers...</span>
                    </div>
                }

                <MudAutocomplete T="BusinessPartnerDto"
                                 Value="selectedBusinessPartner"
                                 ValueChanged="OnSelectedBusinessPartnerChanged"
                                 SearchFunc="SearchBusinessPartnersAsync"
                                 ToStringFunc="@(bp => bp == null ? string.Empty : bp.DisplayName)"
                                 Placeholder="Search by code or name..."
                                 Dense="true"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 ResetValueOnEmptyText="true"
                                 ShowProgressIndicator="true"
                                 MaxItems="20"
                                 DebounceInterval="150"
                                 Clearable="true"
                                 Disabled="@isLoadingLookups">
                    <ItemTemplate>
                        <div class="d-flex flex-column py-1">
                            <span class="fw-semibold">@context.CardCode</span>
                            <small class="text-muted">@context.CardName</small>
                        </div>
                    </ItemTemplate>
                </MudAutocomplete>

                @if (selectedBusinessPartner is not null)
                {
                    <div class="cpo-selected-card" style="margin-top:.75rem;">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="cpo-selected-code">
                                    <i class="bi bi-check-circle-fill me-1"></i>@selectedBusinessPartner.CardCode
                                </div>
                                <div class="cpo-selected-name">@selectedBusinessPartner.CardName</div>
                                @if (!string.IsNullOrWhiteSpace(selectedBusinessPartner.Phone1))
                                {
                                    <div class="cpo-selected-meta"><i class="bi bi-telephone me-1"></i>@selectedBusinessPartner.Phone1</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(selectedBusinessPartner.Currency))
                                {
                                    <div class="cpo-selected-meta"><i class="bi bi-cash-coin me-1"></i>@selectedBusinessPartner.Currency</div>
                                }
                            </div>
                            <button type="button" class="cpo-clear-button" @onclick="ClearSelectedBP">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>
                }

                @if (HasError("CardCode"))
                {
                    <div class="cpo-inline-error">@GetError("CardCode")</div>
                }
            </div>
        </div>

                <div class="cpo-card">
                    <div class="cpo-card-title"><i class="bi bi-info-circle"></i> Order Details</div>
                    <div class="cpo-grid cpo-grid-three">
                        <div class="cpo-field">
                            <label>Supplier Reference</label>
                            <input type="text" @bind="purchaseOrder.SupplierRefNo" placeholder="Quote / Ref number" />
                        </div>
                        <div class="cpo-field">
                            <label>Delivery Date</label>
                            <input type="date" @bind-value="deliveryDate" @bind-value:format="yyyy-MM-dd" />
                        </div>
                        <div class="cpo-field">
                            <label>Currency</label>
                            <select @bind="purchaseOrder.Currency">
                                <option value="USD">USD</option>
                                <option value="ZIG">ZIG</option>
                            </select>
                        </div>
                        <div class="cpo-field">
                            <label>Receiving Warehouse</label>
                            <MudAutocomplete T="WarehouseDto"
                                             Value="GetSelectedWarehouse(purchaseOrder.WarehouseCode)"
                                             ValueChanged="OnHeaderWarehouseChanged"
                                             SearchFunc="SearchWarehousesAsync"
                                             ToStringFunc="@(warehouse => warehouse == null ? string.Empty : warehouse.DisplayName)"
                                             Placeholder="Search warehouse..."
                                             Dense="true"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             ResetValueOnEmptyText="true"
                                             ShowProgressIndicator="true"
                                             MaxItems="20"
                                             DebounceInterval="150"
                                             Clearable="true"
                                             Disabled="@isLoadingLookups">
                                <ItemTemplate>
                                    <div class="d-flex flex-column py-1">
                                        <span class="fw-semibold">@context.WarehouseCode</span>
                                        <small class="text-muted">@context.WarehouseName</small>
                                    </div>
                                </ItemTemplate>
                            </MudAutocomplete>
                        </div>
                        <div class="cpo-field">
                            <label>Header Discount %</label>
                            <input type="number" @bind="purchaseOrder.DiscountPercent" min="0" max="100" step="0.5" />
                        </div>
                        <div class="cpo-field full">
                            <label>Comments</label>
                            <textarea @bind="purchaseOrder.Comments" rows="2"
                                      placeholder="Optional notes for this order..."></textarea>
                        </div>
                    </div>
                    <p class="cpo-helper" style="margin:.85rem 0 0;">Header discount is applied to the subtotal before tax is
                        added.</p>
                    </div>

                    <div class="cpo-card">
                        <div class="cpo-section-header">
                            <div class="cpo-section-title"><i class="bi bi-list-ul"></i> Order Lines</div>
                            <button type="button" class="btn-po-gradient" @onclick="AddLine">
                                <i class="bi bi-plus-lg"></i>
                                <span>Add Line</span>
                            </button>
                        </div>

                        @if (validationErrors.ContainsKey("Lines"))
                        {
                            <div class="cpo-inline-error" style="margin-bottom:.75rem;">@validationErrors["Lines"]</div>
                        }

                        @if (purchaseOrder.Lines.Any())
                        {
                            @for (int i = 0; i < purchaseOrder.Lines.Count; i++)
                            {
                                var idx = i;
                                var line = purchaseOrder.Lines[idx];

                                <div class="cpo-line-card">
                                    <div class="cpo-line-header">
                                        <div class="cpo-line-heading">
                                            <span class="cpo-line-badge">@(idx + 1)</span>
                                            @if (!string.IsNullOrWhiteSpace(line.ItemCode) ||
                                                                    !string.IsNullOrWhiteSpace(line.ItemDescription))
                                            {
                                                @if (!string.IsNullOrWhiteSpace(line.ItemCode))
                                                {
                                                    <span class="cpo-line-code">@line.ItemCode</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(line.ItemCode) &&
                                                                        !string.IsNullOrWhiteSpace(line.ItemDescription))
                                                {
                                                    <span class="cpo-line-sep">-</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(line.ItemDescription))
                                                {
                                                    <span class="cpo-line-desc">@line.ItemDescription</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="cpo-line-placeholder">New Line Item</span>
                                            }
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="cpo-line-total">@CalculateLineTotal(line).ToString("N2")</span>
                                            <button type="button" class="cpo-line-remove" @onclick="() => RemoveLine(idx)"
                                                    disabled="@(purchaseOrder.Lines.Count == 1)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="cpo-line-grid cpo-line-grid-top">
                                        <div class="cpo-field compact">
                                            <label>Item Code <span class="req">*</span></label>
                                            <MudAutocomplete T="ProductDto"
                                                             Value="GetSelectedProduct(line.ItemCode)"
                                                             ValueChanged="(product) => OnLineProductChanged(idx, product)"
                                                             SearchFunc="SearchProductsAsync"
                                                             ToStringFunc="@(product => product == null ? string.Empty : $"{product.ItemCode} - {product.ItemName}")"
                                                             Placeholder="Search item..."
                                                             Dense="true"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             ResetValueOnEmptyText="true"
                                                             ShowProgressIndicator="true"
                                                             MaxItems="20"
                                                             DebounceInterval="150"
                                                             Clearable="true"
                                                             Disabled="@isLoadingLookups">
                                                <ItemTemplate>
                                                    <div class="d-flex justify-content-between align-items-center py-1 w-100">
                                                        <div class="d-flex flex-column">
                                                            <span class="fw-semibold">@context.ItemCode</span>
                                                            <small class="text-muted">@context.ItemName</small>
                                                        </div>
                                                        @if (context.QuantityInStock > 0)
                                                        {
                                                            <span class="badge bg-success-subtle text-success ms-2">@context.QuantityInStock.ToString("N0") in stock</span>
                                                        }
                                                    </div>
                                                </ItemTemplate>
                                            </MudAutocomplete>
                                            @if (HasError($"Line{idx}_ItemCode"))
                                            {
                                                <div class="cpo-inline-error">@GetError($"Line{idx}_ItemCode")</div>
                                            }
                                        </div>
                                        <div class="cpo-field compact">
                                            <label>Description</label>
                                            <input type="text" @bind="line.ItemDescription" placeholder="Description" />
                                        </div>
                                    </div>

                                    <div class="cpo-line-grid cpo-line-grid-bottom">
                                        <div class="cpo-field compact">
                                            <label>Qty <span class="req">*</span></label>
                                            <input class="@(HasError($"Line{idx}_Quantity") ? "has-error" : string.Empty)" type="number"
                                                   @bind="line.Quantity" min="0.0001" step="any" />
                                            @if (HasError($"Line{idx}_Quantity"))
                                            {
                                                <div class="cpo-inline-error">@GetError($"Line{idx}_Quantity")</div>
                                            }
                                        </div>
                                        <div class="cpo-field compact">
                                            <label>Unit Price</label>
                                            <input type="number" @bind="line.UnitPrice" min="0" step="any" />
                                        </div>
                                        <div class="cpo-field compact">
                                            <label>Tax %</label>
                                            <input type="number" @bind="line.TaxPercent" min="0" max="100" step="0.5" />
                                        </div>
                                        <div class="cpo-field compact">
                                            <label>Discount %</label>
                                            <input type="number" @bind="line.DiscountPercent" min="0" max="100" step="0.5" />
                                        </div>
                                        <div class="cpo-field compact">
                                            <label>Warehouse</label>
                                            <MudAutocomplete T="WarehouseDto"
                                                             Value="GetSelectedWarehouse(line.WarehouseCode)"
                                                             ValueChanged="(warehouse) => OnLineWarehouseChanged(idx, warehouse)"
                                                             SearchFunc="SearchWarehousesAsync"
                                                             ToStringFunc="@(warehouse => warehouse == null ? string.Empty : warehouse.DisplayName)"
                                                             Placeholder="@(purchaseOrder.WarehouseCode ?? "Search warehouse...")"
                                                             Dense="true"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             ResetValueOnEmptyText="true"
                                                             ShowProgressIndicator="true"
                                                             MaxItems="20"
                                                             DebounceInterval="150"
                                                             Clearable="true"
                                                             Disabled="@isLoadingLookups">
                                                <ItemTemplate>
                                                    <div class="d-flex flex-column py-1">
                                                        <span class="fw-semibold">@context.WarehouseCode</span>
                                                        <small class="text-muted">@context.WarehouseName</small>
                                                    </div>
                                                </ItemTemplate>
                                            </MudAutocomplete>
                                        </div>
                                    </div>
                                </div>
                            }

                            <div style="text-align:center; margin-top:.5rem;">
                                <button type="button" class="cpo-add-another" @onclick="AddLine">
                                    <i class="bi bi-plus-lg me-1"></i>Add Another Line
                                </button>
                            </div>

                            <div class="cpo-summary">
                                <div class="cpo-summary-grid">
                                    <div class="cpo-summary-item">
                                        <span>Lines</span>
                                        <strong>@purchaseOrder.Lines.Count</strong>
                                    </div>
                                    <div class="cpo-summary-item">
                                        <span>Subtotal</span>
                                        <strong>@CalculateSubTotal().ToString("N2")</strong>
                                    </div>
                                    <div class="cpo-summary-item">
                                        <span>Discount + Tax</span>
                                        <strong>@CalculateDiscount().ToString("N2") / @CalculateTax().ToString("N2")</strong>
                                    </div>
                                    <div class="cpo-summary-item">
                                        <span>Grand Total</span>
                                        <strong>@purchaseOrder.Currency @CalculateGrandTotal().ToString("N2")</strong>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="cpo-empty-state">
                                <i class="bi bi-inbox"></i>
                                <p class="cpo-empty-title">No order lines yet</p>
                                <p class="cpo-empty-text">Add items to build the purchase order.</p>
                                <button type="button" class="btn-po-gradient" @onclick="AddLine">
                                    <i class="bi bi-plus-lg"></i>
                                    <span>Add First Line</span>
                                </button>
                            </div>
                        }
                    </div>

                    <div class="cpo-footer">
                        <button type="button" class="btn-secondary-action" @onclick="GoBack">Cancel</button>
                        <button type="button" class="btn-outline-action" @onclick="SaveAsDraft" disabled="@isSubmitting">
                            @if (isSubmitting && !submitForApproval)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            <i class="bi bi-save"></i>
                            <span>Save as Draft</span>
                        </button>
                        <button type="button" class="btn-create" @onclick="SaveAndSubmit" disabled="@isSubmitting">
                            @if (isSubmitting && submitForApproval)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            <i class="bi bi-send"></i>
                            <span>Save &amp; Submit for Approval</span>
                        </button>
                    </div>
                </div>
            </div>

@code {
    private CreatePurchaseOrderRequest purchaseOrder = new()
    {
        Currency = "USD",
        Lines = new List<CreatePurchaseOrderLineRequest>
{
new CreatePurchaseOrderLineRequest()
}
    };

    private DateTime? deliveryDate;
    private bool isSubmitting = false;
    private string? successMessage;
    private string? errorMessage;
    private Dictionary<string, string> validationErrors = new();
    private bool submitForApproval = false;

    // Business Partner fields
    private List<BusinessPartnerDto> allBusinessPartners = new();
    private List<ProductDto> cachedProducts = new();
    private List<WarehouseDto> cachedWarehouses = new();
    private BusinessPartnerDto? selectedBusinessPartner;
    private bool isLoadingLookups = true;
    private bool _hasInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasInitialized)
        {
            _hasInitialized = true;
            await LoadLookupsAsync();
            StateHasChanged();
        }
    }

    private async Task LoadLookupsAsync()
    {
        isLoadingLookups = true;
        StateHasChanged();

        try
        {
            var businessPartnerTask = CacheService.GetBusinessPartnersAsync();
            var productTask = CacheService.GetProductsAsync();
            var warehouseTask = CacheService.GetWarehousesAsync();

            await Task.WhenAll(businessPartnerTask, productTask, warehouseTask);

            allBusinessPartners = await businessPartnerTask;
            cachedProducts = await productTask;
            cachedWarehouses = await warehouseTask;

            Logger.LogInformation(
                "Loaded PO creation lookups: {BPCount} suppliers, {ProductCount} products, {WarehouseCount} warehouses",
                allBusinessPartners.Count,
                cachedProducts.Count,
                cachedWarehouses.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading purchase order lookups");
            errorMessage = "Failed to load suppliers, products, or warehouses. Refresh and try again.";
        }
        finally
        {
            isLoadingLookups = false;
        }
    }

    private Task<IEnumerable<BusinessPartnerDto>> SearchBusinessPartnersAsync(string searchText, CancellationToken cancellationToken)
    {
        IEnumerable<BusinessPartnerDto> results = allBusinessPartners
            .Where(bp => !string.IsNullOrWhiteSpace(bp.CardCode));

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            results = results.Where(bp =>
                (bp.CardCode?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (bp.CardName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        return Task.FromResult(results.Take(20));
    }

    private Task<IEnumerable<WarehouseDto>> SearchWarehousesAsync(string searchText, CancellationToken cancellationToken)
    {
        IEnumerable<WarehouseDto> results = cachedWarehouses;

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            results = results.Where(warehouse =>
                (warehouse.WarehouseCode?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (warehouse.WarehouseName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        return Task.FromResult(results.Take(20));
    }

    private Task<IEnumerable<ProductDto>> SearchProductsAsync(string searchText, CancellationToken cancellationToken)
    {
        IEnumerable<ProductDto> results = cachedProducts;

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            results = results.Where(product =>
                (product.ItemCode?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (product.ItemName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (product.BarCode?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        return Task.FromResult(results.Take(20));
    }

    private void OnSelectedBusinessPartnerChanged(BusinessPartnerDto? bp)
    {
        if (bp is null)
        {
            ClearSelectedBP();
            return;
        }

        selectedBusinessPartner = bp;
        purchaseOrder.CardCode = bp.CardCode ?? string.Empty;
        purchaseOrder.CardName = bp.CardName;

        if (!string.IsNullOrWhiteSpace(bp.Currency) && !string.Equals(bp.Currency, "##", StringComparison.OrdinalIgnoreCase))
        {
            purchaseOrder.Currency = bp.Currency.Trim().ToUpperInvariant();
        }

        validationErrors.Remove("CardCode");
    }

    private void ClearSelectedBP()
    {
        selectedBusinessPartner = null;
        purchaseOrder.CardCode = string.Empty;
        purchaseOrder.CardName = null;
        validationErrors.Remove("CardCode");
    }

    private bool HasError(string key) => validationErrors.ContainsKey(key);
    private string? GetError(string key) => validationErrors.GetValueOrDefault(key);

    private void AddLine()
    {
        purchaseOrder.Lines.Add(new CreatePurchaseOrderLineRequest
        {
            WarehouseCode = purchaseOrder.WarehouseCode
        });
    }

    private void RemoveLine(int index)
    {
        if (purchaseOrder.Lines.Count > 1)
        {
            purchaseOrder.Lines.RemoveAt(index);
        }
    }

    private decimal CalculateLineTotal(CreatePurchaseOrderLineRequest line)
    {
        return line.Quantity * line.UnitPrice * (1 - line.DiscountPercent / 100);
    }

    private decimal CalculateSubTotal()
    {
        return purchaseOrder.Lines.Sum(l => CalculateLineTotal(l));
    }

    private decimal CalculateDiscount()
    {
        return CalculateSubTotal() * purchaseOrder.DiscountPercent / 100;
    }

    private decimal CalculateTax()
    {
        return purchaseOrder.Lines.Sum(l =>
        {
            var lineTotal = CalculateLineTotal(l);
            return lineTotal * l.TaxPercent / 100;
        });
    }

    private decimal CalculateGrandTotal()
    {
        return CalculateSubTotal() - CalculateDiscount() + CalculateTax();
    }

    private WarehouseDto? GetSelectedWarehouse(string? warehouseCode)
    {
        if (string.IsNullOrWhiteSpace(warehouseCode))
            return null;

        return cachedWarehouses.FirstOrDefault(warehouse =>
            string.Equals(warehouse.WarehouseCode, warehouseCode, StringComparison.OrdinalIgnoreCase));
    }

    private ProductDto? GetSelectedProduct(string? itemCode)
    {
        if (string.IsNullOrWhiteSpace(itemCode))
            return null;

        return cachedProducts.FirstOrDefault(product =>
            string.Equals(product.ItemCode, itemCode, StringComparison.OrdinalIgnoreCase));
    }

    private void OnHeaderWarehouseChanged(WarehouseDto? warehouse)
    {
        var previousWarehouseCode = purchaseOrder.WarehouseCode;
        purchaseOrder.WarehouseCode = warehouse?.WarehouseCode;

        foreach (var line in purchaseOrder.Lines)
        {
            if (string.IsNullOrWhiteSpace(line.WarehouseCode) ||
                string.Equals(line.WarehouseCode, previousWarehouseCode, StringComparison.OrdinalIgnoreCase))
            {
                line.WarehouseCode = purchaseOrder.WarehouseCode;
            }
        }
    }

    private void OnLineWarehouseChanged(int index, WarehouseDto? warehouse)
    {
        if (index < 0 || index >= purchaseOrder.Lines.Count)
            return;

        purchaseOrder.Lines[index].WarehouseCode = warehouse?.WarehouseCode;
    }

    private void OnLineProductChanged(int index, ProductDto? product)
    {
        if (index < 0 || index >= purchaseOrder.Lines.Count)
            return;

        var line = purchaseOrder.Lines[index];

        if (product is null)
        {
            line.ItemCode = string.Empty;
            line.ItemDescription = null;
            line.UoMCode = null;
            return;
        }

        line.ItemCode = product.ItemCode ?? string.Empty;
        line.ItemDescription = product.ItemName;

        if (line.UnitPrice <= 0 && product.Price > 0)
        {
            line.UnitPrice = product.Price;
        }

        if (string.IsNullOrWhiteSpace(line.WarehouseCode))
        {
            line.WarehouseCode = purchaseOrder.WarehouseCode ?? product.DefaultWarehouse;
        }

        if (string.IsNullOrWhiteSpace(line.UoMCode))
        {
            line.UoMCode = product.UoM;
        }

        validationErrors.Remove($"Line{index}_ItemCode");
    }

    private bool ValidateForm()
    {
        validationErrors.Clear();

        if (string.IsNullOrWhiteSpace(purchaseOrder.CardCode))
            validationErrors["CardCode"] = "Supplier code is required";

        if (purchaseOrder.Lines.Count == 0)
            validationErrors["Lines"] = "At least one line item is required";

        for (int i = 0; i < purchaseOrder.Lines.Count; i++)
        {
            var line = purchaseOrder.Lines[i];
            if (string.IsNullOrWhiteSpace(line.ItemCode))
                validationErrors[$"Line{i}_ItemCode"] = "Required";
            if (line.Quantity <= 0)
                validationErrors[$"Line{i}_Quantity"] = "Must be > 0";
        }

        return validationErrors.Count == 0;
    }

    private async Task SaveAsDraft()
    {
        submitForApproval = false;
        await SubmitOrder();
    }

    private async Task SaveAndSubmit()
    {
        submitForApproval = true;
        await SubmitOrder();
    }

    private async Task SubmitOrder()
    {
        if (!ValidateForm()) return;

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            purchaseOrder.DeliveryDate = deliveryDate;

            Logger.LogInformation("Submitting PO for supplier {CardCode} with {Lines} lines",
            purchaseOrder.CardCode, purchaseOrder.Lines.Count);

            var result = await PurchaseOrderService.CreatePurchaseOrderAsync(purchaseOrder);
            if (result != null)
            {
                if (submitForApproval)
                {
                    try
                    {
                        await PurchaseOrderService.UpdateStatusAsync(result.Id, PurchaseOrderStatus.Pending, "Submitted for approval");
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "PO created but failed to submit for approval. It remains as Draft.");
                    }
                }

                successMessage = $"Purchase order {result.OrderNumber} created successfully!";
                Logger.LogInformation("Created purchase order {OrderNumber}", result.OrderNumber);
                await AuditService.LogAsync(AuditActions.CreatePurchaseOrder, "PurchaseOrder", result.OrderNumber);

                // Reset form
                purchaseOrder = new CreatePurchaseOrderRequest
                {
                    Currency = "USD",
                    Lines = new List<CreatePurchaseOrderLineRequest> { new() }
                };
                deliveryDate = null;
                validationErrors.Clear();
                selectedBusinessPartner = null;

                // Navigate to list after brief delay
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/purchase-orders");
            }
            else
            {
                errorMessage = "Failed to create purchase order. The API returned no result — check server logs for details.";
                await AuditService.LogAsync(AuditActions.CreatePurchaseOrder, "PurchaseOrder", null, null, false, errorMessage);
            }
        }
        catch (HttpRequestException ex)
        {
            Logger.LogError(ex, "HTTP error creating purchase order");
            errorMessage = ShopInventory.Web.Services.ApiErrorResponse.GetFriendlyMessage(
                ex,
                "We couldn't create this purchase order right now. Please try again.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating purchase order");
            errorMessage = ShopInventory.Web.Services.ApiErrorResponse.GetFriendlyMessage(
                ex,
                "We couldn't create this purchase order right now. Please try again.");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/purchase-orders");
    }
}