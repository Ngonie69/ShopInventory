    private void OnBulkFilesSelected(InputFileChangeEventArgs e)
    {
        bulkFiles = e.GetMultipleFiles(1500).ToList();
        bulkMessage = null;
        bulkMappings = bulkFiles.Select(f => new BulkFileMapping
        {
            File = f,
            FileName = f.Name,
            DocNum = ExtractDocNumFromFileName(f.Name),
            FileSize = f.Size,
            Status = BulkFileStatus.Pending
        }).ToList();
    }

    private static int? ExtractDocNumFromFileName(string fileName)
    {
        // Extract leading digits from filename (before any separator or extension)
        var nameWithoutExt = System.IO.Path.GetFileNameWithoutExtension(fileName);
        var match = System.Text.RegularExpressions.Regex.Match(nameWithoutExt, @"^(\d+)");
        if (match.Success && int.TryParse(match.Groups[1].Value, out var docNum) && docNum > 0)
            return docNum;
        return null;
    }

    private async Task ValidateBulkFiles()
    {
        if (isBulkValidating || bulkMappings.Count == 0) return;
        isBulkValidating = true;
        bulkMessage = null;
        bulkAutoRetryRound = 0;
        bulkValidationCts?.Cancel();
        bulkValidationCts = new CancellationTokenSource();
        var ct = bulkValidationCts.Token;

        try
        {
            await ValidateBulkFilesCore(bulkMappings, ct);

            // Auto-retry failed items up to bulkMaxAutoRetries times
            var errorCount = bulkMappings.Count(m => m.Status == BulkFileStatus.Error
                && m.ErrorMessage != null
                && !m.ErrorMessage.StartsWith("Excluded BP")
                && m.ErrorMessage != "No invoice number in filename"
                && m.ErrorMessage != "File exceeds 20MB limit");

            while (errorCount > 0 && bulkAutoRetryRound < bulkMaxAutoRetries && !ct.IsCancellationRequested)
            {
                bulkAutoRetryRound++;
                bulkMessage = $"Auto-retrying {errorCount} failed items (round {bulkAutoRetryRound}/{bulkMaxAutoRetries})...";
                bulkSuccess = false;
                await InvokeAsync(StateHasChanged);

                // Brief pause before retry round
                await Task.Delay(1000 * bulkAutoRetryRound, ct);

                var retryMappings = bulkMappings.Where(m => m.Status == BulkFileStatus.Error
                    && m.ErrorMessage != null
                    && !m.ErrorMessage.StartsWith("Excluded BP")
                    && m.ErrorMessage != "No invoice number in filename"
                    && m.ErrorMessage != "File exceeds 20MB limit").ToList();

                foreach (var m in retryMappings)
                {
                    m.Status = BulkFileStatus.Pending;
                    m.ErrorMessage = null;
                    m.ExistingPodCount = 0;
                }

                await ValidateBulkFilesCore(retryMappings, ct);

                errorCount = bulkMappings.Count(m => m.Status == BulkFileStatus.Error
                    && m.ErrorMessage != null
                    && !m.ErrorMessage.StartsWith("Excluded BP")
                    && m.ErrorMessage != "No invoice number in filename"
                    && m.ErrorMessage != "File exceeds 20MB limit");
            }

            UpdateBulkValidationSummary();
        }
        catch (OperationCanceledException)
        {
            bulkMessage = "Validation cancelled.";
            bulkSuccess = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error validating bulk files");
            bulkMessage = "Validation error. Please try again.";
            bulkSuccess = false;
        }
        finally
        {
            isBulkValidating = false;
        }
    }

    private async Task ValidateBulkFilesCore(List<BulkFileMapping> mappings, CancellationToken ct)
    {
        var docNums = mappings
            .Where(m => m.DocNum.HasValue)
            .Select(m => m.DocNum!.Value)
            .Distinct()
            .ToList();

        var totalToValidate = docNums.Count;
        bulkValidationProgress = $"(0/{totalToValidate})";
        await InvokeAsync(StateHasChanged);

        var validationResponse = totalToValidate == 0
            ? new BulkPodValidationResponse()
            : await PodService.ValidateBulkPodsAsync(docNums, ct);

        var validationResults = validationResponse?.Results
            .GroupBy(result => result.DocNum)
            .ToDictionary(group => group.Key, group => group.First())
            ?? new Dictionary<int, BulkPodValidationResult>();

        bulkValidationProgress = $"({totalToValidate}/{totalToValidate})";
        await InvokeAsync(StateHasChanged);

        foreach (var map in mappings)
        {
            if (!map.DocNum.HasValue)
            {
                map.Status = BulkFileStatus.Error;
                map.ErrorMessage = "No invoice number in filename";
                continue;
            }

            if (map.FileSize > 20 * 1024 * 1024)
            {
                map.Status = BulkFileStatus.Error;
                map.ErrorMessage = "File exceeds 20MB limit";
                continue;
            }

            if (!validationResults.TryGetValue(map.DocNum.Value, out var validationResult))
            {
                map.Status = BulkFileStatus.Error;
                map.ErrorMessage = validationResponse == null
                    ? "Invoice lookup failed (API unavailable or rate limited)"
                    : $"Invoice #{map.DocNum} not found in SAP";
                continue;
            }

            if (validationResult.Found && validationResult.DocEntry.HasValue)
            {
                if (ExcludedCardCodes.Contains(validationResult.CardCode ?? ""))
                {
                    map.DocEntry = validationResult.DocEntry;
                    map.CardName = validationResult.CardName;
                    map.Status = BulkFileStatus.Error;
                    map.ErrorMessage = $"Excluded BP ({validationResult.CardCode})";
                }
                else
                {
                    map.DocEntry = validationResult.DocEntry;
                    map.CardName = validationResult.CardName;
                    map.ExistingPodCount = validationResult.ExistingPodCount;
                    if (map.ExistingPodCount > 0)
                    {
                        map.Status = BulkFileStatus.Skipped;
                        map.ErrorMessage = $"Already uploaded ({map.ExistingPodCount} existing POD{(map.ExistingPodCount > 1 ? "s" : "")})";
                    }
                    else
                    {
                        map.Status = BulkFileStatus.Valid;
                    }
                }
            }
            else
            {
                map.Status = BulkFileStatus.Error;
                map.ErrorMessage = validationResult.ErrorMessage ?? $"Invoice #{map.DocNum} not found in SAP";
            }
        }
    }

    private void UpdateBulkValidationSummary()
    {
        var readyCount = bulkMappings.Count(m => m.Status is BulkFileStatus.Valid or BulkFileStatus.ValidWithWarning);
        var skippedCount = bulkMappings.Count(m => m.Status == BulkFileStatus.Skipped);
        var errorCount = bulkMappings.Count(m => m.Status == BulkFileStatus.Error);

        var parts = new List<string>();
        if (readyCount > 0) parts.Add($"{readyCount} ready");
        if (skippedCount > 0) parts.Add($"{skippedCount} skipped (already uploaded)");
        if (errorCount > 0) parts.Add($"{errorCount} with errors");

        var suffix = bulkAutoRetryRound > 0 ? $" (after {bulkAutoRetryRound} auto-retry round{(bulkAutoRetryRound > 1 ? "s" : "")})" : "";

        if (readyCount > 0)
        {
            bulkMessage = string.Join(", ", parts) + suffix + ". You can upload the valid ones.";
            bulkSuccess = true;
        }
        else if (skippedCount > 0 && errorCount == 0)
        {
            bulkMessage = $"All {skippedCount} files already have PODs uploaded. Nothing to upload.";
            bulkSuccess = false;
        }
        else
        {
            bulkMessage = "No valid files found. Check filenames start with invoice numbers." + suffix;
            bulkSuccess = false;
        }
    }

    private async Task RetryBulkValidation()
    {
        // Reset retryable error items back to Pending and re-validate with auto-retry
        var errorMappings = bulkMappings.Where(m => m.Status == BulkFileStatus.Error).ToList();
        if (errorMappings.Count == 0 || isBulkValidating) return;

        isBulkValidating = true;
        bulkMessage = null;
        bulkAutoRetryRound = 0;
        bulkValidationCts?.Cancel();
        bulkValidationCts = new CancellationTokenSource();
        var ct = bulkValidationCts.Token;

        try
        {
            foreach (var m in errorMappings)
            {
                m.Status = BulkFileStatus.Pending;
                m.ErrorMessage = null;
                m.ExistingPodCount = 0;
            }

            await ValidateBulkFilesCore(errorMappings, ct);

            // Auto-retry remaining retryable errors
            var retryableCount = errorMappings.Count(m => m.Status == BulkFileStatus.Error
                && m.ErrorMessage != null
                && !m.ErrorMessage.StartsWith("Excluded BP")
                && m.ErrorMessage != "No invoice number in filename"
                && m.ErrorMessage != "File exceeds 20MB limit");

            while (retryableCount > 0 && bulkAutoRetryRound < bulkMaxAutoRetries && !ct.IsCancellationRequested)
            {
                bulkAutoRetryRound++;
                bulkMessage = $"Auto-retrying {retryableCount} failed items (round {bulkAutoRetryRound}/{bulkMaxAutoRetries})...";
                bulkSuccess = false;
                await InvokeAsync(StateHasChanged);

                await Task.Delay(1000 * bulkAutoRetryRound, ct);

                var retryMappings = errorMappings.Where(m => m.Status == BulkFileStatus.Error
                    && m.ErrorMessage != null
                    && !m.ErrorMessage.StartsWith("Excluded BP")
                    && m.ErrorMessage != "No invoice number in filename"
                    && m.ErrorMessage != "File exceeds 20MB limit").ToList();

                foreach (var m in retryMappings)
                {
                    m.Status = BulkFileStatus.Pending;
                    m.ErrorMessage = null;
                    m.ExistingPodCount = 0;
                }

                await ValidateBulkFilesCore(retryMappings, ct);

                retryableCount = errorMappings.Count(m => m.Status == BulkFileStatus.Error
                    && m.ErrorMessage != null
                    && !m.ErrorMessage.StartsWith("Excluded BP")
                    && m.ErrorMessage != "No invoice number in filename"
                    && m.ErrorMessage != "File exceeds 20MB limit");
            }

            UpdateBulkValidationSummary();
        }
        catch (OperationCanceledException)
        {
            bulkMessage = "Validation cancelled.";
            bulkSuccess = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error retrying bulk validation");
            bulkMessage = "Validation error. Please try again.";
            bulkSuccess = false;
        }
        finally
        {
            isBulkValidating = false;
        }
    }

    private async Task ExecuteBulkUpload()
    {
        var validMappings = bulkMappings.Where(m => m.Status is BulkFileStatus.Valid or BulkFileStatus.ValidWithWarning).ToList();
        if (validMappings.Count == 0 || isBulkUploading) return;

        isBulkUploading = true;
        bulkMessage = null;
        var successCount = 0;
        var failCount = 0;

        try
        {
            // Upload in parallel batches (5 concurrent uploads)
            var uploadSemaphore = new SemaphoreSlim(5, 5);
            var completed = 0;

            var uploadTasks = validMappings.Select(async (map, i) =>
            {
                await uploadSemaphore.WaitAsync();
                try
                {
                    map.Status = BulkFileStatus.Uploading;
                    await InvokeAsync(StateHasChanged);

                    try
                    {
                        using var stream = map.File.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
                        var (success, message, _) = await PodService.UploadPodAsync(
                            map.DocEntry!.Value, stream, map.File.Name, map.File.ContentType,
                            bulkDescription, currentUsername);

                        if (success)
                        {
                            map.Status = BulkFileStatus.Uploaded;
                            Interlocked.Increment(ref successCount);
                        }
                        else
                        {
                            map.Status = BulkFileStatus.Error;
                            map.ErrorMessage = message;
                            Interlocked.Increment(ref failCount);
                        }
                    }
                    catch (Exception ex)
                    {
                        map.Status = BulkFileStatus.Error;
                        map.ErrorMessage = "Upload failed";
                        Interlocked.Increment(ref failCount);
                        Logger.LogError(ex, "Bulk upload failed for {FileName}", map.FileName);
                    }

                    var done = Interlocked.Increment(ref completed);
                    bulkUploadProgress = $"({done}/{validMappings.Count})";
                    await InvokeAsync(StateHasChanged);
                }
                finally
                {
                    uploadSemaphore.Release();
                }
            }).ToArray();

            await Task.WhenAll(uploadTasks);

            if (failCount == 0)
            {
                bulkSuccess = true;
                bulkMessage = $"All {successCount} PODs uploaded successfully!";
                // Audit log: bulk POD upload
                await AuditService.LogAsync(AuditActions.BulkUploadPod, "POD", null, $"{successCount} files uploaded", true);
                // Clear all since everything uploaded
                bulkMappings.Clear();
                bulkFiles.Clear();
                bulkInputFileKey++;
                await ReloadPodsTableAsync(resetToFirstPage: true);
            }
            else
            {
                bulkSuccess = successCount > 0;
                bulkMessage = $"{successCount} uploaded, {failCount} failed. You can retry the failed ones.";
                if (successCount > 0)
                {
                    // Remove successfully uploaded items, keep only errors
                    bulkMappings.RemoveAll(m => m.Status == BulkFileStatus.Uploaded);
                    await AuditService.LogAsync(AuditActions.BulkUploadPod, "POD", null, $"{successCount} of {successCount + failCount} files uploaded", true);
                    await ReloadPodsTableAsync(resetToFirstPage: true);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during bulk upload");
            bulkMessage = "An unexpected error occurred during bulk upload.";
            bulkSuccess = false;
        }
        finally
        {
            isBulkUploading = false;
        }
    }

    private void ClearBulkUpload()
    {
        bulkFiles.Clear();
        bulkMappings.Clear();
        bulkDescription = null;
        bulkMessage = null;
        bulkInputFileKey++;
    }

    private void RemoveBulkMapping(BulkFileMapping mapping)
    {
        bulkMappings.Remove(mapping);
        bulkFiles.Remove(mapping.File);
    }
