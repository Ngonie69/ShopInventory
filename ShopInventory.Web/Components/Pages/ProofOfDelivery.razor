@code {
    private MudTable<PodAttachmentItemDto>? _podsTable;
    private PodAttachmentListResponse? podResponse;
    private string? podLoadError;
    private bool isLoading = true;
    private int podsTableKey;
    private const int DefaultPodPageSize = 20;
    private string? filterCardCode;
    private string? filterSearch;
    private DateTime? filterFromDate;
    private DateTime? filterToDate;
    private string? activeFilterCardCode;
    private string? activeFilterSearch;
    private DateTime? activeFilterFromDate;
    private DateTime? activeFilterToDate;

    private bool HasActiveFilters =>
        !string.IsNullOrEmpty(activeFilterCardCode) ||
        !string.IsNullOrEmpty(activeFilterSearch) ||
        activeFilterFromDate.HasValue ||
        activeFilterToDate.HasValue;

    // Upload mode
    private UploadMode uploadMode = UploadMode.Single;

    // Business partners excluded from POD uploads
    private static readonly HashSet<string> ExcludedCardCodes = new(StringComparer.OrdinalIgnoreCase)
    {
        "CIS006", "MAC009", "MAC006", "COR007", "COR006", "COR008",
        "VAN008", "VAN009", "VAN010", "VAN011", "VAN012", "VAN013",
        "VAN014", "VAN015", "VAN016", "VAN017", "VAN018", "VAN019", "VAN020",
        "STA040", "STA041", "STA042", "STA043", "STA044", "STA045", "STA046", "STA047", "STA048",
        "PRO030", "PRO031", "PRO032", "PRO033", "PRO034", "PRO035", "PRO036",
        "CAS004(FCA)", "DON004", "TEA006", "TEA007"
    };

    // Single upload state
    private int? uploadDocNum;
    private int inputFileKey;
    private List<IBrowserFile> selectedFiles = new();
    private string? uploadDescription;
    private bool isUploading;
    private string? uploadProgress;
    private string? uploadMessage;
    private bool uploadSuccess;
    private InvoiceDto? lookupInvoice;
    private string? lookupError;
    private bool isLookingUp;

    // Bulk upload state
    private int bulkInputFileKey;
    private List<IBrowserFile> bulkFiles = new();
    private List<BulkFileMapping> bulkMappings = new();
    private string? bulkDescription;
    private bool isBulkValidating;
    private string? bulkValidationProgress;
    private bool isBulkUploading;
    private string? bulkUploadProgress;
    private string? bulkMessage;
    private bool bulkSuccess;
    private int bulkAutoRetryRound;
    private int bulkMaxAutoRetries = 3;
    private CancellationTokenSource? bulkValidationCts;

    private enum UploadMode { Single, Bulk }

    private enum BulkFileStatus { Pending, Valid, ValidWithWarning, Uploading, Uploaded, Skipped, Error }

    private class BulkFileMapping
    {
        public IBrowserFile File { get; set; } = default!;
        public string FileName { get; set; } = string.Empty;
        public int? DocNum { get; set; }
        public int? DocEntry { get; set; }
        public string? CardName { get; set; }
        public long FileSize { get; set; }
        public BulkFileStatus Status { get; set; } = BulkFileStatus.Pending;
        public string? ErrorMessage { get; set; }
        public int ExistingPodCount { get; set; }
    }

    // Viewer state
    private bool showViewer;
    private bool isLoadingViewer;
    private string? viewerDataUri;
    private string? viewerFileName;
    private string? viewerMimeType;
    private PodAttachmentItemDto? viewerPod;

    // Delete state
    private bool showDeleteConfirm;
    private bool isDeleting;
    private string? deleteMessage;
    private bool deleteSuccess;
    private PodAttachmentItemDto? deletePod;
    private string? currentUsername;

    [SupplyParameterFromQuery(Name = "docNum")]
    public int? InitialDocNum { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUsername = authState.User.Identity?.Name;

        if (InitialDocNum.HasValue && InitialDocNum.Value > 0)
        {
            uploadDocNum = InitialDocNum.Value;
            await LookupInvoice();
        }
    }

    private async Task<TableData<PodAttachmentItemDto>> LoadPodsTableData(TableState state, CancellationToken cancellationToken)
    {
        var fallbackResponse = podResponse;
        isLoading = true;
        podLoadError = null;

        try
        {
            var requestedPage = state.Page + 1;
            var requestedPageSize = state.PageSize > 0 ? state.PageSize : DefaultPodPageSize;
            var response = await PodService.GetAllPodsAsync(requestedPage, requestedPageSize, activeFilterCardCode, activeFilterFromDate, activeFilterToDate, activeFilterSearch, cancellationToken);
            if (response != null)
            {
                podResponse = response;
                return new TableData<PodAttachmentItemDto>
                {
                    TotalItems = response.TotalCount,
                    Items = response.Items
                };
            }
            else
            {
                podLoadError = "Failed to load POD records. Please refresh and try again.";
            }
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading PODs");
            podLoadError = "Failed to load POD records. Please refresh and try again.";
        }
        finally
        {
            isLoading = false;
        }

        return new TableData<PodAttachmentItemDto>
        {
            TotalItems = fallbackResponse?.TotalCount ?? 0,
            Items = fallbackResponse?.Items ?? new List<PodAttachmentItemDto>()
        };
    }

