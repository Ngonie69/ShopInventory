    private async Task ReloadPodsTableAsync(bool resetToFirstPage = false)
    {
        podLoadError = null;

        if (resetToFirstPage)
        {
            podsTableKey++;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_podsTable != null)
        {
            await _podsTable.ReloadServerData();
        }
    }

    private async Task LookupInvoice()
    {
        if (uploadDocNum is null or <= 0 || isLookingUp) return;

        isLookingUp = true;
        lookupInvoice = null;
        lookupError = null;

        try
        {
            lookupInvoice = await InvoiceService.GetInvoiceByDocNumAsync(uploadDocNum.Value);
            if (lookupInvoice == null)
            {
                lookupError = "Invoice not found";
            }
            else if (ExcludedCardCodes.Contains(lookupInvoice.CardCode ?? ""))
            {
                lookupError = $"POD uploads are not required for {lookupInvoice.CardName} ({lookupInvoice.CardCode})";
                lookupInvoice = null;
            }
        }
        catch
        {
            lookupError = "Could not look up invoice";
        }
        finally
        {
            isLookingUp = false;
        }
    }

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        selectedFiles = e.GetMultipleFiles(20).ToList();
        uploadMessage = null;
    }

    private async Task UploadPod()
    {
        if (lookupInvoice == null || !selectedFiles.Any() || isUploading) return;

        isUploading = true;
        uploadMessage = null;

        try
        {
            var total = selectedFiles.Count;
            var successCount = 0;
            var failedFiles = new List<string>();

            for (var i = 0; i < total; i++)
            {
                var file = selectedFiles[i];
                uploadProgress = $"({i + 1}/{total})";
                StateHasChanged();

                if (file.Size > 20 * 1024 * 1024)
                {
                    failedFiles.Add($"{file.Name} (too large)");
                    continue;
                }

                using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
                var (success, message, _) = await PodService.UploadPodAsync(
                    lookupInvoice.DocEntry, stream, file.Name, file.ContentType, uploadDescription, currentUsername);

                if (success)
                    successCount++;
                else
                    failedFiles.Add(file.Name);
            }

            if (failedFiles.Count == 0)
            {
                uploadSuccess = true;
                uploadMessage = total == 1
                    ? "POD uploaded successfully."
                    : $"All {successCount} PODs uploaded successfully.";
                // Audit log: POD uploaded
                await AuditService.LogAsync(AuditActions.UploadPod, "POD", lookupInvoice?.DocNum.ToString(), $"{successCount} file(s) for invoice #{lookupInvoice?.DocNum}", true);
                selectedFiles.Clear();
                inputFileKey++;
                uploadDocNum = null;
                uploadDescription = null;
                lookupInvoice = null;
                lookupError = null;
                await ReloadPodsTableAsync(resetToFirstPage: true);
            }
            else
            {
                uploadSuccess = successCount > 0;
                uploadMessage = successCount > 0
                    ? $"{successCount} of {total} uploaded. Failed: {string.Join(", ", failedFiles)}"
                    : $"Upload failed for: {string.Join(", ", failedFiles)}";
                if (successCount > 0)
                    await ReloadPodsTableAsync(resetToFirstPage: true);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error uploading POD");
            uploadMessage = "An unexpected error occurred. Please try again.";
            uploadSuccess = false;
        }
        finally
        {
            isUploading = false;
        }
    }

