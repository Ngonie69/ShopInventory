@page "/pods"
@using Microsoft.AspNetCore.Authorization
@using ShopInventory.Web.Models
@using ShopInventory.Web.Services
@attribute [Authorize(Roles = "Admin,Cashier,PodOperator,Driver,SalesRep")]
@inject IPodService PodService
@inject IInvoiceService InvoiceService
@inject IJSRuntime JS
@using ShopInventory.Web.Data
@inject ILogger<ProofOfDelivery> Logger
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuditService AuditService
@rendermode InteractiveServer

<PageTitle>Proof of Delivery - Shop Inventory</PageTitle>

<div class="container-fluid fade-in staff-dashboard staff-shell">
    @* Hero Header *@
    <div class="pod-hero">
        <div class="pod-hero-content">
            <div>
                <h2 class="pod-hero-title">
                    <span class="pod-hero-icon">
                        <i class="bi bi-clipboard-check"></i>
                    </span>
                    Proof of Delivery
                </h2>
                <p class="pod-hero-subtitle">Upload and manage POD attachments for invoices</p>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <span class="pod-stat-pill">
                    <i class="bi bi-file-earmark-check me-1"></i>
                    @(podResponse?.TotalCount ?? 0) records
                </span>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="RefreshData"
                           StartIcon="@Icons.Material.Filled.Refresh" Disabled="@isLoading"
                           Class="pod-refresh-btn">
                    Refresh
                </MudButton>
            </div>
        </div>
    </div>

    @* Upload Mode Toggle *@
    <div class="pod-mode-toggle mb-3">
        <button class="pod-mode-btn @(uploadMode == UploadMode.Single ? "pod-mode-active" : "")" @onclick='() => SwitchUploadMode(UploadMode.Single)'>
            <i class="bi bi-file-earmark-arrow-up me-1"></i> Single Upload
        </button>
        <button class="pod-mode-btn @(uploadMode == UploadMode.Bulk ? "pod-mode-active" : "")" @onclick='() => SwitchUploadMode(UploadMode.Bulk)'>
            <i class="bi bi-files me-1"></i> Bulk Upload
        </button>
    </div>

    @if (uploadMode == UploadMode.Single)
    {
        @* Single Upload Section *@
        <div class="pod-upload-card">
            <div class="pod-upload-header">
                <i class="bi bi-cloud-arrow-up"></i>
                <span>Upload POD</span>
            </div>
            <div class="pod-upload-body">
                <div class="row g-3 align-items-end mb-3">
                    <div class="col-md-4">
                        <label class="pod-label">Invoice Number</label>
                        <input type="number" class="form-control pod-input" @bind="uploadDocNum" placeholder="e.g. 10001" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" OnClick="LookupInvoice"
                                   Disabled="@(uploadDocNum is null or <= 0 || isLookingUp)" Class="pod-lookup-btn">
                            @if (isLookingUp)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                <text>Looking up...</text>
                            }
                            else
                            {
                                <i class="bi bi-search me-1"></i><text>Lookup</text>
                            }
                        </MudButton>
                    </div>
                    <div class="col-md-6">
                        @if (isLookingUp)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-0">
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2"
                                                     Style="vertical-align: middle;" />
                                Searching for invoice...
                            </MudAlert>
                        }
                        else if (lookupInvoice != null)
                        {
                            <MudAlert Severity="Severity.Success" Dense="true" Class="mb-0">
                                Invoice #@lookupInvoice.DocNum &mdash; @lookupInvoice.CardName
                            </MudAlert>
                        }
                        else if (lookupError != null)
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-0">@lookupError</MudAlert>
                        }
                    </div>
                </div>
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="pod-label">POD File(s)</label>
                        <InputFile @key="inputFileKey" OnChange="OnFilesSelected" class="form-control pod-input" accept=".jpg,.jpeg,.png,.webp,.pdf" multiple />
                        <div class="form-text">JPG, PNG, WebP, PDF &mdash; max 20MB each. Select multiple files.</div>
                    </div>
                    <div class="col-md-5">
                        <label class="pod-label">Description (optional)</label>
                        <input type="text" class="form-control pod-input" @bind="uploadDescription"
                               placeholder="e.g. Signed delivery note from driver" />
                    </div>
                    <div class="col-md-3">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="UploadPod"
                                   Disabled="@(isUploading || lookupInvoice == null || !selectedFiles.Any())" FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.CloudUpload" Class="pod-upload-btn">
                            @if (isUploading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                <text>Uploading @uploadProgress...</text>
                            }
                            else
                            {
                                <text>Upload @(selectedFiles.Count > 1 ? $"{selectedFiles.Count} PODs" : "POD")</text>
                            }
                        </MudButton>
                    </div>
                </div>

                @if (selectedFiles.Count > 0 && !isUploading)
                {
                    <div class="pod-file-chips">
                        <span class="text-muted small">@selectedFiles.Count file(s) selected:</span>
                        <div class="d-flex flex-wrap gap-1 mt-1">
                            @foreach (var f in selectedFiles)
                            {
                                <span class="pod-file-chip">
                                    <i class="bi bi-file-earmark me-1"></i>@f.Name
                                    <span class="pod-file-chip-size">(@FormatFileSize(f.Size))</span>
                                </span>
                            }
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(uploadMessage))
                {
                    <MudAlert Severity="@(uploadSuccess? Severity.Success: Severity.Error)" Class="mt-3" Dense="true">
                        @uploadMessage
                    </MudAlert>
                }
            </div>
        </div>
    }
    else
    {
        @* Bulk Upload Section *@
        <div class="pod-upload-card">
            <div class="pod-upload-header">
                <i class="bi bi-files"></i>
                <span>Bulk Upload PODs</span>
            </div>
            <div class="pod-upload-body">
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    <strong>Naming convention:</strong> Name each file starting with the invoice number, e.g.
                    <code>10001.pdf</code>, <code>10001_signed.jpg</code>, <code>10002_delivery.png</code>.
                    The leading digits in each filename will be matched to the SAP invoice number.
                </MudAlert>

                <div class="row g-3 align-items-end mb-3">
                    <div class="col-md-6">
                        <label class="pod-label">Select POD Files</label>
                        <InputFile @key="bulkInputFileKey" OnChange="OnBulkFilesSelected" class="form-control pod-input"
                                   accept=".jpg,.jpeg,.png,.webp,.pdf" multiple />
                        <div class="form-text">Select multiple files. Each filename must start with the invoice number.</div>
                    </div>
                    <div class="col-md-3">
                        <label class="pod-label">Description (optional)</label>
                        <input type="text" class="form-control pod-input" @bind="bulkDescription"
                               placeholder="e.g. Weekly delivery batch" />
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ValidateBulkFiles"
                                   Disabled="@(isBulkValidating || !bulkFiles.Any())" FullWidth="true" Class="pod-lookup-btn">
                            @if (isBulkValidating)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                <text>Validating @bulkValidationProgress</text>
                            }
                            else
                            {
                                <i class="bi bi-check2-circle me-1"></i><text>Validate</text>
                            }
                        </MudButton>
                    </div>
                </div>

                @if (bulkFiles.Count > 0 && bulkMappings.Count > 0)
                {
                    <div class="table-responsive mb-3">
                        <table class="pod-table">
                            <thead>
                                <tr>
                                    <th style="width: 40px;">#</th>
                                    <th>Filename</th>
                                    <th>Invoice #</th>
                                    <th>Customer</th>
                                    <th>Existing PODs</th>
                                    <th>Size</th>
                                    <th>Status</th>
                                    <th style="width: 40px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (map, idx) in bulkMappings.Select((m, i) => (m, i)))
                                {
                                    <tr class="pod-row @(map.Status == BulkFileStatus.Error ? "table-danger" : map.Status == BulkFileStatus.Uploaded ? "table-success" : map.Status == BulkFileStatus.Skipped ? "table-secondary" : "")">
                                        <td>@(idx + 1)</td>
                                        <td>
                                            <div class="pod-file-name">@map.FileName</div>
                                        </td>
                                        <td>
                                            @if (map.DocNum.HasValue)
                                            {
                                                <span class="pod-invoice-badge">@map.DocNum</span>
                                            }
                                            else
                                            {
                                                <span class="text-danger fw-semibold">No number found</span>
                                            }
                                        </td>
                                        <td>@(map.CardName ?? "-")</td>
                                        <td>
                                            @if (map.ExistingPodCount > 0)
                                            {
                                                <span class="badge bg-warning text-dark" title="This invoice already has @map.ExistingPodCount POD(s) uploaded">
                                                    <i class="bi bi-exclamation-triangle me-1"></i>@map.ExistingPodCount existing
                                                </span>
                                            }
                                            else if (map.Status != BulkFileStatus.Pending && map.Status != BulkFileStatus.Error)
                                            {
                                                <span class="text-success small"><i class="bi bi-check-lg me-1"></i>None</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="pod-size">@FormatFileSize(map.FileSize)</td>
                                        <td>
                                            @switch (map.Status)
                                            {
                                                case BulkFileStatus.Pending:
                                                    <span class="badge bg-secondary">Pending</span>
                                                    break;
                                                case BulkFileStatus.Valid:
                                                    <span class="badge bg-success"><i class="bi bi-check-lg me-1"></i>Ready</span>
                                                    break;
                                                case BulkFileStatus.ValidWithWarning:
                                                    <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle me-1"></i>Ready (has POD)</span>
                                                    break;
                                                case BulkFileStatus.Skipped:
                                                    <span class="badge bg-secondary" title="@map.ErrorMessage"><i class="bi bi-skip-forward me-1"></i>Skipped</span>
                                                    break;
                                                case BulkFileStatus.Uploading:
                                                    <span class="badge bg-primary"><MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width:14px;height:14px;" Class="me-1" />Uploading</span>
                                                    break;
                                                case BulkFileStatus.Uploaded:
                                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Uploaded</span>
                                                    break;
                                                case BulkFileStatus.Error:
                                                    <span class="badge bg-danger" title="@map.ErrorMessage"><i class="bi bi-x-circle me-1"></i>@map.ErrorMessage</span>
                                                    break;
                                            }
                                        </td>
                                        <td>
                                            @if (map.Status != BulkFileStatus.Uploading && map.Status != BulkFileStatus.Uploaded && !isBulkUploading)
                                            {
                                                <button class="btn btn-sm btn-outline-danger border-0 p-1" title="Remove" @onclick="() => RemoveBulkMapping(map)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="text-muted small">
                                @bulkMappings.Count(m => m.Status is BulkFileStatus.Valid or BulkFileStatus.ValidWithWarning) of @bulkMappings.Count ready to upload
                                @if (bulkMappings.Any(m => m.Status == BulkFileStatus.Skipped))
                                {
                                    <text> &mdash; <span class="text-secondary">@bulkMappings.Count(m => m.Status == BulkFileStatus.Skipped) skipped</span></text>
                                }
                                @if (bulkMappings.Any(m => m.Status == BulkFileStatus.Error))
                                {
                                    <text> &mdash; <span class="text-danger">@bulkMappings.Count(m => m.Status == BulkFileStatus.Error) with errors</span></text>
                                }
                            </span>
                        </div>
                        <div class="d-flex gap-2">
                            @if (bulkMappings.Any(m => m.Status == BulkFileStatus.Error))
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="RetryBulkValidation"
                                           Disabled="@(isBulkValidating || isBulkUploading)">
                                    @if (isBulkValidating)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                        <text>Retrying @bulkValidationProgress</text>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-clockwise me-1"></i><text>Retry @bulkMappings.Count(m => m.Status == BulkFileStatus.Error) Errors</text>
                                    }
                                </MudButton>
                            }
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ClearBulkUpload"
                                       Disabled="@isBulkUploading">
                                <i class="bi bi-x-circle me-1"></i> Clear
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ExecuteBulkUpload"
                                       Disabled="@(isBulkUploading || !bulkMappings.Any(m => m.Status is BulkFileStatus.Valid or BulkFileStatus.ValidWithWarning))"
                                       StartIcon="@Icons.Material.Filled.CloudUpload" Class="pod-upload-btn">
                                @if (isBulkUploading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                    <text>Uploading @bulkUploadProgress...</text>
                                }
                                else
                                {
                                    <text>Upload @bulkMappings.Count(m => m.Status is BulkFileStatus.Valid or BulkFileStatus.ValidWithWarning) PODs</text>
                                }
                            </MudButton>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(bulkMessage))
                {
                    <MudAlert Severity="@(bulkSuccess ? Severity.Success : Severity.Error)" Class="mt-3" Dense="true">
                        @bulkMessage
                    </MudAlert>
                }
            </div>
        </div>
    }

    @* Invoice Details *@
    @if (lookupInvoice != null)
    {
        <div class="pod-invoice-card">
            <div class="pod-invoice-header">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-receipt"></i>
                    <span>Invoice #@lookupInvoice.DocNum</span>
                </div>
                <span class="pod-status-badge @(lookupInvoice.DocStatus == "O" ? "pod-status-open" : "pod-status-closed")">
                    <span class="pod-status-dot"></span>
                    @(lookupInvoice.DocStatus == "O" ? "Open" : "Closed")
                </span>
            </div>
            <div class="pod-invoice-body">
                <div class="pod-invoice-grid">
                    <div class="pod-invoice-field">
                        <span class="pod-field-label">Customer</span>
                        <span class="pod-field-value">@lookupInvoice.CardName</span>
                        <span class="pod-field-sub">@lookupInvoice.CardCode</span>
                    </div>
                    <div class="pod-invoice-field">
                        <span class="pod-field-label">Invoice Date</span>
                        <span class="pod-field-value">@FormatDate(lookupInvoice.DocDate)</span>
                    </div>
                    <div class="pod-invoice-field">
                        <span class="pod-field-label">Due Date</span>
                        <span class="pod-field-value">@FormatDate(lookupInvoice.DocDueDate)</span>
                    </div>
                    <div class="pod-invoice-field">
                        <span class="pod-field-label">Total</span>
                        <span class="pod-field-value">@lookupInvoice.DocCurrency @lookupInvoice.DocTotal.ToString("N2")</span>
                    </div>
                    <div class="pod-invoice-field">
                        <span class="pod-field-label">Paid</span>
                        <span class="pod-field-value">@lookupInvoice.DocCurrency @lookupInvoice.PaidToDate.ToString("N2")</span>
                        @{
                            var balance = lookupInvoice.DocTotal - lookupInvoice.PaidToDate;
                        }
                        @if (balance > 0)
                        {
                            <span class="pod-field-balance">Balance: @lookupInvoice.DocCurrency @balance.ToString("N2")</span>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(lookupInvoice.NumAtCard))
                {
                    <div class="mt-2">
                        <span class="text-muted small">Customer Ref:</span>
                        <span class="small">@lookupInvoice.NumAtCard</span>
                    </div>
                }

                @if (lookupInvoice.Lines?.Any() == true)
                {
                    <div class="table-responsive mt-3">
                        <table class="table table-sm table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Item Code</th>
                                    <th>Description</th>
                                    <th class="text-end">Qty</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Discount</th>
                                    <th class="text-end">Line Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in lookupInvoice.Lines)
                                {
                                    <tr>
                                        <td>@(line.LineNum + 1)</td>
                                        <td><code>@line.ItemCode</code></td>
                                        <td>@line.ItemDescription</td>
                                        <td class="text-end">@QuantityDisplay.FormatWithUom(line.Quantity, line.UoMCode)</td>
                                        <td class="text-end">@line.UnitPrice.ToString("N2")</td>
                                        <td class="text-end">@(line.DiscountPercent > 0 ? $"{line.DiscountPercent:N1}%" : "-")</td>
                                        <td class="text-end fw-semibold">@line.LineTotal.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-light">
                                    <td colspan="6" class="text-end fw-semibold">VAT:</td>
                                    <td class="text-end fw-semibold">@lookupInvoice.VatSum.ToString("N2")</td>
                                </tr>
                                <tr class="table-light">
                                    <td colspan="6" class="text-end fw-semibold">Total:</td>
                                    <td class="text-end fw-semibold">@lookupInvoice.DocCurrency
                                        @lookupInvoice.DocTotal.ToString("N2")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }

        @* Filter & List *@
        <div class="pod-list-card">
            <div class="pod-list-header">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-list-task"></i>
                    <span>All POD Uploads</span>
                </div>
                <span class="pod-record-count">@(podResponse?.TotalCount ?? 0) records</span>
            </div>
            <div class="pod-filter-bar">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="pod-label">Search</label>
                        <input type="text" class="form-control pod-input" @bind="filterSearch" @bind:event="oninput"
                               @onkeydown="OnFilterKeyDown" placeholder="Invoice #, customer name or code" />
                    </div>
                    <div class="col-md-2">
                        <label class="pod-label">Customer Code</label>
                        <input type="text" class="form-control pod-input" @bind="filterCardCode" @bind:event="oninput"
                               @onkeydown="OnFilterKeyDown" placeholder="e.g. C00001" />
                    </div>
                    <div class="col-md-2">
                        <label class="pod-label">From Date</label>
                        <input type="date" class="form-control pod-input" @bind="filterFromDate" />
                    </div>
                    <div class="col-md-2">
                        <label class="pod-label">To Date</label>
                        <input type="date" class="form-control pod-input" @bind="filterToDate" />
                    </div>
                    <div class="col-md-1">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" OnClick="ApplyFilter" Class="pod-filter-btn">
                            <i class="bi bi-funnel me-1"></i>Filter
                        </MudButton>
                    </div>
                    @if (HasActiveFilters)
                    {
                        <div class="col-md-1">
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" OnClick="ClearFilter">
                                <i class="bi bi-x-circle me-1"></i>Clear
                            </MudButton>
                        </div>
                    }
                </div>
            </div>
            <div class="pod-table-wrap">
                @if (!string.IsNullOrWhiteSpace(podLoadError))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="m-3">
                        @podLoadError
                    </MudAlert>
                }

                <MudTable T="PodAttachmentItemDto"
                          @key="podsTableKey"
                          @ref="_podsTable"
                          ServerData="LoadPodsTableData"
                          Dense="true"
                          Hover="true"
                          Loading="@isLoading"
                          RowsPerPage="@DefaultPodPageSize"
                          Elevation="0"
                          Class="pod-mud-table">
                    <HeaderContent>
                        <MudTh>Invoice #</MudTh>
                        <MudTh>Customer</MudTh>
                        <MudTh>File</MudTh>
                        <MudTh>Description</MudTh>
                        <MudTh>Size</MudTh>
                        <MudTh>Uploaded</MudTh>
                        <MudTh>By</MudTh>
                        <MudTh Class="text-end">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Invoice #">
                            <span class="pod-invoice-badge">@(context.InvoiceDocNum > 0 ? context.InvoiceDocNum.ToString() : "-")</span>
                        </MudTd>
                        <MudTd DataLabel="Customer">
                            <div class="pod-customer-name">@(context.CardName ?? "-")</div>
                            <div class="pod-customer-code">@(context.CardCode ?? "-")</div>
                        </MudTd>
                        <MudTd DataLabel="File">
                            <div class="pod-file-name">@context.FileName</div>
                            <div class="pod-file-type">@context.MimeType</div>
                        </MudTd>
                        <MudTd DataLabel="Description" Class="pod-description">@(context.Description ?? "-")</MudTd>
                        <MudTd DataLabel="Size" Class="pod-size">@context.FileSizeFormatted</MudTd>
                        <MudTd DataLabel="Uploaded">
                            <div class="pod-date">@context.UploadedAt.ToString("MMM dd, yyyy")</div>
                            <div class="pod-time">@context.UploadedAt.ToString("HH:mm")</div>
                        </MudTd>
                        <MudTd DataLabel="By" Class="pod-user">@(context.UploadedByUserName ?? "-")</MudTd>
                        <MudTd DataLabel="Actions" Class="text-end">
                            <div class="pod-actions">
                                @if (IsViewable(context.MimeType))
                                {
                                    <button class="pod-action-btn pod-action-view" @onclick="() => ViewPod(context)" title="View">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                }
                                <button class="pod-action-btn pod-action-download" @onclick="() => DownloadPod(context)" title="Download">
                                    <i class="bi bi-download"></i>
                                </button>
                                <button class="pod-action-btn pod-action-delete" @onclick="() => ConfirmDeletePod(context)" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        @if (string.IsNullOrWhiteSpace(podLoadError))
                        {
                            <div class="pod-empty-state">
                                <div class="pod-empty-icon">
                                    <i class="bi bi-clipboard-x"></i>
                                </div>
                                <p class="pod-empty-title">No POD records found</p>
                                <p class="pod-empty-sub">Upload a POD using the form above.</p>
                            </div>
                        }
                    </NoRecordsContent>
                    <LoadingContent>
                        <div class="pod-loading-state">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Medium" />
                            <p class="pod-loading-text">Loading PODs...</p>
                        </div>
                    </LoadingContent>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </div>
        </div>
    </div>

@* POD Viewer Modal *@
@if (showViewer)
{
    <div class="pod-viewer-overlay" @onclick="CloseViewer">
        <div class="pod-viewer-container" @onclick:stopPropagation>
            <div class="pod-viewer-header">
                <h6 class="mb-0 text-truncate">@viewerFileName</h6>
                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               OnClick="() => DownloadPod(viewerPod!)">
                        <i class="bi bi-download me-1"></i> Download
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                               OnClick="CloseViewer">
                        <i class="bi bi-x-lg"></i>
                    </MudButton>
                </div>
            </div>
            <div class="pod-viewer-body">
                @if (isLoadingViewer)
                {
                    <div class="d-flex justify-content-center align-items-center h-100">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    </div>
                }
                else if (viewerMimeType?.StartsWith("image/") == true)
                {
                    <img src="@viewerDataUri" alt="@viewerFileName" class="pod-viewer-image" />
                }
                else if (viewerMimeType == "application/pdf")
                {
                    <iframe src="@viewerDataUri" class="pod-viewer-pdf" title="@viewerFileName"></iframe>
                }
            </div>
        </div>
    </div>
}

@* Delete Confirmation Modal *@
@if (showDeleteConfirm)
{
    <div class="pod-viewer-overlay" @onclick="CancelDelete">
        <div class="pod-delete-dialog" @onclick:stopPropagation>
            <div class="p-4 text-center">
                <i class="bi bi-exclamation-triangle" style="font-size: 2.5rem; color: var(--mud-palette-error);"></i>
                <h5 class="mt-3 mb-2">Delete POD?</h5>
                <p class="text-muted mb-1">Are you sure you want to delete this attachment?</p>
                <p class="fw-semibold mb-3">@deletePod?.FileName</p>
                @if (isDeleting)
                {
                    <MudProgressCircular Indeterminate="true" Color="Color.Error" Size="Size.Small" />
                }
                else
                {
                    <div class="d-flex gap-2 justify-content-center">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="CancelDelete">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeletePod">
                            <i class="bi bi-trash me-1"></i> Delete
                        </MudButton>
                    </div>
                }
                @if (!string.IsNullOrEmpty(deleteMessage))
                {
                    <MudAlert Severity="@(deleteSuccess ? Severity.Success : Severity.Error)" Class="mt-3" Dense="true">
                        @deleteMessage
                    </MudAlert>
                }
            </div>
        </div>
    </div>
}

