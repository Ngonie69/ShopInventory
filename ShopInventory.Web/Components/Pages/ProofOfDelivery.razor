@code {
    private PodAttachmentListResponse? podResponse;
    private bool isLoading = true;
    private int currentPage = 1;
    private const int pageSize = 20;
    private string? filterCardCode;
    private string? filterSearch;
    private DateTime? filterFromDate;
    private DateTime? filterToDate;
    private string? activeFilterCardCode;
    private string? activeFilterSearch;
    private DateTime? activeFilterFromDate;
    private DateTime? activeFilterToDate;

    private int totalPages => podResponse != null && podResponse.TotalCount > 0
        ? (int)Math.Ceiling((double)podResponse.TotalCount / pageSize)
        : 1;

    private bool HasActiveFilters =>
        !string.IsNullOrEmpty(activeFilterCardCode) ||
        !string.IsNullOrEmpty(activeFilterSearch) ||
        activeFilterFromDate.HasValue ||
        activeFilterToDate.HasValue;

    // Upload state
    private int? uploadDocNum;
    private int inputFileKey;
    private List<IBrowserFile> selectedFiles = new();
    private string? uploadDescription;
    private bool isUploading;
    private string? uploadProgress;
    private string? uploadMessage;
    private bool uploadSuccess;
    private InvoiceDto? lookupInvoice;
    private string? lookupError;
    private bool isLookingUp;

    // Viewer state
    private bool showViewer;
    private bool isLoadingViewer;
    private string? viewerDataUri;
    private string? viewerFileName;
    private string? viewerMimeType;
    private PodAttachmentItemDto? viewerPod;

    // Delete state
    private bool showDeleteConfirm;
    private bool isDeleting;
    private string? deleteMessage;
    private bool deleteSuccess;
    private PodAttachmentItemDto? deletePod;
    private string? currentUsername;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUsername = authState.User.Identity?.Name;
        await LoadPods();
    }

    private async Task LoadPods()
    {
        isLoading = true;

        try
        {
            podResponse = await PodService.GetAllPodsAsync(currentPage, pageSize, activeFilterCardCode, activeFilterFromDate, activeFilterToDate, activeFilterSearch);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading PODs");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadPage(int page)
    {
        currentPage = page;
        await LoadPods();
    }

    private async Task RefreshData()
    {
        currentPage = 1;
        await LoadPods();
    }

    private async Task ApplyFilter()
    {
        activeFilterCardCode = string.IsNullOrWhiteSpace(filterCardCode) ? null : filterCardCode.Trim();
        activeFilterSearch = string.IsNullOrWhiteSpace(filterSearch) ? null : filterSearch.Trim();
        activeFilterFromDate = filterFromDate;
        activeFilterToDate = filterToDate;
        currentPage = 1;
        await LoadPods();
    }

    private async Task ClearFilter()
    {
        filterCardCode = null;
        filterSearch = null;
        filterFromDate = null;
        filterToDate = null;
        activeFilterCardCode = null;
        activeFilterSearch = null;
        activeFilterFromDate = null;
        activeFilterToDate = null;
        currentPage = 1;
        await LoadPods();
    }

    private async Task OnFilterKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ApplyFilter();
    }

    private List<int> GetPageNumbers()
    {
        var pages = new List<int>();
        if (totalPages <= 7)
        {
            for (int i = 1; i <= totalPages; i++)
                pages.Add(i);
        }
        else
        {
            pages.Add(1);
            if (currentPage > 3)
                pages.Add(-1); // ellipsis
            for (int i = Math.Max(2, currentPage - 1); i <= Math.Min(totalPages - 1, currentPage + 1); i++)
                pages.Add(i);
            if (currentPage < totalPages - 2)
                pages.Add(-1); // ellipsis
            pages.Add(totalPages);
        }
        return pages;
    }

    private async Task LookupInvoice()
    {
        if (uploadDocNum is null or <= 0 || isLookingUp) return;

        isLookingUp = true;
        lookupInvoice = null;
        lookupError = null;

        try
        {
            lookupInvoice = await InvoiceService.GetInvoiceByDocNumAsync(uploadDocNum.Value);
            if (lookupInvoice == null)
            {
                lookupError = "Invoice not found";
            }
        }
        catch
        {
            lookupError = "Could not look up invoice";
        }
        finally
        {
            isLookingUp = false;
        }
    }

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        selectedFiles = e.GetMultipleFiles(20).ToList();
        uploadMessage = null;
    }

    private async Task UploadPod()
    {
        if (lookupInvoice == null || !selectedFiles.Any() || isUploading) return;

        isUploading = true;
        uploadMessage = null;

        try
        {
            var total = selectedFiles.Count;
            var successCount = 0;
            var failedFiles = new List<string>();

            for (var i = 0; i < total; i++)
            {
                var file = selectedFiles[i];
                uploadProgress = $"({i + 1}/{total})";
                StateHasChanged();

                if (file.Size > 20 * 1024 * 1024)
                {
                    failedFiles.Add($"{file.Name} (too large)");
                    continue;
                }

                using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
                var (success, message, _) = await PodService.UploadPodAsync(
                    lookupInvoice.DocEntry, stream, file.Name, file.ContentType, uploadDescription, currentUsername);

                if (success)
                    successCount++;
                else
                    failedFiles.Add(file.Name);
            }

            if (failedFiles.Count == 0)
            {
                uploadSuccess = true;
                uploadMessage = total == 1
                    ? "POD uploaded successfully."
                    : $"All {successCount} PODs uploaded successfully.";
                selectedFiles.Clear();
                inputFileKey++;
                uploadDocNum = null;
                uploadDescription = null;
                lookupInvoice = null;
                lookupError = null;
                currentPage = 1;
                await LoadPods();
            }
            else
            {
                uploadSuccess = successCount > 0;
                uploadMessage = successCount > 0
                    ? $"{successCount} of {total} uploaded. Failed: {string.Join(", ", failedFiles)}"
                    : $"Upload failed for: {string.Join(", ", failedFiles)}";
                if (successCount > 0)
                    await LoadPods();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error uploading POD");
            uploadMessage = "An unexpected error occurred. Please try again.";
            uploadSuccess = false;
        }
        finally
        {
            isUploading = false;
        }
    }

    private async Task DownloadPod(PodAttachmentItemDto pod)
    {
        try
        {
            var url = $"/download/pod/{pod.InvoiceDocEntry}/{pod.Id}";
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error downloading POD {PodId}", pod.Id);
        }
    }

    private static bool IsViewable(string? mimeType) =>
        mimeType != null && (mimeType.StartsWith("image/") || mimeType == "application/pdf");

    private void ViewPod(PodAttachmentItemDto pod)
    {
        viewerPod = pod;
        viewerFileName = pod.FileName;
        viewerMimeType = pod.MimeType;
        viewerDataUri = $"/download/pod/{pod.InvoiceDocEntry}/{pod.Id}";
        showViewer = true;
        isLoadingViewer = false;
    }

    private void CloseViewer()
    {
        showViewer = false;
        viewerDataUri = null;
        viewerPod = null;
    }

    private void ConfirmDeletePod(PodAttachmentItemDto pod)
    {
        deletePod = pod;
        deleteMessage = null;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deletePod = null;
        deleteMessage = null;
    }

    private async Task DeletePod()
    {
        if (deletePod == null || isDeleting) return;

        isDeleting = true;
        deleteMessage = null;

        try
        {
            var success = await PodService.DeletePodAsync(deletePod.Id);
            if (success)
            {
                showDeleteConfirm = false;
                deletePod = null;
                await LoadPods();
            }
            else
            {
                deleteSuccess = false;
                deleteMessage = "Failed to delete the attachment. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting POD {PodId}", deletePod.Id);
            deleteSuccess = false;
            deleteMessage = "An unexpected error occurred.";
        }
        finally
        {
            isDeleting = false;
        }
    }

    private static string FormatDate(string? dateStr)
    {
        if (string.IsNullOrWhiteSpace(dateStr)) return "-";
        return DateTime.TryParse(dateStr, out var dt) ? dt.ToString("dd MMM yyyy") : dateStr;
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:N1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):N1} MB"
    };
}
