@page "/customer-portal/invoices"
@using ShopInventory.Web.Models
@inject ICustomerStatementService StatementService
@inject IInvoiceService InvoiceService
@inject ICustomerLinkedAccountService LinkedAccountService
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject ILogger<CustomerInvoices> Logger
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@layout CustomerPortalLayout

<PageTitle>Invoices - Customer Portal</PageTitle>

<div class="container-fluid fade-in staff-dashboard staff-shell customer-invoices">
    @if (isLoading)
    {
        <div class="card dashboard-panel">
            <div class="card-body text-center py-5">
                <div class="spinner-border" role="status" style="width: 2.5rem; height: 2.5rem;">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted mt-3 mb-0">Loading invoices...</p>
            </div>
        </div>
    }
    else if (customerInfo == null)
    {
        <div class="card dashboard-panel">
            <div class="card-body text-center py-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" fill="currentColor" viewBox="0 0 16 16"
                     class="mb-3">
                    <path
                    d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" />
                </svg>
                <h2 class="mb-2">Authentication Required</h2>
                <p class="text-muted mb-4">Please login to view your invoices.</p>
                <a href="/customer-portal/login" class="btn btn-primary">Login to Portal</a>
            </div>
        </div>
    }
    else
    {
        <div class="dashboard-hero">
            <div class="page-header staff-dashboard-header">
                <div class="dashboard-title">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor"
                             viewBox="0 0 16 16">
                            <path
                            d="M1.92.506a.5.5 0 0 1 .434.14L3 1.293l.646-.647a.5.5 0 0 1 .708 0L5 1.293l.646-.647a.5.5 0 0 1 .708 0L7 1.293l.646-.647a.5.5 0 0 1 .708 0L9 1.293l.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .801.13l.5 1A.5.5 0 0 1 15 2v12a.5.5 0 0 1-.053.224l-.5 1a.5.5 0 0 1-.8.13L13 14.707l-.646.647a.5.5 0 0 1-.708 0L11 14.707l-.646.647a.5.5 0 0 1-.708 0L9 14.707l-.646.647a.5.5 0 0 1-.708 0L7 14.707l-.646.647a.5.5 0 0 1-.708 0L5 14.707l-.646.647a.5.5 0 0 1-.708 0L3 14.707l-.646.647a.5.5 0 0 1-.801-.13l-.5-1A.5.5 0 0 1 1 14V2a.5.5 0 0 1 .053-.224l.5-1a.5.5 0 0 1 .367-.27z" />
                        </svg>
                        Invoices
                    </h2>
                    <span class="text-muted">Open invoices for @customerInfo.CardName</span>
                    @if (customerInfo.AccountStructure == "Multi")
                    {
                        @if (string.IsNullOrEmpty(selectedAccountFilter))
                        {
                            <span class="badge bg-info mt-1" style="font-size: 0.75rem;">
                                Multi-Account &mdash; showing invoices across all main accounts
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-info mt-1" style="font-size: 0.75rem;">
                                Filtered &mdash; @(linkedAccounts.FirstOrDefault(a => a.CardCode == selectedAccountFilter)?.CardName
                                                                                    ?? selectedAccountFilter)
                            </span>
                        }
                    }
                </div>
                <div class="dashboard-meta">
                    <span class="meta-pill">
                        <span class="meta-dot"></span>
                        Open Balance
                    </span>
                    <span class="meta-subtitle">
                        @if (hasLoaded)
                        {
                            @($"{FormatCurrency(filteredOutstanding)} across {filteredInvoices.Count} invoices")
                        }
                        else
                        {
                            <text>Select date range and load invoices</text>
                        }
                    </span>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        <a href="/customer-portal/dashboard" class="btn btn-outline-primary btn-sm">Back to Dashboard</a>
                        <a href="/customer-portal/statements" class="btn btn-primary btn-sm">View Statement</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="card dashboard-panel mb-3">
            <div class="card-header dashboard-panel-header">
                <h5 class="mb-0 d-flex align-items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"
                         class="panel-icon">
                        <path
                        d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2z" />
                    </svg>
                    Filters
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <FlexibleDatePicker Label="From" @bind-Date="fromDate" />
                    </div>
                    <div class="col-md-3">
                        <FlexibleDatePicker Label="To" @bind-Date="toDate" />
                    </div>
                    @if (isMultiAccount && linkedAccounts.Any())
                    {
                        <div class="col-md-3">
                            <MudSelect T="string" Label="Account" Value="@selectedAccountFilter"
                                       ValueChanged="OnAccountFilterChanged" Variant="Variant.Outlined" Dense="true"
                                       AnchorOrigin="Origin.BottomCenter">
                                <MudSelectItem T="string" Value="@("")">All Accounts</MudSelectItem>
                                @foreach (var account in linkedAccounts)
                                {
                                    <MudSelectItem T="string" Value="@account.CardCode">
                                        @account.CardName @(!string.IsNullOrEmpty(account.Currency) ? $"({account.Currency})" : "")
                                        — @account.CardCode
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </div>
                        <div class="col-md-3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="w-100" OnClick="LoadInvoices"
                                       Disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                    <span>Loading...</span>
                                }
                                else
                                {
                                    <span>Load Invoices</span>
                                }
                            </MudButton>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-6">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="w-100" OnClick="LoadInvoices"
                                       Disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                    <span>Loading...</span>
                                }
                                else
                                {
                                    <span>Load Invoices</span>
                                }
                            </MudButton>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (hasLoaded)
        {
            <div class="card dashboard-panel invoices-panel">
                <div class="card-header d-flex align-items-center justify-content-between dashboard-panel-header">
                    <h5 class="mb-0 d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"
                             class="panel-icon">
                            <path
                            d="M1.92.506a.5.5 0 0 1 .434.14L3 1.293l.646-.647a.5.5 0 0 1 .708 0L5 1.293l.646-.647a.5.5 0 0 1 .708 0L7 1.293l.646-.647a.5.5 0 0 1 .708 0L9 1.293l.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .801.13l.5 1A.5.5 0 0 1 15 2v12a.5.5 0 0 1-.053.224l-.5 1a.5.5 0 0 1-.8.13L13 14.707l-.646.647a.5.5 0 0 1-.708 0L11 14.707l-.646.647a.5.5 0 0 1-.708 0L9 14.707l-.646.647a.5.5 0 0 1-.708 0L7 14.707l-.646.647a.5.5 0 0 1-.708 0L5 14.707l-.646.647a.5.5 0 0 1-.708 0L3 14.707l-.646.647a.5.5 0 0 1-.801-.13l-.5-1A.5.5 0 0 1 1 14V2a.5.5 0 0 1 .053-.224l.5-1a.5.5 0 0 1 .367-.27z" />
                        </svg>
                        Open Invoices
                        <span class="badge bg-primary bg-opacity-10 text-primary ms-2"
                              style="font-size: 0.75rem;">@filteredInvoices.Count total</span>
                    </h5>
                    <span class="text-muted small">Last updated @(lastUpdated?.ToString("MMM dd, yyyy 'at' HH:mm") ?? "just now") UTC</span>
                </div>
                <div class="card-body p-0">
                    @if (pagedInvoices.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle dashboard-table invoices-table">
                                <thead>
                                    <tr>
                                        <th>Invoice #</th>
                                        @if (isMultiAccount)
                                        {
                                            <th>Account</th>
                                        }
                                        <th>Date</th>
                                        <th>Due Date</th>
                                        <th class="text-end">Amount</th>
                                        <th class="text-end">Paid</th>
                                        <th class="text-end">Balance</th>
                                        <th>Status</th>
                                        <th class="text-end">Details</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var invoice in pagedInvoices)
                                    {
                                        <tr class="invoice-row">
                                            <td>
                                                <span class="invoice-num-badge">@invoice.DocNum</span>
                                            </td>
                                            @if (isMultiAccount)
                                            {
                                                <td>
                                                    <small class="d-block fw-semibold">@(invoice.CardCode ?? "-")</small>
                                                    @if (!string.IsNullOrEmpty(invoice.Currency))
                                                    {
                                                        <span class="badge bg-outline-dark border"
                                                              style="font-size: 0.65rem;">@invoice.Currency</span>
                                                    }
                                                </td>
                                            }
                                            <td>@invoice.DocDate.ToString("MMM dd, yyyy")</td>
                                            <td>@(invoice.DueDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                                            <td class="text-end">@FormatCurrency(invoice.DocTotal)</td>
                                            <td class="text-end">@FormatCurrency(invoice.PaidToDate)</td>
                                            <td class="text-end fw-semibold">@FormatCurrency(invoice.Balance)</td>
                                            <td><span class="badge status-pill @GetStatusClass(invoice)">@GetStatusText(invoice)</span>
                                            </td>
                                            <td class="text-end">
                                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                                           OnClick="() => ViewInvoiceDetails(invoice)">
                                                    VIEW
                                                </MudButton>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @* Pagination *@
                        @if (totalPages > 1)
                        {
                            <div class="invoices-pagination">
                                <div class="pagination-info">
                                    Showing @(((currentPage - 1) * pageSize) + 1)&ndash;@(Math.Min(currentPage * pageSize,
                                                                                                                                                                    filteredInvoices.Count)) of @filteredInvoices.Count invoices
                                </div>
                                <nav>
                                    <ul class="pagination pagination-sm mb-0">
                                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => GoToPage(1)" disabled="@(currentPage == 1)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                                     viewBox="0 0 16 16">
                                                    <path fill-rule="evenodd"
                                                          d="M8.354 1.646a.5.5 0 0 1 0 .708L2.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0zM12.354 1.646a.5.5 0 0 1 0 .708L6.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z" />
                                                </svg>
                                            </button>
                                        </li>
                                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => GoToPage(currentPage - 1)"
                                                    disabled="@(currentPage == 1)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                                     viewBox="0 0 16 16">
                                                    <path fill-rule="evenodd"
                                                          d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z" />
                                                </svg>
                                            </button>
                                        </li>
                                        @foreach (var pg in GetVisiblePages())
                                        {
                                            @if (pg == -1)
                                            {
                                                <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                                            }
                                            else
                                            {
                                                <li class="page-item @(pg == currentPage ? "active" : "")">
                                                    <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                                                </li>
                                            }
                                        }
                                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => GoToPage(currentPage + 1)"
                                                    disabled="@(currentPage == totalPages)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                                     viewBox="0 0 16 16">
                                                    <path fill-rule="evenodd"
                                                          d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z" />
                                                </svg>
                                            </button>
                                        </li>
                                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => GoToPage(totalPages)"
                                                    disabled="@(currentPage == totalPages)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                                     viewBox="0 0 16 16">
                                                    <path fill-rule="evenodd"
                                                          d="M3.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L9.293 8 3.646 2.354a.5.5 0 0 1 0-.708zM7.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L13.293 8 7.646 2.354a.5.5 0 0 1 0-.708z" />
                                                </svg>
                                            </button>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5 dashboard-empty">
                            <p class="text-muted mb-0">No open invoices found for the selected period.</p>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@if (showInvoiceModal)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background-color: rgba(0,0,0,0.6); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable modal-dialog-centered">
            <div class="modal-content invoice-modal-content">
                <div class="modal-header invoice-modal-header">
                    <div class="d-flex align-items-center gap-2">
                        <div class="invoice-modal-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                 viewBox="0 0 16 16">
                                <path
                                d="M1.92.506a.5.5 0 0 1 .434.14L3 1.293l.646-.647a.5.5 0 0 1 .708 0L5 1.293l.646-.647a.5.5 0 0 1 .708 0L7 1.293l.646-.647a.5.5 0 0 1 .708 0L9 1.293l.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .801.13l.5 1A.5.5 0 0 1 15 2v12a.5.5 0 0 1-.053.224l-.5 1a.5.5 0 0 1-.8.13L13 14.707l-.646.647a.5.5 0 0 1-.708 0L11 14.707l-.646.647a.5.5 0 0 1-.708 0L9 14.707l-.646.647a.5.5 0 0 1-.708 0L7 14.707l-.646.647a.5.5 0 0 1-.708 0L5 14.707l-.646.647a.5.5 0 0 1-.708 0L3 14.707l-.646.647a.5.5 0 0 1-.801-.13l-.5-1A.5.5 0 0 1 1 14V2a.5.5 0 0 1 .053-.224l.5-1a.5.5 0 0 1 .367-.27z" />
                            </svg>
                        </div>
                        <div>
                            <h5 class="modal-title mb-0">Invoice #@(selectedInvoice?.DocNum ??
                                                                                                                                                            selectedInvoiceSummary?.DocNum)</h5>
                            </div>
                        </div>
                        <button type="button" class="invoice-modal-close" @onclick="CloseInvoiceModal">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                                 viewBox="0 0 16 16">
                                <path
                                d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z" />
                            </svg>
                        </button>
                    </div>
                    <div class="modal-body invoice-modal-body">
                        @if (isDetailLoading)
                        {
                            <div class="text-center py-5">
                                <div class="spinner-border" role="status" style="width: 2rem; height: 2rem;">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="text-muted mt-3 mb-0">Loading invoice details...</p>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(detailError))
                        {
                            <div class="alert alert-danger mb-0">@detailError</div>
                        }
                        else if (selectedInvoice == null)
                        {
                            <div class="alert alert-warning mb-0">Invoice details are not available.</div>
                        }
                        else
                        {
                            <div class="invoice-detail-grid">
                                <div class="invoice-detail-card">
                                    <div class="detail-label">Invoice Date</div>
                                    <div class="detail-value">@FormatDate(selectedInvoice.DocDate)</div>
                                </div>
                                <div class="invoice-detail-card">
                                    <div class="detail-label">Due Date</div>
                                    <div class="detail-value">@FormatDate(selectedInvoice.DocDueDate)</div>
                                </div>
                                <div class="invoice-detail-card">
                                    <div class="detail-label">Amount</div>
                                    <div class="detail-value detail-value-lg">@FormatCurrencyWithCode(selectedInvoice.DocTotal,
                                                                                                                                                                                            selectedInvoice.DocCurrency)</div>
                                    </div>
                                    <div class="invoice-detail-card">
                                        <div class="detail-label">VAT</div>
                                        <div class="detail-value">@FormatCurrencyWithCode(selectedInvoice.VatSum,
                                                                                                                                                                                                            selectedInvoice.DocCurrency)</div>
                                        </div>
                                        <div class="invoice-detail-card">
                                            <div class="detail-label">Reference</div>
                                            <div class="detail-value">@(selectedInvoice.NumAtCard ?? "-")</div>
                                        </div>
                                        <div class="invoice-detail-card">
                                            <div class="detail-label">Status</div>
                                            <div class="detail-value">
                                                <span
                                                class="badge status-pill @GetStatusClass(selectedInvoiceSummary!)">@GetSelectedInvoiceStatusText()</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="invoice-section-header mt-4">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                             viewBox="0 0 16 16">
                                            <path
                                            d="M0 .5A.5.5 0 0 1 .5 0h15a.5.5 0 0 1 .5.5v3a.5.5 0 0 1-.5.5H.5a.5.5 0 0 1-.5-.5v-3zm0 6A.5.5 0 0 1 .5 6h15a.5.5 0 0 1 .5.5v3a.5.5 0 0 1-.5.5H.5a.5.5 0 0 1-.5-.5v-3zm0 6a.5.5 0 0 1 .5-.5h15a.5.5 0 0 1 .5.5v3a.5.5 0 0 1-.5.5H.5a.5.5 0 0 1-.5-.5v-3z" />
                                        </svg>
                                        Items Invoiced
                                    </div>
                                    @if (selectedInvoice.Lines?.Any() == true)
                                    {
                                        <div class="table-responsive mb-4">
                                            <table class="table table-sm align-middle invoice-items-table">
                                                <thead>
                                                    <tr>
                                                        <th>#</th>
                                                        <th>Item Code</th>
                                                        <th>Description</th>
                                                        <th class="text-end">Qty</th>
                                                        <th>UoM</th>
                                                        <th class="text-end">Gross Price</th>
                                                        <th class="text-end">Total</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var line in selectedInvoice.Lines)
                                                    {
                                                        <tr>
                                                            <td>@line.LineNum</td>
                                                            <td><code class="item-code">@line.ItemCode</code></td>
                                                            <td>@line.ItemDescription</td>
                                                            <td class="text-end">@QuantityDisplay.Format(line.Quantity, line.UoMCode)</td>
                                                            <td>@(line.UoMCode ?? "-")</td>
                                                            <td class="text-end">@FormatCurrencyWithCode(line.GrossPrice,
                                                                                                                                                                                                                                                                                                    selectedInvoice.DocCurrency)</td>
                                                                <td class="text-end fw-semibold">@FormatCurrencyWithCode(line.LineTotal,
                                                                                                                                                                                                                                                                                                                    selectedInvoice.DocCurrency)</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                        else
                                            {
                                                <div class="text-muted small mb-4">No line items available for this invoice.</div>
                                            }

                                            <div class="invoice-section-header">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                                     viewBox="0 0 16 16">
                                                    <path
                                                    d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z" />
                                                    <path
                                                    d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z" />
                                                </svg>
                                                Proof of Delivery (POD)
                                            </div>
                                            @if (podAttachments.Any())
                                            {
                                                <div class="pod-list">
                                                    @foreach (var attachment in podAttachments)
                                                    {
                                                        <div class="pod-item">
                                                            <div class="pod-item-info">
                                                                <div class="fw-semibold">@attachment.FileName</div>
                                                                <div class="text-muted small">
                                                                    @attachment.FileSizeFormatted &middot; @attachment.UploadedAt.ToString("MMM dd, yyyy")
                                                                    @if (!string.IsNullOrWhiteSpace(attachment.Description))
                                                                    {
                                                                        <span>&middot; @attachment.Description</span>
                                                                    }
                                                                </div>
                                                            </div>
                                                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                                                       OnClick="() => DownloadAttachment(attachment)">
                                                                View POD
                                                            </MudButton>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="pod-empty">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                                         viewBox="0 0 16 16">
                                                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                                                        <path
                                                        d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                                                    </svg>
                                                    No POD is attached to this invoice yet.
                                                </div>
                                            }
                                        }
                                    </div>
                                    <div class="modal-footer invoice-modal-footer">
                                        <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Primary"
                                                   OnClick="DownloadInvoicePdf" Disabled="@isPdfLoading">
                                            @if (isPdfLoading)
                                            {
                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                                <span>Generating...</span>
                                            }
                                            else
                                            {
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                                     viewBox="0 0 16 16" class="me-2">
                                                    <path
                                                    d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z" />
                                                    <path
                                                    d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z" />
                                                </svg>
                                                <span>Download PDF</span>
                                            }
                                        </MudButton>
                                        <MudButton ButtonType="ButtonType.Button" Variant="Variant.Outlined" Color="Color.Default"
                                                   OnClick="CloseInvoiceModal">Close</MudButton>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

@code {
    private CustomerInfo? customerInfo;
    private List<CustomerInvoiceSummary> invoices = new();
    private bool isLoading = true;
    private bool hasLoaded = false;
    private int currentPage = 1;
    private int pageSize = 15;
    private int totalPages => (int)Math.Ceiling((double)filteredInvoices.Count / pageSize);
    private List<CustomerInvoiceSummary> pagedInvoices => filteredInvoices
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();
    private DateTime? lastUpdated;
    private decimal totalOutstanding;
    private decimal filteredOutstanding => filteredInvoices.Sum(i => i.Balance);
    private bool isMultiAccount;
    private DateTime? fromDate = DateTime.Today.AddMonths(-3);
    private DateTime? toDate = DateTime.Today;
    private CustomerInvoiceSummary? selectedInvoiceSummary;
    private InvoiceDto? selectedInvoice;
    private List<DocumentAttachmentDto> podAttachments = new();
    private bool showInvoiceModal;
    private bool isDetailLoading;
    private string? detailError;
    private bool isPdfLoading;
    private string selectedAccountFilter = "";
    private List<LinkedAccountInfo> linkedAccounts = new();
    private List<CustomerInvoiceSummary> filteredInvoices => string.IsNullOrEmpty(selectedAccountFilter)
        ? invoices
        : invoices.Where(i => i.CardCode == selectedAccountFilter).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadCustomerInfo();
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadCustomerInfo()
    {
        try
        {
            var customerInfoJson = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "customerInfo");

            if (!string.IsNullOrEmpty(customerInfoJson))
            {
                customerInfo = System.Text.Json.JsonSerializer.Deserialize<CustomerInfo>(customerInfoJson);
                if (customerInfo != null)
                {
                    isMultiAccount = customerInfo.AccountStructure == "Multi";
                    if (isMultiAccount)
                    {
                        linkedAccounts = await LinkedAccountService.GetLinkedAccountsAsync(customerInfo.CardCode);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading customer info");
        }
    }

    private async Task LoadInvoices()
    {
        if (customerInfo == null) return;

        isLoading = true;

        try
        {
            invoices = await StatementService.GetOpenInvoicesAsync(customerInfo.CardCode, fromDate, toDate);
            totalOutstanding = invoices.Sum(i => i.Balance);
            lastUpdated = DateTime.UtcNow;
            hasLoaded = true;
            currentPage = 1;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading invoices");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnAccountFilterChanged(string value)
    {
        selectedAccountFilter = value;
        currentPage = 1;
    }

    private async Task ViewInvoiceDetails(CustomerInvoiceSummary invoice)
    {
        showInvoiceModal = true;
        isDetailLoading = true;
        detailError = null;
        selectedInvoiceSummary = invoice;
        selectedInvoice = null;
        podAttachments = new List<DocumentAttachmentDto>();

        try
        {
            selectedInvoice = await InvoiceService.GetInvoiceByDocEntryAsync(invoice.DocEntry);
            var attachmentsResponse = await Http.GetFromJsonAsync<DocumentAttachmentListResponse>(
                $"api/invoice/{invoice.DocEntry}/attachments");
            var attachments = attachmentsResponse?.Attachments ?? new List<DocumentAttachmentDto>();
            podAttachments = attachments.Where(IsPodAttachment).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading invoice details for {DocEntry}", invoice.DocEntry);
            detailError = "Unable to load invoice details. Please try again.";
        }
        finally
        {
            isDetailLoading = false;
        }
    }

    private void CloseInvoiceModal()
    {
        showInvoiceModal = false;
        selectedInvoiceSummary = null;
        selectedInvoice = null;
        podAttachments = new List<DocumentAttachmentDto>();
        detailError = null;
    }

    private async Task DownloadInvoicePdf()
    {
        if (selectedInvoice == null || isPdfLoading) return;
        isPdfLoading = true;
        try
        {
            var pdfBytes = await InvoiceService.GetInvoicePdfAsync(selectedInvoice.DocEntry);
            if (pdfBytes == null || pdfBytes.Length == 0)
            {
                detailError = "Failed to retrieve invoice PDF.";
                return;
            }
            var base64 = Convert.ToBase64String(pdfBytes);
            var fileName = $"Invoice_{selectedInvoice.DocNum}.pdf";
            await JSRuntime.InvokeVoidAsync("downloadPdfFromBase64", base64, fileName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error downloading invoice PDF for DocEntry {DocEntry}", selectedInvoice.DocEntry);
            detailError = "Failed to download invoice PDF.";
        }
        finally
        {
            isPdfLoading = false;
        }
    }

    private async Task DownloadAttachment(DocumentAttachmentDto attachment)
    {
        if (selectedInvoiceSummary == null)
        {
            detailError = "Invoice details are missing. Please try again.";
            return;
        }

        try
        {
            var response = await Http.GetAsync(
                $"api/invoice/{selectedInvoiceSummary.DocEntry}/attachments/{attachment.Id}/download");

            if (!response.IsSuccessStatusCode)
            {
                detailError = "Unable to download the POD. Please try again.";
                return;
            }

            var content = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(content);
            var contentType = attachment.MimeType ?? "application/octet-stream";
            await JSRuntime.InvokeVoidAsync("downloadFile", attachment.FileName, contentType, base64);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error downloading attachment {AttachmentId}", attachment.Id);
            detailError = "Unable to download the POD. Please try again.";
        }
    }

    private string FormatCurrency(decimal amount)
    {
        return $"${amount:N2}";
    }

    private string FormatCurrencyWithCode(decimal amount, string? currency)
    {
        if (string.IsNullOrWhiteSpace(currency))
        {
            return FormatCurrency(amount);
        }

        return $"{currency} {amount:N2}";
    }

    private static bool IsPodAttachment(DocumentAttachmentDto attachment)
    {
        var label = $"{attachment.FileName} {attachment.Description}";
        return label.Contains("pod", StringComparison.OrdinalIgnoreCase)
            || label.Contains("proof of delivery", StringComparison.OrdinalIgnoreCase);
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
        }
    }

    private List<int> GetVisiblePages()
    {
        var pages = new List<int>();
        if (totalPages <= 7)
        {
            for (int i = 1; i <= totalPages; i++) pages.Add(i);
            return pages;
        }

        pages.Add(1);
        if (currentPage > 3) pages.Add(-1); // ellipsis

        int start = Math.Max(2, currentPage - 1);
        int end = Math.Min(totalPages - 1, currentPage + 1);
        for (int i = start; i <= end; i++) pages.Add(i);

        if (currentPage < totalPages - 2) pages.Add(-1); // ellipsis
        pages.Add(totalPages);
        return pages;
    }

    private string GetStatusClass(CustomerInvoiceSummary invoice)
    {
        if (invoice.Balance <= 0) return "text-bg-primary";
        if (invoice.DaysOverdue > 0) return "text-bg-danger";
        return "text-bg-success";
    }

    private string GetStatusText(CustomerInvoiceSummary invoice)
    {
        if (invoice.Balance <= 0) return "Paid";
        if (invoice.DaysOverdue > 0) return $"Overdue ({invoice.DaysOverdue} days)";
        return "Current";
    }

    private string GetSelectedInvoiceStatusText()
    {
        return selectedInvoiceSummary == null ? "-" : GetStatusText(selectedInvoiceSummary);
    }

    private string FormatDate(string? dateStr)
    {
        if (string.IsNullOrWhiteSpace(dateStr))
        {
            return "-";
        }

        return DateTime.TryParse(dateStr, out var date)
            ? date.ToString("MMM dd, yyyy")
            : dateStr;
    }
}
