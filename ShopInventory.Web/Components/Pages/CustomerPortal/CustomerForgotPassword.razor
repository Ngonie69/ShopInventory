@page "/customer-portal/forgot-password"
@inject ICustomerAuthService CustomerAuthService
@inject WebClientAuditContext ClientAuditContext
@inject ILogger<CustomerForgotPassword> Logger
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@layout EmptyLayout

<PageTitle>Forgot Password - Customer Portal</PageTitle>

<div class="customer-recovery-page">
    <div class="customer-recovery-card">
        <img src="/images/kefalos-logo.jpg" alt="Kefalos" class="customer-recovery-logo" />
        <p class="customer-recovery-eyebrow">Customer Portal</p>
        <h1>Reset your password</h1>
        <p class="text-muted">Enter the customer code and email address registered on your portal account.</p>

        @if (requestSubmitted)
        {
            <div class="alert alert-success" role="status">@resultMessage</div>
            <a class="btn btn-dark w-100" href="/customer-portal/login">Back to sign in</a>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(resultMessage))
            {
                <div class="alert alert-danger" role="alert">@resultMessage</div>
            }

            <EditForm Model="model" OnValidSubmit="RequestReset" FormName="customer-forgot-password">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label" for="reset-card-code">Customer code</label>
                    <InputText id="reset-card-code" class="form-control" @bind-Value="model.CardCode" autocomplete="username" />
                    <ValidationMessage For="@(() => model.CardCode)" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="reset-email">Email address</label>
                    <InputText id="reset-email" class="form-control" type="email" @bind-Value="model.Email" autocomplete="email" />
                    <ValidationMessage For="@(() => model.Email)" />
                </div>
                <button class="btn btn-dark w-100" type="submit" disabled="@isSubmitting">
                    @(isSubmitting ? "Sending..." : "Send reset link")
                </button>
            </EditForm>

            <a class="customer-recovery-back" href="/customer-portal/login">Back to sign in</a>
        }
    </div>
</div>

@code {
    private readonly CustomerPasswordResetRequest model = new();
    private bool isSubmitting;
    private bool requestSubmitted;
    private string? resultMessage;

    private async Task RequestReset()
    {
        if (isSubmitting)
        {
            return;
        }

        isSubmitting = true;
        resultMessage = null;

        try
        {
            model.CardCode = model.CardCode.Trim();
            model.Email = model.Email.Trim();
            var result = await CustomerAuthService.RequestPasswordResetAsync(
                model,
                ClientAuditContext.IpAddress ?? "unknown");

            resultMessage = result.Message;
            requestSubmitted = result.Success;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Customer password reset request failed");
            resultMessage = "We couldn't process the request right now. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
