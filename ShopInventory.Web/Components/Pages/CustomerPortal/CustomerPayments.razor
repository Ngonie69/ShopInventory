@page "/customer-portal/payments"
@using ShopInventory.Web.Models
@using ShopInventory.Web.Services
@inject ICustomerStatementService StatementService
@inject ICustomerPortalSessionService CustomerSession
@inject ILogger<CustomerPayments> Logger
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@layout CustomerPortalLayout

<PageTitle>Payments - Customer Portal</PageTitle>

<div class="container-fluid fade-in staff-dashboard staff-shell customer-payments">
    @if (isLoading)
    {
        <div class="card dashboard-panel">
            <div class="card-body text-center py-5">
                <div class="spinner-border" role="status" style="width: 2.5rem; height: 2.5rem;">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted mt-3 mb-0">Loading payments...</p>
            </div>
        </div>
    }
    else if (customerInfo == null)
    {
        <div class="card dashboard-panel">
            <div class="card-body text-center py-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" fill="currentColor" viewBox="0 0 16 16"
                     class="mb-3">
                    <path
                    d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" />
                </svg>
                <h2 class="mb-2">Authentication Required</h2>
                <p class="text-muted mb-4">Please login to view your payments.</p>
                <a href="/customer-portal/login" class="btn btn-primary">Login to Portal</a>
            </div>
        </div>
    }
    else
    {
        <div class="dashboard-hero">
            <div class="page-header staff-dashboard-header">
                <div class="dashboard-title">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor"
                             viewBox="0 0 16 16">
                            <path d="M8 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" />
                            <path
                            d="M0 4a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V4zm3 0a2 2 0 0 1-2 2v4a2 2 0 0 1 2 2h10a2 2 0 0 1 2-2V6a2 2 0 0 1-2-2H3z" />
                        </svg>
                        Payments
                    </h2>
                    <span class="text-muted">Payment history for @customerInfo.CardName</span>
                    @if (isMultiAccount)
                    {
                        @if (string.IsNullOrEmpty(selectedAccountFilter))
                        {
                            <span class="badge bg-info mt-1" style="font-size: 0.75rem;">
                                Multi-Account &mdash; showing payments across all main accounts
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-info mt-1" style="font-size: 0.75rem;">
                                Filtered &mdash; @(linkedAccounts.FirstOrDefault(a => a.CardCode == selectedAccountFilter)?.CardName
                                                    ?? selectedAccountFilter)
                            </span>
                        }
                    }
                </div>
                <div class="dashboard-meta">
                    <span class="meta-pill">
                        <span class="meta-dot"></span>
                        Payment Summary
                    </span>
                    <span class="meta-subtitle">
                        @if (hasLoaded)
                        {
                            @($"{FormatCurrency(filteredTotalPaid)} across {filteredPayments.Count} payments")
                        }
                        else
                        {
                            <text>Select date range and load payments</text>
                        }
                    </span>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        <a href="/customer-portal/dashboard" class="btn btn-outline-primary btn-sm">Back to Dashboard</a>
                        <a href="/customer-portal/statements" class="btn btn-primary btn-sm">View Statement</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="card dashboard-panel">
            <div class="card-header d-flex align-items-center justify-content-between dashboard-panel-header">
                <h5 class="mb-0 d-flex align-items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"
                         class="panel-icon-emerald">
                        <path d="M8 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" />
                        <path
                        d="M0 4a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V4zm3 0a2 2 0 0 1-2 2v4a2 2 0 0 1 2 2h10a2 2 0 0 1 2-2V6a2 2 0 0 1-2-2H3z" />
                    </svg>
                    Payment History
                </h5>
                <span class="text-muted small">Last updated @(lastUpdated?.ToString("MMM dd, yyyy 'at' HH:mm") ?? "just                now") UTC</span>
            </div>
            <div class="card-body">
                <div class="row g-3 align-items-end mb-4">
                    <div class="col-md-3">
                        <FlexibleDatePicker Label="From" @bind-Date="fromDate" />
                    </div>
                    <div class="col-md-3">
                        <FlexibleDatePicker Label="To" @bind-Date="toDate" />
                    </div>
                    @if (isMultiAccount && linkedAccounts.Any())
                    {
                        <div class="col-md-3">
                            <MudSelect T="string" Label="Account" Value="@selectedAccountFilter"
                                       ValueChanged="OnAccountFilterChanged" Variant="Variant.Outlined" Dense="true"
                                       AnchorOrigin="Origin.BottomCenter">
                                <MudSelectItem T="string" Value="@("")">All Accounts</MudSelectItem>
                                @foreach (var account in linkedAccounts)
                                {
                                    <MudSelectItem T="string" Value="@account.CardCode">
                                        @account.CardName @(!string.IsNullOrEmpty(account.Currency) ? $"({account.Currency})" : "")
                                        — @account.CardCode
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </div>
                        <div class="col-md-3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="w-100" OnClick="ApplyFilters"
                                       Disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                    <span>Loading...</span>
                                }
                                else
                                {
                                    <span>Load Payments</span>
                                }
                            </MudButton>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-6">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="w-100" OnClick="ApplyFilters"
                                       Disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                    <span>Loading...</span>
                                }
                                else
                                {
                                    <span>Load Payments</span>
                                }
                            </MudButton>
                        </div>
                    }
                </div>

                @if (hasLoaded)
                {
                    @if (pagedPayments.Any())
                    {
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="badge bg-primary bg-opacity-10 text-primary"
                                  style="font-size: 0.75rem;">@filteredPayments.Count
                                total</span>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover mb-0 align-middle dashboard-table payments-table">
                                    <thead>
                                        <tr>
                                            <th>Payment #</th>
                                            @if (isMultiAccount)
                                            {
                                                <th>Account</th>
                                            }
                                            <th>Date</th>
                                            <th>Method</th>
                                            <th>Reference</th>
                                            <th class="text-end">Amount</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var payment in pagedPayments)
                                        {
                                            <tr class="payment-row">
                                                <td><span class="payment-num-badge">@payment.DocNum</span></td>
                                                @if (isMultiAccount)
                                                {
                                                    <td>
                                                        <small class="d-block fw-semibold">@(payment.CardCode ?? "-")</small>
                                                        @if (!string.IsNullOrEmpty(payment.Currency))
                                                        {
                                                            <span class="badge bg-outline-dark border"
                                                                  style="font-size: 0.65rem;">@payment.Currency</span>
                                                        }
                                                    </td>
                                                }
                                                <td>@payment.DocDate.ToString("MMM dd, yyyy")</td>
                                                <td>
                                                    <span class="payment-method-chip">@payment.PaymentMethod</span>
                                                </td>
                                                <td>@(payment.Reference ?? "-")</td>
                                                <td class="text-end fw-semibold text-success">@FormatCurrency(payment.DocTotal)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @* Pagination *@
                            @if (totalPages > 1)
                            {
                                <div class="invoices-pagination">
                                    <div class="pagination-info">
                                        Showing @(((currentPage - 1) * pageSize) + 1)&ndash;@(Math.Min(currentPage * pageSize,
                                                                                                    filteredPayments.Count)) of @filteredPayments.Count payments
                                    </div>
                                    <nav>
                                        <ul class="pagination pagination-sm mb-0">
                                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                                <button class="page-link" @onclick="() => GoToPage(1)" disabled="@(currentPage == 1)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                                         viewBox="0 0 16 16">
                                                        <path fill-rule="evenodd"
                                                              d="M8.354 1.646a.5.5 0 0 1 0 .708L2.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0zM12.354 1.646a.5.5 0 0 1 0 .708L6.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z" />
                                                    </svg>
                                                </button>
                                            </li>
                                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                                <button class="page-link" @onclick="() => GoToPage(currentPage - 1)"
                                                        disabled="@(currentPage == 1)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                                         viewBox="0 0 16 16">
                                                        <path fill-rule="evenodd"
                                                              d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z" />
                                                    </svg>
                                                </button>
                                            </li>
                                            @foreach (var pg in GetVisiblePages())
                                            {
                                                @if (pg == -1)
                                                {
                                                    <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                                                }
                                                else
                                                {
                                                    <li class="page-item @(pg == currentPage ? "active" : "")">
                                                        <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                                                    </li>
                                                }
                                            }
                                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                                <button class="page-link" @onclick="() => GoToPage(currentPage + 1)"
                                                        disabled="@(currentPage == totalPages)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                                         viewBox="0 0 16 16">
                                                        <path fill-rule="evenodd"
                                                              d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z" />
                                                    </svg>
                                                </button>
                                            </li>
                                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                                <button class="page-link" @onclick="() => GoToPage(totalPages)"
                                                        disabled="@(currentPage == totalPages)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                                         viewBox="0 0 16 16">
                                                        <path fill-rule="evenodd"
                                                              d="M3.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L9.293 8 3.646 2.354a.5.5 0 0 1 0-.708zM7.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L13.293 8 7.646 2.354a.5.5 0 0 1 0-.708z" />
                                                    </svg>
                                                </button>
                                            </li>
                                        </ul>
                                    </nav>
                                </div>
                            }
                        }
                else
                        {
                            <div class="text-center py-5 dashboard-empty">
                                <p class="text-muted mb-0">No payments found for the selected period.</p>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>

@code {
    private CustomerPortalSession? portalSession;
    private CustomerInfo? customerInfo;
    private List<CustomerPaymentSummary> payments = new();
    private bool isLoading = true;
    private bool hasLoaded = false;
    private int currentPage = 1;
    private int pageSize = 15;
    private int totalPages => (int)Math.Ceiling((double)filteredPayments.Count / pageSize);
    private List<CustomerPaymentSummary> pagedPayments => filteredPayments
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();
    private DateTime? lastUpdated;
    private decimal totalPaid;
    private decimal filteredTotalPaid => filteredPayments.Sum(p => p.DocTotal);
    private DateTime? fromDate = DateTime.Today.AddMonths(-6);
    private DateTime? toDate = DateTime.Today;
    private bool isMultiAccount;
    private string selectedAccountFilter = "";
    private List<LinkedAccountInfo> linkedAccounts = new();
    private List<CustomerPaymentSummary> filteredPayments => string.IsNullOrEmpty(selectedAccountFilter)
        ? payments
        : payments.Where(p => p.CardCode == selectedAccountFilter).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadCustomerInfo();
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadCustomerInfo()
    {
        try
        {
            portalSession = await CustomerSession.GetCurrentSessionAsync();
            customerInfo = portalSession?.Customer;

            if (customerInfo != null)
            {
                isMultiAccount = customerInfo.AccountStructure == "Multi";
                linkedAccounts = portalSession?.LinkedAccounts.ToList() ?? new List<LinkedAccountInfo>();
                selectedAccountFilter = CustomerSession.CanAccessCardCode(portalSession, selectedAccountFilter)
                    ? selectedAccountFilter
                    : string.Empty;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading customer info");
        }
    }

    private void OnAccountFilterChanged(string value)
    {
        if (!CustomerSession.CanAccessCardCode(portalSession, value))
        {
            Logger.LogWarning("Rejected unauthorized customer payment account filter {CardCode}", value);
            selectedAccountFilter = string.Empty;
            currentPage = 1;
            return;
        }

        selectedAccountFilter = value;
        currentPage = 1;
    }

    private async Task ApplyFilters()
    {
        await LoadPayments();
    }

    private async Task LoadPayments()
    {
        if (customerInfo == null) return;

        isLoading = true;

        try
        {
            payments = await StatementService.GetPaymentHistoryAsync(customerInfo.CardCode, fromDate, toDate);
            totalPaid = payments.Sum(p => p.DocTotal);
            lastUpdated = DateTime.UtcNow;
            hasLoaded = true;
            currentPage = 1;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading payments");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string FormatCurrency(decimal amount)
    {
        return $"${amount:N2}";
    }

    private void GoToPage(int pg)
    {
        if (pg >= 1 && pg <= totalPages)
        {
            currentPage = pg;
        }
    }

    private List<int> GetVisiblePages()
    {
        var pages = new List<int>();
        if (totalPages <= 7)
        {
            for (int i = 1; i <= totalPages; i++) pages.Add(i);
            return pages;
        }

        pages.Add(1);
        if (currentPage > 3) pages.Add(-1);

        int start = Math.Max(2, currentPage - 1);
        int end = Math.Min(totalPages - 1, currentPage + 1);
        for (int i = start; i <= end; i++) pages.Add(i);

        if (currentPage < totalPages - 2) pages.Add(-1);
        pages.Add(totalPages);
        return pages;
    }
}