@page "/customer-portal"
@inject ICustomerPortalSessionService CustomerSession
@inject NavigationManager NavigationManager
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@layout EmptyLayout

<PageTitle>Customer Portal</PageTitle>

<div class="d-flex min-vh-100 align-items-center justify-content-center bg-light">
    <div class="text-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="text-muted mt-3">Opening the customer portal...</p>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var session = await CustomerSession.GetCurrentSessionAsync();
        var destination = session == null
            ? "/customer-portal/login"
            : "/customer-portal/dashboard";

        NavigationManager.NavigateTo(destination, forceLoad: true, replace: true);
    }
}
