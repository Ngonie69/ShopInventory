@page "/customer-portal/activity-log"
@using ShopInventory.Web.Models
@inject ICustomerAuthService CustomerAuthService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject ILogger<CustomerActivityLog> Logger
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@layout CustomerPortalLayout

<PageTitle>Activity Log - Customer Portal</PageTitle>

<div class="container-fluid fade-in staff-dashboard staff-shell customer-activity-log">
    @if (isLoading)
    {
        <div class="card dashboard-panel">
            <div class="card-body text-center py-5">
                <div class="spinner-border" role="status" style="width: 2.5rem; height: 2.5rem;">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted mt-3 mb-0">Loading activity log...</p>
            </div>
        </div>
    }
    else if (customerInfo == null)
    {
        <div class="card dashboard-panel">
            <div class="card-body text-center py-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" fill="currentColor" viewBox="0 0 16 16"
                     class="mb-3">
                    <path
                    d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" />
                </svg>
                <h2 class="mb-2">Authentication Required</h2>
                <p class="text-muted mb-4">Please login to view your activity log.</p>
                <a href="/customer-portal/login" class="btn btn-primary">Login to Portal</a>
            </div>
        </div>
    }
    else
    {
        <div class="dashboard-hero">
            <div class="page-header staff-dashboard-header">
                <div class="dashboard-title">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor"
                             viewBox="0 0 16 16" class="me-2">
                            <path
                            d="M8.515 1.019A7 7 0 0 0 8 1V0a8 8 0 0 1 .589.022l-.074.997zm2.004.45a7.003 7.003 0 0 0-.985-.299l.219-.976c.383.086.76.2 1.126.342l-.36.933zm1.37.71a7.01 7.01 0 0 0-.439-.27l.493-.87a8.025 8.025 0 0 1 .979.654l-.615.789a6.996 6.996 0 0 0-.418-.302zm1.834 1.79a6.99 6.99 0 0 0-.653-.796l.724-.69c.27.285.52.59.747.91l-.818.576zm.744 1.352a7.08 7.08 0 0 0-.214-.468l.893-.45a7.976 7.976 0 0 1 .45 1.088l-.95.313a7.023 7.023 0 0 0-.179-.483zm.53 2.507a6.991 6.991 0 0 0-.1-1.025l.985-.17c.067.386.106.778.116 1.17l-1 .025zm-.131 1.538c.033-.17.06-.339.081-.51l.993.123a7.957 7.957 0 0 1-.23 1.155l-.964-.267c.046-.165.086-.332.12-.501zm-.952 2.379c.184-.29.346-.594.486-.908l.914.405c-.16.36-.345.706-.555 1.038l-.845-.535zm-.964 1.205c.122-.122.239-.248.35-.378l.758.653a8.073 8.073 0 0 1-.401.432l-.707-.707z" />
                            <path d="M8 1a7 7 0 1 0 4.95 11.95l.707.707A8.001 8.001 0 1 1 8 0v1z" />
                            <path
                            d="M7.5 3a.5.5 0 0 1 .5.5v5.21l3.248 1.856a.5.5 0 0 1-.496.868l-3.5-2A.5.5 0 0 1 7 9V3.5a.5.5 0 0 1 .5-.5z" />
                        </svg>
                        Account Activity
                    </h2>
                    <p class="text-muted mb-0">Recent security events and account actions</p>
                </div>
                <div class="dashboard-actions">
                    <button class="btn btn-sm btn-outline-primary" @onclick="RefreshData" disabled="@isLoadingLogs">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                             viewBox="0 0 16 16" class="me-1">
                            <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z" />
                            <path
                            d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z" />
                        </svg>
                        Refresh
                    </button>
                </div>
            </div>
        </div>

        <div class="card dashboard-panel">
            <div class="card-body p-0">
                @if (isLoadingLogs)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border spinner-border-sm" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (!logs.Any())
                {
                    <div class="text-center py-5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16"
                             class="text-muted mb-3" style="opacity: 0.4;">
                            <path
                            d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z" />
                            <path
                            d="M4 5.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5zM4 8a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7A.5.5 0 0 1 4 8zm0 2.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 0 1h-4a.5.5 0 0 1-.5-.5z" />
                        </svg>
                        <p class="text-muted mb-0">No activity recorded yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 staff-table">
                            <thead>
                                <tr>
                                    <th>Date &amp; Time</th>
                                    <th>Action</th>
                                    <th>Status</th>
                                    <th>Details</th>
                                    <th class="d-none d-md-table-cell">IP Address</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in logs)
                                {
                                    <tr>
                                        <td>
                                            <span class="text-nowrap">@log.Timestamp.ToLocalTime().ToString("dd MMM yyyy")</span>
                                            <br />
                                            <small class="text-muted">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</small>
                                        </td>
                                        <td>
                                            <span class="fw-semibold">@FormatAction(log.Action)</span>
                                        </td>
                                        <td>
                                            @if (log.Success)
                                            {
                                                <span class="badge text-bg-success">Success</span>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-danger">Failed</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(log.Details))
                                            {
                                                <span class="text-muted small">@log.Details</span>
                                            }
                                            else if (!string.IsNullOrEmpty(log.FailureReason))
                                            {
                                                <span class="text-danger small">@log.FailureReason</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">&mdash;</span>
                                            }
                                        </td>
                                        <td class="d-none d-md-table-cell">
                                            <code class="small">@(log.IpAddress ?? "—")</code>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (hasMorePages)
                    {
                        <div class="text-center py-3 border-top">
                            <button class="btn btn-sm btn-outline-primary" @onclick="LoadMore" disabled="@isLoadingLogs">
                                @if (isLoadingLogs)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                Load More
                            </button>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private CustomerInfo? customerInfo;
    private List<CustomerSecurityAuditLog> logs = new();
    private bool isLoading = true;
    private bool isLoadingLogs;
    private int currentPage = 1;
    private const int PageSize = 20;
    private bool hasMorePages = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var customerInfoJson = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "customerInfo");

                if (string.IsNullOrEmpty(customerInfoJson))
                {
                    customerInfo = null;
                    return;
                }

                customerInfo = System.Text.Json.JsonSerializer.Deserialize<CustomerInfo>(customerInfoJson);

                if (customerInfo != null)
                {
                    await LoadLogs();
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error loading activity log");
            }
            finally
            {
                isLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task LoadLogs()
    {
        isLoadingLogs = true;
        try
        {
            var page = await CustomerAuthService.GetSecurityLogsAsync(customerInfo!.CardCode, currentPage, PageSize);
            if (currentPage == 1)
                logs = page;
            else
                logs.AddRange(page);

            hasMorePages = page.Count == PageSize;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading security logs");
        }
        finally
        {
            isLoadingLogs = false;
        }
    }

    private async Task LoadMore()
    {
        currentPage++;
        await LoadLogs();
    }

    private async Task RefreshData()
    {
        currentPage = 1;
        await LoadLogs();
    }

    private string FormatAction(string action)
    {
        return action switch
        {
            "Login" => "Sign In",
            "LoginFailed" => "Sign In Attempt",
            "Logout" => "Sign Out",
            "PasswordChange" => "Password Changed",
            "PasswordReset" => "Password Reset",
            "TwoFactorEnabled" => "2FA Enabled",
            "TwoFactorDisabled" => "2FA Disabled",
            "TwoFactorVerified" => "2FA Verified",
            "TokenRefresh" => "Session Renewed",
            "AccountLocked" => "Account Locked",
            "AccountUnlocked" => "Account Unlocked",
            _ => action.Replace("_", " ")
        };
    }
}
