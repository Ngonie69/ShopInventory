    .cpod-action-view {
        color: #0f766e;
    }
    .cpod-action-view:hover {
        background: #f0fdfa;
        border-color: #99f6e4;
    }
    .cpod-action-download {
        color: #0369a1;
    }
    .cpod-action-download:hover {
