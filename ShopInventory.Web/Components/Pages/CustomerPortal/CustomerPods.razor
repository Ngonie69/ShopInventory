        gap: 0.75rem;
    }
    .cpod-hero-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        background: rgba(255,255,255,0.2);
        border-radius: 12px;
        font-size: 1.25rem;
        backdrop-filter: blur(4px);
    }
    .cpod-hero-subtitle {
        margin: 0.25rem 0 0;
        font-size: 0.9rem;
        opacity: 0.85;
    }
    .cpod-hero-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.75rem;
    }
    .cpod-stat-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(4px);
        border-radius: 20px;
        padding: 0.4rem 1rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: #fff;
    }
    .cpod-nav-links {
        display: flex;
        gap: 0.5rem;
    }
    .cpod-nav-btn {
        display: inline-flex;
        align-items: center;
        padding: 0.4rem 0.85rem;
        border-radius: 10px;
