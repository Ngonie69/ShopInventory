    .cpod-viewer-pdf {
        width: 100%;
        height: calc(90vh - 70px);
        border: none;
    }
</style>

@code {
    private CustomerPortalSession? portalSession;
    private CustomerInfo? customerInfo;
    private PodAttachmentListResponse? podResponse;
    private bool isLoading = false;
    private bool hasLoaded = false;
    private int currentPage = 1;
    private const int pageSize = 20;
    private DateTime? fromDate = DateTime.Today.AddMonths(-3);
    private DateTime? toDate = DateTime.Today;
    private bool isMultiAccount;
    private string selectedAccountFilter = "";
    private List<LinkedAccountInfo> linkedAccounts = new();

    // Viewer state
    private bool showViewer;
    private bool isLoadingViewer;
    private string? viewerDataUri;
    private string? viewerFileName;
    private string? viewerMimeType;
    private PodAttachmentItemDto? viewerPod;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadCustomerInfo();
            StateHasChanged();
        }
    }

    private async Task LoadCustomerInfo()
    {
        try
        {
            portalSession = await CustomerSession.GetCurrentSessionAsync();
            customerInfo = portalSession?.Customer;

            if (customerInfo != null)
            {
                isMultiAccount = customerInfo.AccountStructure == "Multi";
                linkedAccounts = portalSession?.LinkedAccounts.ToList() ?? new List<LinkedAccountInfo>();
                selectedAccountFilter = CustomerSession.CanAccessCardCode(portalSession, selectedAccountFilter)
                    ? selectedAccountFilter
                    : string.Empty;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading customer info");
        }
    }

    private async Task<List<string>> ResolveCardCodesAsync()
    {
        var cardCodes = CustomerSession.ResolveAccessibleCardCodes(portalSession, selectedAccountFilter).ToList();
        if (cardCodes.Count > 0)
        {
            return cardCodes;
        }

        if (!string.IsNullOrEmpty(selectedAccountFilter))
        {
            Logger.LogWarning("Rejected unauthorized customer POD account access {CardCode}", selectedAccountFilter);
            selectedAccountFilter = string.Empty;
        }

        await Task.CompletedTask;
        return new List<string>();
    }

    private async Task LoadData()
    {
        if (customerInfo == null) return;

        isLoading = true;

        try
        {
            currentPage = 1;
            var cardCodes = await ResolveCardCodesAsync();
            podResponse = await PodService.GetAllPodsForAccountsAsync(currentPage, pageSize, cardCodes, fromDate, toDate);
            hasLoaded = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading POD data");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadPage(int page)
    {
        if (customerInfo == null) return;
        currentPage = page;

        try
        {
            var cardCodes = await ResolveCardCodesAsync();
            podResponse = await PodService.GetAllPodsForAccountsAsync(currentPage, pageSize, cardCodes, fromDate, toDate);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading POD page {Page}", page);
        }
    }

    private async Task OnAccountFilterChanged(string value)
    {
        if (!CustomerSession.CanAccessCardCode(portalSession, value))
        {
            Logger.LogWarning("Rejected unauthorized customer POD account filter {CardCode}", value);
            selectedAccountFilter = string.Empty;
            return;
        }

        selectedAccountFilter = value;
        await LoadData();
    }

    private async Task DownloadPod(PodAttachmentItemDto pod)
    {
        try
        {
            if (!CustomerSession.CanAccessCardCode(portalSession, pod.CardCode))
            {
                Logger.LogWarning("Rejected unauthorized customer POD download {PodId} for {CardCode}", pod.Id, pod.CardCode);
                return;
            }

            var content = await PodService.DownloadPodAsync(pod.InvoiceDocEntry, pod.Id);
            if (content == null || content.Length == 0)
            {
                return;
            }

            var contentType = pod.MimeType ?? "application/octet-stream";
            await JSRuntime.InvokeVoidAsync("downloadFile", pod.FileName, contentType, Convert.ToBase64String(content));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error downloading POD {PodId}", pod.Id);
        }
    }

    private static bool IsViewable(string? mimeType) =>
        mimeType != null && (mimeType.StartsWith("image/") || mimeType == "application/pdf");

    private async Task ViewPod(PodAttachmentItemDto pod)
    {
        try
        {
            if (!CustomerSession.CanAccessCardCode(portalSession, pod.CardCode))
            {
                Logger.LogWarning("Rejected unauthorized customer POD view {PodId} for {CardCode}", pod.Id, pod.CardCode);
                return;
            }

            await RevokeViewerDataUriAsync();

            viewerPod = pod;
            viewerFileName = pod.FileName;
            viewerMimeType = pod.MimeType;
            viewerDataUri = null;
            showViewer = true;
            isLoadingViewer = true;
            StateHasChanged();

            var content = await PodService.DownloadPodAsync(pod.InvoiceDocEntry, pod.Id);
            if (content == null || content.Length == 0)
            {
                showViewer = false;
                return;
            }

            viewerDataUri = await JSRuntime.InvokeAsync<string>(
                "createObjectUrlFromBase64",
                viewerMimeType ?? "application/octet-stream",
                Convert.ToBase64String(content));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error viewing POD {PodId}", pod.Id);
            showViewer = false;
        }
        finally
        {
            isLoadingViewer = false;
            StateHasChanged();
        }
    }

    private async Task CloseViewer()
    {
        showViewer = false;
        await RevokeViewerDataUriAsync();
        viewerPod = null;
    }

    private async Task RevokeViewerDataUriAsync()
    {
        if (!string.IsNullOrWhiteSpace(viewerDataUri))
        {
            await JSRuntime.InvokeVoidAsync("revokeObjectUrl", viewerDataUri);
            viewerDataUri = null;
        }
    }
}
