    }
    .cpod-invoice-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 52px;
        padding: 0.3rem 0.65rem;
        background: linear-gradient(135deg, #0f766e, #14b8a6);
        color: #fff;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.02em;
    }
    .cpod-customer-name { font-weight: 600; color: #0f172a; }
    .cpod-file-name { font-weight: 600; color: #0f172a; font-size: 0.85rem; }
    .cpod-file-type { font-size: 0.75rem; color: #94a3b8; }
