@page "/customer-portal/pods"
@using ShopInventory.Web.Models
@using ShopInventory.Web.Services
@inject IPodService PodService
@inject ICustomerPortalSessionService CustomerSession
@inject IJSRuntime JSRuntime
@inject ILogger<CustomerPods> Logger
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@layout CustomerPortalLayout

<PageTitle>Proof of Delivery - Customer Portal</PageTitle>

<div class="container-fluid fade-in staff-dashboard staff-shell">
    @* Hero Header *@
    <div class="cpod-hero">
        <div class="cpod-hero-content">
            <div>
                <h2 class="cpod-hero-title">
                    <span class="cpod-hero-icon">
                        <i class="bi bi-clipboard-check"></i>
                    </span>
                    Proof of Delivery
                </h2>
                @if (customerInfo != null)
                {
                    <p class="cpod-hero-subtitle">POD records for @customerInfo.CardName</p>
                    @if (isMultiAccount)
                    {
                        @if (string.IsNullOrEmpty(selectedAccountFilter))
                        {
                            <span class="badge bg-light text-dark mt-1" style="font-size: 0.75rem;">
                                Multi-Account &mdash; showing PODs across all accounts
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-light text-dark mt-1" style="font-size: 0.75rem;">
                                Filtered &mdash; @(linkedAccounts.FirstOrDefault(a => a.CardCode == selectedAccountFilter)?.CardName ?? selectedAccountFilter)
                            </span>
                        }
                    }
                }
            </div>
            <div class="cpod-hero-right">
                <span class="cpod-stat-pill">
                    <i class="bi bi-file-earmark-check me-1"></i>
                    @(podResponse?.TotalCount ?? 0) PODs
                </span>
                <div class="cpod-nav-links">
                    <a href="/customer-portal/dashboard" class="cpod-nav-btn cpod-nav-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Dashboard
                    </a>
                    <a href="/customer-portal/invoices" class="cpod-nav-btn cpod-nav-primary">
                        <i class="bi bi-receipt me-1"></i>Invoices
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (customerInfo == null && !isLoading)
    {
        <div class="cpod-card">
            <div class="cpod-auth-state">
                <div class="cpod-empty-icon">
                    <i class="bi bi-lock"></i>
                </div>
                <h5 class="cpod-empty-title">Authentication Required</h5>
                <p class="cpod-empty-sub">Please login to view proof of delivery records.</p>
                <a href="/customer-portal/login" class="cpod-nav-btn cpod-nav-primary" style="text-decoration:none;">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Login to Portal
                </a>
            </div>
        </div>
    }
    else if (customerInfo != null)
    {
        @* Date Range Filters *@
        <div class="card dashboard-panel mb-3">
            <div class="card-header dashboard-panel-header">
                <h5 class="mb-0 d-flex align-items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" class="panel-icon">
                        <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2z"/>
                    </svg>
                    Filters
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <FlexibleDatePicker Label="From" @bind-Date="fromDate" />
                    </div>
                    <div class="col-md-3">
                        <FlexibleDatePicker Label="To" @bind-Date="toDate" />
                    </div>
                    @if (isMultiAccount && linkedAccounts.Any())
                    {
                        <div class="col-md-3">
                            <MudSelect T="string" Label="Account" Value="@selectedAccountFilter"
                                       ValueChanged="OnAccountFilterChanged" Variant="Variant.Outlined"
                                       Dense="true" AnchorOrigin="Origin.BottomCenter">
                                <MudSelectItem T="string" Value="@("")">All Accounts</MudSelectItem>
                                @foreach (var account in linkedAccounts)
                                {
                                    <MudSelectItem T="string" Value="@account.CardCode">
                                        @account.CardName @(!string.IsNullOrEmpty(account.Currency) ? $"({account.Currency})" : "") — @account.CardCode
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </div>
                        <div class="col-md-3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="w-100"
                                       OnClick="LoadData" Disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                    <span>Loading...</span>
                                }
                                else
                                {
                                    <span>Load PODs</span>
                                }
                            </MudButton>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-6">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="w-100"
                                       OnClick="LoadData" Disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                    <span>Loading...</span>
                                }
                                else
                                {
                                    <span>Load PODs</span>
                                }
                            </MudButton>
                        </div>
                    }
                </div>
            </div>
        </div>

    @if (isLoading)
    {
        @* Skeleton *@
        <div class="cpod-card">
            <div class="cpod-card-header">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-file-earmark-text"></i>
                    <span>Delivery Confirmations</span>
                </div>
            </div>
            <div class="cpod-table-wrap">
                <div class="table-responsive">
                    <table class="cpod-table">
                        <thead>
                            <tr>
                                <th>Invoice #</th>
                                <th>Customer</th>
                                <th>File Name</th>
                                <th>Description</th>
                                <th>Size</th>
                                <th>Uploaded</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < 5; i++)
                            {
                                <tr>
                                    <td><span class="placeholder-glow"><span class="placeholder col-8 rounded"></span></span></td>
                                    <td><span class="placeholder-glow"><span class="placeholder col-10 rounded"></span></span></td>
                                    <td><span class="placeholder-glow"><span class="placeholder col-10 rounded"></span><br/><span class="placeholder col-6 rounded" style="opacity:.5"></span></span></td>
                                    <td><span class="placeholder-glow"><span class="placeholder col-7 rounded"></span></span></td>
                                    <td><span class="placeholder-glow"><span class="placeholder col-6 rounded"></span></span></td>
                                    <td><span class="placeholder-glow"><span class="placeholder col-8 rounded"></span><br/><span class="placeholder col-4 rounded" style="opacity:.5"></span></span></td>
                                    <td class="text-end"><span class="placeholder-glow"><span class="placeholder col-8 rounded"></span></span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (hasLoaded)
    {
        @* POD List *@
        <div class="cpod-card">
            <div class="cpod-card-header">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-file-earmark-text"></i>
                    <span>Delivery Confirmations</span>
                </div>
                <span class="cpod-record-count">@(podResponse?.TotalCount ?? 0) total</span>
            </div>
            <div class="cpod-table-wrap">
                @if (podResponse?.Items?.Any() == true)
                {
                    <div class="table-responsive">
                        <table class="cpod-table">
                            <thead>
                                <tr>
                                    <th>Invoice #</th>
                                    <th>Customer</th>
                                    <th>File Name</th>
                                    <th>Description</th>
                                    <th>Size</th>
                                    <th>Uploaded</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var grouped = podResponse.Items.GroupBy(p => p.InvoiceDocEntry).ToList(); }
                                @foreach (var group in grouped)
                                {
                                    var first = group.First();
                                    var pods = group.ToList();
                                    @foreach (var (pod, idx) in pods.Select((p, i) => (p, i)))
                                    {
                                        <tr class="cpod-row">
                                            @if (idx == 0)
                                            {
                                                <td rowspan="@pods.Count" class="align-middle">
                                                    <span class="cpod-invoice-badge">@(first.InvoiceDocNum > 0 ? first.InvoiceDocNum.ToString() : "-")</span>
                                                </td>
                                                <td rowspan="@pods.Count" class="align-middle">
                                                    <div class="cpod-customer-name">@(first.CardName ?? "-")</div>
                                                </td>
                                            }
                                            <td>
                                                <div class="cpod-file-name">@pod.FileName</div>
                                                <div class="cpod-file-type">@pod.MimeType</div>
                                            </td>
                                            <td class="cpod-description">@(pod.Description ?? "-")</td>
                                            <td class="cpod-size">@pod.FileSizeFormatted</td>
                                            <td>
                                                <div class="cpod-date">@pod.UploadedAt.ToString("MMM dd, yyyy")</div>
                                                <div class="cpod-time">@pod.UploadedAt.ToString("HH:mm")</div>
                                            </td>
                                            <td class="text-end">
                                                <div class="cpod-actions">
                                                    @if (IsViewable(pod.MimeType))
                                                    {
                                                        <button class="cpod-action-btn cpod-action-view" @onclick="() => ViewPod(pod)" title="View">
                                                            <i class="bi bi-eye"></i>
                                                        </button>
                                                    }
                                                    <button class="cpod-action-btn cpod-action-download" @onclick="() => DownloadPod(pod)" title="Download">
                                                        <i class="bi bi-download"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    @* Pagination *@
                    @if (podResponse.TotalCount > pageSize)
                    {
                        <div class="cpod-pagination">
                            <span class="cpod-pagination-info">
                                Showing @((currentPage - 1) * pageSize + 1)–@Math.Min(currentPage * pageSize, podResponse.TotalCount)
                                of @podResponse.TotalCount
                            </span>
                            <div class="cpod-pagination-btns">
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@(currentPage <= 1)"
                                           OnClick="() => LoadPage(currentPage - 1)">
                                    <i class="bi bi-chevron-left me-1"></i>Previous
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@(!podResponse.HasMore)"
                                           OnClick="() => LoadPage(currentPage + 1)">
                                    Next<i class="bi bi-chevron-right ms-1"></i>
                                </MudButton>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="cpod-empty-state">
                        <div class="cpod-empty-icon">
                            <i class="bi bi-clipboard-x"></i>
                        </div>
                        <p class="cpod-empty-title">No proof of delivery records found</p>
                        <p class="cpod-empty-sub">PODs will appear here once uploaded by staff for your invoices.</p>
                    </div>
                }
            </div>
        </div>
    }
    }
</div>

@* POD Viewer Modal *@
@if (showViewer)
{
    <div class="cpod-viewer-overlay" @onclick="CloseViewer">
        <div class="cpod-viewer-container" @onclick:stopPropagation>
            <div class="cpod-viewer-header">
                <h6 class="mb-0 text-truncate">@viewerFileName</h6>
                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               OnClick="() => DownloadPod(viewerPod!)">
                        <i class="bi bi-download me-1"></i> Download
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                               OnClick="CloseViewer">
                        <i class="bi bi-x-lg"></i>
                    </MudButton>
                </div>
            </div>
            <div class="cpod-viewer-body">
                @if (isLoadingViewer)
                {
                    <div class="d-flex justify-content-center align-items-center h-100">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    </div>
                }
                else if (viewerMimeType?.StartsWith("image/") == true)
                {
                    <img src="@viewerDataUri" alt="@viewerFileName" class="cpod-viewer-image" />
                }
                else if (viewerMimeType == "application/pdf")
                {
                    <iframe src="@viewerDataUri" class="cpod-viewer-pdf" title="@viewerFileName"></iframe>
                }
            </div>
        </div>
    </div>
}

<style>
    /* ── Hero ─────────────────────────────────────── */
    .cpod-hero {
        background: linear-gradient(135deg, #0f766e 0%, #0d9488 50%, #14b8a6 100%);
        border-radius: 16px;
        padding: 2rem 2.5rem;
        margin-bottom: 1.5rem;
        color: #fff;
        position: relative;
        overflow: hidden;
    }
    .cpod-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        border-radius: 50%;
    }
    .cpod-hero-content {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
