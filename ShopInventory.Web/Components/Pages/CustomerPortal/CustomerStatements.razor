@using System.Globalization
@using ShopInventory.Web.Services

@page "/customer-portal/statements"
@using ShopInventory.Web.Models
@inject ICustomerStatementService StatementService
@inject ICustomerPortalSessionService CustomerSession
@inject IJSRuntime JSRuntime
@inject ILogger<CustomerStatements> Logger
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@layout CustomerPortalLayout

<PageTitle>My Statements - Customer Portal</PageTitle>

<div class="container-fluid fade-in staff-dashboard staff-shell customer-statements">
    @if (isLoading && statement == null)
    {
        <div class="card dashboard-panel">
            <div class="card-body text-center py-5">
                <div class="spinner-border" role="status" style="width: 2.5rem; height: 2.5rem;">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted mt-3 mb-0">Loading your statement...</p>
            </div>
        </div>
    }
    else if (customerInfo == null)
    {
        <div class="card dashboard-panel">
            <div class="card-body text-center py-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" fill="currentColor" viewBox="0 0 16 16"
                     class="mb-3">
                    <path
                    d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" />
                </svg>
                <h2 class="mb-2">Authentication Required</h2>
                <p class="text-muted mb-4">Please login to view your statements.</p>
                <a href="/customer-portal/login" class="btn btn-primary">Login to Portal</a>
            </div>
        </div>
    }
    else
    {
        <div class="dashboard-hero">
            <div class="page-header staff-dashboard-header">
                <div class="dashboard-title">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor"
                             viewBox="0 0 16 16">
                            <path
                            d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zM4 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.5L9.5 0H4z" />
                            <path
                            d="M4.5 12.5A.5.5 0 0 1 5 12h3a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5zm0-2A.5.5 0 0 1 5 10h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5zm0-2A.5.5 0 0 1 5 8h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5zm0-2A.5.5 0 0 1 5 6h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5z" />
                        </svg>
                        Account Statement
                    </h2>
                    <span class="text-muted">Statement for @customerInfo.CardName</span>
                    @if (isMultiAccount)
                    {
                        @if (string.IsNullOrEmpty(selectedAccountFilter))
                        {
                            <span class="badge bg-info mt-1" style="font-size: 0.75rem;">
                                Multi-Account &mdash; showing transactions across all main accounts
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-info mt-1" style="font-size: 0.75rem;">
                                Filtered &mdash; @(linkedAccounts.FirstOrDefault(a => a.CardCode == selectedAccountFilter)?.CardName
                                                                                    ?? selectedAccountFilter)
                            </span>
                        }
                    }
                </div>
                <div class="dashboard-meta">
                    <span class="meta-pill">
                        <span class="meta-dot"></span>
                        Statement
                    </span>
                    <span class="meta-subtitle">
                        @if (statement != null)
                        {
                            @($"Closing Balance: {FormatCurrency(statement.ClosingBalance)}")
                        }
                        else
                        {
                            <text>Select date range and generate</text>
                        }
                    </span>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        <a href="/customer-portal/dashboard" class="btn btn-outline-primary btn-sm">Back to Dashboard</a>
                        <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" OnClick="DownloadPdf"
                                   Disabled="@(isDownloading || statement == null)">
                            @if (isDownloading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                <span>Downloading...</span>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                     viewBox="0 0 16 16" class="me-1">
                                    <path
                                    d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z" />
                                    <path
                                    d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z" />
                                </svg>
                                <span>Download PDF</span>
                            }
                        </MudButton>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="card dashboard-panel mb-3">
            <div class="card-header dashboard-panel-header">
                <h5 class="mb-0 d-flex align-items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"
                         class="panel-icon">
                        <path
                        d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2z" />
                    </svg>
                    Filters
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <FlexibleDatePicker Label="From" @bind-Date="fromDate" />
                    </div>
                    <div class="col-md-3">
                        <FlexibleDatePicker Label="To" @bind-Date="toDate" />
                    </div>
                    @if (isMultiAccount && linkedAccounts.Any())
                    {
                        <div class="col-md-2">
                            <MudSelect T="string" Label="Account" Value="@selectedAccountFilter"
                                       ValueChanged="OnAccountFilterChanged" Variant="Variant.Outlined" Dense="true"
                                       AnchorOrigin="Origin.BottomCenter">
                                <MudSelectItem T="string" Value="@("")">All Accounts</MudSelectItem>
                                @foreach (var account in linkedAccounts)
                                {
                                    <MudSelectItem T="string" Value="@account.CardCode">
                                        @account.CardName @(!string.IsNullOrEmpty(account.Currency) ? $"({account.Currency})" : "")
                                        — @account.CardCode
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </div>
                        <div class="col-md-2 d-flex align-items-center" style="padding-top: 0.5rem;">
                            <MudCheckBox T="bool" @bind-Value="includeClosedInvoices" Label="Include Closed" Color="Color.Dark"
                                         Dense="true" />
                        </div>
                        <div class="col-md-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="w-100" OnClick="GenerateStatement"
                                       Disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                    <span>Loading...</span>
                                }
                                else
                                {
                                    <span>Generate Statement</span>
                                }
                            </MudButton>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-3 d-flex align-items-center" style="padding-top: 0.5rem;">
                            <MudCheckBox T="bool" @bind-Value="includeClosedInvoices" Label="Include Closed Invoices"
                                         Color="Color.Dark" Dense="true" />
                        </div>
                        <div class="col-md-3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="w-100" OnClick="GenerateStatement"
                                       Disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                    <span>Loading...</span>
                                }
                                else
                                {
                                    <span>Generate Statement</span>
                                }
                            </MudButton>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (statement != null)
        {
            <!-- Balance Summary Cards -->
            <div class="row mb-3 g-3 dashboard-stats">
                <div class="col-6 col-xl-3">
                    <div class="card stat-card staff-stat-card bg-secondary">
                        <div class="card-body">
                            <div class="stat-title">Opening Balance</div>
                            <div class="stat-value">@FormatCurrency(statement.OpeningBalance)</div>
                            <div class="stat-sub">@statement.FromDate.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="card stat-card staff-stat-card bg-primary">
                        <div class="card-body">
                            <div class="stat-title">Total Invoices</div>
                            <div class="stat-value">@FormatCurrency(statement.TotalInvoices)</div>
                            <div class="stat-sub">Debits in period</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="card stat-card staff-stat-card bg-success">
                        <div class="card-body">
                            <div class="stat-title">Total Payments</div>
                            <div class="stat-value">@FormatCurrency(statement.TotalPayments)</div>
                            <div class="stat-sub">Credits in period</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="card stat-card staff-stat-card bg-dark">
                        <div class="card-body">
                            <div class="stat-title">Closing Balance</div>
                            <div class="stat-value">@FormatCurrency(statement.ClosingBalance)</div>
                            <div class="stat-sub">@statement.ToDate.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Transaction Details -->
            <div class="card dashboard-panel mb-3">
                <div class="card-header d-flex align-items-center justify-content-between dashboard-panel-header">
                    <h5 class="mb-0 d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"
                             class="panel-icon">
                            <path
                            d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5z" />
                        </svg>
                        Transaction Details
                    </h5>
                    <span class="text-muted small">
                        @statement.FromDate.ToString("MMM dd, yyyy") &mdash; @statement.ToDate.ToString("MMM dd, yyyy")
                    </span>
                </div>
                <div class="card-body p-0">
                    @if (statement.Lines.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle dashboard-table">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Type</th>
                                        <th>Document #</th>
                                        <th>Description</th>
                                        <th class="text-end">Debit</th>
                                        <th class="text-end">Credit</th>
                                        <th class="text-end">Balance</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="table-light">
                                        <td>@statement.FromDate.ToString("MMM dd, yyyy")</td>
                                        <td colspan="3"><strong>Opening Balance</strong></td>
                                        <td class="text-end">-</td>
                                        <td class="text-end">-</td>
                                        <td class="text-end fw-bold">@FormatCurrency(statement.OpeningBalance)</td>
                                    </tr>

                                    @foreach (var line in statement.Lines)
                                    {
                                        <tr>
                                            <td>@line.Date.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                @{
                                                    var badgeClass = line.DocumentType switch
                                                    {
                                                        "Payment" => "bg-success",
                                                        "Credit Note" => "bg-warning text-dark",
                                                        _ => "bg-primary"
                                                    };
                                                }
                                                <span class="badge @badgeClass">@line.DocumentType</span>
                                            </td>
                                            <td>@line.DocumentNumber</td>
                                            <td>
                                                @line.Description
                                                @if (!string.IsNullOrEmpty(line.Reference))
                                                {
                                                    <small class="d-block text-muted">Ref: @line.Reference</small>
                                                }
                                                @if (line.DaysOverdue > 0)
                                                {
                                                    <span class="badge bg-danger ms-1" style="font-size: 0.65rem;">@line.DaysOverdue days
                                                        overdue</span>
                                                    }
                                                </td>
                                                <td class="text-end fw-semibold @(line.Debit > 0 ? "text-dark" : "")">
                                                    @(line.Debit > 0 ? FormatCurrency(line.Debit) : "-")
                                                </td>
                                                <td class="text-end fw-semibold @(line.Credit > 0 ? "text-success" : "")">
                                                    @(line.Credit > 0 ? FormatCurrency(line.Credit) : "-")
                                                </td>
                                                <td class="text-end fw-bold">@FormatCurrency(line.Balance)</td>
                                            </tr>
                                        }

                                        <tr class="table-dark">
                                            <td>@statement.ToDate.ToString("MMM dd, yyyy")</td>
                                            <td colspan="3"><strong>Closing Balance</strong></td>
                                            <td class="text-end fw-bold">@FormatCurrency(statement.TotalInvoices)</td>
                                            <td class="text-end fw-bold">@FormatCurrency(statement.TotalPayments)</td>
                                            <td class="text-end fw-bold">@FormatCurrency(statement.ClosingBalance)</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        }
                    else
                        {
                            <div class="text-center py-5 dashboard-empty">
                                <p class="text-muted mb-0">No transactions found for this period.</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Aging Summary -->
                <div class="card dashboard-panel mb-3">
                    <div class="card-header dashboard-panel-header">
                        <h5 class="mb-0 d-flex align-items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"
                                 class="panel-icon">
                                <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z" />
                                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z" />
                            </svg>
                            Aging Summary
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-6 col-md-4 col-xl-2">
                                <div class="aging-card-v2 aging-current">
                                    <span class="aging-lbl">Current</span>
                                    <span class="aging-val">@FormatCurrency(statement.Aging.Current)</span>
                                </div>
                            </div>
                            <div class="col-6 col-md-4 col-xl-2">
                                <div class="aging-card-v2 aging-30">
                                    <span class="aging-lbl">@statement.Aging.Bucket1Label</span>
                                    <span class="aging-val">@FormatCurrency(statement.Aging.Days1To30)</span>
                                </div>
                            </div>
                            <div class="col-6 col-md-4 col-xl-2">
                                <div class="aging-card-v2 aging-60">
                                    <span class="aging-lbl">@statement.Aging.Bucket2Label</span>
                                    <span class="aging-val">@FormatCurrency(statement.Aging.Days31To60)</span>
                                </div>
                            </div>
                            <div class="col-6 col-md-4 col-xl-2">
                                <div class="aging-card-v2 aging-90">
                                    <span class="aging-lbl">@statement.Aging.Bucket3Label</span>
                                    <span class="aging-val">@FormatCurrency(statement.Aging.Days61To90)</span>
                                </div>
                            </div>
                            <div class="col-6 col-md-4 col-xl-2">
                                <div class="aging-card-v2 aging-over90">
                                    <span class="aging-lbl">@statement.Aging.Bucket4Label</span>
                                    <span class="aging-val">@FormatCurrency(statement.Aging.Over90Days)</span>
                                </div>
                            </div>
                            <div class="col-6 col-md-4 col-xl-2">
                                <div class="aging-card-v2 aging-total">
                                    <span class="aging-lbl">Total</span>
                                    <span class="aging-val">@FormatCurrency(statement.Aging.Total)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="text-center text-muted small py-3">
                <p class="mb-1">Statement generated on @IAuditService.ToCAT(DateTime.UtcNow).ToString("MMMM dd, yyyy 'at' HH:mm") CAT</p>
                <p class="mb-0">If you have any questions about this statement, please contact our accounts department.</p>
            </div>
        }
    </div>

    <style>
        .customer-statements .aging-card-v2 {
            padding: 1rem;
            border-radius: 10px;
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
            text-align: center;
            transition: transform 0.2s;
        }

        .customer-statements .aging-card-v2:hover {
            transform: translateY(-2px);
        }

        .customer-statements .aging-lbl {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            opacity: 0.8;
        }

        .customer-statements .aging-val {
            font-size: 1.1rem;
            font-weight: 700;
        }

        .customer-statements .aging-current {
            background: #f0f4f8;
            border: 1px solid #d0d8e0;
            color: #344054;
        }

        .customer-statements .aging-30 {
            background: #fff8e6;
            border: 1px solid #f0d060;
            color: #7a5c00;
        }

        .customer-statements .aging-60 {
            background: #fff0e0;
            border: 1px solid #f0a030;
            color: #7a4000;
        }

        .customer-statements .aging-90 {
            background: #ffe8e8;
            border: 1px solid #e06060;
            color: #7a1010;
        }

        .customer-statements .aging-over90 {
            background: #2d2d2d;
            border: 1px solid #000;
            color: #fff;
        }

        .customer-statements .aging-total {
            background: var(--bs-primary);
            border: 1px solid var(--bs-primary);
            color: #fff;
        }
    </style>

@code {
    private CustomerPortalSession? portalSession;
    private CustomerInfo? customerInfo;
    private CustomerStatementResponse? statement;
    private DateTime? fromDate = IAuditService.ToCAT(DateTime.UtcNow).AddMonths(-3);
    private DateTime? toDate = IAuditService.ToCAT(DateTime.UtcNow);
    private bool includeClosedInvoices = false;
    private bool isLoading = true;
    private bool isDownloading = false;
    private bool isMultiAccount;
    private string selectedAccountFilter = "";
    private List<LinkedAccountInfo> linkedAccounts = new();

    private CustomerStatementRequest BuildRequest() => new()
    {
        FromDate = fromDate ?? IAuditService.ToCAT(DateTime.UtcNow).AddMonths(-3),
        ToDate = toDate ?? IAuditService.ToCAT(DateTime.UtcNow),
        IncludeClosedInvoices = includeClosedInvoices
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadCustomerInfo();
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadCustomerInfo()
    {
        try
        {
            portalSession = await CustomerSession.GetCurrentSessionAsync();
            customerInfo = portalSession?.Customer;

            if (customerInfo != null)
            {
                isMultiAccount = customerInfo.AccountStructure == "Multi";
                linkedAccounts = portalSession?.LinkedAccounts.ToList() ?? new List<LinkedAccountInfo>();
                selectedAccountFilter = CustomerSession.CanAccessCardCode(portalSession, selectedAccountFilter)
                    ? selectedAccountFilter
                    : string.Empty;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading customer info");
        }
        finally
        {
            if (customerInfo == null)
            {
                isLoading = false;
            }
        }
    }

    private void OnAccountFilterChanged(string value)
    {
        if (!CustomerSession.CanAccessCardCode(portalSession, value))
        {
            Logger.LogWarning("Rejected unauthorized customer statement account filter {CardCode}", value);
            selectedAccountFilter = string.Empty;
            return;
        }

        selectedAccountFilter = value;
    }

    private async Task GenerateStatement()
    {
        if (customerInfo == null) return;

        isLoading = true;

        try
        {
            var request = BuildRequest();
            var cardCode = ResolveSelectedCardCode();
            if (cardCode == null) return;

            statement = await StatementService.GetStatementAsync(cardCode, request);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error generating statement");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DownloadPdf()
    {
        if (customerInfo == null) return;

        isDownloading = true;
        StateHasChanged();

        try
        {
            var request = BuildRequest();
            var cardCode = ResolveSelectedCardCode();
            if (cardCode == null) return;

            var pdfBytes = await StatementService.GenerateStatementPdfAsync(cardCode, request);

            if (pdfBytes == null || pdfBytes.Length == 0)
            {
                Logger.LogError("PDF generation returned empty byte array");
                await JSRuntime.InvokeVoidAsync("alert", "Failed to generate PDF. Please try again.");
                return;
            }

            // Validate PDF magic bytes (%PDF-)
            if (pdfBytes.Length >= 5)
            {
                var header = System.Text.Encoding.ASCII.GetString(pdfBytes, 0, 5);
                if (!header.StartsWith("%PDF-"))
                {
                    var preview = System.Text.Encoding.UTF8.GetString(pdfBytes, 0, Math.Min(100, pdfBytes.Length));
                    Logger.LogError("Invalid PDF response. First bytes: {Preview}", preview);
                    await JSRuntime.InvokeVoidAsync("alert", "Failed to generate PDF. The server returned an invalid response.");
                    return;
                }
            }

            var base64 = Convert.ToBase64String(pdfBytes);
            var fileName = $"Statement_{cardCode}_{IAuditService.ToCAT(DateTime.UtcNow):yyyyMMdd}.pdf";

            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error downloading PDF");
            await JSRuntime.InvokeVoidAsync("alert", $"Error downloading PDF: {ex.Message}");
        }
        finally
        {
            isDownloading = false;
            StateHasChanged();
        }
    }

    private string? ResolveSelectedCardCode()
    {
        if (customerInfo == null)
        {
            return null;
        }

        var cardCode = string.IsNullOrEmpty(selectedAccountFilter) ? customerInfo.CardCode : selectedAccountFilter;
        if (CustomerSession.CanAccessCardCode(portalSession, cardCode))
        {
            return cardCode;
        }

        Logger.LogWarning("Rejected unauthorized customer statement account access {CardCode}", cardCode);
        selectedAccountFilter = string.Empty;
        return null;
    }

    private string FormatCurrency(decimal amount)
    {
        return $"${amount:N2}";
    }
}