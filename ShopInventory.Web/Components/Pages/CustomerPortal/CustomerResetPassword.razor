@page "/customer-portal/reset-password"
@inject ICustomerAuthService CustomerAuthService
@inject WebClientAuditContext ClientAuditContext
@inject ILogger<CustomerResetPassword> Logger
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@layout EmptyLayout

<PageTitle>Choose New Password - Customer Portal</PageTitle>

<div class="customer-recovery-page">
    <div class="customer-recovery-card">
        <img src="/images/kefalos-logo.jpg" alt="Kefalos" class="customer-recovery-logo" />
        <p class="customer-recovery-eyebrow">Customer Portal</p>
        <h1>Choose a new password</h1>
        <p class="text-muted">Use at least eight characters, including uppercase, lowercase, a number, and a special character.</p>

        @if (resetComplete)
        {
            <div class="alert alert-success" role="status">@resultMessage</div>
            <a class="btn btn-dark w-100" href="/customer-portal/login">Sign in</a>
        }
        else if (string.IsNullOrWhiteSpace(Token))
        {
            <div class="alert alert-danger" role="alert">This password reset link is invalid or incomplete.</div>
            <a class="btn btn-dark w-100" href="/customer-portal/forgot-password">Request a new link</a>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(resultMessage))
            {
                <div class="alert alert-danger" role="alert">@resultMessage</div>
            }

            <EditForm Model="model" OnValidSubmit="ResetPassword" FormName="customer-reset-password">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label" for="new-password">New password</label>
                    <InputText id="new-password" class="form-control" type="password" @bind-Value="model.NewPassword" autocomplete="new-password" />
                    <ValidationMessage For="@(() => model.NewPassword)" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="confirm-password">Confirm password</label>
                    <InputText id="confirm-password" class="form-control" type="password" @bind-Value="model.ConfirmPassword" autocomplete="new-password" />
                    <ValidationMessage For="@(() => model.ConfirmPassword)" />
                </div>
                <button class="btn btn-dark w-100" type="submit" disabled="@isSubmitting">
                    @(isSubmitting ? "Updating..." : "Update password")
                </button>
            </EditForm>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private readonly ResetPasswordForm model = new();
    private bool isSubmitting;
    private bool resetComplete;
    private string? resultMessage;

    private async Task ResetPassword()
    {
        if (isSubmitting || string.IsNullOrWhiteSpace(Token))
        {
            return;
        }

        isSubmitting = true;
        resultMessage = null;

        try
        {
            var result = await CustomerAuthService.ResetPasswordAsync(
                Token.Trim(),
                model.NewPassword,
                ClientAuditContext.IpAddress ?? "unknown");

            resultMessage = result.Message;
            resetComplete = result.Success;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Customer password reset failed");
            resultMessage = "We couldn't update the password right now. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class ResetPasswordForm
    {
        [Required(ErrorMessage = "New password is required")]
        [RegularExpression(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$",
            ErrorMessage = "Use 8+ characters with uppercase, lowercase, a number, and a special character")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm the new password")]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
