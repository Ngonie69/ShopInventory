@page "/purchase-invoices/create"
@attribute [Authorize(Roles = "Admin,Manager")]
@rendermode InteractiveServer

<PageTitle>Create A/P Invoice</PageTitle>

<style>
    .cpinv-page { max-width: 1450px; margin: 0 auto; padding: 1.5rem; }
    .cpinv-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .cpinv-header h1 { margin: 0; font-size: 1.75rem; font-weight: 800; color: #162033; }
    .cpinv-header p { margin: .4rem 0 0; color: #607081; max-width: 760px; }
    .cpinv-actions { display: flex; gap: .75rem; flex-wrap: wrap; }

    .cpinv-layout { display: grid; grid-template-columns: minmax(0, 1.7fr) minmax(280px, .9fr); gap: 1rem; }
    .cpinv-panel { background: #fff; border: 1px solid #e6ebf0; border-radius: 20px; overflow: hidden; box-shadow: 0 12px 30px rgba(23, 32, 51, .05); }
    .cpinv-panel-header { padding: 1rem 1.15rem; border-bottom: 1px solid #edf1f5; }
    .cpinv-panel-header h2 { margin: 0; font-size: 1rem; font-weight: 700; color: #162033; }
    .cpinv-panel-body { padding: 1.15rem; }
    .cpinv-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
    .cpinv-field { position: relative; }
    .cpinv-field.full { grid-column: 1 / -1; }
    .cpinv-field label { display: block; font-size: .78rem; font-weight: 700; color: #607081; margin-bottom: .4rem; text-transform: uppercase; letter-spacing: .05em; }
    .cpinv-field input,
    .cpinv-field select,
    .cpinv-field textarea { width: 100%; border: 1px solid #d8e0e8; border-radius: 12px; padding: .75rem .85rem; background: #fbfcfe; color: #162033; }
    .cpinv-field textarea { min-height: 110px; resize: vertical; }
    .cpinv-field .invalid-feedback { display: block; font-size: .8rem; margin-top: .3rem; }
    .cpinv-search-results { position: absolute; z-index: 10; left: 0; right: 0; top: calc(100% + .3rem); background: #fff; border: 1px solid #d8e0e8; border-radius: 14px; max-height: 250px; overflow-y: auto; box-shadow: 0 16px 30px rgba(23, 32, 51, .12); }
    .cpinv-search-option { width: 100%; border: none; background: transparent; text-align: left; padding: .8rem .9rem; border-bottom: 1px solid #edf1f5; color: #162033; }
    .cpinv-search-option:last-child { border-bottom: none; }
    .cpinv-search-option:hover { background: #fff6df; }
    .cpinv-chip { display: inline-flex; align-items: center; gap: .5rem; padding: .45rem .7rem; border-radius: 999px; background: #fff4d3; color: #785d18; font-weight: 700; margin-top: .55rem; }

    .cpinv-line-toolbar { display: flex; justify-content: space-between; align-items: center; gap: .75rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .cpinv-line-table { width: 100%; border-collapse: collapse; }
    .cpinv-line-table th { text-align: left; font-size: .74rem; color: #6b7280; text-transform: uppercase; letter-spacing: .06em; padding: .85rem .75rem; background: #fbfcfe; border-bottom: 1px solid #edf1f5; }
    .cpinv-line-table td { padding: .8rem .75rem; border-bottom: 1px solid #f2f5f8; vertical-align: top; }
    .cpinv-line-table input,
    .cpinv-line-table select { width: 100%; border: 1px solid #d8e0e8; border-radius: 10px; padding: .65rem .7rem; background: #fff; }
    .cpinv-line-total { white-space: nowrap; font-weight: 700; color: #162033; padding-top: 1rem; }

    .cpinv-summary { display: grid; gap: .85rem; }
    .cpinv-summary-card { border: 1px solid #edf1f5; border-radius: 16px; padding: 1rem; background: linear-gradient(180deg, #fffef9 0%, #fff 100%); }
    .cpinv-summary-label { color: #8a6f2f; font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
    .cpinv-summary-value { margin-top: .3rem; font-size: 1.5rem; font-weight: 800; color: #162033; }
    .cpinv-summary-row { display: flex; justify-content: space-between; gap: 1rem; margin-top: .45rem; color: #4a5565; }

    .cpinv-alert { border-radius: 14px; padding: .9rem 1rem; margin-bottom: 1rem; border: 1px solid transparent; }
    .cpinv-alert.error { background: #fff2f2; border-color: #f1c4c4; color: #8f2727; }
    .cpinv-alert.success { background: #edf9f0; border-color: #bee1c4; color: #276738; }
    .cpinv-loading { color: #607081; }

    .dark-theme .cpinv-header h1,
    .dark-theme .cpinv-panel-header h2,
    .dark-theme .cpinv-summary-value,
    .dark-theme .cpinv-line-total,
    .dark-theme .cpinv-search-option { color: #edf2f7; }
    .dark-theme .cpinv-header p,
    .dark-theme .cpinv-field label,
    .dark-theme .cpinv-summary-label,
    .dark-theme .cpinv-summary-row,
    .dark-theme .cpinv-loading,
    .dark-theme .cpinv-line-table th { color: #a9b4c2; }
    .dark-theme .cpinv-panel,
    .dark-theme .cpinv-search-results { background: #16202c; border-color: #2a3645; box-shadow: none; }
    .dark-theme .cpinv-panel-header,
    .dark-theme .cpinv-line-table th,
    .dark-theme .cpinv-line-table td,
    .dark-theme .cpinv-summary-card { border-color: #2a3645; }
    .dark-theme .cpinv-field input,
    .dark-theme .cpinv-field select,
    .dark-theme .cpinv-field textarea,
    .dark-theme .cpinv-line-table input,
    .dark-theme .cpinv-line-table select,
    .dark-theme .cpinv-summary-card { background: #101823; color: #edf2f7; }
    .dark-theme .cpinv-line-table th { background: #101823; }
    .dark-theme .cpinv-search-option:hover { background: #263647; }
    .dark-theme .cpinv-chip { background: #263647; color: #f7d37d; }

    @@media (max-width: 1150px) {
        .cpinv-layout { grid-template-columns: 1fr; }
    }

    @@media (max-width: 720px) {
        .cpinv-page { padding: 1rem; }
        .cpinv-grid { grid-template-columns: 1fr; }
        .cpinv-line-toolbar { align-items: stretch; }
        .cpinv-actions { width: 100%; }
    }
</style>

<div class="cpinv-page">
    <div class="cpinv-header">
        <div>
            <h1>Create A/P Invoice</h1>
            <p>Create a supplier invoice directly against SAP using the same purchasing permissions as the purchase-order workflow.</p>
        </div>
        <div class="cpinv-actions">
            <button class="btn btn-outline-secondary" @onclick="GoBack">Back to Invoices</button>
            <button class="btn btn-warning" @onclick="SubmitAsync" disabled="@(isSubmitting || isLoadingLookups)">
                @(isSubmitting ? "Posting..." : "Post A/P Invoice")
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="cpinv-alert error">@errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="cpinv-alert success">@successMessage</div>
    }

    <div class="cpinv-layout">
        <section class="cpinv-panel">
            <div class="cpinv-panel-header">
                <h2>Document Details</h2>
            </div>
            <div class="cpinv-panel-body">
                @if (isLoadingLookups)
                {
                    <div class="cpinv-loading">Loading suppliers, products, and warehouses...</div>
                }

                <div class="cpinv-grid">
                    <div class="cpinv-field full">
                        <label>Supplier</label>
                        <input type="text"
                               @bind="supplierSearchTerm"
                               @bind:event="oninput"
                               @onfocus="ShowSupplierResults"
                               @onblur="HandleSupplierBlur"
                               class="@(HasError("CardCode") ? "is-invalid" : string.Empty)"
                               placeholder="Search supplier by code or name" />
                        @if (showSupplierResults && FilteredSuppliers.Any())
                        {
                            <div class="cpinv-search-results">
                                @foreach (var supplier in FilteredSuppliers)
                                {
                                    <button type="button" class="cpinv-search-option" @onmousedown="() => SelectSupplier(supplier)">
                                        <div><strong>@supplier.CardCode</strong> - @supplier.CardName</div>
                                        <small>@supplier.Currency</small>
                                    </button>
                                }
                            </div>
                        }
                        @if (selectedSupplier is not null)
                        {
                            <div class="cpinv-chip">
                                @selectedSupplier.DisplayName
                                <button type="button" class="btn btn-sm btn-link p-0 text-decoration-none" @onclick="ClearSupplier">Change</button>
                            </div>
                        }
                        @if (HasError("CardCode"))
                        {
                            <div class="invalid-feedback">@GetError("CardCode")</div>
                        }
                    </div>

                    <div class="cpinv-field">
                        <label>Posting Date</label>
                        <input type="date" @bind-value="purchaseInvoice.DocDate" @bind-value:format="yyyy-MM-dd" />
                    </div>

                    <div class="cpinv-field">
                        <label>Due Date</label>
                        <input type="date" @bind-value="purchaseInvoice.DocDueDate" @bind-value:format="yyyy-MM-dd" />
                    </div>

                    <div class="cpinv-field">
                        <label>Tax Date</label>
                        <input type="date" @bind-value="purchaseInvoice.TaxDate" @bind-value:format="yyyy-MM-dd" />
                    </div>

                    <div class="cpinv-field">
                        <label>Currency</label>
                        <input type="text" @bind="purchaseInvoice.DocCurrency" placeholder="USD" />
                    </div>

                    <div class="cpinv-field">
                        <label>Supplier Ref</label>
                        <input type="text" @bind="purchaseInvoice.NumAtCard" placeholder="Supplier invoice number" />
                    </div>

                    <div class="cpinv-field">
                        <label>Header Discount %</label>
                        <input type="number" min="0" step="0.01" @bind="purchaseInvoice.DiscountPercent" />
                    </div>

                    <div class="cpinv-field full">
                        <label>Comments</label>
                        <textarea @bind="purchaseInvoice.Comments" placeholder="Optional comments for SAP"></textarea>
                    </div>
                </div>
            </div>

            <div class="cpinv-panel-header">
                <h2>Invoice Lines</h2>
            </div>
            <div class="cpinv-panel-body">
                <div class="cpinv-line-toolbar">
                    <div class="cpinv-loading">Use exact SAP item codes. Description auto-fills when a cached product match exists.</div>
                    <button class="btn btn-outline-dark" @onclick="AddLine">Add Line</button>
                </div>

                <div style="overflow-x: auto;">
                    <table class="cpinv-line-table">
                        <thead>
                            <tr>
                                <th style="min-width: 160px;">Item Code</th>
                                <th style="min-width: 220px;">Description</th>
                                <th style="width: 110px;">Qty</th>
                                <th style="width: 130px;">Unit Price</th>
                                <th style="width: 150px;">Warehouse</th>
                                <th style="width: 120px;">Tax Code</th>
                                <th style="width: 120px;">Line Total</th>
                                <th style="width: 60px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var index = 0; index < purchaseInvoice.Lines.Count; index++)
                            {
                                var line = purchaseInvoice.Lines[index];

                                <tr>
                                    <td>
                                        <input type="text" @bind="line.ItemCode" @bind:event="oninput" @onblur="() => SyncProduct(index)" class="@(HasError($"Lines[{index}].ItemCode") ? "is-invalid" : string.Empty)" />
                                        @if (HasError($"Lines[{index}].ItemCode"))
                                        {
                                            <div class="invalid-feedback">@GetError($"Lines[{index}].ItemCode")</div>
                                        }
                                    </td>
                                    <td>
                                        <input type="text" @bind="line.ItemDescription" placeholder="Item description" />
                                    </td>
                                    <td>
                                        <input type="number" min="0.01" step="0.01" @bind="line.Quantity" class="@(HasError($"Lines[{index}].Quantity") ? "is-invalid" : string.Empty)" />
                                        @if (HasError($"Lines[{index}].Quantity"))
                                        {
                                            <div class="invalid-feedback">@GetError($"Lines[{index}].Quantity")</div>
                                        }
                                    </td>
                                    <td>
                                        <input type="number" min="0.01" step="0.01" @bind="line.UnitPrice" class="@(HasError($"Lines[{index}].UnitPrice") ? "is-invalid" : string.Empty)" />
                                        @if (HasError($"Lines[{index}].UnitPrice"))
                                        {
                                            <div class="invalid-feedback">@GetError($"Lines[{index}].UnitPrice")</div>
                                        }
                                    </td>
                                    <td>
                                        <select @bind="line.WarehouseCode">
                                            <option value="">Select warehouse</option>
                                            @foreach (var warehouse in warehouses)
                                            {
                                                <option value="@warehouse.WarehouseCode">@warehouse.DisplayName</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <input type="text" @bind="line.TaxCode" placeholder="A15" />
                                    </td>
                                    <td>
                                        <div class="cpinv-line-total">@CalculateLineTotal(line).ToString("N2")</div>
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLine(index)" disabled="@(purchaseInvoice.Lines.Count == 1)">X</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <aside class="cpinv-panel">
            <div class="cpinv-panel-header">
                <h2>Summary</h2>
            </div>
            <div class="cpinv-panel-body">
                <div class="cpinv-summary">
                    <div class="cpinv-summary-card">
                        <div class="cpinv-summary-label">Estimated Total</div>
                        <div class="cpinv-summary-value">@EstimatedTotal.ToString("N2")</div>
                        <div class="cpinv-summary-row">
                            <span>Lines</span>
                            <strong>@purchaseInvoice.Lines.Count</strong>
                        </div>
                        <div class="cpinv-summary-row">
                            <span>Subtotal</span>
                            <strong>@SubTotal.ToString("N2")</strong>
                        </div>
                        <div class="cpinv-summary-row">
                            <span>Header Discount</span>
                            <strong>@HeaderDiscountAmount.ToString("N2")</strong>
                        </div>
                    </div>

                    <div class="cpinv-summary-card">
                        <div class="cpinv-summary-label">Posting Notes</div>
                        <div class="cpinv-summary-row">
                            <span>Supplier</span>
                            <strong>@(selectedSupplier?.CardCode ?? purchaseInvoice.CardCode)</strong>
                        </div>
                        <div class="cpinv-summary-row">
                            <span>Currency</span>
                            <strong>@(string.IsNullOrWhiteSpace(purchaseInvoice.DocCurrency) ? "Not set" : purchaseInvoice.DocCurrency)</strong>
                        </div>
                        <div class="cpinv-summary-row">
                            <span>Tax</span>
                            <strong>Calculated by SAP</strong>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>