@page "/webhooks"
@inject IWebhookService WebhookService
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<PageTitle>Webhooks - Shop Inventory</PageTitle>

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-broadcast me-2"></i>Webhooks</h2>
            <p class="text-muted mb-0">Receive real-time HTTP notifications when events occur in your system.</p>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="() => showGuideSection = !showGuideSection">
                <i class="bi bi-book me-1"></i>@(showGuideSection ? "Hide" : "Show") Guide
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => ShowCreateModal()">
                <i class="bi bi-plus-circle me-2"></i>Add Webhook
            </MudButton>
        </div>
    </div>

    <!-- Integration Guide Section -->
    @if (showGuideSection)
    {
        <div class="card border-info mb-4">
            <div class="card-header bg-info bg-opacity-10">
                <h5 class="mb-0"><i class="bi bi-book me-2"></i>How to Consume Webhooks</h5>
            </div>
            <div class="card-body">
                <!-- Overview -->
                <div class="mb-4">
                    <h6><i class="bi bi-info-circle me-1"></i> Overview</h6>
                    <p>When an event occurs (e.g. an invoice is created), Shop Inventory sends an <strong>HTTP POST</strong> request to your registered URL with a JSON payload describing the event. Your server must respond with a <code>2xx</code> status code within the configured timeout.</p>
                </div>

                <!-- Payload Format -->
                <div class="mb-4">
                    <h6><i class="bi bi-braces me-1"></i> Payload Format</h6>
                    <p>Every webhook delivery sends a JSON body with this structure:</p>
                    <pre class="bg-dark text-light p-3 rounded"><code>{
  "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
  "event": "invoice.created",
  "timestamp": "2026-03-17T10:30:00Z",
  "data": {
    // Event-specific data (invoice details, payment info, stock levels, etc.)
  }
}</code></pre>
                </div>

                <!-- HTTP Headers -->
                <div class="mb-4">
                    <h6><i class="bi bi-list-columns me-1"></i> HTTP Headers Sent</h6>
                    <table class="table table-sm table-bordered">
                        <thead class="table-light">
                            <tr><th>Header</th><th>Description</th></tr>
                        </thead>
                        <tbody>
                            <tr><td><code>Content-Type</code></td><td><code>application/json</code></td></tr>
                            <tr><td><code>X-Webhook-Event</code></td><td>The event type (e.g., <code>invoice.created</code>)</td></tr>
                            <tr><td><code>X-Webhook-Delivery-Id</code></td><td>Unique ID for this delivery (GUID)</td></tr>
                            <tr><td><code>X-Webhook-Signature</code></td><td>HMAC-SHA256 signature of the body (only if a secret is set)</td></tr>
                        </tbody>
                    </table>
                </div>

                <!-- Signature Verification -->
                <div class="mb-4">
                    <h6><i class="bi bi-shield-lock me-1"></i> Verifying the Signature</h6>
                    <p>If you set a <strong>Secret</strong> when creating the webhook, every delivery includes an <code>X-Webhook-Signature</code> header. To verify it:</p>
                    <ol>
                        <li>Read the raw request body as a UTF-8 string.</li>
                        <li>Compute <code>HMAC-SHA256</code> using your secret as the key.</li>
                        <li>Compare the computed hash with the header value (format: <code>sha256=&lt;hex&gt;</code>).</li>
                    </ol>
                    <p><strong>C# example:</strong></p>
                    <pre class="bg-dark text-light p-3 rounded"><code>using var hmac = new HMACSHA256(Encoding.UTF8.GetBytes(secret));
var hash = hmac.ComputeHash(Encoding.UTF8.GetBytes(rawBody));
var expected = $"sha256={Convert.ToHexString(hash).ToLowerInvariant()}";
bool isValid = expected == request.Headers["X-Webhook-Signature"];</code></pre>

                    <p class="mt-2"><strong>Node.js example:</strong></p>
                    <pre class="bg-dark text-light p-3 rounded"><code>const crypto = require('crypto');
const expected = 'sha256=' + crypto
  .createHmac('sha256', secret)
  .update(rawBody, 'utf8')
  .digest('hex');
const isValid = expected === req.headers['x-webhook-signature'];</code></pre>
                </div>

                <!-- Retry Behaviour -->
                <div class="mb-4">
                    <h6><i class="bi bi-arrow-repeat me-1"></i> Retry Behaviour</h6>
                    <ul class="mb-0">
                        <li>If your server returns a non-2xx code or times out, Shop Inventory retries with <strong>exponential backoff</strong> (2, 4, 8, 16... seconds).</li>
                        <li>The retry count is configurable per webhook (1-10 attempts, default 3).</li>
                        <li>Timeout is configurable per webhook (5-60 seconds, default 30).</li>
                    </ul>
                </div>

                <!-- Sample Endpoint -->
                <div class="mb-4">
                    <h6><i class="bi bi-code-slash me-1"></i> Example Receiver Endpoint (C#)</h6>
                    <pre class="bg-dark text-light p-3 rounded"><code>[HttpPost("webhook")]
public async Task&lt;IActionResult&gt; ReceiveWebhook()
{
    using var reader = new StreamReader(Request.Body);
    var body = await reader.ReadToEndAsync();

    // 1. Verify signature (recommended)
    var signature = Request.Headers["X-Webhook-Signature"].FirstOrDefault();
    if (!VerifySignature(body, signature, _mySecret))
        return Unauthorized();

    // 2. Parse the event
    var payload = JsonSerializer.Deserialize&lt;WebhookPayload&gt;(body);
    var eventType = Request.Headers["X-Webhook-Event"].FirstOrDefault();

    // 3. Handle the event
    switch (eventType)
    {
        case "invoice.created":
            // Process new invoice...
            break;
        case "stock.low":
            // Trigger reorder...
            break;
    }

    return Ok(); // Return 2xx to acknowledge
}</code></pre>
                    <p class="mt-2"><strong>Node.js / Express example:</strong></p>
                    <pre class="bg-dark text-light p-3 rounded"><code>app.post('/webhook', express.raw({ type: 'application/json' }), (req, res) => {
  const body = req.body.toString('utf8');

  // 1. Verify signature
  if (!verifySignature(body, req.headers['x-webhook-signature'], SECRET))
    return res.status(401).send('Invalid signature');

  // 2. Parse & handle event
  const payload = JSON.parse(body);
  console.log(`Event: ${payload.event}`, payload.data);

  res.status(200).send('OK');
});</code></pre>
                </div>

                <!-- Quick Tips -->
                <div class="alert alert-warning mb-0">
                    <strong><i class="bi bi-lightbulb me-1"></i> Tips:</strong>
                    <ul class="mb-0 mt-1">
                        <li>Always return <code>200 OK</code> quickly. Process heavy work asynchronously (e.g., via a queue).</li>
                        <li>Use the <strong>Test</strong> button below to send a test payload to your endpoint before going live.</li>
                        <li>Check the <strong>Delivery Logs</strong> to troubleshoot failures and see response codes.</li>
                        <li>Set a <strong>Secret</strong> to verify payloads are genuinely from Shop Inventory.</li>
                        <li>Your endpoint <strong>must use HTTPS</strong> in production.</li>
                    </ul>
                </div>
            </div>
        </div>
    }

    <!-- Webhooks List -->
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Loading webhooks...</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-exclamation-triangle me-2 fs-5"></i>
            <div>@errorMessage</div>
        </div>
    }
    else if (webhooks?.Any() == true)
    {
        <div class="row">
            @foreach (var webhook in webhooks)
            {
                <div class="col-lg-6 mb-4">
                    <div class="card h-100 @(webhook.IsActive ? "border-start border-success border-3" : "border-start border-secondary border-3 opacity-75")">
                        <div class="card-header d-flex justify-content-between align-items-center py-3">
                            <div class="d-flex align-items-center gap-2">
                                @if (webhook.IsActive)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-pause-circle me-1"></i>Paused</span>
                                }
                                <h6 class="mb-0 fw-bold">@webhook.Name</h6>
                            </div>
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       checked="@webhook.IsActive"
                                       @onchange="() => ToggleWebhook(webhook)" />
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <small class="text-muted d-block mb-1">Endpoint</small>
                                <code class="d-block text-break bg-light p-2 rounded small">@webhook.Url</code>
                            </div>

                            <div class="mb-3">
                                <small class="text-muted d-block mb-1">Subscribed Events</small>
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var evt in webhook.Events)
                                    {
                                        <span class="badge bg-info bg-opacity-75">@evt</span>
                                    }
                                </div>
                            </div>

                            <div class="row text-center mb-2">
                                <div class="col-3">
                                    <div class="border rounded p-2">
                                        <span class="d-block fs-6 fw-bold text-success">@webhook.SuccessCount</span>
                                        <small class="text-muted">Delivered</small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="border rounded p-2">
                                        <span class="d-block fs-6 fw-bold text-danger">@webhook.FailureCount</span>
                                        <small class="text-muted">Failed</small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="border rounded p-2">
                                        <span class="d-block fs-6 fw-bold">@webhook.RetryCount</span>
                                        <small class="text-muted">Max Retries</small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="border rounded p-2">
                                        <span class="d-block fs-6 fw-bold">@(webhook.TimeoutSeconds)s</span>
                                        <small class="text-muted">Timeout</small>
                                    </div>
                                </div>
                            </div>

                            @if (webhook.LastTriggeredAt.HasValue)
                            {
                                <small class="text-muted">
                                    <i class="bi bi-clock me-1"></i>Last triggered: @webhook.LastTriggeredAt.Value.ToString("dd MMM yyyy HH:mm")
                                </small>
                            }
                            else
                            {
                                <small class="text-muted"><i class="bi bi-clock me-1"></i>Never triggered</small>
                            }
                        </div>
                        <div class="card-footer bg-transparent py-2">
                            <div class="d-flex gap-2">
                                <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                                           OnClick="() => TestWebhook(webhook.Id)" Disabled="@(!webhook.IsActive || isTesting)">
                                    @if (isTesting && testingWebhookId == webhook.Id)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi bi-send me-1"></i>Test
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                                           OnClick="() => ShowDeliveries(webhook)">
                                    <i class="bi bi-list-ul me-1"></i>Logs
                                </MudButton>
                                <div class="ms-auto d-flex gap-2">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                               OnClick="() => EditWebhook(webhook)">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                               OnClick="() => ConfirmDelete(webhook)">
                                        <i class="bi bi-trash"></i>
                                    </MudButton>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Test Result Toast -->
        @if (testResult != null)
        {
            <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050;">
                <div class="toast show @(testResult.Value ? "border-success" : "border-danger")" role="alert">
                    <div class="toast-header">
                        @if (testResult.Value)
                        {
                            <i class="bi bi-check-circle text-success me-2"></i>
                            <strong class="me-auto">Test Successful</strong>
                        }
                        else
                        {
                            <i class="bi bi-x-circle text-danger me-2"></i>
                            <strong class="me-auto">Test Failed</strong>
                        }
                        <button type="button" class="btn-close" @onclick="() => testResult = null"></button>
                    </div>
                    <div class="toast-body">
                        @(testResult.Value ? "Your endpoint responded with 2xx. Webhook is working correctly!" : "The test delivery failed. Check Delivery Logs for details.")
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="card text-center py-5">
            <div class="card-body">
                <i class="bi bi-broadcast display-4 text-muted"></i>
                <h5 class="mt-3">No Webhooks Configured</h5>
                <p class="text-muted">Add a webhook to start receiving real-time event notifications via HTTP.</p>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => ShowCreateModal()">
                    <i class="bi bi-plus-circle me-2"></i>Add Your First Webhook
                </MudButton>
            </div>
        </div>
    }

    <!-- Available Events Reference -->
    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-lightning me-2"></i>Available Event Types</h5>
            <span class="badge bg-primary">@WebhookEvents.All.Count events</span>
        </div>
        <div class="card-body">
            <div class="row">
                @foreach (var group in WebhookEvents.Grouped)
                {
                    <div class="col-lg-4 col-md-6 mb-3">
                        <h6 class="fw-bold text-primary border-bottom pb-1">
                            @GetCategoryIcon(group.Key) @group.Key
                        </h6>
                        @foreach (var (eventType, description) in group.Value)
                        {
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <code class="small">@eventType</code>
                                <small class="text-muted ms-2">@description</small>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Create/Edit Webhook Modal -->
@if (showCreateModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-broadcast me-2"></i>@(editingWebhook != null ? "Edit" : "Add") Webhook
                    </h5>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseCreateModal" Size="Size.Small" />
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(saveError))
                    {
                        <div class="alert alert-danger mb-3">
                            <i class="bi bi-exclamation-triangle me-1"></i>@saveError
                        </div>
                    }
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="newWebhook.Name"
                                   placeholder="e.g., ERP Integration" />
                            <small class="text-muted">A friendly name to identify this webhook.</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Endpoint URL <span class="text-danger">*</span></label>
                            <input type="url" class="form-control" @bind="newWebhook.Url"
                                   placeholder="https://your-server.com/webhook" />
                            <small class="text-muted">Must be HTTPS in production.</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Secret <span class="text-muted fw-normal">(recommended)</span></label>
                            <input type="password" class="form-control" @bind="newWebhook.Secret"
                                   placeholder="Your HMAC secret key" />
                            <small class="text-muted">Used to sign payloads with HMAC-SHA256 for verification.</small>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Retries</label>
                            <input type="number" class="form-control" @bind="newWebhook.RetryCount" min="1" max="10" />
                            <small class="text-muted">1-10 attempts</small>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Timeout</label>
                            <input type="number" class="form-control" @bind="newWebhook.TimeoutSeconds" min="5" max="60" />
                            <small class="text-muted">5-60 seconds</small>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Events <span class="text-danger">*</span></label>
                            <div class="d-flex gap-2 mb-2">
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="SelectAllEvents">Select All</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearAllEvents">Clear All</button>
                                <span class="ms-auto text-muted small align-self-center">@selectedEvents.Count selected</span>
                            </div>
                            <div class="row">
                                @foreach (var group in WebhookEvents.Grouped)
                                {
                                    <div class="col-md-4 col-sm-6 mb-3">
                                        <div class="border rounded p-2">
                                            <strong class="small text-primary">@GetCategoryIcon(group.Key) @group.Key</strong>
                                            @foreach (var (eventType, description) in group.Value)
                                            {
                                                <div class="form-check mt-1">
                                                    <input class="form-check-input" type="checkbox" id="evt-@eventType"
                                                           checked="@selectedEvents.Contains(eventType)"
                                                           @onchange="(e) => ToggleEvent(eventType, (bool)(e.Value ?? false))" />
                                                    <label class="form-check-label small" for="evt-@eventType" title="@description">
                                                        <code>@eventType</code>
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Default"
                               OnClick="CloseCreateModal">Cancel</MudButton>
                    <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="SaveWebhook" Disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @(editingWebhook != null ? "Update" : "Create") Webhook
                    </MudButton>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delivery Logs Modal -->
@if (showDeliveriesModal && selectedWebhook != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-list-ul me-2"></i>Delivery Logs: @selectedWebhook.Name
                    </h5>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => showDeliveriesModal = false"
                                   Size="Size.Small" />
                </div>
                <div class="modal-body">
                    @if (deliveries?.Any() == true)
                    {
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Event</th>
                                    <th>Status</th>
                                    <th>Response</th>
                                    <th>Duration</th>
                                    <th>Retry</th>
                                    <th>Error</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var delivery in deliveries)
                                {
                                    <tr class="@(delivery.IsSuccess ? "" : "table-danger")">
                                        <td>@delivery.CreatedAt.ToString("dd MMM HH:mm:ss")</td>
                                        <td><code>@delivery.EventType</code></td>
                                        <td>
                                            @if (delivery.IsSuccess)
                                            {
                                                <i class="bi bi-check-circle text-success"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-x-circle text-danger"></i>
                                            }
                                        </td>
                                        <td>
                                            @if (delivery.ResponseStatusCode.HasValue)
                                            {
                                                <span class="badge @(delivery.ResponseStatusCode < 300 ? "bg-success" : "bg-danger")">
                                                    @delivery.ResponseStatusCode
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>@delivery.DurationMs ms</td>
                                        <td>@delivery.RetryAttempt</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(delivery.ErrorMessage))
                                            {
                                                <span class="text-danger small" title="@delivery.ErrorMessage">
                                                    @TruncateUrl(delivery.ErrorMessage, 30)
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">No delivery logs found.</p>
                    }
                </div>
                <div class="modal-footer">
                    <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Default"
                               OnClick="() => showDeliveriesModal = false">Close</MudButton>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (showDeleteModal && webhookToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Delete Webhook</h5>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => showDeleteModal = false"
                                   Size="Size.Small" />
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this webhook?</p>
                    <p><strong>@webhookToDelete.Name</strong></p>
                    <p class="text-muted small">@webhookToDelete.Url</p>
                </div>
                <div class="modal-footer">
                    <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Default"
                               OnClick="() => showDeleteModal = false">Cancel</MudButton>
                    <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Error"
                               OnClick="DeleteWebhook">Delete</MudButton>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<WebhookDto>? webhooks;
    private List<WebhookDeliveryDto>? deliveries;
    private WebhookDto? selectedWebhook;
    private WebhookDto? editingWebhook;
    private WebhookDto? webhookToDelete;
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isTesting = false;
    private int? testingWebhookId;
    private bool? testResult;
    private bool showCreateModal = false;
    private bool showDeliveriesModal = false;
    private bool showDeleteModal = false;
    private bool showGuideSection = false;
    private string? errorMessage;
    private string? saveError;

    private CreateWebhookRequest newWebhook = new();
    private List<string> availableEvents = WebhookEvents.All;
    private HashSet<string> selectedEvents = new();

    protected override async Task OnInitializedAsync()
    {
        availableEvents = await WebhookService.GetAvailableEventsAsync();
        await LoadWebhooks();
    }

    private async Task LoadWebhooks()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await WebhookService.GetAllWebhooksAsync();
            if (response != null)
            {
                webhooks = response.Webhooks;
            }
            else
            {
                errorMessage = "Failed to load webhooks. Please check your connection and try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading webhooks: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateModal()
    {
        editingWebhook = null;
        newWebhook = new CreateWebhookRequest { RetryCount = 3, TimeoutSeconds = 30 };
        selectedEvents.Clear();
        saveError = null;
        showCreateModal = true;
    }

    private void EditWebhook(WebhookDto webhook)
    {
        editingWebhook = webhook;
        newWebhook = new CreateWebhookRequest
        {
            Name = webhook.Name,
            Url = webhook.Url,
            Events = webhook.Events,
            RetryCount = webhook.RetryCount,
            TimeoutSeconds = webhook.TimeoutSeconds
        };
        selectedEvents = new HashSet<string>(webhook.Events);
        saveError = null;
        showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        showCreateModal = false;
        editingWebhook = null;
        newWebhook = new();
        selectedEvents.Clear();
        saveError = null;
    }

    private void ToggleEvent(string evt, bool isChecked)
    {
        if (isChecked)
            selectedEvents.Add(evt);
        else
            selectedEvents.Remove(evt);
    }

    private void SelectAllEvents()
    {
        selectedEvents = new HashSet<string>(availableEvents);
    }

    private void ClearAllEvents()
    {
        selectedEvents.Clear();
    }

    private async Task SaveWebhook()
    {
        saveError = null;

        if (string.IsNullOrWhiteSpace(newWebhook.Name))
        {
            saveError = "Please enter a webhook name.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newWebhook.Url))
        {
            saveError = "Please enter an endpoint URL.";
            return;
        }
        if (!selectedEvents.Any())
        {
            saveError = "Please select at least one event.";
            return;
        }

        newWebhook.Events = selectedEvents.ToList();
        isSaving = true;

        try
        {
            if (editingWebhook != null)
            {
                var updateRequest = new UpdateWebhookRequest
                {
                    Name = newWebhook.Name,
                    Url = newWebhook.Url,
                    Secret = newWebhook.Secret,
                    Events = newWebhook.Events,
                    RetryCount = newWebhook.RetryCount,
                    TimeoutSeconds = newWebhook.TimeoutSeconds
                };
                var result = await WebhookService.UpdateWebhookAsync(editingWebhook.Id, updateRequest);
                if (result != null)
                {
                    CloseCreateModal();
                    await LoadWebhooks();
                }
                else
                {
                    saveError = "Failed to update webhook. Please try again.";
                }
            }
            else
            {
                var result = await WebhookService.CreateWebhookAsync(newWebhook);
                if (result != null)
                {
                    CloseCreateModal();
                    await LoadWebhooks();
                }
                else
                {
                    saveError = "Failed to create webhook. Please check your inputs and try again.";
                }
            }
        }
        catch (Exception ex)
        {
            saveError = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ToggleWebhook(WebhookDto webhook)
    {
        await WebhookService.ToggleWebhookAsync(webhook.Id, !webhook.IsActive);
        await LoadWebhooks();
    }

    private async Task TestWebhook(int id)
    {
        isTesting = true;
        testingWebhookId = id;
        testResult = null;
        try
        {
            var success = await WebhookService.TestWebhookAsync(id);
            testResult = success;
            await LoadWebhooks();

            // Auto-dismiss toast
            _ = Task.Run(async () =>
            {
                await Task.Delay(5000);
                await InvokeAsync(() =>
                {
                    testResult = null;
                    StateHasChanged();
                });
            });
        }
        finally
        {
            isTesting = false;
            testingWebhookId = null;
        }
    }

    private async Task ShowDeliveries(WebhookDto webhook)
    {
        selectedWebhook = webhook;
        var response = await WebhookService.GetDeliveriesAsync(webhook.Id);
        deliveries = response?.Deliveries;
        showDeliveriesModal = true;
    }

    private void ConfirmDelete(WebhookDto webhook)
    {
        webhookToDelete = webhook;
        showDeleteModal = true;
    }

    private async Task DeleteWebhook()
    {
        if (webhookToDelete == null) return;

        var success = await WebhookService.DeleteWebhookAsync(webhookToDelete.Id);
        if (success)
        {
            showDeleteModal = false;
            webhookToDelete = null;
            await LoadWebhooks();
        }
    }

    private static string GetCategoryIcon(string category) => category switch
    {
        "Invoice" => "\U0001f4c4",
        "Payment" => "\U0001f4b3",
        "Stock" => "\U0001f4e6",
        "Inventory" => "\U0001f4cb",
        "Customer" => "\U0001f465",
        "SAP" => "\U0001f504",
        _ => "\U0001f4cc"
    };

    private string TruncateUrl(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "-";
        return text.Length <= maxLength ? text : text.Substring(0, maxLength) + "...";
    }
}