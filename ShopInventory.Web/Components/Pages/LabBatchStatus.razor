@page "/lab/batch-status"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Lab")]
@rendermode InteractiveServer

<PageTitle>Lab Batch Status - Shop Inventory</PageTitle>

<div class="lbs-page">
    <div class="lbs-shell">
        <section class="lbs-hero">
            <div>
                <span class="lbs-kicker">Lab Operations</span>
                <h1>Batch Status Control</h1>
                <p>Search by batch number, review the live stock rows that still have quantity on hand, and change the
                    SAP batch status from one dedicated page.</p>
                </div>

                <div class="lbs-search-card">
                    <label for="lab-batch-search">Batch Number</label>
                    <div class="lbs-search-row">
                        <input id="lab-batch-search" class="lbs-input" @bind="searchTerm" @bind:event="oninput"
                               @onkeydown="HandleSearchKeyDown" placeholder="Type a batch number" />
                        <button type="button" class="lbs-search-btn" disabled="@isSearching" @onclick="SearchAsync">
                            @(isSearching ? "Searching..." : "Search")
                        </button>
                    </div>
                    <p class="lbs-helper">Results are limited to the first 100 in-stock matches.</p>
                </div>
            </section>

            @if (isSearching)
            {
                <div class="lbs-state-card">
                    <div class="lbs-spinner"></div>
                    <span>Searching batches...</span>
                </div>
            }
            else if (hasSearched && results.Count == 0)
            {
                <section class="lbs-state-card lbs-empty-card">
                    <h2>No Matching Batches</h2>
                    <p>No in-stock batches matched <strong>@lastSearchTerm</strong>.</p>
                </section>
            }
            else if (results.Count > 0)
            {
                <section class="lbs-results-card">
                    <div class="lbs-results-header">
                        <div>
                            <h2>Results</h2>
                            <p>@results.Count row(s) for <strong>@lastSearchTerm</strong></p>
                            <p class="lbs-helper">Rows are returned per SAP stock record, so the same visible batch can appear
                                more than once when it exists in multiple warehouses or internal entries.</p>
                            </div>
                        </div>

                        <div class="lbs-table-wrap">
                            <table class="lbs-table">
                                <thead>
                                    <tr>
                                        <th>Batch</th>
                                        <th>Item</th>
                                        <th>Warehouse</th>
                                        <th>Qty</th>
                                        <th>Status</th>
                                        <th>Change To</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in results)
                                    {
                                        <tr>
                                            <td>
                                                <div class="lbs-primary">@item.BatchNumber</div>
                                                @if (!string.IsNullOrWhiteSpace(item.ExpiryDate))
                                                {
                                                    <div class="lbs-secondary">Expiry @FormatDate(item.ExpiryDate)</div>
                                                }
                                            </td>
                                            <td>
                                                <div class="lbs-primary">@item.ItemCode</div>
                                                @if (!string.IsNullOrWhiteSpace(item.ItemName))
                                                {
                                                    <div class="lbs-secondary">@item.ItemName</div>
                                                }
                                            </td>
                                            <td>@item.WarehouseCode</td>
                                            <td>@item.Quantity</td>
                                            <td>
                                                <span class="@GetStatusChipClass(item.Status)">@GetStatusLabel(item.Status)</span>
                                            </td>
                                            <td>
                                                <select class="lbs-select" @bind="item.PendingStatus">
                                                    @foreach (var status in StatusOptions)
                                                    {
                                                        <option value="@status">@status</option>
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <button type="button" class="lbs-update-btn"
                                                        disabled="@(IsUpdating(item.BatchEntryId) || string.Equals(item.PendingStatus, item.Status, StringComparison.Ordinal))"
                                                        @onclick="() => UpdateStatusAsync(item)">
                                                    @(IsUpdating(item.BatchEntryId) ? "Updating..." : "Update")
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                }
            </div>
        </div>

        <style>
            .lbs-page {
                min-height: 100vh;
                padding: 1.5rem;
                background:
                    radial-gradient(circle at top right, rgba(14, 165, 233, 0.12), transparent 28%),
                    linear-gradient(180deg, #f8fafc 0%, #ecfdf5 100%);
            }

            .lbs-shell {
                max-width: 1280px;
                margin: 0 auto;
                display: flex;
                flex-direction: column;
                gap: 1.25rem;
            }

            .lbs-hero,
            .lbs-state-card,
            .lbs-results-card {
                background: rgba(255, 255, 255, 0.94);
                border: 1px solid rgba(148, 163, 184, 0.2);
                border-radius: 24px;
                box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
            }

            .lbs-hero {
                padding: 1.6rem 1.75rem;
                display: grid;
                grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
                gap: 1.25rem;
                align-items: start;
            }

            .lbs-kicker {
                display: inline-flex;
                align-items: center;
                gap: .35rem;
                padding: .38rem .72rem;
                border-radius: 999px;
                background: rgba(8, 145, 178, 0.12);
                color: #0f766e;
                font-size: .82rem;
                font-weight: 700;
                letter-spacing: .04em;
                text-transform: uppercase;
            }

            .lbs-hero h1,
            .lbs-results-header h2,
            .lbs-empty-card h2 {
                margin: .8rem 0 .4rem;
                color: #0f172a;
            }

            .lbs-hero p,
            .lbs-results-header p,
            .lbs-helper,
            .lbs-secondary,
            .lbs-empty-card p {
                color: #475569;
            }

            .lbs-search-card {
                padding: 1rem;
                border-radius: 20px;
                background: linear-gradient(180deg, rgba(241, 245, 249, 0.85) 0%, rgba(255, 255, 255, 0.98) 100%);
                border: 1px solid rgba(148, 163, 184, 0.18);
            }

            .lbs-search-card label {
                display: block;
                margin-bottom: .45rem;
                font-weight: 600;
                color: #1e293b;
            }

            .lbs-search-row {
                display: flex;
                gap: .75rem;
            }

            .lbs-input,
            .lbs-select {
                width: 100%;
                border-radius: 14px;
                border: 1px solid rgba(148, 163, 184, 0.35);
                background: #fff;
                color: #0f172a;
                padding: .78rem .95rem;
            }

            .lbs-input:focus,
            .lbs-select:focus {
                outline: none;
                border-color: rgba(8, 145, 178, 0.55);
                box-shadow: 0 0 0 4px rgba(8, 145, 178, 0.12);
            }

            .lbs-search-btn,
            .lbs-update-btn {
                border: none;
                border-radius: 14px;
                font-weight: 700;
                transition: transform .16s ease, opacity .16s ease;
            }

            .lbs-search-btn {
                min-width: 118px;
                background: linear-gradient(135deg, #0891b2 0%, #0f766e 100%);
                color: #fff;
                padding: 0 1rem;
            }

            .lbs-update-btn {
                width: 100%;
                background: #0f172a;
                color: #fff;
                padding: .72rem .95rem;
            }

            .lbs-search-btn:disabled,
            .lbs-update-btn:disabled {
                opacity: .6;
                cursor: not-allowed;
                transform: none;
            }

            .lbs-search-btn:not(:disabled):hover,
            .lbs-update-btn:not(:disabled):hover {
                transform: translateY(-1px);
            }

            .lbs-state-card,
            .lbs-empty-card {
                padding: 1.5rem 1.75rem;
                display: flex;
                align-items: center;
                gap: .85rem;
            }

            .lbs-empty-card {
                flex-direction: column;
                align-items: flex-start;
            }

            .lbs-spinner {
                width: 1.2rem;
                height: 1.2rem;
                border-radius: 50%;
                border: 3px solid rgba(15, 23, 42, 0.12);
                border-top-color: #0f766e;
                animation: lbs-spin .8s linear infinite;
            }

            .lbs-results-card {
                padding: 1.4rem 1.5rem;
            }

            .lbs-results-header {
                margin-bottom: 1rem;
            }

            .lbs-table-wrap {
                overflow-x: auto;
            }

            .lbs-table {
                width: 100%;
                border-collapse: separate;
                border-spacing: 0;
                min-width: 920px;
            }

            .lbs-table th,
            .lbs-table td {
                padding: 1rem;
                border-bottom: 1px solid rgba(226, 232, 240, 0.9);
                text-align: left;
                vertical-align: top;
            }

            .lbs-table th {
                font-size: .8rem;
                font-weight: 800;
                letter-spacing: .04em;
                text-transform: uppercase;
                color: #64748b;
            }

            .lbs-primary {
                font-weight: 700;
                color: #0f172a;
            }

            .lbs-secondary {
                margin-top: .18rem;
                font-size: .9rem;
            }

            .lbs-chip {
                display: inline-flex;
                align-items: center;
                padding: .42rem .7rem;
                border-radius: 999px;
                font-size: .82rem;
                font-weight: 700;
            }

            .lbs-chip-released {
                background: rgba(34, 197, 94, 0.14);
                color: #166534;
            }

            .lbs-chip-locked {
                background: rgba(249, 115, 22, 0.14);
                color: #9a3412;
            }

            .lbs-chip-notaccessible {
                background: rgba(220, 38, 38, 0.14);
                color: #991b1b;
            }

            .lbs-chip-unknown {
                background: rgba(100, 116, 139, 0.14);
                color: #475569;
            }

            @@keyframes lbs-spin {
                to {
                    transform: rotate(360deg);
                }
            }

            @@media (max-width: 980px) {
                .lbs-hero {
                    grid-template-columns: 1fr;
                }
            }

            @@media (max-width: 640px) {
                .lbs-page {
                    padding: 1rem;
                }

                .lbs-search-row {
                    flex-direction: column;
                }

                .lbs-search-btn {
                    width: 100%;
                    min-height: 48px;
                }
            }
        </style>