        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--mud-palette-text-secondary);
        border-bottom: 2px solid var(--mud-palette-lines-default);
        padding: 12px 16px;
    }
    .ts-table tbody td { padding: 12px 16px; vertical-align: middle; font-size: 0.88rem; }
    .ts-row-active { background: rgba(76, 175, 80, 0.06); }

    .ts-customer-name { font-weight: 600; }
    .ts-customer-code { font-size: 0.75rem; color: var(--mud-palette-text-secondary); }
    .ts-cell-time { white-space: nowrap; }
    .ts-cell-duration { font-weight: 600; }
    .ts-cell-notes { max-width: 200px; }
    .ts-note { font-size: 0.8rem; color: var(--mud-palette-text-secondary); }

    .ts-merchandiser-name { font-weight: 600; }
    .ts-merchandiser-username { font-size: 0.75rem; color: var(--mud-palette-text-secondary); }
