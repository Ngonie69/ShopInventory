    .ts-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px; }
    .ts-title { font-size: 1.6rem; font-weight: 700; display: flex; align-items: center; gap: 10px; margin: 0; }
    .ts-title-icon { font-size: 28px !important; }
    .ts-subtitle { font-size: 0.85rem; color: var(--mud-palette-text-secondary); margin: 4px 0 0; }

    .ts-filters {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 24px;
    }
    .ts-filter-label { font-size: 0.8rem; font-weight: 600; margin-bottom: 4px; display: block; color: var(--mud-palette-text-secondary); }

    .ts-summary-row {
        display: grid;
