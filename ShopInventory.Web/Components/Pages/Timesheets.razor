        background: var(--mud-palette-surface);
        border-radius: 8px;
        border: 1px solid var(--mud-palette-lines-default);
    }

    .ts-badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .ts-badge-completed { background: #E8F5E9; color: #2E7D32; }
    .ts-badge-active { background: #FFF3E0; color: #E65100; }

    .ts-pagination {
        display: flex;
