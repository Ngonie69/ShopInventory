    .ts-summary-label { font-size: 0.8rem; color: var(--mud-palette-text-secondary); margin-top: 4px; }

    .ts-loading { display: flex; align-items: center; gap: 12px; justify-content: center; padding: 40px; }
    .ts-empty { text-align: center; padding: 60px 20px; color: var(--mud-palette-text-secondary); }

    .ts-table-wrapper { overflow-x: auto; border-radius: 12px; border: 1px solid var(--mud-palette-lines-default); }
