@page "/timesheets"
@attribute [Authorize(Roles = "Admin,Manager,SalesRep,Merchandiser")]
@rendermode InteractiveServer
@inject ITimesheetService TimesheetService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>Timesheets</PageTitle>

<div class="ts-container">
    <!-- Header -->
    <div class="ts-header">
        <div class="ts-header-left">
            <h2 class="ts-title">
                <MudIcon Icon="@Icons.Material.Filled.Schedule" Class="ts-title-icon" />
                Timesheets
            </h2>
            <p class="ts-subtitle">View merchandiser check-in and check-out activity</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="ts-filters">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="ts-filter-label">From Date</label>
                <MudDatePicker @bind-Date="fromDate" DateFormat="dd/MM/yyyy" Variant="Variant.Outlined"
                               Margin="Margin.Dense" Class="ts-date-picker" />
            </div>
            <div class="col-md-3">
                <label class="ts-filter-label">To Date</label>
                <MudDatePicker @bind-Date="toDate" DateFormat="dd/MM/yyyy" Variant="Variant.Outlined"
                               Margin="Margin.Dense" Class="ts-date-picker" />
            </div>
            @if (isAdmin)
            {
                <div class="col-md-3">
                    <label class="ts-filter-label">Username</label>
                    <MudTextField @bind-Value="filterUsername" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Placeholder="Filter by username..." Class="ts-text-filter" />
                </div>
            }
            <div class="col-md-3">
                <label class="ts-filter-label">Customer Code</label>
                <MudTextField @bind-Value="filterCustomerCode" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Placeholder="Filter by customer..." Class="ts-text-filter" />
            </div>
            <div class="col-md-12 d-flex gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Dark" OnClick="LoadTimesheets"
                           StartIcon="@Icons.Material.Filled.Search" Disabled="isLoading">
                    @if (isLoading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" /> }
                    Search
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ClearFilters"
                           StartIcon="@Icons.Material.Filled.Clear">
                    Clear
                </MudButton>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    @if (timesheetData is not null)
    {
        <div class="ts-summary-row">
            <div class="ts-summary-card">
                <div class="ts-summary-value">@timesheetData.TotalCount</div>
                <div class="ts-summary-label">Total Visits</div>
            </div>
            <div class="ts-summary-card">
                <div class="ts-summary-value">@completedCount</div>
                <div class="ts-summary-label">Completed</div>
            </div>
            <div class="ts-summary-card">
                <div class="ts-summary-value">@activeCount</div>
                <div class="ts-summary-label">Active</div>
            </div>
            <div class="ts-summary-card">
                <div class="ts-summary-value">@FormatHours(totalMinutes)</div>
                <div class="ts-summary-label">Total Time</div>
            </div>
        </div>
    }

    <!-- Loading -->
    @if (isLoading)
    {
        <div class="ts-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Dark" />
            <span>Loading timesheets...</span>
        </div>
    }
    else if (loadError is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">@loadError</MudAlert>
    }
    else if (timesheetData?.Entries.Count == 0)
    {
        <div class="ts-empty">
            <MudIcon Icon="@Icons.Material.Filled.EventBusy" Style="font-size: 48px; opacity: 0.3;" />
            <p>No timesheet entries found for the selected criteria.</p>
        </div>
    }
    else if (timesheetData is not null)
    {
        <!-- Timesheet Table -->
        <div class="ts-table-wrapper">
            <table class="table table-hover ts-table">
                <thead>
                    <tr>
                        <th>Merchandiser</th>
                        <th>Customer</th>
                        <th>Check In</th>
                        <th>Check Out</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th>Location</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in timesheetData.Entries)
                    {
                        <tr class="@(entry.CheckOutTime.HasValue ? "" : "ts-row-active")">
                            <td class="ts-cell-user">
                                <div class="ts-merchandiser-name">@(!string.IsNullOrWhiteSpace(entry.FullName) ? entry.FullName : entry.Username)</div>
                                <div class="ts-merchandiser-username">@entry.Username</div>
                            </td>
                            <td>
                                <div class="ts-customer-name">@entry.CustomerName</div>
                                <div class="ts-customer-code">@entry.CustomerCode</div>
                            </td>
                            <td class="ts-cell-time">@ToCat(entry.CheckInTime).ToString("dd MMM yyyy HH:mm")</td>
                            <td class="ts-cell-time">
                                @if (entry.CheckOutTime.HasValue)
                                {
                                    @ToCat(entry.CheckOutTime.Value).ToString("dd MMM yyyy HH:mm")
                                }
                                else
                                {
                                    <span class="ts-badge-active">In Progress</span>
                                }
                            </td>
                            <td class="ts-cell-duration">@entry.DurationDisplay</td>
                            <td>
                                <span class="ts-badge @(entry.CheckOutTime.HasValue ? "ts-badge-completed" : "ts-badge-active")">
                                    @entry.StatusDisplay
                                </span>
                            </td>
                            <td class="ts-cell-location">
                                @if (entry.CheckInLatitude.HasValue && entry.CheckInLongitude.HasValue)
                                {
                                    <MudTooltip Text="View check-in location">
                                        <MudIconButton Icon="@Icons.Material.Filled.LocationOn" Color="Color.Info" Size="Size.Small"
                                                       OnClick="@(() => ShowMap(entry, true))" />
                                    </MudTooltip>
                                }
                                @if (entry.CheckOutLatitude.HasValue && entry.CheckOutLongitude.HasValue)
                                {
                                    <MudTooltip Text="View check-out location">
                                        <MudIconButton Icon="@Icons.Material.Filled.LocationOff" Color="Color.Warning" Size="Size.Small"
                                                       OnClick="@(() => ShowMap(entry, false))" />
                                    </MudTooltip>
                                }
                                @if (!entry.CheckInLatitude.HasValue && !entry.CheckOutLatitude.HasValue)
                                {
                                    <span class="ts-no-location">—</span>
                                }
                            </td>
                            <td class="ts-cell-notes">
                                @if (!string.IsNullOrWhiteSpace(entry.CheckInNotes))
                                {
                                    <div class="ts-note"><strong>In:</strong> @entry.CheckInNotes</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(entry.CheckOutNotes))
                                {
                                    <div class="ts-note"><strong>Out:</strong> @entry.CheckOutNotes</div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <div class="ts-pagination">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="currentPage <= 1"
                           OnClick="() => GoToPage(currentPage - 1)">Previous</MudButton>
                <span class="ts-page-info">Page @currentPage of @totalPages (@timesheetData.TotalCount entries)</span>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="currentPage >= totalPages"
                           OnClick="() => GoToPage(currentPage + 1)">Next</MudButton>
            </div>
        }
    }
</div>

<!-- Map Dialog -->
<MudDialog @bind-Visible="showMapDialog" Options="mapDialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Map" />
            <span>@mapDialogTitle</span>
        </div>
    </TitleContent>
    <DialogContent>
        @if (mapLatitude.HasValue && mapLongitude.HasValue)
        {
            <div class="ts-map-container">
                <iframe
                    width="100%"
                    height="400"
                    style="border:0; border-radius: 8px;"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    src="@GetMapUrl(mapLatitude.Value, mapLongitude.Value)">
                </iframe>
                <div class="ts-map-coords">
                    <MudIcon Icon="@Icons.Material.Filled.MyLocation" Size="Size.Small" />
                    <span>@mapLatitude.Value.ToString("F6"), @mapLongitude.Value.ToString("F6")</span>
                    <MudTooltip Text="Open in Google Maps">
                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Info"
                                       Href="@GetGoogleMapsLink(mapLatitude.Value, mapLongitude.Value)" Target="_blank" />
                    </MudTooltip>
                </div>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => showMapDialog = false)" Variant="Variant.Text">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private ShopInventory.Web.Models.TimesheetListResponse? timesheetData;
    private bool isLoading;
    private string? loadError;
    private bool isAdmin;
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalPages;

    private DateTime? fromDate;
    private DateTime? toDate;
    private string? filterUsername;
    private string? filterCustomerCode;

    private int completedCount;
    private int activeCount;
    private double totalMinutes;

    // Map dialog state
    private bool showMapDialog;
    private string mapDialogTitle = "";
    private double? mapLatitude;
    private double? mapLongitude;
    private readonly DialogOptions mapDialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAdmin = user.IsInRole("Admin") || user.IsInRole("Manager") || user.IsInRole("SalesRep");

        fromDate = DateTime.Today.AddDays(-30);
        toDate = DateTime.Today;

        await LoadTimesheets();
    }

    private async Task LoadTimesheets()
    {
        isLoading = true;
        loadError = null;
        StateHasChanged();

        try
        {
            // Adjust toDate to end of day for inclusive filtering
            var adjustedToDate = toDate?.AddDays(1).AddSeconds(-1);

            timesheetData = await TimesheetService.GetTimesheetsAsync(
                currentPage, pageSize,
                username: isAdmin ? filterUsername : null,
                customerCode: filterCustomerCode,
                fromDate: fromDate,
                toDate: adjustedToDate);

            if (timesheetData is not null)
            {
                totalPages = (int)Math.Ceiling((double)timesheetData.TotalCount / pageSize);
                completedCount = timesheetData.Entries.Count(e => e.CheckOutTime.HasValue);
                activeCount = timesheetData.Entries.Count(e => !e.CheckOutTime.HasValue);
                totalMinutes = timesheetData.Entries
                    .Where(e => e.DurationMinutes.HasValue)
                    .Sum(e => e.DurationMinutes!.Value);
            }
        }
        catch (Exception ex)
        {
            loadError = $"Failed to load timesheets: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadTimesheets();
    }

    private async Task ClearFilters()
    {
        fromDate = DateTime.Today.AddDays(-30);
        toDate = DateTime.Today;
        filterUsername = null;
        filterCustomerCode = null;
        currentPage = 1;
        await LoadTimesheets();
    }

    private static DateTime ToCat(DateTime utc) => utc.AddHours(2);

    private static string FormatHours(double minutes)
    {
        var hours = (int)(minutes / 60);
        var mins = (int)(minutes % 60);
        return $"{hours}h {mins}m";
    }

    private void ShowMap(ShopInventory.Web.Models.TimesheetEntryDto entry, bool isCheckIn)
    {
        var name = !string.IsNullOrWhiteSpace(entry.FullName) ? entry.FullName : entry.Username;
        if (isCheckIn)
        {
            mapDialogTitle = $"Check-In Location — {name} @ {entry.CustomerName}";
            mapLatitude = entry.CheckInLatitude;
            mapLongitude = entry.CheckInLongitude;
        }
        else
        {
            mapDialogTitle = $"Check-Out Location — {name} @ {entry.CustomerName}";
            mapLatitude = entry.CheckOutLatitude;
            mapLongitude = entry.CheckOutLongitude;
        }
        showMapDialog = true;
    }

    private static string GetMapUrl(double lat, double lon)
    {
        return $"https://www.openstreetmap.org/export/embed.html?bbox={lon - 0.005},{lat - 0.005},{lon + 0.005},{lat + 0.005}&layer=mapnik&marker={lat},{lon}";
    }

    private static string GetGoogleMapsLink(double lat, double lon)
    {
        return $"https://www.google.com/maps?q={lat},{lon}";
    }
}

<style>
