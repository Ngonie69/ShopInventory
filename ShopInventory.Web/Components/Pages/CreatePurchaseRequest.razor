@page "/purchase-requests/create"
@attribute [Authorize(Roles = "Admin,Manager")]
@rendermode InteractiveServer

<PageTitle>Create Purchase Request</PageTitle>

<datalist id="purchase-request-products">
    @foreach (var product in products)
    {
        <option value="@product.ItemCode">@product.ItemName</option>
    }
</datalist>

<datalist id="purchase-request-warehouses">
    @foreach (var warehouse in warehouses)
    {
        <option value="@warehouse.WarehouseCode">@warehouse.WarehouseName</option>
    }
</datalist>

<div class="pdoc-create-page is-request">
    <div class="container-fluid pdoc-create-container">
        <div class="pdoc-create-breadcrumb">
            <a href="/purchase-requests">Purchase Requests</a>
            <span class="sep">/</span>
            <span>Create New</span>
        </div>

        <div class="pdoc-create-header">
            <div class="pdoc-create-header-left">
                <div class="pdoc-create-header-icon"><i class="bi bi-journal-plus"></i></div>
                <div>
                    <h2>Create Purchase Request</h2>
                    <p>Raise a new internal purchase request in SAP and capture the requested items, destination warehouses, and expected need dates.</p>
                </div>
            </div>
            <div class="pdoc-create-header-actions">
                <button type="button" class="btn-doc-back" @onclick="GoBack" disabled="@isSubmitting">
                    <i class="bi bi-arrow-left"></i>
                    <span>Back</span>
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="pdoc-create-alert error">@errorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="pdoc-create-alert success">@successMessage</div>
        }

        <div class="pdoc-create-card">
            <div class="pdoc-create-card-title"><i class="bi bi-info-circle"></i> Request Details</div>
            @if (isLoadingLookups)
            {
                <div class="pdoc-create-loading">
                    <span class="spinner-border spinner-border-sm"></span>
                    <span>Loading products and warehouses...</span>
                </div>
            }
            <div class="pdoc-create-form-grid three-cols">
                <div class="pdoc-create-field">
                    <label>Posting Date</label>
                    <input type="date" @bind-value="purchaseRequest.DocDate" @bind-value:format="yyyy-MM-dd" />
                </div>
                <div class="pdoc-create-field">
                    <label>Required Date</label>
                    <input type="date" @bind-value="purchaseRequest.RequriedDate" @bind-value:format="yyyy-MM-dd" />
                </div>
                <div class="pdoc-create-field">
                    <label>Requester ID</label>
                    <input type="number" @bind-value="purchaseRequest.Requester" />
                </div>
                <div class="pdoc-create-field full">
                    <label>Comments</label>
                    <textarea rows="3" @bind="purchaseRequest.Comments" placeholder="Optional request notes or sourcing context"></textarea>
                </div>
            </div>
        </div>

        <div class="pdoc-create-card">
            <div class="pdoc-create-section-header">
                <div class="pdoc-create-section-title"><i class="bi bi-list-ul"></i> Requested Lines</div>
                <button type="button" class="btn-doc-add" @onclick="AddLine">
                    <i class="bi bi-plus-lg"></i>
                    <span>Add Line</span>
                </button>
            </div>

            @if (HasError("Lines"))
            {
                <div class="pdoc-create-inline-error" style="margin-bottom:.75rem;">@GetError("Lines")</div>
            }

            <div class="pdoc-create-table-wrap">
                <table class="pdoc-create-table">
                    <thead>
                        <tr>
                            <th>Item Code</th>
                            <th>Description</th>
                            <th class="cell-compact">Quantity</th>
                            <th>Warehouse</th>
                            <th class="cell-compact">Required Date</th>
                            <th>Vendor</th>
                            <th class="cell-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var index = 0; index < purchaseRequest.Lines.Count; index++)
                        {
                            var lineIndex = index;
                            var line = purchaseRequest.Lines[lineIndex];
                            <tr>
                                <td>
                                    <input class="@(HasError($"Lines[{lineIndex}].ItemCode") ? "has-error" : string.Empty)"
                                           list="purchase-request-products"
                                           @bind="line.ItemCode"
                                           @onblur="() => SyncProduct(lineIndex)"
                                           placeholder="Item code" />
                                    @if (HasError($"Lines[{lineIndex}].ItemCode"))
                                    {
                                        <div class="pdoc-create-inline-error">@GetError($"Lines[{lineIndex}].ItemCode")</div>
                                    }
                                </td>
                                <td>
                                    <input @bind="line.ItemDescription" placeholder="Description" />
                                </td>
                                <td class="cell-compact">
                                    <input class="@(HasError($"Lines[{lineIndex}].Quantity") ? "has-error" : string.Empty)"
                                           type="number"
                                           step="0.01"
                                           @bind-value="line.Quantity" />
                                    @if (HasError($"Lines[{lineIndex}].Quantity"))
                                    {
                                        <div class="pdoc-create-inline-error">@GetError($"Lines[{lineIndex}].Quantity")</div>
                                    }
                                </td>
                                <td>
                                    <input list="purchase-request-warehouses" @bind="line.WarehouseCode" placeholder="Warehouse" />
                                </td>
                                <td class="cell-compact">
                                    <input type="date" @bind-value="line.RequiredDate" @bind-value:format="yyyy-MM-dd" />
                                </td>
                                <td>
                                    <input @bind="line.LineVendor" placeholder="Preferred vendor" />
                                </td>
                                <td class="cell-actions">
                                    <button type="button"
                                            class="btn-doc-remove"
                                            @onclick="() => RemoveLine(lineIndex)"
                                            disabled="@(purchaseRequest.Lines.Count == 1)">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="pdoc-create-total-banner">
                <div class="pdoc-create-total-item">
                    <span>Line Count</span>
                    <strong>@purchaseRequest.Lines.Count</strong>
                </div>
                <div class="pdoc-create-total-item">
                    <span>Total Quantity</span>
                    <strong>@TotalQuantity.ToString("N2")</strong>
                </div>
            </div>
            <p class="pdoc-create-summary-note" style="margin: .85rem 0 0;">
                Each line can carry its own required date and preferred vendor, but blank required dates will inherit the header date when you add a new line.
            </p>
        </div>

        <div class="pdoc-create-footer">
            <button type="button" class="btn-doc-secondary" @onclick="GoBack">Cancel</button>
            <button type="button" class="btn-doc-submit" @onclick="SubmitAsync" disabled="@(isSubmitting || isLoadingLookups)">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                }
                <span>Create Purchase Request</span>
            </button>
        </div>
    </div>
</div>