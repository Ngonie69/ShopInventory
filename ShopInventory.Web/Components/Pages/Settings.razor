    // Warehouse autocomplete methods
    private Task<IEnumerable<CachedWarehouse>> SearchWarehousesAsync(string searchText, CancellationToken cancellationToken)
    {
        var active = cachedWarehouses.Where(w => w.IsActive);
        if (string.IsNullOrWhiteSpace(searchText))
            return Task.FromResult(active.Take(20));

        var term = searchText.ToLower();
        return Task.FromResult(active.Where(w =>
            (w.WarehouseCode?.ToLower().Contains(term) ?? false) ||
            (w.WarehouseName?.ToLower().Contains(term) ?? false))
            .Take(20));
    }

    private void OnWarehouseSelected(CachedWarehouse? warehouse)
    {
        selectedWarehouse = warehouse;
        var code = warehouse?.WarehouseCode ?? "";
        OnSettingChanged(SettingKeys.DefaultWarehouse, code);
    }

    // Database Reset Methods
    private void ShowResetConfirmation()
    {
        resetConfirmationText = string.Empty;
        resetMessage = null;
        showResetConfirmation = true;
    }

    private void CancelReset()
    {
        showResetConfirmation = false;
        resetConfirmationText = string.Empty;
    }

    private async Task ConfirmResetDatabase()
    {
        if (resetConfirmationText != "RESET")
            return;

        isResettingDatabase = true;
        showResetConfirmation = false;
        resetMessage = null;
        StateHasChanged();

        try
        {
            var (success, message) = await BackupService.ResetDatabaseAsync();
            resetSuccess = success;
            resetMessage = success
            ? "Database has been reset successfully. All transactional data has been deleted."
                                                                : message;

            if (success)
            {
                // Clear cached master data from web database so stale test data doesn't persist
                await ClearWebCachesAfterDatabaseResetAsync();

                // Invalidate in-memory caches so fresh data is fetched on next access
                CacheService.InvalidateCache();

                await LogAudit(AuditActions.ResetDatabase, "Database reset completed - all transactional and cached data deleted");
            }
        }
        catch (Exception ex)
        {
            resetSuccess = false;
            resetMessage = $"Database reset failed: {ex.Message}";
        }
        finally
        {
            isResettingDatabase = false;
            resetConfirmationText = string.Empty;
            StateHasChanged();
        }
    }

    private async Task ClearWebCachesAfterDatabaseResetAsync()
    {
        await using var dbContext = await DbContextFactory.CreateDbContextAsync();

        await ExecuteDeleteIfTableExistsAsync(dbContext.CachedProducts, "CachedProducts");
        await ExecuteDeleteIfTableExistsAsync(dbContext.CachedPrices, "CachedPrices");
        await ExecuteDeleteIfTableExistsAsync(dbContext.CachedBusinessPartners, "CachedBusinessPartners");
        await ExecuteDeleteIfTableExistsAsync(dbContext.CachedWarehouses, "CachedWarehouses");
        await ExecuteDeleteIfTableExistsAsync(dbContext.CachedWarehouseStocks, "CachedWarehouseStocks");
        await ExecuteDeleteIfTableExistsAsync(dbContext.CachedGLAccounts, "CachedGLAccounts");
        await ExecuteDeleteIfTableExistsAsync(dbContext.CachedCostCentres, "CachedCostCentres");
        await ExecuteDeleteIfTableExistsAsync(dbContext.CachedIncomingPayments, "CachedIncomingPayments");
        await ExecuteDeleteIfTableExistsAsync(dbContext.CachedInventoryTransfers, "CachedInventoryTransfers");
        await ExecuteDeleteIfTableExistsAsync(dbContext.CacheSyncInfo, "CacheSyncInfo");
    }

    private async Task ExecuteDeleteIfTableExistsAsync<TEntity>(IQueryable<TEntity> query, string tableName)
        where TEntity : class
    {
        try
        {
            await query.ExecuteDeleteAsync();
        }
        catch (Npgsql.PostgresException ex) when (ex.SqlState == Npgsql.PostgresErrorCodes.UndefinedTable)
        {
            Logger.LogWarning(
                ex,
                "Skipped cache clear for missing web table {TableName} during database reset",
                tableName);
        }
    }
