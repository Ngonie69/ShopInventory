    private void OnScheduleFrequencyChanged(ChangeEventArgs e)
    {
        if (editingSchedule is null)
        {
            return;
        }

        editingSchedule.Frequency = e.Value?.ToString() ?? nameof(PodReportEmailFrequency.Weekly);
        var frequency = PodReportEmailService.ParseFrequency(editingSchedule.Frequency);
        switch (frequency)
        {
            case PodReportEmailFrequency.Weekly:
                editingSchedule.DayOfWeek ??= (int)DayOfWeek.Monday;
                break;
            case PodReportEmailFrequency.Monthly:
                editingSchedule.DayOfMonth ??= 1;
                break;
            case PodReportEmailFrequency.EveryNDays:
                editingSchedule.IntervalDays ??= 1;
                break;
        }
    }

    private async Task SaveScheduleAsync()
    {
        if (editingSchedule is null)
        {
            return;
        }

        scheduleValidationError = null;
        var frequency = PodReportEmailService.ParseFrequency(editingSchedule.Frequency);

        if (string.IsNullOrWhiteSpace(editingSchedule.Name))
        {
            scheduleValidationError = "Enter a name for this schedule.";
            return;
        }
        if (ParseEmailRecipients(editingSchedule.ToRecipients).Count == 0)
        {
            scheduleValidationError = "Add at least one To recipient.";
            return;
        }

        // Normalize the cadence fields for the chosen frequency.
        editingSchedule.Name = editingSchedule.Name.Trim();
        editingSchedule.SendMinuteOfDay = scheduleSendTime.HasValue
            ? PodScheduleTime.FromTimeOfDay(scheduleSendTime.Value)
            : PodScheduleTime.NormalizeMinuteOfDay(editingSchedule.SendMinuteOfDay);
        editingSchedule.DayOfWeek = frequency == PodReportEmailFrequency.Weekly
            ? Math.Clamp(editingSchedule.DayOfWeek ?? (int)DayOfWeek.Monday, 0, 6)
            : null;
        editingSchedule.DayOfMonth = frequency == PodReportEmailFrequency.Monthly
            ? Math.Clamp(editingSchedule.DayOfMonth ?? 1, 1, 31)
            : null;
        editingSchedule.IntervalDays = frequency == PodReportEmailFrequency.EveryNDays
            ? Math.Max(1, editingSchedule.IntervalDays ?? 1)
            : null;

        isSavingSchedule = true;
        try
        {
            var isNew = editingSchedule.Id == 0;
            await PodReportEmailScheduleService.SaveScheduleAsync(editingSchedule, currentUsername);
            await LoadSchedulesAsync();
            await LogAudit(
                AuditActions.UpdateSettings,
                $"{(isNew ? "Created" : "Updated")} POD report email schedule '{editingSchedule.Name}'.");
            showScheduleModal = false;
            editingSchedule = null;
            podEmailMessageSuccess = true;
            podEmailMessage = isNew ? "Schedule created." : "Schedule updated.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save POD report email schedule.");
            scheduleValidationError = $"Failed to save schedule: {ex.Message}";
        }
        finally
        {
            isSavingSchedule = false;
        }
    }

    /// <summary>
    /// The master automation switch persists immediately, like the per-schedule toggles — it isn't
    /// part of the page's "Save Changes" batch, so a reload can't silently drop it.
    /// </summary>
    private async Task OnPodScheduledSendingChangedAsync(ChangeEventArgs e)
    {
        var enabled = e.Value is bool flag ? flag : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;
        var previous = GetBoolValue(SettingKeys.PodReportEmailsEnabled);
        var value = enabled.ToString().ToLowerInvariant();

        isSavingPodAutomation = true;
        ApplyPodScheduledSendingValue(value);

        try
        {
            await SettingsService.SaveSettingAsync(SettingKeys.PodReportEmailsEnabled, value, currentUsername);
            await AppSettingsProvider.ReloadAsync();
            await LogAudit(
                AuditActions.UpdateSettings,
                $"{(enabled ? "Enabled" : "Paused")} scheduled POD report email sending.");
            podEmailMessageSuccess = true;
            podEmailMessage = enabled
                ? "Scheduled sending is on."
                : "Scheduled sending paused. Existing schedules are kept.";
        }
        catch (Exception ex)
        {
            ApplyPodScheduledSendingValue(previous.ToString().ToLowerInvariant());
            Logger.LogError(ex, "Failed to update the POD report scheduled sending master switch.");
            podEmailMessageSuccess = false;
            podEmailMessage = $"Failed to update scheduled sending: {ex.Message}";
        }
        finally
        {
            isSavingPodAutomation = false;
        }
    }

    // Keep both the edit buffer and the loaded settings in sync so a later "Save Changes"
    // batch doesn't write back a stale value.
    private void ApplyPodScheduledSendingValue(string value)
    {
        editedValues[SettingKeys.PodReportEmailsEnabled] = value;
        var setting = allSettings.FirstOrDefault(s => s.Key == SettingKeys.PodReportEmailsEnabled);
        if (setting is not null)
        {
            setting.Value = value;
        }
    }

