@page "/settings"
@using ShopInventory.Web.Data
@using ShopInventory.Web.Services
@using ShopInventory.Web.Models
@using Microsoft.EntityFrameworkCore
@inject IAppSettingsService SettingsService
@inject IAuditService AuditService
@inject IMasterDataCacheService CacheService
@inject IAuthService AuthService
@inject IBackupService BackupService
@inject IPrinterService PrinterService
@inject IDbContextFactory<WebAppDbContext> DbContextFactory
@inject ILogger<Settings> Logger
@inject AuthenticationStateProvider AuthStateProvider
@inject IAppSettingsProvider AppSettingsProvider
@inject IJSRuntime JS
@inject IThemeService ThemeService
@inject ISAPSettingsService SAPSettingsService
@inject IMobileVersionPolicySettingsService MobileVersionPolicySettingsService
@inject IPodReportEmailService PodEmailService
@inject IPodReportEmailScheduleService PodReportEmailScheduleService
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<PageTitle>Settings - Shop Inventory</PageTitle>

<div class="settings-page">
    <!-- Page Header -->
    <div class="settings-header">
        <div class="settings-header-left">
            <div class="settings-icon-box">
                <i class="bi bi-gear-wide-connected"></i>
            </div>
            <div>
                <h2 class="settings-title">Settings</h2>
                <p class="settings-subtitle">Manage application configuration, data sync, and user accounts</p>
            </div>
        </div>
        <MudButton Class="btn-settings-save" OnClick="SaveSettings" Disabled="@(!hasChanges || isSaving)">
            @if (isSaving)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            }
            else
            {
                <i class="bi bi-check2-circle me-1"></i>
            }
            Save Changes
        </MudButton>
    </div>

    <!-- Alerts -->
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="settings-alert settings-alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@successMessage</span>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                           OnClick="() => successMessage = null" Size="Size.Small" />
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="settings-alert settings-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@errorMessage</span>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                           OnClick="() => errorMessage = null" Size="Size.Small" />
        </div>
    }

    @if (isLoading)
    {
        <div class="settings-loading">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Loading settings...</p>
        </div>
    }
    else
    {
        <div class="settings-layout">
            <!-- Sidebar Navigation -->
            <nav class="settings-sidebar">
                <div class="sidebar-group">
                    <span class="sidebar-group-label">Configuration</span>
                    @foreach (var category in categories.Where(c => new[] { SettingCategories.General, SettingCategories.Display, SettingCategories.Printing }.Contains(c)))
                    {
                        <button class="@($"sidebar-item {(selectedCategory == category ? "active" : "")}")"
                                @onclick="() => SelectCategory(category)">
                            <i class="bi @GetCategoryIcon(category)"></i>
                            <span>@category</span>
                        </button>
                    }
                </div>
                <div class="sidebar-group">
                    <span class="sidebar-group-label">Integration</span>
                    <button class="@($"sidebar-item {(selectedCategory == PaymentsCategory ? "active" : "")}")"
                            @onclick="() => SelectCategory(PaymentsCategory)">
                        <i class="bi bi-cash-coin"></i>
                        <span>Payments</span>
                    </button>
                    <button class="@($"sidebar-item {(selectedCategory == SAPCategory ? "active" : "")}")"
                            @onclick="() => SelectCategory(SAPCategory)">
                        <i class="bi bi-cloud-arrow-up"></i>
                        <span>SAP Connection</span>
                    </button>
                    <button class="@($"sidebar-item {(selectedCategory == MobileAppCategory ? "active" : "")}")"
                            @onclick="() => SelectCategory(MobileAppCategory)">
                        <i class="bi bi-phone"></i>
                        <span>Mobile App</span>
                    </button>
                    @foreach (var category in categories.Where(c => new[] { SettingCategories.API }.Contains(c)))
                    {
                        <button class="@($"sidebar-item {(selectedCategory == category ? "active" : "")}")"
                                @onclick="() => SelectCategory(category)">
                            <i class="bi @GetCategoryIcon(category)"></i>
                            <span>@category</span>
                        </button>
                    }
                    <button class="@($"sidebar-item {(selectedCategory == SettingCategories.EmailReports ? "active" : "")}")"
                            @onclick="() => SelectCategory(SettingCategories.EmailReports)">
                        <i class="bi bi-envelope-paper"></i>
                        <span>Email Reports</span>
                    </button>
                </div>
                <div class="sidebar-group">
                    <span class="sidebar-group-label">System</span>
                    @foreach (var category in categories.Where(c => new[] { SettingCategories.Audit, SettingCategories.Security }.Contains(c)))
                    {
                        <button class="@($"sidebar-item {(selectedCategory == category ? "active" : "")}")"
                                @onclick="() => SelectCategory(category)">
                            <i class="bi @GetCategoryIcon(category)"></i>
                            <span>@category</span>
                        </button>
                    }
                    <button class="@($"sidebar-item {(selectedCategory == DataManagementCategory ? "active" : "")}")"
                            @onclick="() => SelectCategory(DataManagementCategory)">
                        <i class="bi bi-arrow-repeat"></i>
                        <span>Data Sync</span>
                    </button>
                    <button class="@($"sidebar-item sidebar-item-danger {(selectedCategory == DangerZoneCategory ? "active" : "")}")"
                            @onclick="() => SelectCategory(DangerZoneCategory)">
                        <i class="bi bi-exclamation-triangle"></i>
                        <span>Danger Zone</span>
                    </button>
                </div>
            </nav>

            <!-- Content -->
            <div class="settings-content">

            @if (selectedCategory == PaymentsCategory)
            {
                <!-- Payments Settings Section -->
                <div class="settings-section" style="animation-delay: 0.05s;">
                    <div class="section-header">
                        <div class="section-icon" style="background: linear-gradient(135deg, #059669, #10b981);">
                            <i class="bi bi-cash-coin" style="color: white;"></i>
                        </div>
                        <div>
                            <h5 class="section-title">Incoming Payment Settings</h5>
                            <p class="section-desc">Configure the default G/L account and allowed business partners for incoming
                                payments.</p>
                            </div>
                        </div>

                        <div class="setting-items">
                            <!-- G/L Account Setting -->
                            <div class="setting-item">
                                <div class="setting-info">
                                    <label class="setting-label">
                                        <i class="bi bi-journal-text me-1"></i>Default G/L Account for Incoming Payments
                                    </label>
                                    <span class="setting-desc">
                                        Select a <strong>cash or bank</strong> G/L account for posting incoming payments.
                                        Do not select expense, revenue, or controlling accounts.
                                    </span>
                                </div>
                                <div class="setting-control" style="min-width: 350px;">
                                    <MudAutocomplete T="CachedGLAccount" Label="Search G/L Account" Value="selectedGLAccount"
                                                     ValueChanged="OnGLAccountSelected" SearchFunc="@SearchGLAccountsAsync"
                                                     ToStringFunc="@(gl => gl == null ? string.Empty : $"{gl.Code} - {gl.Name}")"
                                                     ShowProgressIndicator="true" MinCharacters="0" Immediate="true" ResetValueOnEmptyText="true"
                                                     CoerceText="false" CoerceValue="false" Variant="Variant.Outlined" Dense="true"
                                                     Margin="Margin.Dense" Clearable="true" DebounceInterval="200" MaxItems="20"
                                                     AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary">
                                        <ItemTemplate Context="gl">
                                            <MudText>
                                                <b>@gl.Code</b> — @gl.Name
                                                <MudText Typo="Typo.caption" Class="ms-2">(@FormatAccountType(gl.AccountType))
                                                </MudText>
                                            </MudText>
                                        </ItemTemplate>
                                        <NoItemsTemplate>
                                            <MudText Class="px-3 py-2">
                                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="me-1" />
                                                No G/L accounts found
                                            </MudText>
                                        </NoItemsTemplate>
                                    </MudAutocomplete>
                                    @if (!cachedGLAccounts.Any())
                                    {
                                        <small class="gl-warning" style="font-size:.75rem; display:block; margin-top:.25rem;">
                                            <i class="bi bi-exclamation-triangle me-1"></i>No G/L accounts found. Please sync G/L
                                            accounts from the Data Sync tab first.
                                        </small>
                                    }
                                </div>
                            </div>

                            <!-- Default Payment Method -->
                            <div class="setting-item">
                                <div class="setting-info">
                                    <label class="setting-label">
                                        <i class="bi bi-wallet2 me-1"></i>Default Payment Method
                                    </label>
                                    <span class="setting-desc">
                                        Select the payment method that will be used for incoming payments. Users will not be able to
                                        change this.
                                    </span>
                                </div>
                                <div class="setting-control" style="min-width: 220px;">
                                    <select class="field-input field-input-sm" value="@defaultPaymentMethod"
                                            @onchange="OnDefaultPaymentMethodChanged">
                                        <option value="cash">Cash</option>
                                        <option value="transfer">Transfer</option>
                                        <option value="check">Check</option>
                                        <option value="credit">Credit Card</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Allowed Business Partners -->
                            <div class="setting-item" style="flex-direction: column; align-items: stretch;">
                                <div class="setting-info" style="margin-bottom: 1rem;">
                                    <label class="setting-label">
                                        <i class="bi bi-people me-1"></i>Allowed Business Partners for Incoming Payments
                                    </label>
                                    <span class="setting-desc">
                                        Select which business partners users can choose when creating an incoming payment.
                                        If none are selected, <strong>all</strong> business partners will be available.
                                    </span>
                                </div>

                                <!-- Search and filter -->
                                <div class="bp-search-wrap">
                                    <div class="bp-search-field">
                                        <input type="text" class="field-input field-input-sm"
                                               placeholder="Search business partners..." @oninput="OnPaymentBPSearchInput"
                                               value="@paymentBPSearchTerm" style="max-width:100%;" />
                                        @if (!string.IsNullOrEmpty(paymentBPSearchTerm))
                                        {
                                            <button type="button" class="bp-search-clear"
                                                    @onclick="() => { paymentBPSearchTerm = string.Empty; }">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                    </div>
                                    <span class="bp-count">
                                        <strong>@allowedPaymentBPs.Count</strong> selected out of @cachedBusinessPartners.Count
                                    </span>
                                </div>

                                <!-- Selected BPs chips -->
                                @if (allowedPaymentBPs.Any())
                                {
                                    <div class="bp-selected-chips">
                                        @foreach (var bpCode in allowedPaymentBPs)
                                        {
                                            var bp = cachedBusinessPartners.FirstOrDefault(b => b.CardCode == bpCode);
                                            <span class="bp-chip">
                                                @bpCode @(bp != null ? $"- {bp.CardName}" : "")
                                                <button type="button" class="bp-chip-close"
                                                        @onclick="() => TogglePaymentBP(bpCode)">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </span>
                                        }
                                    </div>
                                }

                                <!-- BP list with checkboxes -->
                                <div class="bp-list-container">
                                    @{
                                        var filteredBPs = string.IsNullOrWhiteSpace(paymentBPSearchTerm)
                                        ? cachedBusinessPartners
                                        : cachedBusinessPartners.Where(bp =>
                                        (bp.CardCode?.Contains(paymentBPSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                                        (bp.CardName?.Contains(paymentBPSearchTerm, StringComparison.OrdinalIgnoreCase) ??
                                        false)).ToList();
                                    }
                                    @if (!filteredBPs.Any())
                                    {
                                        <div class="bp-empty-state">
                                            <i class="bi bi-search"></i>
                                            @if (!cachedBusinessPartners.Any())
                                            {
                                                <span>No business partners found. Please sync from the Data Sync tab.</span>
                                            }
                                            else
                                            {
                                                <span>No business partners match your search.</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        @foreach (var bp in filteredBPs)
                                        {
                                            var isSelected = allowedPaymentBPs.Contains(bp.CardCode);
                                            <label class="bp-check-row @(isSelected ? "selected" : "")">
                                                <input type="checkbox" checked="@isSelected" @onchange="() => TogglePaymentBP(bp.CardCode)" />
                                                <div style="flex:1; min-width:0;">
                                                    <div class="bp-code">@bp.CardCode</div>
                                                    <div class="bp-name">@bp.CardName</div>
                                                    </div>
                                                    @if (bp.Balance > 0)
                                                    {
                                                        <span class="bp-balance-badge">
                                                            Bal: @bp.Balance?.ToString("N2")
                                                        </span>
                                                    }
                                                </label>
                                            }
                                        }
                                    </div>

                                    @if (allowedPaymentBPs.Any())
                                    {
                                        <div style="margin-top:.5rem; display:flex; justify-content:flex-end;">
                                            <button type="button" class="btn-clear-all"
                                                    @onclick="ClearAllPaymentBPs">
                                                <i class="bi bi-x-circle me-1"></i>Clear All
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
        else if (selectedCategory == SAPCategory)
                    {
                        <!-- SAP Connection Settings Section -->
                        <div class="settings-section" style="animation-delay: 0.05s;">
                            <div class="section-header">
                                <div class="section-icon" style="background: linear-gradient(135deg, #2563eb, #3b82f6);">
                                    <i class="bi bi-cloud-arrow-up" style="color: white;"></i>
                                </div>
                                <div>
                                    <h5 class="section-title">SAP Business One Connection</h5>
                                    <p class="section-desc">Configure the connection to your SAP Business One Service Layer.</p>
                                </div>
                            </div>

                            @if (isLoadingSAPSettings)
                            {
                                <div style="text-align:center; padding:2rem;">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                                    <MudText Typo="Typo.body2" Class="mt-2">Loading SAP settings...</MudText>
                                </div>
                            }
                            else
                            {
                                <div class="setting-items">
                                    <!-- Connection Status -->
                                    @if (sapConnectionTested)
                                    {
                                        <div class="settings-alert @(sapConnectionSuccess ? "settings-alert-success" : "settings-alert-error")"
                                             style="margin-bottom: 1rem;">
                                            <i class="bi @(sapConnectionSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                            <span>@sapConnectionMessage</span>
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                                                           OnClick="() => sapConnectionTested = false" Size="Size.Small" />
                                        </div>
                                    }

                                    <!-- Service Layer URL -->
                                    <div class="setting-item">
                                        <div class="setting-info">
                                            <label class="setting-label">
                                                <i class="bi bi-link-45deg me-1"></i>Service Layer URL
                                            </label>
                                            <span class="setting-desc">The base URL for SAP Business One Service Layer (e.g.
                                                https://server:50000/b1s/v1/)</span>
                                            </div>
                                            <div class="setting-control" style="min-width: 350px;">
                                                <MudTextField @bind-Value="sapServiceLayerUrl" Label="Service Layer URL"
                                                              Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="https://server:50000/b1s/v1/"
                                                              FullWidth="true" />
                                            </div>
                                        </div>

                                        <!-- Company Database -->
                                        <div class="setting-item">
                                            <div class="setting-info">
                                                <label class="setting-label">
                                                    <i class="bi bi-database me-1"></i>Company Database
                                                </label>
                                                <span class="setting-desc">The SAP Business One company database name.</span>
                                            </div>
                                            <div class="setting-control" style="min-width: 350px;">
                                                <MudTextField @bind-Value="sapCompanyDB" Label="Company Database" Variant="Variant.Outlined"
                                                              Margin="Margin.Dense" Placeholder="COMPANY_DB" FullWidth="true" />
                                            </div>
                                        </div>

                                        <!-- A/R Invoice Series -->
                                        <div class="setting-item">
                                            <div class="setting-info">
                                                <label class="setting-label">
                                                    <i class="bi bi-receipt me-1"></i>A/R Invoice Series
                                                </label>
                                                <span class="setting-desc">The SAP A/R Invoice numbering series name for this company database.</span>
                                            </div>
                                            <div class="setting-control" style="min-width: 350px;">
                                                <MudTextField @bind-Value="sapInvoiceSeriesName" Label="A/R Invoice Series" Variant="Variant.Outlined"
                                                              Margin="Margin.Dense" Placeholder="New1" FullWidth="true" />
                                            </div>
                                        </div>

                                        <!-- Username -->
                                        <div class="setting-item">
                                            <div class="setting-info">
                                                <label class="setting-label">
                                                    <i class="bi bi-person me-1"></i>Username
                                                </label>
                                                <span class="setting-desc">SAP Business One service user account.</span>
                                            </div>
                                            <div class="setting-control" style="min-width: 350px;">
                                                <MudTextField @bind-Value="sapUsername" Label="Username" Variant="Variant.Outlined"
                                                              Margin="Margin.Dense" Placeholder="manager" FullWidth="true" />
                                            </div>
                                        </div>

                                        <!-- Password -->
                                        <div class="setting-item">
                                            <div class="setting-info">
                                                <label class="setting-label">
                                                    <i class="bi bi-key me-1"></i>Password
                                                </label>
                                                <span class="setting-desc">SAP Business One service user password. Leave blank to keep the
                                                    current password.</span>
                                                </div>
                                                <div class="setting-control" style="min-width: 350px;">
                                                    <MudTextField @bind-Value="sapPassword" Label="Password" Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense" Placeholder="Enter new password"
                                                                  InputType="@(showSAPPassword ? InputType.Text : InputType.Password)"
                                                                  Adornment="Adornment.End"
                                                                  AdornmentIcon="@(showSAPPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                                  OnAdornmentClick="() => showSAPPassword = !showSAPPassword" FullWidth="true" />
                                                </div>
                                            </div>

                                            <!-- Test Connection -->
                                            <div class="setting-item">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-plug me-1"></i>Connection Test
                                                    </label>
                                                    <span class="setting-desc">Verify the SAP connection with the current saved credentials.</span>
                                                </div>
                                                <div class="setting-control">
                                                    <MudCheckBox @bind-Value="sapTestOnSave" Label="Test connection on save" Dense="true" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Action Buttons -->
                                        <div class="section-actions">
                                            <MudButton OnClick="TestSAPConnection" Variant="Variant.Outlined" Color="Color.Primary"
                                                       Disabled="@isSAPTesting" StartIcon="@Icons.Material.Filled.NetworkCheck">
                                                @if (isSAPTesting)
                                                {
                                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                                }
                                                Test Connection
                                            </MudButton>
                                            <MudButton OnClick="SaveSAPSettings" Variant="Variant.Filled" Color="Color.Primary"
                                                       Disabled="@(isSAPSaving || string.IsNullOrWhiteSpace(sapServiceLayerUrl) || string.IsNullOrWhiteSpace(sapCompanyDB) || string.IsNullOrWhiteSpace(sapUsername))"
                                                       StartIcon="@Icons.Material.Filled.Save">
                                                @if (isSAPSaving)
                                                {
                                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                                }
                                                Save SAP Settings
                                            </MudButton>
                                        </div>
                                    }
                                </div>
                            }
                else if (selectedCategory == MobileAppCategory)
                            {
                                <div class="settings-section" style="animation-delay: 0.05s;">
                                    <div class="section-header">
                                        <div class="section-icon" style="background: linear-gradient(135deg, #ea580c, #f59e0b);">
                                            <i class="bi bi-phone" style="color: white;"></i>
                                        </div>
                                        <div>
                                            <h5 class="section-title">Mobile App Version Policy</h5>
                                            <p class="section-desc">Control the minimum supported Android version, upgrade guidance, and app-store link shown to mobile users.</p>
                                        </div>
                                    </div>

                                    @if (isLoadingMobileVersionPolicy)
                                    {
                                        <div style="text-align:center; padding:2rem;">
                                            <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                                            <MudText Typo="Typo.body2" Class="mt-2">Loading mobile app policy...</MudText>
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="background: rgba(245, 158, 11, 0.08); border: 1px solid rgba(245, 158, 11, 0.2); border-radius: 12px; padding: 1rem; margin-bottom: 1rem; color: #92400e;">
                                            <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                                                <i class="bi bi-info-circle-fill" style="font-size: 1rem; margin-top: 0.125rem;"></i>
                                                <div>
                                                    <div style="font-weight: 600; margin-bottom: 0.25rem;">Version ordering</div>
                                                    <div>Use <strong>minimum supported &lt;= recommended &lt;= latest</strong>. Leave recommended or minimum blank to fall back to the next higher version.</div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="setting-items">
                                            @if (!string.IsNullOrWhiteSpace(mobileVersionPolicyMessage))
                                            {
                                                <div class="settings-alert @(mobileVersionPolicySaveSucceeded ? "settings-alert-success" : "settings-alert-error")"
                                                     style="margin-bottom: 1rem;">
                                                    <i class="bi @(mobileVersionPolicySaveSucceeded ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                                    <span>@mobileVersionPolicyMessage</span>
                                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                                                                   OnClick="() => mobileVersionPolicyMessage = null" Size="Size.Small" />
                                                </div>
                                            }

                                            <div class="setting-item">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-phone me-1"></i>Target Mobile App
                                                    </label>
                                                    <span class="setting-desc">Choose which connected mobile app's version policy you want to edit.</span>
                                                </div>
                                                <div class="setting-control" style="min-width: 350px;">
                                                    <MudSelect T="string" Value="@selectedMobileVersionPolicyAppId" ValueChanged="OnMobileVersionPolicyAppChanged"
                                                               Label="Mobile app" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                                                        @foreach (var mobileApp in mobileVersionPolicyApps)
                                                        {
                                                            <MudSelectItem T="string" Value="@mobileApp.Key">@mobileApp.Value</MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                </div>
                                            </div>

                                            <div class="setting-item">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-shield-check me-1"></i>Version Policy Enabled
                                                    </label>
                                                    <span class="setting-desc">Turn Android version enforcement on or off without redeploying the API.</span>
                                                </div>
                                                <div class="setting-control">
                                                    <MudCheckBox @bind-Value="mobileVersionPolicyEnabled" Label="Enforce Android app versions" Dense="true" />
                                                </div>
                                            </div>

                                            <div class="setting-item">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-card-heading me-1"></i>Require Version Headers
                                                    </label>
                                                    <span class="setting-desc">Require Android requests to include <strong>X-App-Platform</strong> and <strong>X-App-Version</strong> metadata.</span>
                                                </div>
                                                <div class="setting-control">
                                                    <MudCheckBox @bind-Value="mobileVersionPolicyRequireHeaders" Label="Require headers on protected API calls" Dense="true" />
                                                </div>
                                            </div>

                                            <div class="setting-item">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-arrow-up-circle me-1"></i>Latest Version
                                                    </label>
                                                    <span class="setting-desc">The current Android release shown to the app and used as the upper version bound.</span>
                                                </div>
                                                <div class="setting-control" style="min-width: 350px;">
                                                    <MudTextField @bind-Value="mobileVersionPolicyLatestVersion" Label="Latest version" Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense" Placeholder="1.0.2" FullWidth="true" />
                                                </div>
                                            </div>

                                            <div class="setting-item">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-bell me-1"></i>Recommended Version
                                                    </label>
                                                    <span class="setting-desc">Versions below this value will be warned but can still continue.</span>
                                                </div>
                                                <div class="setting-control" style="min-width: 350px;">
                                                    <MudTextField @bind-Value="mobileVersionPolicyRecommendedVersion" Label="Recommended version" Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense" Placeholder="1.0.2" FullWidth="true" />
                                                </div>
                                            </div>

                                            <div class="setting-item">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-slash-circle me-1"></i>Minimum Supported Version
                                                    </label>
                                                    <span class="setting-desc">Versions below this value are blocked until the user upgrades.</span>
                                                </div>
                                                <div class="setting-control" style="min-width: 350px;">
                                                    <MudTextField @bind-Value="mobileVersionPolicyMinimumSupportedVersion" Label="Minimum supported version"
                                                                  Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="1.0.1" FullWidth="true" />
                                                </div>
                                            </div>

                                            <div class="setting-item">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-google-play me-1"></i>Google Play URL
                                                    </label>
                                                    <span class="setting-desc">Store link used by the mobile app when users choose to update.</span>
                                                </div>
                                                <div class="setting-control" style="min-width: 350px;">
                                                    <MudTextField @bind-Value="mobileVersionPolicyGooglePlayUrl" Label="Google Play URL" Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense" Placeholder="https://play.google.com/store/apps/details?id=com.shopinventory.mobile"
                                                                  FullWidth="true" />
                                                </div>
                                            </div>

                                            <div class="setting-item" style="align-items: flex-start;">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-journal-text me-1"></i>Release Notes
                                                    </label>
                                                    <span class="setting-desc">Optional notes shown to the app when a newer version is available.</span>
                                                </div>
                                                <div class="setting-control" style="min-width: 350px;">
                                                    <MudTextField @bind-Value="mobileVersionPolicyReleaseNotes" Label="Release notes" Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense" Lines="3" FullWidth="true" />
                                                </div>
                                            </div>

                                            <div class="setting-item" style="align-items: flex-start;">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-chat-left-text me-1"></i>Warn Message
                                                    </label>
                                                    <span class="setting-desc">Optional message shown when the current app build is still usable but outdated.</span>
                                                </div>
                                                <div class="setting-control" style="min-width: 350px;">
                                                    <MudTextField @bind-Value="mobileVersionPolicyWarnMessage" Label="Warn message" Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense" Lines="3" FullWidth="true" />
                                                </div>
                                            </div>

                                            <div class="setting-item" style="align-items: flex-start;">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-exclamation-octagon me-1"></i>Block Message
                                                    </label>
                                                    <span class="setting-desc">Optional message shown when the current build is below the minimum supported version.</span>
                                                </div>
                                                <div class="setting-control" style="min-width: 350px;">
                                                    <MudTextField @bind-Value="mobileVersionPolicyBlockMessage" Label="Block message" Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense" Lines="3" FullWidth="true" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="section-actions">
                                            <MudButton OnClick="SaveMobileVersionPolicySettings" Variant="Variant.Filled" Color="Color.Primary"
                                                       Disabled="@(!CanSaveMobileVersionPolicy)" StartIcon="@Icons.Material.Filled.Save">
                                                @if (isSavingMobileVersionPolicy)
                                                {
                                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                                }
                                                Save @SelectedMobileVersionPolicyAppName Policy
                                            </MudButton>
                                        </div>
                                    }
                                </div>
                            }
        else if (selectedCategory == SettingCategories.EmailReports)
                            {
                                <div class="settings-section pod-email-section" style="animation-delay: 0.05s;">
                                    <div class="section-header pod-email-header">
                                        <div class="section-icon section-icon-blue">
                                            <i class="bi bi-envelope-paper"></i>
                                        </div>
                                        <div class="section-header-text">
                                            <h5 class="section-title">POD Email Reports</h5>
                                            <p class="section-desc">Create as many delivery schedules as you need — each with its own frequency and recipients. POD reports are generated and emailed as Excel attachments.</p>
                                        </div>
                                        <button type="button" class="btn-primary-action" @onclick="OpenNewSchedule">
                                            <i class="bi bi-plus-lg"></i> Add schedule
                                        </button>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(podEmailMessage))
                                    {
                                        <div class="settings-alert @(podEmailMessageSuccess ? "settings-alert-success" : "settings-alert-error")">
                                            <i class="bi @(podEmailMessageSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                            <span>@podEmailMessage</span>
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                                                           OnClick="() => podEmailMessage = null" Size="Size.Small" />
                                        </div>
                                    }

                                    <div class="pod-email-overview">
                                        <div class="stat-tile">
                                            <span>Schedules</span>
                                            <strong>@podSchedules.Count</strong>
                                        </div>
                                        <div class="stat-tile">
                                            <span>Active</span>
                                            <strong>@podSchedules.Count(s => s.Enabled)</strong>
                                        </div>
                                        <div class="stat-tile stat-tile-wide">
                                            <span>Recipients</span>
                                            <strong>@TotalScheduleRecipientCount() addresses</strong>
                                        </div>
                                        <div class="stat-tile stat-tile-wide">
                                            <span>Automation</span>
                                            <strong>@(GetBoolValue(SettingKeys.PodReportEmailsEnabled) ? "On" : "Paused")</strong>
                                        </div>
                                    </div>

                                    <div class="setting-items">
                                        <div class="setting-item">
                                            <div class="setting-info">
                                                <label class="setting-label">
                                                    <i class="bi bi-calendar-check me-1"></i>Scheduled Sending
                                                </label>
                                                <span class="setting-desc">Master switch for automatic delivery. When off, schedules are kept but nothing is sent on a schedule — “Send now” still works. Saved as soon as you toggle it.</span>
                                            </div>
                                            <div class="setting-control">
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked="@GetBoolValue(SettingKeys.PodReportEmailsEnabled)"
                                                           disabled="@isSavingPodAutomation"
                                                           @onchange="OnPodScheduledSendingChangedAsync" />
                                                    <span class="toggle-slider"></span>
                                                    <span class="toggle-text">@(GetBoolValue(SettingKeys.PodReportEmailsEnabled) ? "On" : "Off")</span>
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    @if (!GetBoolValue(SettingKeys.PodReportEmailsEnabled))
                                    {
                                        <div class="pod-email-hint">
                                            <i class="bi bi-pause-circle"></i>
                                            <span>Automatic sending is paused. Turn on <strong>Scheduled Sending</strong> above to resume deliveries.</span>
                                        </div>
                                    }

                                    @if (podSchedules.Count == 0)
                                    {
                                        <div class="sched-empty">
                                            <i class="bi bi-envelope-plus"></i>
                                            <h6>No schedules yet</h6>
                                            <p>Add a schedule to start delivering POD reports to a group of recipients.</p>
                                            <button type="button" class="btn-primary-action" @onclick="OpenNewSchedule">
                                                <i class="bi bi-plus-lg"></i> Add your first schedule
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="sched-grid">
                                            @foreach (var schedule in podSchedules)
                                            {
                                                var sending = sendingScheduleIds.Contains(schedule.Id);
                                                <div class="sched-card @(schedule.Enabled ? "" : "sched-card-off")">
                                                    <div class="sched-card-top">
                                                        <div class="sched-card-title">
                                                            <span class="sched-freq-badge sched-freq-@GetFrequencyKey(schedule)">@GetScheduleFrequencyLabel(schedule)</span>
                                                            <h6>@(string.IsNullOrWhiteSpace(schedule.Name) ? "Untitled schedule" : schedule.Name)</h6>
                                                        </div>
                                                        <label class="toggle-switch" title="@(schedule.Enabled ? "Enabled" : "Disabled")">
                                                            <input type="checkbox" checked="@schedule.Enabled"
                                                                   @onchange="() => ToggleScheduleEnabledAsync(schedule)" />
                                                            <span class="toggle-slider"></span>
                                                        </label>
                                                    </div>

                                                    <div class="sched-card-meta">
                                                        <div class="sched-meta-row">
                                                            <i class="bi bi-clock"></i>
                                                            <span>@GetScheduleCadenceLabel(schedule)</span>
                                                        </div>
                                                        <div class="sched-meta-row">
                                                            <i class="bi bi-calendar-event"></i>
                                                            <span>Next send: @FormatScheduleNextSend(schedule)</span>
                                                        </div>
                                                        <div class="sched-meta-row">
                                                            <i class="bi bi-people"></i>
                                                            <span>@ScheduleRecipientSummary(schedule)</span>
                                                        </div>
                                                        <div class="sched-meta-row">
                                                            <i class="bi bi-clock-history"></i>
                                                            <span>Last sent: @FormatScheduleLastSent(schedule)</span>
                                                        </div>
                                                    </div>

                                                    <div class="sched-card-actions">
                                                        @if (confirmingDeleteId == schedule.Id)
                                                        {
                                                            <span class="sched-confirm-text">Delete this schedule?</span>
                                                            <button type="button" class="sched-btn sched-btn-danger" @onclick="() => DeleteScheduleAsync(schedule.Id)">Delete</button>
                                                            <button type="button" class="sched-btn" @onclick="() => confirmingDeleteId = null">Cancel</button>
                                                        }
                                                        else
                                                        {
                                                            <button type="button" class="sched-btn" @onclick="() => OpenEditSchedule(schedule)">
                                                                <i class="bi bi-pencil"></i> Edit
                                                            </button>
                                                            <button type="button" class="sched-btn sched-btn-primary" @onclick="() => SendScheduleNowAsync(schedule)" disabled="@sending">
                                                                @if (sending)
                                                                {
                                                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                                                    <span>Sending…</span>
                                                                }
                                                                else
                                                                {
                                                                    <i class="bi bi-send"></i>
                                                                    <span>Send now</span>
                                                                }
                                                            </button>
                                                            <button type="button" class="sched-btn sched-btn-icon-danger" @onclick="() => confirmingDeleteId = schedule.Id" title="Delete schedule">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
        else if (selectedCategory == SettingCategories.Printing)
                            {
                                var savedPrinters = GetSavedPrintersList();
                                var defaultPrinter = GetDefaultPrinter();
                                var printerOptions = GetPrinterOptions(savedPrinters, defaultPrinter);
                                var availablePrinters = GetAvailablePrinters(savedPrinters);

                                <div class="settings-section printing-section" style="animation-delay: 0.05s;">
                                    <div class="section-header printing-header">
                                        <div class="section-icon section-icon-amber">
                                            <i class="bi bi-printer"></i>
                                        </div>
                                        <div>
                                            <h5 class="section-title">Printing</h5>
                                            <p class="section-desc">Invoice print behavior, default printer preference, and cashier quick picks.</p>
                                        </div>
                                        <button type="button" class="btn-icon-action" @onclick="RefreshInstalledPrinters" title="Refresh printer list">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </button>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(printingMessage))
                                    {
                                        <div class="settings-alert @(printingMessageSuccess ? "settings-alert-success" : "settings-alert-error")">
                                            <i class="bi @(printingMessageSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                            <span>@printingMessage</span>
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                                                           OnClick="() => printingMessage = null" Size="Size.Small" />
                                        </div>
                                    }

                                    <div class="printing-overview">
                                        <div class="printing-stat">
                                            <span>Installed</span>
                                            <strong>@installedPrinters.Count</strong>
                                        </div>
                                        <div class="printing-stat">
                                            <span>Saved</span>
                                            <strong>@savedPrinters.Count</strong>
                                        </div>
                                        <div class="printing-stat">
                                            <span>Copies</span>
                                            <strong>@GetPrintCopies()</strong>
                                        </div>
                                        <div class="printing-stat printing-stat-wide">
                                            <span>Default</span>
                                            <strong>@(string.IsNullOrWhiteSpace(defaultPrinter) ? "System default" : defaultPrinter)</strong>
                                        </div>
                                    </div>

                                    <div class="setting-items printing-settings-list">
                                        <div class="setting-item">
                                            <div class="setting-info">
                                                <label class="setting-label">
                                                    <i class="bi bi-lightning-charge me-1"></i>Auto Print Invoice
                                                </label>
                                                <span class="setting-desc">Open the invoice PDF print flow automatically after a successful invoice.</span>
                                            </div>
                                            <div class="setting-control">
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked="@GetBoolValue(SettingKeys.AutoPrintInvoice)"
                                                           @onchange="e => OnBoolSettingChanged(SettingKeys.AutoPrintInvoice, e)" />
                                                    <span class="toggle-slider"></span>
                                                    <span class="toggle-text">@(GetBoolValue(SettingKeys.AutoPrintInvoice) ? "On" : "Off")</span>
                                                </label>
                                            </div>
                                        </div>

                                        <div class="setting-item">
                                            <div class="setting-info">
                                                <label class="setting-label">
                                                    <i class="bi bi-files me-1"></i>Print Copies
                                                </label>
                                                <span class="setting-desc">Default number of invoice copies, capped to keep accidental repeats under control.</span>
                                            </div>
                                            <div class="setting-control">
                                                <input type="number" class="field-input field-input-sm print-copy-input" min="1" max="10"
                                                       value="@GetPrintCopies()"
                                                       @onchange="OnPrintCopiesChanged" />
                                            </div>
                                        </div>

                                        <div class="setting-item">
                                            <div class="setting-info">
                                                <label class="setting-label">
                                                    <i class="bi bi-star me-1"></i>Default Printer
                                                </label>
                                                <span class="setting-desc">The printer highlighted first when invoices are printed from the web app.</span>
                                            </div>
                                            <div class="setting-control printer-default-control">
                                                <select class="field-input field-input-sm printer-select" value="@defaultPrinter"
                                                        @onchange="OnDefaultPrinterChanged">
                                                    <option value="">System default</option>
                                                    @foreach (var printer in printerOptions)
                                                    {
                                                        <option value="@printer">@printer</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="printing-manager">
                                        <div class="printer-manager-header">
                                            <div>
                                                <h6>Quick Pick Printers</h6>
                                                <p>Saved printers appear in the invoice print dialog for faster cashier selection.</p>
                                            </div>
                                            <span>@savedPrinters.Count saved</span>
                                        </div>

                                        @if (savedPrinters.Any())
                                        {
                                            <div class="printer-chip-list">
                                                @foreach (var printer in savedPrinters)
                                                {
                                                    var isDefault = IsSamePrinter(printer, defaultPrinter);
                                                    <div class="printer-chip @(isDefault ? "printer-chip-default" : string.Empty)">
                                                        <i class="bi @(isDefault ? "bi-star-fill" : "bi-printer")"></i>
                                                        <span>@printer</span>
                                                        @if (!isDefault)
                                                        {
                                                            <button type="button" class="printer-chip-action" @onclick="() => SetDefaultPrinter(printer)" title="Set as default">
                                                                <i class="bi bi-star"></i>
                                                            </button>
                                                        }
                                                        <button type="button" class="printer-chip-action printer-chip-remove" @onclick="() => RemoveSavedPrinter(printer)" title="Remove">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="printer-empty-state">
                                                <i class="bi bi-printer"></i>
                                                <span>No quick pick printers saved yet.</span>
                                            </div>
                                        }

                                        <div class="printer-add-grid">
                                            <div class="printer-add-row">
                                                <select class="field-input printer-select" @bind="printerToAdd" disabled="@(!availablePrinters.Any())">
                                                    <option value="">Select an installed printer</option>
                                                    @foreach (var printer in availablePrinters)
                                                    {
                                                        <option value="@printer">@printer</option>
                                                    }
                                                </select>
                                                <button type="button" class="btn-secondary-action" @onclick="AddSelectedPrinter" disabled="@string.IsNullOrWhiteSpace(printerToAdd)">
                                                    <i class="bi bi-plus-lg"></i>
                                                    Add
                                                </button>
                                            </div>

                                            <div class="printer-add-row">
                                                <input type="text" class="field-input" placeholder="Type a printer name or network path"
                                                       @bind="customPrinterName" @bind:event="oninput" />
                                                <button type="button" class="btn-secondary-action" @onclick="AddCustomPrinter" disabled="@string.IsNullOrWhiteSpace(customPrinterName)">
                                                    <i class="bi bi-plus-lg"></i>
                                                    Add Custom
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="printing-test-panel">
                                        <div>
                                            <h6>Test Output</h6>
                                            <p>Send a clean test page through the same browser print path used by reports.</p>
                                        </div>
                                        <MudButton OnClick="PrintSettingsTestPage" Disabled="@isTestingPrinter" Variant="Variant.Filled"
                                                   Color="Color.Primary" StartIcon="@Icons.Material.Filled.Print">
                                            @if (isTestingPrinter)
                                            {
                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                            }
                                            Test Print
                                        </MudButton>
                                    </div>
                                </div>
                            }
        else if (selectedCategory == DangerZoneCategory)
                            {
                                <!-- Danger Zone Section -->
                                <div class="settings-section danger-section" style="animation-delay: 0.05s;">
                                    <div class="section-header">
                                        <div class="section-icon" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
                                            <i class="bi bi-exclamation-triangle-fill" style="color: white;"></i>
                                        </div>
                                        <div>
                                            <h5 class="section-title danger-label">Danger Zone</h5>
                                            <p class="section-desc">Irreversible actions that affect your entire database. Proceed with extreme
                                                caution.</p>
                                            </div>
                                        </div>

                                        <div class="setting-items">
                                            <div class="setting-item danger-card">
                                                <div class="setting-info" style="flex: 1;">
                                                    <label class="setting-label danger-label">
                                                        <i class="bi bi-database-x me-2"></i>Reset Database
                                                    </label>
                                                    <span class="setting-desc" style="margin-top: 0.5rem; display: block;">
                                                        Permanently delete all transactional data including invoices, orders, payments,
                                                        products, transfers, and audit logs. Admin user accounts will be preserved.
                                                        <strong>This action cannot be undone.</strong> Consider creating a backup first.
                                                    </span>
                                                </div>
                                                <div class="setting-control">
                                                    <MudButton Class="btn-danger-action"
                                                               OnClick="ShowResetConfirmation" Disabled="@isResettingDatabase">
                                                        @if (isResettingDatabase)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                                            <span>Resetting...</span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-trash3 me-1"></i>
                                                            <span>Reset Database</span>
                                                        }
                                                    </MudButton>
                                                </div>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrEmpty(resetMessage))
                                        {
                                            <div class="settings-alert @(resetSuccess ? "settings-alert-success" : "settings-alert-error") mt-3">
                                                <i class="bi @(resetSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                                <span>@resetMessage</span>
                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                                                               OnClick="() => resetMessage = null" Size="Size.Small" />
                                            </div>
                                        }
                                    </div>
                                }
        else if (selectedCategory == DataManagementCategory)
                                {
                                    <!-- Data Management Section -->
                                    <div class="settings-section" style="animation-delay: 0.05s;">
                                        <div class="section-header">
                                            <div class="section-icon section-icon-blue">
                                                <i class="bi bi-cloud-arrow-down"></i>
                                            </div>
                                            <div>
                                                <h5 class="section-title">Data Synchronization</h5>
                                                <p class="section-desc">Manually refresh cached data from SAP. Use when data has changed in the
                                                    source system.</p>
                                                </div>
                                            </div>

                                            <div class="sync-grid">
                                                <!-- Products -->
                                                <div class="sync-card">
                                                    <div class="sync-card-icon" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                                                        <i class="bi bi-box-seam"></i>
                                                    </div>
                                                    <div class="sync-card-body">
                                                        <h6>Products</h6>
                                                        <p>Sync product catalog from SAP</p>
                                                        @if (productsLastSync.HasValue)
                                                        {
                                                            <span class="sync-timestamp">
                                                                <i class="bi bi-clock-history"></i> @productsLastSync.Value.ToString("dd MMM yyyy HH:mm")
                                                            </span>
                                                        }
                                                    </div>
                                                    <MudButton Class="btn-sync" OnClick="RefreshProducts" Disabled="@isRefreshingProducts">
                                                        @if (isRefreshingProducts)
                                                        {
                                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        }
                                                    </MudButton>
                                                </div>

                                                <!-- Prices -->
                                                <div class="sync-card">
                                                    <div class="sync-card-icon" style="background: linear-gradient(135deg, #11998e, #38ef7d);">
                                                        <i class="bi bi-tag"></i>
                                                    </div>
                                                    <div class="sync-card-body">
                                                        <h6>Prices</h6>
                                                        <p>Sync item prices from SAP</p>
                                                        @if (pricesLastSync.HasValue)
                                                        {
                                                            <span class="sync-timestamp">
                                                                <i class="bi bi-clock-history"></i> @pricesLastSync.Value.ToString("dd MMM yyyy HH:mm")
                                                            </span>
                                                        }
                                                    </div>
                                                    <MudButton Class="btn-sync" OnClick="RefreshPrices" Disabled="@isRefreshingPrices">
                                                        @if (isRefreshingPrices)
                                                        {
                                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        }
                                                    </MudButton>
                                                </div>

                                                <!-- Business Partners -->
                                                <div class="sync-card">
                                                    <div class="sync-card-icon" style="background: linear-gradient(135deg, #f093fb, #f5576c);">
                                                        <i class="bi bi-people"></i>
                                                    </div>
                                                    <div class="sync-card-body">
                                                        <h6>Business Partners</h6>
                                                        <p>Sync customers and suppliers</p>
                                                        @if (bpLastSync.HasValue)
                                                        {
                                                            <span class="sync-timestamp">
                                                                <i class="bi bi-clock-history"></i> @bpLastSync.Value.ToString("dd MMM yyyy HH:mm")
                                                            </span>
                                                        }
                                                    </div>
                                                    <MudButton Class="btn-sync" OnClick="RefreshBusinessPartners" Disabled="@isRefreshingBP">
                                                        @if (isRefreshingBP)
                                                        {
                                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        }
                                                    </MudButton>
                                                </div>

                                                <!-- Warehouses -->
                                                <div class="sync-card">
                                                    <div class="sync-card-icon" style="background: linear-gradient(135deg, #f7971e, #ffd200);">
