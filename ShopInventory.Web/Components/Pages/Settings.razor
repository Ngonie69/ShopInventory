    // SAP Settings Methods
    private async Task LoadSAPSettings()
    {
        isLoadingSAPSettings = true;
        try
        {
            var settings = await SAPSettingsService.GetSettingsAsync();
            if (settings != null)
            {
                sapServiceLayerUrl = settings.ServiceLayerUrl ?? string.Empty;
                sapCompanyDB = settings.CompanyDB ?? string.Empty;
                sapUsername = settings.UserName ?? string.Empty;
                sapPassword = string.Empty; // Never pre-fill password
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load SAP settings: {ex.Message}";
        }
        finally
        {
            isLoadingSAPSettings = false;
        }
    }

    private async Task SaveSAPSettings()
    {
        isSAPSaving = true;
        sapConnectionTested = false;
        StateHasChanged();

        try
        {
            var request = new SAPSettingsUpdateRequest
            {
                ServiceLayerUrl = sapServiceLayerUrl.Trim(),
                CompanyDB = sapCompanyDB.Trim(),
                UserName = sapUsername.Trim(),
                Password = sapPassword,
                TestConnection = sapTestOnSave
            };

            var result = await SAPSettingsService.UpdateSettingsAsync(request);

            sapConnectionTested = true;
            sapConnectionSuccess = result.Success;
            sapConnectionMessage = result.Message;

            if (result.Success)
            {
                sapPassword = string.Empty; // Clear password after successful save
                await LogAudit(AuditActions.UpdateSettings, $"Updated SAP connection settings (CompanyDB: {sapCompanyDB})");
            }
        }
        catch (Exception ex)
        {
            sapConnectionTested = true;
            sapConnectionSuccess = false;
            sapConnectionMessage = $"Error saving SAP settings: {ex.Message}";
        }
        finally
        {
            isSAPSaving = false;
            StateHasChanged();
        }
    }

    private async Task TestSAPConnection()
    {
        isSAPTesting = true;
        sapConnectionTested = false;
        StateHasChanged();

        try
        {
            var result = await SAPSettingsService.TestConnectionAsync();
            sapConnectionTested = true;
            sapConnectionSuccess = result.Connected;
            sapConnectionMessage = result.Message;
        }
        catch (Exception ex)
        {
            sapConnectionTested = true;
            sapConnectionSuccess = false;
            sapConnectionMessage = $"Connection test error: {ex.Message}";
        }
        finally
        {
            isSAPTesting = false;
            StateHasChanged();
        }
    }

    // Payment Settings Methods
    private async Task LoadPaymentSettingsData()
    {
        try
        {
            await using var db = await DbContextFactory.CreateDbContextAsync();
            cachedGLAccounts = await db.CachedGLAccounts
            .Where(g => g.IsActive)
            .OrderBy(g => g.Code)
            .ToListAsync();
            cachedBusinessPartners = await db.CachedBusinessPartners
            .Where(bp => bp.IsActive && (bp.CardType == "cCustomer" || bp.CardType == "C"))
            .OrderBy(bp => bp.CardCode)
            .ToListAsync();

            // Load current values from settings
            var glSetting = await SettingsService.GetValueAsync(SettingKeys.IncomingPaymentGLAccount);
            paymentGLAccount = glSetting ?? "";
            selectedGLAccount = cachedGLAccounts.FirstOrDefault(gl => gl.Code == paymentGLAccount);

            var methodSetting = await SettingsService.GetValueAsync(SettingKeys.DefaultPaymentMethod);
            defaultPaymentMethod = methodSetting ?? "cash";

            var bpJson = await SettingsService.GetValueAsync(SettingKeys.AllowedPaymentBusinessPartners);
            if (!string.IsNullOrWhiteSpace(bpJson) && bpJson != "[]")
            {
                try
                {
                    allowedPaymentBPs = System.Text.Json.JsonSerializer.Deserialize<List<string>>(bpJson) ?? new();
                }
                catch { allowedPaymentBPs = new(); }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load payment settings data: {ex.Message}";
        }
    }

    private async Task<IEnumerable<CachedGLAccount>> SearchGLAccountsAsync(string searchText, CancellationToken
cancellationToken)
    {
        var eligible = paymentEligibleGLAccounts;
        if (string.IsNullOrWhiteSpace(searchText))
            return eligible.Take(20);

        var term = searchText.ToLower();
        return eligible.Where(gl =>
            (gl.Code?.ToLower().Contains(term) ?? false) ||
            (gl.Name?.ToLower().Contains(term) ?? false))
            .Take(20);
    }

    private async void OnGLAccountSelected(CachedGLAccount? gl)
    {
        selectedGLAccount = gl;
        paymentGLAccount = gl?.Code ?? "";
        await SettingsService.SaveSettingAsync(SettingKeys.IncomingPaymentGLAccount, paymentGLAccount, currentUsername);
        hasChanges = false;
        successMessage = $"G/L Account updated to {(string.IsNullOrEmpty(paymentGLAccount) ? "(none)" : $"{gl?.Code} - {gl?.Name}")}";
        await LogAudit(AuditActions.UpdateSettings, $"Updated incoming payment G/L account to: {paymentGLAccount}");
        StateHasChanged();
    }

    private async void OnDefaultPaymentMethodChanged(ChangeEventArgs e)
    {
        defaultPaymentMethod = e.Value?.ToString() ?? "cash";
        await SettingsService.SaveSettingAsync(SettingKeys.DefaultPaymentMethod, defaultPaymentMethod, currentUsername);
        hasChanges = false;
        var label = defaultPaymentMethod switch
        {
            "cash" => "Cash",
            "transfer" => "Transfer",
            "check" => "Check",
            "credit" => "Credit Card",
            _ => defaultPaymentMethod
        };
        successMessage = $"Default payment method updated to {label}";
        await LogAudit(AuditActions.UpdateSettings, $"Updated default payment method to: {label}");
        StateHasChanged();
    }

    private async void TogglePaymentBP(string cardCode)
    {
        if (allowedPaymentBPs.Contains(cardCode))
            allowedPaymentBPs.Remove(cardCode);
        else
            allowedPaymentBPs.Add(cardCode);

        var json = System.Text.Json.JsonSerializer.Serialize(allowedPaymentBPs);
        await SettingsService.SaveSettingAsync(SettingKeys.AllowedPaymentBusinessPartners, json, currentUsername);
        await LogAudit(AuditActions.UpdateSettings, $"Updated allowed payment business partners ({allowedPaymentBPs.Count} selected)");
        StateHasChanged();
    }

    private async void ClearAllPaymentBPs()
    {
        allowedPaymentBPs.Clear();
        await SettingsService.SaveSettingAsync(SettingKeys.AllowedPaymentBusinessPartners, "[]", currentUsername);
        await LogAudit(AuditActions.UpdateSettings, "Cleared all allowed payment business partners");
        StateHasChanged();
    }

