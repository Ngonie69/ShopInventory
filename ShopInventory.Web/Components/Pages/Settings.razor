    private async Task SendScheduleNowAsync(PodReportEmailSchedule schedule)
    {
        sendingScheduleIds.Add(schedule.Id);
        podEmailMessage = null;
        errorMessage = null;
        successMessage = null;
        StateHasChanged();

        try
        {
            var result = await PodEmailService.SendForScheduleAsync(schedule, currentUsername);
            podEmailMessageSuccess = result.Success;
            podEmailMessage = result.Success
                ? $"{result.Message} Total: {result.TotalInvoices:N0}, uploaded: {result.UploadedCount:N0}, pending: {result.PendingCount:N0}."
                : result.Message;

            if (result.Success)
            {
                await PodReportEmailScheduleService.MarkSentAsync(schedule.Id, DateTime.UtcNow);
                await LoadSchedulesAsync();
                await LogAudit(
                    AuditActions.UpdateSettings,
                    $"Sent POD report email schedule '{schedule.Name}' manually: total {result.TotalInvoices}, uploaded {result.UploadedCount}, pending {result.PendingCount}.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Manual POD report email send failed for schedule {ScheduleId}.", schedule.Id);
            podEmailMessageSuccess = false;
            podEmailMessage = $"Failed to send POD report email: {ex.Message}";
        }
        finally
        {
            sendingScheduleIds.Remove(schedule.Id);
            StateHasChanged();
        }
    }

