@page "/settings"
@using ShopInventory.Web.Data
@using ShopInventory.Web.Services
@using ShopInventory.Web.Models
@using Microsoft.EntityFrameworkCore
@inject IAppSettingsService SettingsService
@inject IAuditService AuditService
@inject IMasterDataCacheService CacheService
@inject IAuthService AuthService
@inject IBackupService BackupService
@inject IPrinterService PrinterService
@inject IDbContextFactory<WebAppDbContext> DbContextFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IAppSettingsProvider AppSettingsProvider
@inject IJSRuntime JS
@inject IThemeService ThemeService
@inject ISAPSettingsService SAPSettingsService
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<PageTitle>Settings - Shop Inventory</PageTitle>

<div class="settings-page">
    <!-- Page Header -->
    <div class="settings-header">
        <div class="settings-header-left">
            <div class="settings-icon-box">
                <i class="bi bi-gear-wide-connected"></i>
            </div>
            <div>
                <h2 class="settings-title">Settings</h2>
                <p class="settings-subtitle">Manage application configuration, data sync, and user accounts</p>
            </div>
        </div>
        <MudButton Class="btn-settings-save" OnClick="SaveSettings" Disabled="@(!hasChanges || isSaving)">
            @if (isSaving)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            }
            else
            {
                <i class="bi bi-check2-circle me-1"></i>
            }
            Save Changes
        </MudButton>
    </div>

    <!-- Alerts -->
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="settings-alert settings-alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@successMessage</span>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                           OnClick="() => successMessage = null" Size="Size.Small" />
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="settings-alert settings-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@errorMessage</span>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                           OnClick="() => errorMessage = null" Size="Size.Small" />
        </div>
    }

    @if (isLoading)
    {
        <div class="settings-loading">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Loading settings...</p>
        </div>
    }
    else
    {
        <!-- Tab Navigation -->
        <div class="settings-tabs">
            @foreach (var category in categories)
            {
                <MudButton Class="@($"settings-tab {(selectedCategory == category ? "active" : "")}")"
                           OnClick="() => SelectCategory(category)">
                    <i class="bi @GetCategoryIcon(category)"></i>
                    <span>@category</span>
                </MudButton>
            }
            <MudButton Class="@($"settings-tab {(selectedCategory == PaymentsCategory ? "active" : "")}")"
                       OnClick="() => SelectCategory(PaymentsCategory)">
                <i class="bi bi-cash-coin"></i>
                <span>Payments</span>
            </MudButton>
            <MudButton Class="@($"settings-tab {(selectedCategory == SAPCategory ? "active" : "")}")"
                       OnClick="() => SelectCategory(SAPCategory)">
                <i class="bi bi-cloud-arrow-up"></i>
                <span>SAP Connection</span>
            </MudButton>
            <MudButton Class="@($"settings-tab {(selectedCategory == DataManagementCategory ? "active" : "")}")"
                       OnClick="() => SelectCategory(DataManagementCategory)">
                <i class="bi bi-arrow-repeat"></i>
                <span>Data Sync</span>
            </MudButton>
            <MudButton Class="@($"settings-tab {(selectedCategory == DangerZoneCategory ? "active" : "")}")"
                       OnClick="() => SelectCategory(DangerZoneCategory)"
                       style="@(selectedCategory == DangerZoneCategory ? "color: #dc3545; border-color: #dc3545;" : "")">
                <i class="bi bi-exclamation-triangle"></i>
                <span>Danger Zone</span>
            </MudButton>
        </div>

        <!-- Tab Content -->
        <div class="settings-content">

            @if (selectedCategory == PaymentsCategory)
            {
                <!-- Payments Settings Section -->
                <div class="settings-section" style="animation-delay: 0.05s;">
                    <div class="section-header">
                        <div class="section-icon" style="background: linear-gradient(135deg, #059669, #10b981);">
                            <i class="bi bi-cash-coin" style="color: white;"></i>
                        </div>
                        <div>
                            <h5 class="section-title">Incoming Payment Settings</h5>
                            <p class="section-desc">Configure the default G/L account and allowed business partners for incoming
                                payments.</p>
                            </div>
                        </div>

                        <div class="setting-items">
                            <!-- G/L Account Setting -->
                            <div class="setting-item">
                                <div class="setting-info">
                                    <label class="setting-label">
                                        <i class="bi bi-journal-text me-1"></i>Default G/L Account for Incoming Payments
                                    </label>
                                    <span class="setting-desc">
                                        Select a <strong>cash or bank</strong> G/L account for posting incoming payments.
                                        Do not select expense, revenue, or controlling accounts.
                                    </span>
                                </div>
                                <div class="setting-control" style="min-width: 350px;">
                                    <MudAutocomplete T="CachedGLAccount" Label="Search G/L Account" Value="selectedGLAccount"
                                                     ValueChanged="OnGLAccountSelected" SearchFunc="@SearchGLAccountsAsync"
                                                     ToStringFunc="@(gl => gl == null ? string.Empty : $"{gl.Code} - {gl.Name}")"
                                                     ShowProgressIndicator="true" MinCharacters="0" Immediate="true" ResetValueOnEmptyText="true"
                                                     CoerceText="false" CoerceValue="false" Variant="Variant.Outlined" Dense="true"
                                                     Margin="Margin.Dense" Clearable="true" DebounceInterval="200" MaxItems="20"
                                                     AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary">
                                        <ItemTemplate Context="gl">
                                            <MudText>
                                                <b>@gl.Code</b> — @gl.Name
                                                <MudText Typo="Typo.caption" Class="ms-2">(@FormatAccountType(gl.AccountType))
                                                </MudText>
                                            </MudText>
                                        </ItemTemplate>
                                        <NoItemsTemplate>
                                            <MudText Class="px-3 py-2">
                                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="me-1" />
                                                No G/L accounts found
                                            </MudText>
                                        </NoItemsTemplate>
                                    </MudAutocomplete>
                                    @if (!cachedGLAccounts.Any())
                                    {
                                        <small style="color:#d97706; font-size:.75rem; display:block; margin-top:.25rem;">
                                            <i class="bi bi-exclamation-triangle me-1"></i>No G/L accounts found. Please sync G/L
                                            accounts from the Data Sync tab first.
                                        </small>
                                    }
                                </div>
                            </div>

                            <!-- Default Payment Method -->
                            <div class="setting-item">
                                <div class="setting-info">
                                    <label class="setting-label">
                                        <i class="bi bi-wallet2 me-1"></i>Default Payment Method
                                    </label>
                                    <span class="setting-desc">
                                        Select the payment method that will be used for incoming payments. Users will not be able to
                                        change this.
                                    </span>
                                </div>
                                <div class="setting-control" style="min-width: 220px;">
                                    <select class="field-input field-input-sm" value="@defaultPaymentMethod"
                                            @onchange="OnDefaultPaymentMethodChanged">
                                        <option value="cash">Cash</option>
                                        <option value="transfer">Transfer</option>
                                        <option value="check">Check</option>
                                        <option value="credit">Credit Card</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Allowed Business Partners -->
                            <div class="setting-item" style="flex-direction: column; align-items: stretch;">
                                <div class="setting-info" style="margin-bottom: 1rem;">
                                    <label class="setting-label">
                                        <i class="bi bi-people me-1"></i>Allowed Business Partners for Incoming Payments
                                    </label>
                                    <span class="setting-desc">
                                        Select which business partners users can choose when creating an incoming payment.
                                        If none are selected, <strong>all</strong> business partners will be available.
                                    </span>
                                </div>

                                <!-- Search and filter -->
                                <div
                                    style="margin-bottom: .75rem; display: flex; gap: .75rem; align-items: center; flex-wrap: wrap;">
                                    <div style="flex: 1; min-width: 250px; position: relative;">
                                        <input type="text" class="field-input field-input-sm"
                                               placeholder="Search business partners..." @oninput="OnPaymentBPSearchInput"
                                               value="@paymentBPSearchTerm" />
                                        @if (!string.IsNullOrEmpty(paymentBPSearchTerm))
                                        {
                                            <button type="button"
                                                    style="position:absolute; right:8px; top:50%; transform:translateY(-50%); background:none; border:none; color:#9ca3af; cursor:pointer; font-size:.85rem;"
                                                    @onclick="() => { paymentBPSearchTerm = string.Empty; }">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                    </div>
                                    <span style="font-size: .82rem; color: #6b7280;">
                                        <strong>@allowedPaymentBPs.Count</strong> selected out of @cachedBusinessPartners.Count
                                    </span>
                                </div>

                                <!-- Selected BPs chips -->
                                @if (allowedPaymentBPs.Any())
                                {
                                    <div
                                        style="display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: .75rem; max-height: 120px; overflow-y: auto; padding: .5rem; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px;">
                                        @foreach (var bpCode in allowedPaymentBPs)
                                        {
                                            var bp = cachedBusinessPartners.FirstOrDefault(b => b.CardCode == bpCode);
                                            <span
                                                style="display:inline-flex; align-items:center; gap:.3rem; background:#d1fae5; color:#065f46; font-size:.78rem; font-weight:500; padding:.2rem .5rem .2rem .6rem; border-radius:5px;">
                                                @bpCode @(bp != null ? $"- {bp.CardName}" : "")
                                                <button type="button"
                                                        style="background:none; border:none; color:#065f46; cursor:pointer; padding:0; font-size:.7rem; line-height:1; opacity:.7;"
                                                        @onclick="() => TogglePaymentBP(bpCode)">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </span>
                                        }
                                    </div>
                                }

                                <!-- BP list with checkboxes -->
                                <div
                                    style="max-height: 350px; overflow-y: auto; border: 1px solid #e5e7eb; border-radius: 8px; background: #fff;">
                                    @{
                                        var filteredBPs = string.IsNullOrWhiteSpace(paymentBPSearchTerm)
                                        ? cachedBusinessPartners
                                        : cachedBusinessPartners.Where(bp =>
                                        (bp.CardCode?.Contains(paymentBPSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                                        (bp.CardName?.Contains(paymentBPSearchTerm, StringComparison.OrdinalIgnoreCase) ??
                                        false)).ToList();
                                    }
                                    @if (!filteredBPs.Any())
                                    {
                                        <div style="text-align:center; padding:2rem; color:#9ca3af; font-size:.85rem;">
                                            <i class="bi bi-search" style="font-size:1.5rem; display:block; margin-bottom:.5rem;"></i>
                                            @if (!cachedBusinessPartners.Any())
                                            {
                                                <span>No business partners found. Please sync from the Data Sync tab.</span>
                                            }
                                            else
                                            {
                                                <span>No business partners match your search.</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        @foreach (var bp in filteredBPs)
                                        {
                                            var isSelected = allowedPaymentBPs.Contains(bp.CardCode);
                                            <label
                                                style="display:flex; align-items:center; gap:.6rem; padding:.55rem .85rem; cursor:pointer; border-bottom:1px solid #f3f4f6; transition:background .12s; @(isSelected ? "background:#f0fdf4;" : "")"
                                                class="bp-check-row">
                                                <input type="checkbox" checked="@isSelected" @onchange="() => TogglePaymentBP(bp.CardCode)"
                                                       style="accent-color:#059669; width:16px; height:16px;" />
                                                <div style="flex:1; min-width:0;">
                                                    <div style="font-size:.88rem; font-weight:600; color:#1a1a2e;">@bp.CardCode</div>
                                                    <div
                                                        style="font-size:.78rem; color:#6b7280; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                                        @bp.CardName</div>
                                                    </div>
                                                    @if (bp.Balance > 0)
                                                    {
                                                        <span
                                                            style="font-size:.72rem; background:#fef3c7; color:#92400e; padding:.1rem .4rem; border-radius:4px; font-weight:500; white-space:nowrap;">
                                                            Bal: @bp.Balance?.ToString("N2")
                                                        </span>
                                                    }
                                                </label>
                                            }
                                        }
                                    </div>

                                    @if (allowedPaymentBPs.Any())
                                    {
                                        <div style="margin-top:.5rem; display:flex; justify-content:flex-end;">
                                            <button type="button"
                                                    style="background:none; border:1px solid #fecaca; color:#dc2626; font-size:.78rem; padding:.3rem .7rem; border-radius:6px; cursor:pointer;"
                                                    @onclick="ClearAllPaymentBPs">
                                                <i class="bi bi-x-circle me-1"></i>Clear All
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
        else if (selectedCategory == SAPCategory)
                    {
                        <!-- SAP Connection Settings Section -->
                        <div class="settings-section" style="animation-delay: 0.05s;">
                            <div class="section-header">
                                <div class="section-icon" style="background: linear-gradient(135deg, #2563eb, #3b82f6);">
                                    <i class="bi bi-cloud-arrow-up" style="color: white;"></i>
                                </div>
                                <div>
                                    <h5 class="section-title">SAP Business One Connection</h5>
                                    <p class="section-desc">Configure the connection to your SAP Business One Service Layer.</p>
                                </div>
                            </div>

                            @if (isLoadingSAPSettings)
                            {
                                <div style="text-align:center; padding:2rem;">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                                    <MudText Typo="Typo.body2" Class="mt-2">Loading SAP settings...</MudText>
                                </div>
                            }
                            else
                            {
                                <div class="setting-items">
                                    <!-- Connection Status -->
                                    @if (sapConnectionTested)
                                    {
                                        <div class="settings-alert @(sapConnectionSuccess ? "settings-alert-success" : "settings-alert-error")"
                                             style="margin-bottom: 1rem;">
                                            <i class="bi @(sapConnectionSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                            <span>@sapConnectionMessage</span>
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                                                           OnClick="() => sapConnectionTested = false" Size="Size.Small" />
                                        </div>
                                    }

                                    <!-- Service Layer URL -->
                                    <div class="setting-item">
                                        <div class="setting-info">
                                            <label class="setting-label">
                                                <i class="bi bi-link-45deg me-1"></i>Service Layer URL
                                            </label>
                                            <span class="setting-desc">The base URL for SAP Business One Service Layer (e.g.
                                                https://server:50000/b1s/v1/)</span>
                                            </div>
                                            <div class="setting-control" style="min-width: 350px;">
                                                <MudTextField @bind-Value="sapServiceLayerUrl" Label="Service Layer URL"
                                                              Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="https://server:50000/b1s/v1/"
                                                              FullWidth="true" />
                                            </div>
                                        </div>

                                        <!-- Company Database -->
                                        <div class="setting-item">
                                            <div class="setting-info">
                                                <label class="setting-label">
                                                    <i class="bi bi-database me-1"></i>Company Database
                                                </label>
                                                <span class="setting-desc">The SAP Business One company database name.</span>
                                            </div>
                                            <div class="setting-control" style="min-width: 350px;">
                                                <MudTextField @bind-Value="sapCompanyDB" Label="Company Database" Variant="Variant.Outlined"
                                                              Margin="Margin.Dense" Placeholder="COMPANY_DB" FullWidth="true" />
                                            </div>
                                        </div>

                                        <!-- Username -->
                                        <div class="setting-item">
                                            <div class="setting-info">
                                                <label class="setting-label">
                                                    <i class="bi bi-person me-1"></i>Username
                                                </label>
                                                <span class="setting-desc">SAP Business One service user account.</span>
                                            </div>
                                            <div class="setting-control" style="min-width: 350px;">
                                                <MudTextField @bind-Value="sapUsername" Label="Username" Variant="Variant.Outlined"
                                                              Margin="Margin.Dense" Placeholder="manager" FullWidth="true" />
                                            </div>
                                        </div>

                                        <!-- Password -->
                                        <div class="setting-item">
                                            <div class="setting-info">
                                                <label class="setting-label">
                                                    <i class="bi bi-key me-1"></i>Password
                                                </label>
                                                <span class="setting-desc">SAP Business One service user password. Leave blank to keep the
                                                    current password.</span>
                                                </div>
                                                <div class="setting-control" style="min-width: 350px;">
                                                    <MudTextField @bind-Value="sapPassword" Label="Password" Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense" Placeholder="Enter new password"
                                                                  InputType="@(showSAPPassword ? InputType.Text : InputType.Password)"
                                                                  Adornment="Adornment.End"
                                                                  AdornmentIcon="@(showSAPPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                                  OnAdornmentClick="() => showSAPPassword = !showSAPPassword" FullWidth="true" />
                                                </div>
                                            </div>

                                            <!-- Test Connection -->
                                            <div class="setting-item">
                                                <div class="setting-info">
                                                    <label class="setting-label">
                                                        <i class="bi bi-plug me-1"></i>Connection Test
                                                    </label>
                                                    <span class="setting-desc">Verify the SAP connection with the current saved credentials.</span>
                                                </div>
                                                <div class="setting-control">
                                                    <MudCheckBox @bind-Value="sapTestOnSave" Label="Test connection on save" Dense="true" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Action Buttons -->
                                        <div
                                            style="display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #e5e7eb;">
                                            <MudButton OnClick="TestSAPConnection" Variant="Variant.Outlined" Color="Color.Primary"
                                                       Disabled="@isSAPTesting" StartIcon="@Icons.Material.Filled.NetworkCheck">
                                                @if (isSAPTesting)
                                                {
                                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                                }
                                                Test Connection
                                            </MudButton>
                                            <MudButton OnClick="SaveSAPSettings" Variant="Variant.Filled" Color="Color.Primary"
                                                       Disabled="@(isSAPSaving || string.IsNullOrWhiteSpace(sapServiceLayerUrl) || string.IsNullOrWhiteSpace(sapCompanyDB) || string.IsNullOrWhiteSpace(sapUsername))"
                                                       StartIcon="@Icons.Material.Filled.Save">
                                                @if (isSAPSaving)
                                                {
                                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                                }
                                                Save SAP Settings
                                            </MudButton>
                                        </div>
                                    }
                                </div>
                            }
        else if (selectedCategory == DangerZoneCategory)
                            {
                                <!-- Danger Zone Section -->
                                <div class="settings-section" style="animation-delay: 0.05s; border: 1px solid #dc3545; border-radius: 8px;">
                                    <div class="section-header">
                                        <div class="section-icon" style="background: linear-gradient(135deg, #dc3545, #c82333);">
                                            <i class="bi bi-exclamation-triangle-fill" style="color: white;"></i>
                                        </div>
                                        <div>
                                            <h5 class="section-title" style="color: #dc3545;">Danger Zone</h5>
                                            <p class="section-desc">Irreversible actions that affect your entire database. Proceed with extreme
                                                caution.</p>
                                            </div>
                                        </div>

                                        <div class="setting-items">
                                            <div class="setting-item"
                                                 style="border: 1px solid #dc354544; border-radius: 8px; padding: 1.5rem; background: #dc354508;">
                                                <div class="setting-info" style="flex: 1;">
                                                    <label class="setting-label" style="color: #dc3545; font-weight: 600; font-size: 1rem;">
                                                        <i class="bi bi-database-x me-2"></i>Reset Database
                                                    </label>
                                                    <span class="setting-desc" style="margin-top: 0.5rem; display: block;">
                                                        Permanently delete all transactional data including invoices, orders, payments,
                                                        products, transfers, and audit logs. Admin user accounts will be preserved.
                                                        <strong>This action cannot be undone.</strong> Consider creating a backup first.
                                                    </span>
                                                </div>
                                                <div class="setting-control">
                                                    <MudButton Class="btn-danger-action"
                                                               Style="background: #dc3545; color: white; border: none; padding: 0.5rem 1.25rem; border-radius: 6px; font-weight: 600;"
                                                               OnClick="ShowResetConfirmation" Disabled="@isResettingDatabase">
                                                        @if (isResettingDatabase)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                                            <span>Resetting...</span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-trash3 me-1"></i>
                                                            <span>Reset Database</span>
                                                        }
                                                    </MudButton>
                                                </div>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrEmpty(resetMessage))
                                        {
                                            <div class="settings-alert @(resetSuccess ? "settings-alert-success" : "settings-alert-error") mt-3">
                                                <i class="bi @(resetSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                                <span>@resetMessage</span>
                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                                                               OnClick="() => resetMessage = null" Size="Size.Small" />
                                            </div>
                                        }
                                    </div>
                                }
        else if (selectedCategory == DataManagementCategory)
                                {
                                    <!-- Data Management Section -->
                                    <div class="settings-section" style="animation-delay: 0.05s;">
                                        <div class="section-header">
                                            <div class="section-icon section-icon-blue">
                                                <i class="bi bi-cloud-arrow-down"></i>
                                            </div>
                                            <div>
                                                <h5 class="section-title">Data Synchronization</h5>
                                                <p class="section-desc">Manually refresh cached data from SAP. Use when data has changed in the
                                                    source system.</p>
                                                </div>
                                            </div>

                                            <div class="sync-grid">
                                                <!-- Products -->
                                                <div class="sync-card">
                                                    <div class="sync-card-icon" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                                                        <i class="bi bi-box-seam"></i>
                                                    </div>
                                                    <div class="sync-card-body">
                                                        <h6>Products</h6>
                                                        <p>Sync product catalog from SAP</p>
                                                        @if (productsLastSync.HasValue)
                                                        {
                                                            <span class="sync-timestamp">
                                                                <i class="bi bi-clock-history"></i> @productsLastSync.Value.ToString("dd MMM yyyy HH:mm")
                                                            </span>
                                                        }
                                                    </div>
                                                    <MudButton Class="btn-sync" OnClick="RefreshProducts" Disabled="@isRefreshingProducts">
                                                        @if (isRefreshingProducts)
                                                        {
                                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        }
                                                    </MudButton>
                                                </div>

                                                <!-- Prices -->
                                                <div class="sync-card">
                                                    <div class="sync-card-icon" style="background: linear-gradient(135deg, #11998e, #38ef7d);">
                                                        <i class="bi bi-tag"></i>
                                                    </div>
                                                    <div class="sync-card-body">
                                                        <h6>Prices</h6>
                                                        <p>Sync item prices from SAP</p>
                                                        @if (pricesLastSync.HasValue)
                                                        {
                                                            <span class="sync-timestamp">
                                                                <i class="bi bi-clock-history"></i> @pricesLastSync.Value.ToString("dd MMM yyyy HH:mm")
                                                            </span>
                                                        }
                                                    </div>
                                                    <MudButton Class="btn-sync" OnClick="RefreshPrices" Disabled="@isRefreshingPrices">
                                                        @if (isRefreshingPrices)
                                                        {
                                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        }
                                                    </MudButton>
                                                </div>

                                                <!-- Business Partners -->
                                                <div class="sync-card">
                                                    <div class="sync-card-icon" style="background: linear-gradient(135deg, #f093fb, #f5576c);">
                                                        <i class="bi bi-people"></i>
                                                    </div>
                                                    <div class="sync-card-body">
                                                        <h6>Business Partners</h6>
                                                        <p>Sync customers and suppliers</p>
                                                        @if (bpLastSync.HasValue)
                                                        {
                                                            <span class="sync-timestamp">
                                                                <i class="bi bi-clock-history"></i> @bpLastSync.Value.ToString("dd MMM yyyy HH:mm")
                                                            </span>
                                                        }
                                                    </div>
                                                    <MudButton Class="btn-sync" OnClick="RefreshBusinessPartners" Disabled="@isRefreshingBP">
                                                        @if (isRefreshingBP)
                                                        {
                                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        }
                                                    </MudButton>
                                                </div>

                                                <!-- Warehouses -->
                                                <div class="sync-card">
                                                    <div class="sync-card-icon" style="background: linear-gradient(135deg, #f7971e, #ffd200);">
                                                        <i class="bi bi-building"></i>
                                                    </div>
                                                    <div class="sync-card-body">
                                                        <h6>Warehouses</h6>
                                                        <p>Sync warehouse list from SAP</p>
                                                        @if (warehousesLastSync.HasValue)
                                                        {
                                                            <span class="sync-timestamp">
                                                                <i class="bi bi-clock-history"></i> @warehousesLastSync.Value.ToString("dd MMM yyyy HH:mm")
                                                            </span>
                                                        }
                                                    </div>
                                                    <MudButton Class="btn-sync" OnClick="RefreshWarehouses" Disabled="@isRefreshingWarehouses">
                                                        @if (isRefreshingWarehouses)
                                                        {
                                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        }
                                                    </MudButton>
                                                </div>

                                                <!-- Cost Centres -->
                                                <div class="sync-card">
                                                    <div class="sync-card-icon" style="background: linear-gradient(135deg, #4facfe, #00f2fe);">
                                                        <i class="bi bi-diagram-3"></i>
                                                    </div>
                                                    <div class="sync-card-body">
                                                        <h6>Cost Centres</h6>
                                                        <p>Sync profit centers from SAP</p>
                                                        @if (costCentresLastSync.HasValue)
                                                        {
                                                            <span class="sync-timestamp">
                                                                <i class="bi bi-clock-history"></i> @costCentresLastSync.Value.ToString("dd MMM yyyy HH:mm")
                                                            </span>
                                                        }
                                                    </div>
                                                    <MudButton Class="btn-sync" OnClick="RefreshCostCentres" Disabled="@isRefreshingCostCentres">
                                                        @if (isRefreshingCostCentres)
                                                        {
                                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        }
                                                    </MudButton>
                                                </div>

                                                <!-- Refresh All -->
                                                <div class="sync-card sync-card-all">
                                                    <div class="sync-card-icon" style="background: linear-gradient(135deg, #1a1a2e, #16213e);">
                                                        <i class="bi bi-arrow-clockwise"></i>
                                                    </div>
                                                    <div class="sync-card-body">
                                                        <h6>Sync Everything</h6>
                                                        <p>Refresh all master data in one go</p>
                                                    </div>
                                                    <MudButton Class="btn-sync btn-sync-all" OnClick="RefreshAllData" Disabled="@isRefreshingAll">
                                                        @if (isRefreshingAll)
                                                        {
                                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-arrow-repeat"></i>
                                                        }
                                                    </MudButton>
                                                </div>
                                            </div>

                                            @if (!string.IsNullOrEmpty(refreshMessage))
                                            {
                                                <div class="settings-alert @(refreshSuccess ? "settings-alert-success" : "settings-alert-error") mt-3">
                                                    <i class="bi @(refreshSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                                    <span>@refreshMessage</span>
                                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Class="settings-alert-close"
                                                                   OnClick="() => refreshMessage = null" Size="Size.Small" />
                                                </div>
                                            }
                                        </div>
                                    }
        else if (categorySettings.Any())
                                    {
                                        <!-- Dynamic Settings -->
                                        <div class="settings-section" style="animation-delay: 0.05s;">
                                            <div class="section-header">
                                                <div class="section-icon @GetSectionIconClass(selectedCategory)">
                                                    <i class="bi @GetCategoryIcon(selectedCategory)"></i>
                                                </div>
                                                <div>
                                                    <h5 class="section-title">@selectedCategory</h5>
                                                    <p class="section-desc">@GetCategoryDescription(selectedCategory)</p>
                                                </div>
                                            </div>

                                            <div class="setting-items">
                                                @foreach (var setting in categorySettings)
                                                {
                                                    <div class="setting-item">
                                                        <div class="setting-info">
                                                            <label class="setting-label">@FormatLabel(setting.Key)</label>
                                                            @if (!string.IsNullOrEmpty(setting.Description))
                                                            {
                                                                <span class="setting-desc">@setting.Description</span>
                                                            }
                                                            @if (setting.LastModifiedBy != null)
                                                            {
                                                                <span class="setting-meta">
                                                                    <i class="bi bi-pencil-square"></i> @setting.LastModifiedBy &middot;
                                                                    @setting.LastModifiedAt.ToString("dd MMM yyyy HH:mm")
                                                                </span>
                                                            }
                                                        </div>
                                                        <div class="setting-control">
                                                            @if (setting.DataType == "bool")
                                                            {
                                                                <label class="toggle-switch">
                                                                    <input type="checkbox" checked="@GetBoolValue(setting.Key)"
                                                                           disabled="@(!setting.IsEditable)"
                                                                           @onchange="e => OnBoolSettingChanged(setting.Key, e)" />
                                                                    <span class="toggle-slider"></span>
                                                                    <span class="toggle-text">@(GetBoolValue(setting.Key) ? "On" : "Off")</span>
                                                                </label>
                                                            }
                                                            else if (setting.DataType == "int")
                                                            {
                                                                <input type="number" class="field-input field-input-sm" value="@GetValue(setting.Key)"
                                                                       disabled="@(!setting.IsEditable)"
                                                                       @onchange="e => OnSettingChanged(setting.Key, e.Value?.ToString())" />
                                                            }
                                                            else if (setting.Key == SettingKeys.PrinterName)
                                                            {
                                                                <select class="field-input field-input-sm" @bind:get="editedValues[setting.Key]"
                                                                        @bind:set="v => OnSettingChanged(setting.Key, v)" disabled="@(!setting.IsEditable)">
                                                                    <option value="">-- Select Printer --</option>
                                                                    @foreach (var printer in installedPrinters)
                                                                    {
                                                                        <option value="@printer">@printer</option>
                                                                    }
                                                                </select>
                                                            }
                                                            else if (setting.Key == SettingKeys.SavedPrinters)
                                                            {
                                                                <div style="display:flex; flex-direction:column; gap:.35rem;">
                                                                    @{
                                                                        var saved = GetSavedPrintersList();
                                                                    }
                                                                    @foreach (var printer in installedPrinters)
                                                                    {
                                                                        <label
                                                                            style="display:flex; align-items:center; gap:.4rem; font-size:.85rem; cursor:pointer;">
                                                                            <input type="checkbox" checked="@saved.Contains(printer)"
                                                                                   @onchange="e => OnSavedPrinterToggled(printer, (bool)(e.Value ?? false))" />
                                                                            @printer
                                                                        </label>
                                                                    }
                                                                    @if (!installedPrinters.Any())
                                                                    {
                                                                        <span style="font-size:.8rem; color:#6b7280;">No printers found on this machine.</span>
                                                                    }
                                                                </div>
                                                            }
                                                            else if (setting.Key == SettingKeys.Theme)
                                                            {
                                                                <select class="field-input field-input-sm" value="@GetValue(setting.Key)"
                                                                        disabled="@(!setting.IsEditable)"
                                                                        @onchange="e => OnSettingChanged(setting.Key, e.Value?.ToString())">
                                                                    <option value="light">Light</option>
                                                                    <option value="dark">Dark</option>
                                                                </select>
                                                            }
                                                            else if (setting.Key == SettingKeys.DateFormat)
                                                            {
                                                                <select class="field-input field-input-sm" value="@GetValue(setting.Key)"
                                                                        disabled="@(!setting.IsEditable)"
                                                                        @onchange="e => OnSettingChanged(setting.Key, e.Value?.ToString())">
                                                                    <option value="dd MMM yyyy">04 Jan 2026</option>
                                                                    <option value="dd/MM/yyyy">04/01/2026</option>
                                                                    <option value="MM/dd/yyyy">01/04/2026</option>
                                                                    <option value="yyyy-MM-dd">2026-01-04</option>
                                                                </select>
                                                            }
                                                            else
                                                            {
                                                                <input type="text" class="field-input field-input-sm" value="@GetValue(setting.Key)"
                                                                       disabled="@(!setting.IsEditable)"
                                                                       @onchange="e => OnSettingChanged(setting.Key, e.Value?.ToString())" />
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="settings-empty">
                                            <i class="bi bi-inbox"></i>
                                            <p>No settings available for this category.</p>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Reset Database Confirmation Dialog -->
                        <MudOverlay Visible="@showResetConfirmation" DarkBackground="true" ZIndex="9999" OnClick="@(() => { })">
                            <MudPaper Elevation="8"
                                      Style="border-radius: 12px; padding: 2rem; max-width: 500px; width: 90vw; border: 2px solid #dc3545;">
                                <div style="text-align: center; margin-bottom: 1.5rem;">
                                    <div
                                        style="width: 64px; height: 64px; border-radius: 50%; background: #dc354515; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
                                        <MudIcon Icon="@Icons.Material.Filled.Warning" Style="font-size: 2rem; color: #dc3545;" />
                                    </div>
                                    <MudText Typo="Typo.h5" Style="color: #dc3545;">Reset Database</MudText>
                                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary, #666);">
                                        This will permanently delete <strong>all</strong> transactional data. This action cannot be undone.
                                    </MudText>
                                </div>

                                <div
                                    style="background: #dc354508; border: 1px solid #dc354530; border-radius: 8px; padding: 1rem; margin-bottom: 1.5rem;">
                                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary, #666); margin-bottom: 0.5rem;">
                                        The following data will be deleted:
                                    </MudText>
                                    <ul
                                        style="font-size: 0.85rem; color: var(--mud-palette-text-secondary, #666); margin: 0; padding-left: 1.5rem;">
                                        <li>All invoices, sales orders, and purchase orders</li>
                                        <li>All payments and credit notes</li>
                                        <li>All products and price lists</li>
                                        <li>All inventory transfers and stock reservations</li>
                                        <li>All audit logs and notifications</li>
                                        <li>All webhooks, templates, and system configs</li>
                                    </ul>
                                    <MudText Typo="Typo.caption"
                                             Style="color: var(--mud-palette-text-primary, #333); margin-top: 0.75rem; font-weight: 600;">
                                        <MudIcon Icon="@Icons.Material.Filled.ShieldMoon" Size="Size.Small" Class="me-1" />Admin user accounts
                                        will be preserved.
                                    </MudText>
                                </div>

                                <div style="margin-bottom: 1.5rem;">
                                    <MudTextField @bind-Value="resetConfirmationText" Label="Type RESET to confirm"
                                                  Placeholder="Type RESET here" Variant="Variant.Outlined" Immediate="true" FullWidth="true"
                                                  Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                                </div>

                                <div style="display: flex; gap: 0.75rem; justify-content: flex-end;">
                                    <MudButton OnClick="CancelReset" Variant="Variant.Outlined">
                                        Cancel
                                    </MudButton>
                                    <MudButton OnClick="ConfirmResetDatabase"
                                               Disabled="@(resetConfirmationText != "RESET" || isResettingDatabase)" Variant="Variant.Filled"
                                               Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">
                                        @if (isResettingDatabase)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                        }
                                        Reset Database
                                    </MudButton>
                                </div>
                            </MudPaper>
                        </MudOverlay>

@code {
    private const string DataManagementCategory = "Data Management";
    private const string DangerZoneCategory = "Danger Zone";
    private const string PaymentsCategory = "Payments";
    private const string SAPCategory = "SAP Connection";

    private List<AppSetting> allSettings = new();
    private List<AppSetting> categorySettings = new();
    private List<string> categories = new();
    private string selectedCategory = SettingCategories.General;
    private Dictionary<string, string> editedValues = new();
    private bool hasChanges = false;
    private bool isLoading = true;
    private bool isSaving = false;
    private string? successMessage;
    private string? errorMessage;
    private string currentUsername = "Unknown";

    // Payment settings fields
    private string paymentGLAccount = "";
    private CachedGLAccount? selectedGLAccount;
    private string defaultPaymentMethod = "cash";
    private List<string> allowedPaymentBPs = new();
    private string paymentBPSearchTerm = "";
    private List<CachedGLAccount> cachedGLAccounts = new();
    private List<CachedBusinessPartner> cachedBusinessPartners = new();

    // Exclude expense, revenue, and controlling accounts — only show cash/bank/other
    private static readonly HashSet<string> _excludedAccountTypes = new(StringComparer.OrdinalIgnoreCase)
{
"at_Expenses", "at_Revenues"
    };

    private IEnumerable<CachedGLAccount> paymentEligibleGLAccounts =>
    cachedGLAccounts.Where(gl => string.IsNullOrEmpty(gl.AccountType) || !_excludedAccountTypes.Contains(gl.AccountType));

    private static string FormatAccountType(string? accountType) => accountType switch
    {
        "at_Other" => "Other",
        "at_Expenses" => "Expense",
        "at_Revenues" => "Revenue",
        _ => accountType ?? "Unknown"
    };

    // Data Management fields
    private bool isRefreshingProducts = false;
    private bool isRefreshingPrices = false;
    private bool isRefreshingBP = false;
    private bool isRefreshingWarehouses = false;
    private bool isRefreshingCostCentres = false;
    private bool isRefreshingAll = false;
    private string? refreshMessage;
    private bool refreshSuccess = false;
    private DateTime? productsLastSync;
    private DateTime? pricesLastSync;
    private DateTime? bpLastSync;
    private DateTime? warehousesLastSync;
    private DateTime? costCentresLastSync;

    // Database reset fields
    private bool showResetConfirmation = false;
    private bool isResettingDatabase = false;
    private string resetConfirmationText = string.Empty;
    private string? resetMessage;
    private bool resetSuccess = false;

    // SAP settings fields
    private string sapServiceLayerUrl = string.Empty;
    private string sapCompanyDB = string.Empty;
    private string sapUsername = string.Empty;
    private string sapPassword = string.Empty;
    private bool showSAPPassword = false;
    private bool sapTestOnSave = true;
    private bool isLoadingSAPSettings = false;
    private bool isSAPSaving = false;
    private bool isSAPTesting = false;
    private bool sapConnectionTested = false;
    private bool sapConnectionSuccess = false;
    private string? sapConnectionMessage;

    // Printer discovery
    private List<string> installedPrinters = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUser();
        await LoadSettings();
        await LoadLastSyncTimes();
        await LoadPaymentSettingsData();
        await LoadSAPSettings();
        LoadInstalledPrinters();
        await LogAudit(AuditActions.ViewSettings);
    }

    private void LoadInstalledPrinters()
    {
        try
        {
            installedPrinters = PrinterService.GetInstalledPrinters();
        }
        catch
        {
            installedPrinters = new();
        }
    }

    private async Task LoadCurrentUser()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUsername = authState.User.Identity?.Name ?? "Unknown";
    }

    private async Task LoadLastSyncTimes()
    {
        productsLastSync = CacheService.GetLastRefreshTime("Products_All");
        pricesLastSync = CacheService.GetLastRefreshTime("ItemPrices");
        bpLastSync = CacheService.GetLastRefreshTime("BusinessPartners");
        warehousesLastSync = CacheService.GetLastRefreshTime("Warehouses");
        costCentresLastSync = CacheService.GetLastRefreshTime("CostCentres");
        await Task.CompletedTask;
    }

    private async Task LoadSettings()
    {
        isLoading = true;
        try
        {
            await SettingsService.InitializeDefaultSettingsAsync();
            allSettings = await SettingsService.GetAllSettingsAsync();
            categories = allSettings.Select(s => s.Category).Distinct()
                .Where(c => c != PaymentsCategory)
                .ToList();
            editedValues = allSettings.ToDictionary(s => s.Key, s => s.Value);
            SelectCategory(selectedCategory);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load settings: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectCategory(string category)
    {
        selectedCategory = category;
        categorySettings = allSettings.Where(s => s.Category == category).ToList();
    }

    private string GetValue(string key)
    {
        return editedValues.TryGetValue(key, out var value) ? value : string.Empty;
    }

    private bool GetBoolValue(string key)
    {
        var value = GetValue(key);
        return bool.TryParse(value, out var result) && result;
    }

    private List<string> GetSavedPrintersList()
    {
        var json = GetValue(SettingKeys.SavedPrinters);
        if (string.IsNullOrWhiteSpace(json) || json == "[]") return new();
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? new();
        }
        catch { return new(); }
    }

    private void OnSavedPrinterToggled(string printer, bool isChecked)
    {
        var list = GetSavedPrintersList();
        if (isChecked && !list.Contains(printer))
            list.Add(printer);
        else if (!isChecked)
            list.Remove(printer);
        editedValues[SettingKeys.SavedPrinters] = System.Text.Json.JsonSerializer.Serialize(list);
        hasChanges = true;
    }

    private void OnBoolSettingChanged(string key, ChangeEventArgs e)
    {
        var newValue = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;
        editedValues[key] = newValue.ToString().ToLower();
        hasChanges = true;
    }

    private void OnSettingChanged(string key, string? value)
    {
        if (value == null) return;
        editedValues[key] = value;
        hasChanges = true;
    }

    private async Task SaveSettings()
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            // Check if theme was changed before saving
            var themeChanged = editedValues.TryGetValue(SettingKeys.Theme, out var newTheme);

            await SettingsService.SaveSettingsAsync(editedValues, currentUsername);
            await AppSettingsProvider.ReloadAsync();

            // Apply theme change to UI immediately
            if (themeChanged && !string.IsNullOrEmpty(newTheme))
            {
                await JS.InvokeVoidAsync("themeManager.setTheme", newTheme, true);
                await ThemeService.SetThemeAsync(newTheme);
            }

            await LoadSettings();
            hasChanges = false;
            successMessage = "Settings saved successfully!";
            await LogAudit(AuditActions.UpdateSettings, details: $"Updated {editedValues.Count} settings");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save settings: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetCategoryIcon(string category) => category switch
    {
        SettingCategories.General => "bi-sliders2",
        SettingCategories.API => "bi-cloud-arrow-up",
        SettingCategories.Display => "bi-palette",
        SettingCategories.Audit => "bi-journal-text",
        SettingCategories.Security => "bi-shield-lock",
        SettingCategories.Printing => "bi-printer",
        SettingCategories.Payments => "bi-cash-coin",
        "Data Management" => "bi-arrow-repeat",
        "User Management" => "bi-person-plus",
        _ => "bi-sliders"
    };

    private string GetSectionIconClass(string category) => category switch
    {
        SettingCategories.General => "section-icon-dark",
        SettingCategories.API => "section-icon-blue",
        SettingCategories.Display => "section-icon-purple",
        SettingCategories.Audit => "section-icon-teal",
        SettingCategories.Security => "section-icon-red",
        SettingCategories.Printing => "section-icon-amber",
        _ => "section-icon-dark"
    };

    private string GetCategoryDescription(string category) => category switch
    {
        SettingCategories.General => "Company defaults, warehouse, currency, and date formatting.",
        SettingCategories.API => "Backend API connection, caching, and synchronization intervals.",
        SettingCategories.Display => "Page layout preferences, theme, and display options.",
        SettingCategories.Audit => "Audit logging configuration and retention policies.",
        SettingCategories.Security => "Security policies and access control settings.",
        SettingCategories.Printing => "Invoice printing preferences and printer configuration.",
        SettingCategories.Payments => "Default G/L account and allowed business partners for incoming payments.",
        _ => "Configure settings for this category."
    };

    private string FormatLabel(string key)
    {
        return System.Text.RegularExpressions.Regex.Replace(key, "(\\B[A-Z])", " $1");
    }

    private async Task LogAudit(string action, string? details = null)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var role = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Unknown";
        await AuditService.LogAsync(action, currentUsername, role, "Settings", null, details, "/settings");
    }

    // Data Management Methods
    private async Task RefreshProducts()
    {
        isRefreshingProducts = true;
        refreshMessage = null;
        StateHasChanged();

        try
        {
            var count = await CacheService.SyncProductsFromApiAsync();
            refreshSuccess = true;
            refreshMessage = $"Successfully synced {count} products from SAP.";
            productsLastSync = DateTime.Now;
            await LogAudit(AuditActions.UpdateSettings, $"Refreshed products cache: {count} items synced");
        }
        catch (Exception ex)
        {
            refreshSuccess = false;
            refreshMessage = $"Failed to refresh products: {ex.Message}";
        }
        finally
        {
            isRefreshingProducts = false;
            StateHasChanged();
        }
    }

    private async Task RefreshPrices()
    {
        isRefreshingPrices = true;
        refreshMessage = null;
        StateHasChanged();

        try
        {
            var count = await CacheService.SyncPricesFromApiAsync();
            refreshSuccess = true;
            refreshMessage = $"Successfully synced {count} prices from SAP.";
            pricesLastSync = DateTime.Now;
            await LogAudit(AuditActions.UpdateSettings, $"Refreshed prices cache: {count} items synced");
        }
        catch (Exception ex)
        {
            refreshSuccess = false;
            refreshMessage = $"Failed to refresh prices: {ex.Message}";
        }
        finally
        {
            isRefreshingPrices = false;
            StateHasChanged();
        }
    }

    private async Task RefreshBusinessPartners()
    {
        isRefreshingBP = true;
        refreshMessage = null;
        StateHasChanged();

        try
        {
            var count = await CacheService.SyncBusinessPartnersFromApiAsync();
            refreshSuccess = true;
            refreshMessage = $"Successfully synced {count} business partners from SAP.";
            bpLastSync = DateTime.Now;
            await LogAudit(AuditActions.UpdateSettings, $"Refreshed business partners cache: {count} items synced");
        }
        catch (Exception ex)
        {
            refreshSuccess = false;
            refreshMessage = $"Failed to refresh business partners: {ex.Message}";
        }
        finally
        {
            isRefreshingBP = false;
            StateHasChanged();
        }
    }

    private async Task RefreshWarehouses()
    {
        isRefreshingWarehouses = true;
        refreshMessage = null;
        StateHasChanged();

        try
        {
            var count = await CacheService.SyncWarehousesFromApiAsync();
            refreshSuccess = true;
            refreshMessage = $"Successfully synced {count} warehouses from SAP.";
            warehousesLastSync = DateTime.Now;
            await LogAudit(AuditActions.UpdateSettings, $"Refreshed warehouses cache: {count} items synced");
        }
        catch (Exception ex)
        {
            refreshSuccess = false;
            refreshMessage = $"Failed to refresh warehouses: {ex.Message}";
        }
        finally
        {
            isRefreshingWarehouses = false;
            StateHasChanged();
        }
    }

