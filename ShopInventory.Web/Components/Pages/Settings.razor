    // SAP Settings Methods
    private async Task LoadSAPSettings()
    {
        isLoadingSAPSettings = true;
        try
        {
            var settings = await SAPSettingsService.GetSettingsAsync();
            if (settings != null)
            {
                sapServiceLayerUrl = settings.ServiceLayerUrl ?? string.Empty;
                sapCompanyDB = settings.CompanyDB ?? string.Empty;
                sapInvoiceSeriesName = settings.InvoiceSeriesName ?? string.Empty;
                sapUsername = settings.UserName ?? string.Empty;
                sapPassword = string.Empty; // Never pre-fill password
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load SAP settings: {ex.Message}";
        }
        finally
        {
            isLoadingSAPSettings = false;
        }
    }

    private async Task SaveSAPSettings()
    {
        isSAPSaving = true;
        sapConnectionTested = false;
        StateHasChanged();

        try
        {
            var request = new SAPSettingsUpdateRequest
            {
                ServiceLayerUrl = sapServiceLayerUrl.Trim(),
                CompanyDB = sapCompanyDB.Trim(),
                InvoiceSeriesName = sapInvoiceSeriesName.Trim(),
                UserName = sapUsername.Trim(),
                Password = sapPassword,
                TestConnection = sapTestOnSave
            };

            var result = await SAPSettingsService.UpdateSettingsAsync(request);

            sapConnectionTested = true;
            sapConnectionSuccess = result.Success;
            sapConnectionMessage = result.Message;

            if (result.Success)
            {
                sapPassword = string.Empty; // Clear password after successful save
                await LogAudit(AuditActions.UpdateSettings, $"Updated SAP connection settings (CompanyDB: {sapCompanyDB})");
            }
        }
        catch (Exception ex)
        {
            sapConnectionTested = true;
            sapConnectionSuccess = false;
            sapConnectionMessage = $"Error saving SAP settings: {ex.Message}";
        }
        finally
        {
            isSAPSaving = false;
            StateHasChanged();
        }
    }

    private async Task TestSAPConnection()
    {
        isSAPTesting = true;
        sapConnectionTested = false;
        StateHasChanged();

        try
        {
            var request = new SAPTestConnectionRequest
            {
                ServiceLayerUrl = sapServiceLayerUrl?.Trim() ?? string.Empty,
                CompanyDB = sapCompanyDB?.Trim() ?? string.Empty,
