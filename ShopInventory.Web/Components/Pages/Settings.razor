    private async Task RefreshAllData()
    {
        isRefreshingAll = true;
        refreshMessage = null;
        StateHasChanged();

        try
        {
            var results = new List<string>();

            try
            {
                var productsCount = await CacheService.SyncProductsFromApiAsync();
                results.Add($"Products: {productsCount}");
                productsLastSync = DateTime.Now;
            }
            catch (Exception ex)
            {
                var inner = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
                results.Add($"Products: FAILED - {inner}");
            }

            try
            {
                var pricesCount = await CacheService.SyncPricesFromApiAsync();
                results.Add($"Prices: {pricesCount}");
                pricesLastSync = DateTime.Now;
            }
            catch (Exception ex)
            {
                var inner = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
                results.Add($"Prices: FAILED - {inner}");
            }

            try
            {
                var bpCount = await CacheService.SyncBusinessPartnersFromApiAsync();
                results.Add($"Business Partners: {bpCount}");
                bpLastSync = DateTime.Now;
            }
            catch (Exception ex)
            {
                var inner = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
                results.Add($"Business Partners: FAILED - {inner}");
            }

            try
            {
                var warehousesCount = await CacheService.SyncWarehousesFromApiAsync();
                results.Add($"Warehouses: {warehousesCount}");
                warehousesLastSync = DateTime.Now;
            }
            catch (Exception ex)
            {
                var inner = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
                results.Add($"Warehouses: FAILED - {inner}");
            }

            try
            {
                var costCentresCount = await CacheService.SyncCostCentresFromApiAsync();
                results.Add($"Cost Centres: {costCentresCount}");
                costCentresLastSync = DateTime.Now;
            }
            catch (Exception ex)
            {
                var inner = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
                results.Add($"Cost Centres: FAILED - {inner}");
            }

            var failures = results.Where(r => r.Contains("FAILED")).ToList();
            if (failures.Any())
            {
                refreshSuccess = false;
                refreshMessage = $"Sync completed with errors: {string.Join("; ", results)}";
            }
            else
            {
                refreshSuccess = true;
                refreshMessage = $"All data synced successfully. {string.Join(", ", results)}";
                await LogAudit(AuditActions.UpdateSettings, $"Refreshed all cache data: {string.Join(", ", results)}");
            }
        }
        catch (Exception ex)
        {
            refreshSuccess = false;
            var innerMsg = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
            refreshMessage = $"Failed to refresh all data: {innerMsg}";
        }
        finally
        {
            isRefreshingAll = false;
            StateHasChanged();
        }
    }

