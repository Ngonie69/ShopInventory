    private async Task RefreshAllData()
    {
        isRefreshingAll = true;
        refreshMessage = null;
        StateHasChanged();

        try
        {
            var results = new List<string>();

            try
            {
                var productsCount = await CacheService.SyncProductsFromApiAsync();
                results.Add($"Products: {productsCount}");
                productsLastSync = DateTime.Now;
            }
            catch (Exception ex)
            {
                var inner = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
                results.Add($"Products: FAILED - {inner}");
            }

            try
            {
                var pricesCount = await CacheService.SyncPricesFromApiAsync();
                results.Add($"Prices: {pricesCount}");
                pricesLastSync = DateTime.Now;
            }
            catch (Exception ex)
            {
                var inner = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
                results.Add($"Prices: FAILED - {inner}");
            }

            try
            {
                var bpCount = await CacheService.SyncBusinessPartnersFromApiAsync();
                results.Add($"Business Partners: {bpCount}");
                bpLastSync = DateTime.Now;
            }
            catch (Exception ex)
            {
                var inner = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
                results.Add($"Business Partners: FAILED - {inner}");
            }

            try
            {
                var warehousesCount = await CacheService.SyncWarehousesFromApiAsync();
                results.Add($"Warehouses: {warehousesCount}");
                warehousesLastSync = DateTime.Now;
            }
            catch (Exception ex)
            {
                var inner = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
                results.Add($"Warehouses: FAILED - {inner}");
            }

            try
            {
                var costCentresCount = await CacheService.SyncCostCentresFromApiAsync();
                results.Add($"Cost Centres: {costCentresCount}");
                costCentresLastSync = DateTime.Now;
            }
            catch (Exception ex)
            {
                var inner = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
                results.Add($"Cost Centres: FAILED - {inner}");
            }

            var failures = results.Where(r => r.Contains("FAILED")).ToList();
            if (failures.Any())
            {
                refreshSuccess = false;
                refreshMessage = $"Sync completed with errors: {string.Join("; ", results)}";
            }
            else
            {
                refreshSuccess = true;
                refreshMessage = $"All data synced successfully. {string.Join(", ", results)}";
                await LogAudit(AuditActions.UpdateSettings, $"Refreshed all cache data: {string.Join(", ", results)}");
            }
        }
        catch (Exception ex)
        {
            refreshSuccess = false;
            var innerMsg = ex.InnerException?.InnerException?.Message ?? ex.InnerException?.Message ?? ex.Message;
            refreshMessage = $"Failed to refresh all data: {innerMsg}";
        }
        finally
        {
            isRefreshingAll = false;
            StateHasChanged();
        }
    }

    public class NewUserModel
    {
        public string Username { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string Password { get; set; } = string.Empty;
        public string Role { get; set; } = "Cashier";
    }

    // Payment Settings Methods
    private async Task LoadPaymentSettingsData()
    {
        try
        {
            await using var db = await DbContextFactory.CreateDbContextAsync();
            cachedGLAccounts = await db.CachedGLAccounts
            .Where(g => g.IsActive)
            .OrderBy(g => g.Code)
            .ToListAsync();
            cachedBusinessPartners = await db.CachedBusinessPartners
            .Where(bp => bp.IsActive && (bp.CardType == "cCustomer" || bp.CardType == "C"))
            .OrderBy(bp => bp.CardCode)
            .ToListAsync();

            // Load current values from settings
            var glSetting = await SettingsService.GetValueAsync(SettingKeys.IncomingPaymentGLAccount);
            paymentGLAccount = glSetting ?? "";
            selectedGLAccount = cachedGLAccounts.FirstOrDefault(gl => gl.Code == paymentGLAccount);

            var methodSetting = await SettingsService.GetValueAsync(SettingKeys.DefaultPaymentMethod);
            defaultPaymentMethod = methodSetting ?? "cash";

            var bpJson = await SettingsService.GetValueAsync(SettingKeys.AllowedPaymentBusinessPartners);
            if (!string.IsNullOrWhiteSpace(bpJson) && bpJson != "[]")
            {
                try
                {
                    allowedPaymentBPs = System.Text.Json.JsonSerializer.Deserialize<List<string>>(bpJson) ?? new();
                }
                catch { allowedPaymentBPs = new(); }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load payment settings data: {ex.Message}";
        }
    }

    private async Task<IEnumerable<CachedGLAccount>> SearchGLAccountsAsync(string searchText, CancellationToken cancellationToken)
    {
        var eligible = paymentEligibleGLAccounts;
        if (string.IsNullOrWhiteSpace(searchText))
            return eligible.Take(20);

        var term = searchText.ToLower();
        return eligible.Where(gl =>
            (gl.Code?.ToLower().Contains(term) ?? false) ||
            (gl.Name?.ToLower().Contains(term) ?? false))
            .Take(20);
    }

    private async void OnGLAccountSelected(CachedGLAccount? gl)
    {
        selectedGLAccount = gl;
        paymentGLAccount = gl?.Code ?? "";
        await SettingsService.SaveSettingAsync(SettingKeys.IncomingPaymentGLAccount, paymentGLAccount, currentUsername);
        hasChanges = false;
        successMessage = $"G/L Account updated to {(string.IsNullOrEmpty(paymentGLAccount) ? "(none)" : $"{gl?.Code} - {gl?.Name}")}";
        await LogAudit(AuditActions.UpdateSettings, $"Updated incoming payment G/L account to: {paymentGLAccount}");
        StateHasChanged();
    }

    private async void OnDefaultPaymentMethodChanged(ChangeEventArgs e)
    {
        defaultPaymentMethod = e.Value?.ToString() ?? "cash";
        await SettingsService.SaveSettingAsync(SettingKeys.DefaultPaymentMethod, defaultPaymentMethod, currentUsername);
        hasChanges = false;
        var label = defaultPaymentMethod switch
        {
            "cash" => "Cash",
            "transfer" => "Transfer",
            "check" => "Check",
            "credit" => "Credit Card",
            _ => defaultPaymentMethod
        };
        successMessage = $"Default payment method updated to {label}";
        await LogAudit(AuditActions.UpdateSettings, $"Updated default payment method to: {label}");
        StateHasChanged();
    }

    private async void TogglePaymentBP(string cardCode)
    {
        if (allowedPaymentBPs.Contains(cardCode))
            allowedPaymentBPs.Remove(cardCode);
        else
            allowedPaymentBPs.Add(cardCode);

        var json = System.Text.Json.JsonSerializer.Serialize(allowedPaymentBPs);
        await SettingsService.SaveSettingAsync(SettingKeys.AllowedPaymentBusinessPartners, json, currentUsername);
        await LogAudit(AuditActions.UpdateSettings, $"Updated allowed payment business partners ({allowedPaymentBPs.Count} selected)");
        StateHasChanged();
    }

    private async void ClearAllPaymentBPs()
    {
        allowedPaymentBPs.Clear();
        await SettingsService.SaveSettingAsync(SettingKeys.AllowedPaymentBusinessPartners, "[]", currentUsername);
        await LogAudit(AuditActions.UpdateSettings, "Cleared all allowed payment business partners");
        StateHasChanged();
    }

    private void OnPaymentBPSearchInput(ChangeEventArgs e)
    {
        paymentBPSearchTerm = e.Value?.ToString() ?? "";
    }

    // Database Reset Methods
    private void ShowResetConfirmation()
    {
        resetConfirmationText = string.Empty;
        resetMessage = null;
        showResetConfirmation = true;
    }

    private void CancelReset()
    {
        showResetConfirmation = false;
        resetConfirmationText = string.Empty;
    }

    private async Task ConfirmResetDatabase()
    {
        if (resetConfirmationText != "RESET")
            return;

        isResettingDatabase = true;
        showResetConfirmation = false;
        resetMessage = null;
        StateHasChanged();

        try
        {
            var (success, message) = await BackupService.ResetDatabaseAsync();
            resetSuccess = success;
            resetMessage = success
            ? "Database has been reset successfully. All transactional data has been deleted."
                                                                : message;

            if (success)
            {
                await LogAudit(AuditActions.ResetDatabase, "Database reset completed - all transactional data deleted");
            }
        }
        catch (Exception ex)
        {
            resetSuccess = false;
            resetMessage = $"Database reset failed: {ex.Message}";
        }
        finally
        {
            isResettingDatabase = false;
            resetConfirmationText = string.Empty;
            StateHasChanged();
        }
    }
}