            sapConnectionMessage = $"Connection test error: {ex.Message}";
        }
        finally
        {
            isSAPTesting = false;
            StateHasChanged();
        }
    }

    private async Task LoadMobileVersionPolicySettings()
    {
        isLoadingMobileVersionPolicy = true;

        try
        {
            var settings = await MobileVersionPolicySettingsService.GetSettingsAsync(selectedMobileVersionPolicyAppId);
            if (settings == null)
            {
                mobileVersionPolicySaveSucceeded = false;
                mobileVersionPolicyMessage = "Failed to load mobile app policy settings.";
                return;
            }

            if (!string.IsNullOrWhiteSpace(settings.AppId))
            {
                selectedMobileVersionPolicyAppId = settings.AppId;
            }

            mobileVersionPolicyEnabled = settings.Enabled;
            mobileVersionPolicyRequireHeaders = settings.RequireHeaders;
            mobileVersionPolicyLatestVersion = settings.LatestVersion;
            mobileVersionPolicyRecommendedVersion = settings.RecommendedVersion;
            mobileVersionPolicyMinimumSupportedVersion = settings.MinimumSupportedVersion;
            mobileVersionPolicyGooglePlayUrl = settings.GooglePlayUrl;
            mobileVersionPolicyReleaseNotes = settings.ReleaseNotes;
            mobileVersionPolicyWarnMessage = settings.WarnMessage;
            mobileVersionPolicyBlockMessage = settings.BlockMessage;
        }
        catch (Exception ex)
        {
            mobileVersionPolicySaveSucceeded = false;
            mobileVersionPolicyMessage = $"Failed to load mobile app policy settings: {ex.Message}";
        }
        finally
        {
            isLoadingMobileVersionPolicy = false;
        }
    }

    private async Task OnMobileVersionPolicyAppChanged(string appId)
    {
        selectedMobileVersionPolicyAppId = appId;
        mobileVersionPolicyMessage = null;
        await LoadMobileVersionPolicySettings();
        StateHasChanged();
    }

    private async Task SaveMobileVersionPolicySettings()
    {
        isSavingMobileVersionPolicy = true;
        mobileVersionPolicyMessage = null;
        StateHasChanged();

        try
        {
            var request = new MobileVersionPolicySettingsUpdateRequest
            {
                AppId = selectedMobileVersionPolicyAppId,
                Enabled = mobileVersionPolicyEnabled,
                RequireHeaders = mobileVersionPolicyRequireHeaders,
                LatestVersion = mobileVersionPolicyLatestVersion.Trim(),
                RecommendedVersion = mobileVersionPolicyRecommendedVersion.Trim(),
                MinimumSupportedVersion = mobileVersionPolicyMinimumSupportedVersion.Trim(),
                GooglePlayUrl = mobileVersionPolicyGooglePlayUrl.Trim(),
                ReleaseNotes = mobileVersionPolicyReleaseNotes.Trim(),
                WarnMessage = mobileVersionPolicyWarnMessage.Trim(),
                BlockMessage = mobileVersionPolicyBlockMessage.Trim()
            };

            var result = await MobileVersionPolicySettingsService.UpdateSettingsAsync(request);
            mobileVersionPolicySaveSucceeded = result.Success;
            mobileVersionPolicyMessage = result.Message;

            if (result.Success)
            {
                await LoadMobileVersionPolicySettings();
                await LogAudit(
                    AuditActions.UpdateSettings,
                    $"Updated {SelectedMobileVersionPolicyAppName} version policy (minimum: {mobileVersionPolicyMinimumSupportedVersion}, recommended: {mobileVersionPolicyRecommendedVersion}, latest: {mobileVersionPolicyLatestVersion})");
            }
        }
        catch (Exception ex)
        {
            mobileVersionPolicySaveSucceeded = false;
            mobileVersionPolicyMessage = $"Failed to save mobile app policy settings: {ex.Message}";
        }
        finally
        {
            isSavingMobileVersionPolicy = false;
            StateHasChanged();
        }
    }

    // Payment Settings Methods
    private async Task LoadPaymentSettingsData()
    {
        try
        {
            await using var db = await DbContextFactory.CreateDbContextAsync();
            cachedGLAccounts = await db.CachedGLAccounts
            .Where(g => g.IsActive)
            .OrderBy(g => g.Code)
            .ToListAsync();
            cachedBusinessPartners = await db.CachedBusinessPartners
            .Where(bp => bp.IsActive && (bp.CardType == "cCustomer" || bp.CardType == "C"))
            .OrderBy(bp => bp.CardCode)
            .ToListAsync();

            cachedWarehouses = await db.CachedWarehouses
            .Where(w => w.IsActive)
            .OrderBy(w => w.WarehouseCode)
            .ToListAsync();

            // Set selected warehouse from current setting
            var whCode = editedValues.TryGetValue(SettingKeys.DefaultWarehouse, out var whVal) ? whVal : "";
            selectedWarehouse = cachedWarehouses.FirstOrDefault(w => w.WarehouseCode == whCode);

            // Load current values from settings
            var glSetting = await SettingsService.GetValueAsync(SettingKeys.IncomingPaymentGLAccount);
            paymentGLAccount = glSetting ?? "";
            selectedGLAccount = cachedGLAccounts.FirstOrDefault(gl => gl.Code == paymentGLAccount);

            var methodSetting = await SettingsService.GetValueAsync(SettingKeys.DefaultPaymentMethod);
            defaultPaymentMethod = methodSetting ?? "cash";

            var bpJson = await SettingsService.GetValueAsync(SettingKeys.AllowedPaymentBusinessPartners);
            if (!string.IsNullOrWhiteSpace(bpJson) && bpJson != "[]")
            {
                try
                {
                    allowedPaymentBPs = System.Text.Json.JsonSerializer.Deserialize<List<string>>(bpJson) ?? new();
                }
                catch { allowedPaymentBPs = new(); }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load payment settings data: {ex.Message}";
        }
    }

    private async Task<IEnumerable<CachedGLAccount>> SearchGLAccountsAsync(string searchText, CancellationToken
cancellationToken)
    {
        var eligible = paymentEligibleGLAccounts;
        if (string.IsNullOrWhiteSpace(searchText))
            return eligible.Take(20);

        var term = searchText.ToLower();
        return eligible.Where(gl =>
            (gl.Code?.ToLower().Contains(term) ?? false) ||
            (gl.Name?.ToLower().Contains(term) ?? false))
            .Take(20);
    }

    private async void OnGLAccountSelected(CachedGLAccount? gl)
    {
        selectedGLAccount = gl;
        paymentGLAccount = gl?.Code ?? "";
        await SettingsService.SaveSettingAsync(SettingKeys.IncomingPaymentGLAccount, paymentGLAccount, currentUsername);
        hasChanges = false;
        successMessage = $"G/L Account updated to {(string.IsNullOrEmpty(paymentGLAccount) ? "(none)" : $"{gl?.Code} - {gl?.Name}")}";
        await LogAudit(AuditActions.UpdateSettings, $"Updated incoming payment G/L account to: {paymentGLAccount}");
        StateHasChanged();
    }

    private async void OnDefaultPaymentMethodChanged(ChangeEventArgs e)
    {
        defaultPaymentMethod = e.Value?.ToString() ?? "cash";
        await SettingsService.SaveSettingAsync(SettingKeys.DefaultPaymentMethod, defaultPaymentMethod, currentUsername);
        hasChanges = false;
        var label = defaultPaymentMethod switch
        {
            "cash" => "Cash",
            "transfer" => "Transfer",
            "check" => "Check",
            "credit" => "Credit Card",
            _ => defaultPaymentMethod
        };
        successMessage = $"Default payment method updated to {label}";
        await LogAudit(AuditActions.UpdateSettings, $"Updated default payment method to: {label}");
        StateHasChanged();
    }

    private async void TogglePaymentBP(string cardCode)
    {
        if (allowedPaymentBPs.Contains(cardCode))
            allowedPaymentBPs.Remove(cardCode);
        else
            allowedPaymentBPs.Add(cardCode);

        var json = System.Text.Json.JsonSerializer.Serialize(allowedPaymentBPs);
        await SettingsService.SaveSettingAsync(SettingKeys.AllowedPaymentBusinessPartners, json, currentUsername);
        await LogAudit(AuditActions.UpdateSettings, $"Updated allowed payment business partners ({allowedPaymentBPs.Count} selected)");
        StateHasChanged();
    }

    private async void ClearAllPaymentBPs()
    {
        allowedPaymentBPs.Clear();
        await SettingsService.SaveSettingAsync(SettingKeys.AllowedPaymentBusinessPartners, "[]", currentUsername);
        await LogAudit(AuditActions.UpdateSettings, "Cleared all allowed payment business partners");
        StateHasChanged();
    }

