    private static int? ParseIntOrNull(string? value) =>
        int.TryParse(value, out var parsed) ? parsed : null;

    private static List<string> ParseEmailRecipients(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return new();
        }

        return value
            .Split(new[] { ',', ';', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(address => !string.IsNullOrWhiteSpace(address))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }


    private List<string> GetSavedPrintersList()
    {
        var json = GetValue(SettingKeys.SavedPrinters);
        if (string.IsNullOrWhiteSpace(json) || json == "[]") return new();
        try
        {
            return (System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? new())
                .Where(p => !string.IsNullOrWhiteSpace(p))
                .Select(p => p.Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(p => p, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch
        {
            return new();
        }
    }

    private string GetDefaultPrinter() => GetValue(SettingKeys.PrinterName).Trim();

    private int GetPrintCopies()
    {
        return int.TryParse(GetValue(SettingKeys.PrintCopies), out var copies)
            ? Math.Clamp(copies, 1, 10)
            : 1;
    }

    private List<string> GetPrinterOptions(List<string>? savedPrinters = null, string? defaultPrinter = null)
    {
        var options = new List<string>();
        AddUniquePrinters(options, installedPrinters);
        AddUniquePrinters(options, savedPrinters ?? GetSavedPrintersList());

        if (!string.IsNullOrWhiteSpace(defaultPrinter))
        {
            AddUniquePrinters(options, new[] { defaultPrinter });
        }

        return options
            .OrderBy(p => p, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private List<string> GetAvailablePrinters(List<string>? savedPrinters = null)
    {
        var saved = savedPrinters ?? GetSavedPrintersList();
        return installedPrinters
            .Where(printer => !saved.Any(savedPrinter => IsSamePrinter(savedPrinter, printer)))
            .OrderBy(p => p, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static bool IsSamePrinter(string? left, string? right) =>
        string.Equals(left?.Trim(), right?.Trim(), StringComparison.OrdinalIgnoreCase);

    private static void AddUniquePrinters(List<string> target, IEnumerable<string> printers)
    {
        foreach (var printer in printers)
        {
            var name = printer?.Trim();
            if (!string.IsNullOrWhiteSpace(name) && !target.Any(existing => IsSamePrinter(existing, name)))
            {
                target.Add(name);
            }
        }
    }

    private void SaveSavedPrintersList(List<string> printers)
    {
        var normalized = new List<string>();
        AddUniquePrinters(normalized, printers);
        normalized = normalized.OrderBy(p => p, StringComparer.OrdinalIgnoreCase).ToList();
        editedValues[SettingKeys.SavedPrinters] = System.Text.Json.JsonSerializer.Serialize(normalized);
        hasChanges = true;
    }

    private void OnSavedPrinterToggled(string printer, bool isChecked)
    {
        var list = GetSavedPrintersList();
        if (isChecked && !list.Any(saved => IsSamePrinter(saved, printer)))
        {
            list.Add(printer.Trim());
        }
        else if (!isChecked)
        {
            list.RemoveAll(saved => IsSamePrinter(saved, printer));
        }

        SaveSavedPrintersList(list);
    }

    private void OnDefaultPrinterChanged(ChangeEventArgs e)
    {
        var printer = e.Value?.ToString()?.Trim() ?? string.Empty;
        editedValues[SettingKeys.PrinterName] = printer;

        if (!string.IsNullOrWhiteSpace(printer))
        {
            var saved = GetSavedPrintersList();
            if (!saved.Any(existing => IsSamePrinter(existing, printer)))
            {
                saved.Add(printer);
                SaveSavedPrintersList(saved);
            }
        }

        hasChanges = true;
    }

    private void OnPrintCopiesChanged(ChangeEventArgs e)
    {
        var copies = int.TryParse(e.Value?.ToString(), out var parsed) ? parsed : 1;
        editedValues[SettingKeys.PrintCopies] = Math.Clamp(copies, 1, 10).ToString();
        hasChanges = true;
    }

    private void SetDefaultPrinter(string printer)
    {
        editedValues[SettingKeys.PrinterName] = printer.Trim();
        OnSavedPrinterToggled(printer, true);
    }

    private void AddSelectedPrinter()
    {
        if (string.IsNullOrWhiteSpace(printerToAdd))
            return;

        AddPrinterToQuickPicks(printerToAdd);
        printerToAdd = string.Empty;
    }

    private void AddCustomPrinter()
    {
        if (string.IsNullOrWhiteSpace(customPrinterName))
            return;

        AddPrinterToQuickPicks(customPrinterName);
        customPrinterName = string.Empty;
    }

    private void AddPrinterToQuickPicks(string printer)
    {
        var name = printer.Trim();
        if (string.IsNullOrWhiteSpace(name))
            return;

        var saved = GetSavedPrintersList();
        if (!saved.Any(existing => IsSamePrinter(existing, name)))
        {
            saved.Add(name);
            SaveSavedPrintersList(saved);
        }

        if (string.IsNullOrWhiteSpace(GetDefaultPrinter()))
        {
            editedValues[SettingKeys.PrinterName] = name;
            hasChanges = true;
        }
    }

    private void RemoveSavedPrinter(string printer)
    {
        var saved = GetSavedPrintersList();
        saved.RemoveAll(existing => IsSamePrinter(existing, printer));
        SaveSavedPrintersList(saved);

        if (IsSamePrinter(GetDefaultPrinter(), printer))
        {
            editedValues[SettingKeys.PrinterName] = string.Empty;
            hasChanges = true;
        }
    }

