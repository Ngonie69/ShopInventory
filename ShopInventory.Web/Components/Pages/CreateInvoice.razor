@page "/invoices/create"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using ShopInventory.Web.Data
@attribute [Authorize(Roles = "Admin,Cashier")]
@inject IInvoiceService InvoiceService
@inject IProductService ProductService
@inject IPriceService PriceService
@inject IBusinessPartnerService BusinessPartnerService
@inject IEmailService EmailService
@inject IMasterDataCacheService CacheService
@inject IAppSettingsService AppSettingsService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject ILogger<CreateInvoice> Logger
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Create Invoice - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .ci-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Breadcrumb ──────────────────────────────────── */
    .ci-breadcrumb {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .85rem;
        color: #6b7280;
        margin-bottom: 1.25rem;
    }

    .ci-breadcrumb a {
        color: #2563eb;
        text-decoration: none;
        font-weight: 500;
    }

    .ci-breadcrumb a:hover {
        text-decoration: underline;
    }

    .ci-breadcrumb .sep {
        color: #d1d5db;
    }

    /* ── Header ──────────────────────────────────────── */
    .ci-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .ci-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .ci-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        box-shadow: 0 4px 14px rgba(37, 99, 235, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .ci-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }

    .ci-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .ci-header-actions {
        display: flex;
        gap: .5rem;
        align-items: center;
    }

    .btn-back {
        background: #fff;
        border: 1px solid #e5e7eb;
        color: #374151;
        padding: .5rem 1.1rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .85rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-back:hover {
        background: #f9fafb;
        border-color: #9ca3af;
        color: #374151;
    }

    .btn-refresh {
        background: #fff;
        border: 1px solid #e5e7eb;
        color: #374151;
        padding: .5rem 1.1rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .85rem;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        cursor: pointer;
    }

    .btn-refresh:hover:not(:disabled) {
        background: #f0fdf4;
        border-color: #059669;
        color: #059669;
    }

    .btn-refresh:disabled {
        opacity: .5;
        cursor: not-allowed;
    }

    /* ── Section Card ────────────────────────────────── */
    .section-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .section-card .card-hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .85rem 1.25rem;
        border-bottom: 1px solid #f3f4f6;
    }

    .section-card .card-hdr .hdr-left {
        display: flex;
        align-items: center;
        gap: .65rem;
    }

    .section-card .card-hdr .header-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .95rem;
        flex-shrink: 0;
    }

    .section-card .card-hdr h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        font-size: .95rem;
    }

    .section-card .card-body-inner {
        padding: 1.25rem;
    }

    /* ── Alert Banners ───────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.success-alert {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .alert-banner .alert-body {
        flex: 1;
    }

    .alert-banner .alert-close {
        background: none;
        border: none;
        color: inherit;
        opacity: .45;
        cursor: pointer;
        padding: .2rem;
        font-size: 1rem;
    }

    .alert-banner .alert-close:hover {
        opacity: 1;
    }

    /* ── Form Fields ─────────────────────────────────── */
    .field-label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .35rem;
    }

    .field-group {
        margin-bottom: 0.5rem;
    }

    .form-control-line,
    .form-select-line {
        font-size: 0.88rem;
        padding: 0.5rem 0.75rem;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control-line:focus,
    .form-select-line:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, .1);
    }

    .form-control-line::placeholder {
        color: #adb5bd;
    }

    /* ── Customer Badge ──────────────────────────────── */
    .selected-customer-badge {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 10px;
        padding: .75rem 1rem;
    }

    .bp-clear-btn {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        width: 28px;
        height: 28px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .8rem;
    }

    .bp-clear-btn:hover {
        background: #dc2626;
        color: #fff;
        border-color: #dc2626;
    }

    /* ── Dropdown ─────────────────────────────────────── */
    .dropdown-autocomplete {
        position: absolute;
        z-index: 1050;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        max-height: 280px;
        overflow-y: auto;
        width: 100%;
        box-shadow: 0 8px 25px rgba(0, 0, 0, .12);
        top: 100%;
        margin-top: 2px;
    }

    .dropdown-autocomplete .dropdown-item {
        padding: .55rem 1rem;
        cursor: pointer;
        transition: background .12s;
        font-size: .88rem;
        border-bottom: 1px solid #f9fafb;
    }

    .dropdown-autocomplete .dropdown-item:hover {
        background: #f0fdf4;
    }

    .dropdown-autocomplete .dropdown-item.selected {
        background: #2563eb;
        color: white;
    }

    /* ── Line Items ──────────────────────────────────── */
    .line-card {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1rem 1.15rem;
        margin-bottom: .75rem;
        transition: all .2s;
        position: relative;
    }

    .line-card:hover {
        border-color: #2563eb;
        box-shadow: 0 2px 10px rgba(37, 99, 235, .08);
    }

    .line-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .75rem;
        padding-bottom: .5rem;
        border-bottom: 1px solid #e5e7eb;
    }

    .line-number {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: white;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 0.8rem;
    }

    .line-total-display {
        font-size: 1.05rem;
        font-weight: 700;
        color: #059669;
    }

    .line-remove {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        width: 28px;
        height: 28px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .8rem;
    }

    .line-remove:hover {
        background: #dc2626;
        color: #fff;
        border-color: #dc2626;
    }

    .product-selected-info {
        background: #f0f9ff;
        border: 1px solid #bae6fd;
        border-radius: 8px;
        padding: 0.5rem 0.75rem;
        font-size: 0.85rem;
        color: #0c4a6e;
    }

    /* ── Global Settings Bar ─────────────────────────── */
    .global-settings-bar {
        background: linear-gradient(135deg, #fefce8 0%, #fef9c3 100%);
        border: 1px solid #fde68a;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.25rem;
    }

    .settings-bar-header {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .85rem;
        padding-bottom: .6rem;
        border-bottom: 1px dashed rgba(217, 119, 6, .2);
    }

    .settings-bar-header .settings-icon {
        width: 28px;
        height: 28px;
        border-radius: 7px;
        background: rgba(217, 119, 6, .12);
        color: #b45309;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
    }

    .settings-bar-header span {
        font-weight: 600;
        font-size: .85rem;
        color: #92400e;
    }

    .batch-required-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        background: #d1fae5;
        color: #065f46;
        font-size: .68rem;
        padding: .2rem .55rem;
        border-radius: 20px;
        font-weight: 600;
        letter-spacing: .2px;
    }

    .settings-fields {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .settings-field-label {
        display: block;
        font-size: .75rem;
        font-weight: 600;
        color: #78716c;
        margin-bottom: .3rem;
    }

    /* ── Empty State ──────────────────────────────────── */
    .empty-lines-placeholder {
        text-align: center;
        padding: 3rem 1.5rem;
        background: linear-gradient(180deg, #f9fafb 0%, #fff 100%);
        border-radius: 12px;
        border: 2px dashed #e5e7eb;
        margin: .5rem 0;
    }

    .empty-lines-placeholder .empty-ico {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #9ca3af;
        margin-bottom: 1rem;
    }

    .empty-lines-placeholder p {
        color: #6b7280;
        font-size: .9rem;
        margin-bottom: .25rem !important;
    }

    .empty-lines-placeholder .empty-hint {
        color: #9ca3af;
        font-size: .8rem;
        margin-bottom: 1.25rem;
    }

    /* ── Summary Sidebar ─────────────────────────────── */
    .summary-section {
        position: sticky;
        top: 1.5rem;
    }

    .summary-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .summary-hdr {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .85rem 1.15rem;
        border-bottom: 1px solid #f3f4f6;
    }

    .summary-hdr h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        font-size: .92rem;
    }

    .summary-body {
        padding: .85rem 1.15rem;
    }

    .sum-line {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .35rem 0;
    }

    .sum-label {
        color: #6b7280;
        font-size: .88rem;
        display: flex;
        align-items: center;
    }

    .sum-value {
        font-weight: 600;
        color: #1a1a2e;
        font-size: .88rem;
    }

    .sum-divider {
        border: none;
        border-top: 1px dashed #e5e7eb;
        margin: .5rem 0;
    }

    .sum-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .5rem 0;
    }

    .total-label {
        font-weight: 700;
        color: #1a1a2e;
        font-size: 1rem;
    }

    .total-value {
        font-weight: 700;
        color: #059669;
        font-size: 1.35rem;
    }

    /* ── Action Buttons ──────────────────────────────── */
    .btn-execute {
        width: 100%;
        padding: .7rem 1.25rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: .92rem;
        border: none;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        cursor: pointer;
        transition: all .2s;
        box-shadow: 0 2px 8px rgba(37, 99, 235, .25);
        margin-bottom: .5rem;
    }

    .btn-execute:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(37, 99, 235, .4);
    }

    .btn-execute:disabled {
        opacity: .55;
        cursor: not-allowed;
    }

    .btn-secondary-action {
        width: 100%;
        padding: .55rem 1rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .85rem;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        cursor: pointer;
        transition: all .15s;
        margin-bottom: .75rem;
    }

    .btn-secondary-action:hover:not(:disabled) {
        background: #f9fafb;
        border-color: #9ca3af;
        color: #374151;
    }

    .btn-secondary-action:disabled {
        opacity: .5;
        cursor: not-allowed;
    }

    .info-hint {
        display: flex;
        gap: .45rem;
        font-size: .78rem;
        color: #9ca3af;
        line-height: 1.4;
        padding: .5rem;
        background: #f9fafb;
        border-radius: 8px;
    }

    .btn-add-line {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        background: #fff;
        color: #059669;
        border: 1.5px solid #a7f3d0;
        border-radius: 8px;
        font-weight: 600;
        font-size: .82rem;
        padding: .4rem .85rem;
        cursor: pointer;
        transition: all .2s;
    }

    .btn-add-line:hover {
        background: #ecfdf5;
        border-color: #059669;
        color: #047857;
    }

    .btn-add-first {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: linear-gradient(135deg, #059669, #047857);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        font-size: .9rem;
        padding: .6rem 1.5rem;
        cursor: pointer;
        transition: all .2s;
        box-shadow: 0 2px 8px rgba(5, 150, 105, .25);
    }

    .btn-add-first:hover {
        background: linear-gradient(135deg, #047857, #065f46);
        box-shadow: 0 4px 14px rgba(5, 150, 105, .35);
        transform: translateY(-1px);
    }

    /* ── Validation ───── */
    .validation-error {
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 2px rgba(239, 68, 68, .15) !important;
    }

    /* ── Data Status ─────────────────────────────────── */
    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
    }

    .status-dot.ready {
        background: #059669;
    }

    .status-dot.loading {
        background: #d97706;
    }

    .status-dot.error {
        background: #dc2626;
    }

    .ds-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .82rem;
        color: #6b7280;
        padding: .2rem 0;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .ci-header {
            flex-direction: column;
        }
    }
</style>

<div class="ci-page">
    <div class="container-fluid">

        <!-- Breadcrumb -->
        <div class="ci-breadcrumb">
            <a href="/invoices">Invoices</a>
            <span class="sep">/</span>
            <span>Create New</span>
        </div>

        <!-- Header -->
        <div class="ci-header">
            <div class="ci-header-left">
                <div class="ci-header-icon"><i class="bi bi-receipt"></i></div>
                <div>
                    <h2>Create Invoice</h2>
                    <p>Create a new sales invoice with batch tracking</p>
                </div>
            </div>
            <div class="ci-header-actions">
                <div class="d-flex align-items-center me-2">
                    <span
                    class="status-dot @(IsCacheReady ? "ready" : (isRefreshingCache ? "loading" : "error")) me-1"></span>
                    <small style="color:#6b7280; font-size:.8rem;">
                        @(IsCacheReady ? "Data Ready" : (isRefreshingCache ? "Syncing…" : "Offline"))
                    </small>
                </div>
                <MudButton Class="btn-refresh" OnClick="RefreshMasterData" Disabled="@isRefreshingCache">
                    @if (isRefreshingCache)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-clockwise"></i>
                    }
                    Refresh
                </MudButton>
                <a href="/invoices" class="btn-back"><i class="bi bi-arrow-left"></i> Back</a>
            </div>
        </div>

        <!-- Alerts -->
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert-banner success-alert">
                <i class="bi bi-check-circle-fill"></i>
                <div class="alert-body">@successMessage</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => successMessage = null" Class="alert-close"
                               Size="Size.Small" />
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner error-alert">
                <i class="bi bi-exclamation-octagon-fill"></i>
                <div class="alert-body">@((MarkupString)errorMessage)</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => errorMessage = null" Class="alert-close"
                               Size="Size.Small" />
            </div>
        }

        <div class="row g-4">
            <!-- ━━━ Left Column ━━━ -->
            <div class="col-lg-8">

                <!-- ── Customer Section ── -->
                <div class="section-card">
                    <div class="card-hdr">
                        <div class="hdr-left">
                            <div class="header-icon" style="background:#d1fae5; color:#059669;"><i
                                class="bi bi-person-fill"></i></div>
                                <h6>Customer Information</h6>
                            </div>
                        </div>
                        <div class="card-body-inner">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="field-label">Customer <span style="color:#ef4444;">*</span></label>
                                    @if (isLoadingBPs)
                                    {
                                        <div class="d-flex align-items-center gap-2" style="padding:.4rem 0;">
                                            <div class="spinner-border spinner-border-sm text-primary"></div>
                                            <span style="color:#6b7280; font-size:.85rem;">Loading customers…</span>
                                        </div>
                                    }
                                    else if (selectedBusinessPartner != null)
                                    {
                                        <div class="selected-customer-badge">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <div style="font-weight:700; color:#065f46;">
                                                        <i class="bi bi-check-circle-fill me-1" style="color:#059669;"></i>
                                                        @selectedBusinessPartner.CardCode
                                                    </div>
                                                    <div style="font-size:.85rem; color:#065f46; opacity:.8;">
                                                        @selectedBusinessPartner.CardName</div>
                                                        @if (!string.IsNullOrEmpty(selectedBusinessPartner.Phone1))
                                                        {
                                                            <div
                                                                style="font-size:.82rem; color:#065f46; opacity:.7; margin-top:.25rem;">
                                                                <i class="bi bi-telephone me-1"></i>@selectedBusinessPartner.Phone1
                                                            </div>
                                                        }
                                                        @if (customerPriceListNum.HasValue)
                                                        {
                                                            <div
                                                                style="font-size:.82rem; color:#065f46; opacity:.7; margin-top:.25rem;">
                                                                <i class="bi bi-tags me-1"></i>Price List #@customerPriceListNum
                                                                @if (isLoadingCustomerPrices)
                                                                {
                                                                    <span class="spinner-border spinner-border-sm ms-1"></span>
                                                                }
                                                                else
                                                                {
                                                                    <span
                                                                        style="background:#d1fae5; color:#065f46; font-size:.7rem; padding:.1rem .4rem; border-radius:4px; font-weight:600; margin-left:.25rem;">
                                                                        @customerPriceListPrices.Count items
                                                                    </span>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                    <MudButton ButtonType="ButtonType.Button" Class="bp-clear-btn"
                                                               OnClick="ClearSelectedBP">
                                                        <i class="bi bi-x"></i>
                                                    </MudButton>
                                                </div>
                                            </div>
                                        }
                                else
                                        {
                                            <div class="position-relative">
                                                <input type="text"
                                                       class="form-control @(validationErrors.ContainsKey("Customer") ? "validation-error" : "")"
                                                       @bind="bpSearchTerm" @bind:event="oninput"
                                                       @onfocus="() => showBPDropdown = true" @onblur="OnBPSearchBlur"
                                                       placeholder="Search by code or name…" autocomplete="off" />
                                                @if (showBPDropdown && filteredBusinessPartners.Any())
                                                {
                                                    <div class="dropdown-autocomplete" @onmousedown:preventDefault>
                                                        @foreach (var bp in filteredBusinessPartners.Take(15))
                                                        {
                                                            <div class="dropdown-item" @onmousedown="() => SelectBusinessPartner(bp)">
                                                                <strong>@bp.CardCode</strong> — <span
                                                                style="color:#6b7280;">@bp.CardName</span>
                                                            </div>
                                                        }
                                                        @if (filteredBusinessPartners.Count() > 15)
                                                        {
                                                            <div class="dropdown-item"
                                                                 style="color:#9ca3af; text-align:center; font-size:.82rem;">
                                                                <i class="bi bi-info-circle me-1"></i>
                                                                @filteredBusinessPartners.Count() total — type more to filter
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else if (showBPDropdown && !string.IsNullOrWhiteSpace(bpSearchTerm) &&
                                                !filteredBusinessPartners.Any())
                                                {
                                                    <div class="dropdown-autocomplete"
                                                         style="padding:1rem; text-align:center; color:#9ca3af;">
                                                        <i class="bi bi-search me-1"></i>No customers found
                                                    </div>
                                                }
                                            </div>
                                        }
                                        @if (validationErrors.ContainsKey("Customer"))
                                        {
                                            <div style="color:#ef4444; font-size:.78rem; margin-top:.2rem;">
                                                @validationErrors["Customer"]</div>
                                            }
                                        </div>
                                        <div class="col-md-6">
                                            <label class="field-label">Customer Reference</label>
                                            <input type="text" class="form-control" @bind="invoice.NumAtCard"
                                                   placeholder="PO / Reference number" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="field-label">Currency</label>
                                            <select class="form-select" @bind="invoice.DocCurrency">
                                                <option value="USD">USD — US Dollar</option>
                                                <option value="ZIG">ZIG — Zimbabwe Gold</option>
                                            </select>
                                        </div>
                                        <div class="col-md-8">
                                            <label class="field-label">Comments</label>
                                            <input type="text" class="form-control" @bind="invoice.Comments"
                                                   placeholder="Optional notes" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- ── Invoice Lines Section ── -->
                            <div class="section-card">
                                <div class="card-hdr">
                                    <div class="hdr-left">
                                        <div class="header-icon" style="background:#dbeafe; color:#2563eb;"><i
                                            class="bi bi-list-ul"></i></div>
                                            <h6>Invoice Lines</h6>
                                        </div>
                                        <MudButton Class="btn-add-line" OnClick="AddLine">
                                            <i class="bi bi-plus-lg me-1"></i>Add Line
                                        </MudButton>
                                    </div>
                                    <div class="card-body-inner">
                                        <!-- Global Settings Bar -->
                                        <div class="global-settings-bar">
                                            <div class="settings-bar-header">
                                                <div class="settings-icon"><i class="bi bi-sliders"></i></div>
                                                <span>Default Settings</span>
                                                <span class="batch-required-badge ms-auto">
                                                    <i class="bi bi-magic"></i>Auto Batch (FEFO)
                                                </span>
                                            </div>
                                            <div class="settings-fields">
                                                <div>
                                                    <label class="settings-field-label">Default Warehouse</label>
                                                    <select class="form-select form-select-line" @bind="warehouseCode">
                                                        <option value="">— Select Warehouse —</option>
                                                        @foreach (var wh in cachedWarehouses)
                                                        {
                                                            <option value="@wh.WarehouseCode">@wh.WarehouseCode</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div>
                                                    <label class="settings-field-label">Default Cost Centre</label>
                                                    <MudAutocomplete T="CostCentreDto" Value="selectedDefaultCostCentre"
                                                                     ValueChanged="OnDefaultCostCentreChanged" SearchFunc="SearchCostCentresAsync"
                                                                     ToStringFunc="@(cc => cc == null ? "" : $"{cc.CenterCode} - {TruncateName(cc.CenterName, 25)}")"
                                                                     Placeholder="— Select Cost Centre —" Dense="true" Variant="Variant.Outlined"
                                                                     Margin="Margin.Dense" Clearable="true" ResetValueOnEmptyText="true"
                                                                     CoerceText="false" Class="form-select-line" />
                                                </div>
                                            </div>
                                        </div>

                                        @if (isLoadingMasterData)
                                        {
                                            <div style="text-align:center; padding:2.5rem 1rem;">
                                                <div class="spinner-border text-primary" role="status" style="width:2rem; height:2rem;">
                                                </div>
                                                <p style="color:#6b7280; margin-top:.75rem; margin-bottom:0; font-size:.88rem;">Loading
                                                    products and warehouses…</p>
                                                </div>
                                            }
                        else if (invoice.Lines.Any())
                                            {
                                                <div>
                                                    @for (int i = 0; i < invoice.Lines.Count; i++)
                                                    {
                                                        var index = i;
                                                        var line = invoice.Lines[index];
                                                        var lineState = GetLineState(index);
                                                        var lineErrors = GetLineValidationErrors(index);

                                                        <div class="line-card">
                                                            <!-- Line Header -->
                                                            <div class="line-card-header">
                                                                <div class="d-flex align-items-center gap-2">
                                                                    <div class="line-number">@(index + 1)</div>
                                                                    @if (!string.IsNullOrEmpty(line.ItemDescription))
                                                                    {
                                                                        <span style="font-weight:600; color:#1a1a2e;">@line.ItemCode</span>
                                                                        <span style="color:#d1d5db;">—</span>
                                                                        <span
                                                                            style="color:#6b7280; font-size:.85rem;">@TruncateName(line.ItemDescription,
                                                                                                                        40)</span>
                                                                        }
                                        else
                                                                        {
                                                                            <span style="color:#9ca3af; font-size:.85rem;">New Line Item</span>
                                                                        }
                                                                    </div>
                                                                    <div class="d-flex align-items-center gap-3">
                                                                        <div class="line-total-display">@CalculateLineTotal(line).ToString("N2")</div>
                                                                        <MudButton Class="line-remove" OnClick="() => RemoveLine(index)"
                                                                                   title="Remove line">
                                                                            <i class="bi bi-x"></i>
                                                                        </MudButton>
                                                                    </div>
                                                                </div>

                                                                <!-- Row 1: Product Selection -->
                                                                <div class="row g-3 mb-3">
                                                                    <div class="col-md-4">
                                                                        <div class="field-group">
                                                                            <label class="field-label">Item Code <span
                                                                                style="color:#ef4444;">*</span></label>
                                                                                <div class="position-relative">
                                                                                    <input type="text"
                                                                                           class="form-control form-control-line @(lineErrors.ContainsKey("ItemCode") ? "validation-error" : "")"
                                                                                           value="@line.ItemCode"
                                                                                           @oninput="(e) => OnItemCodeInput(index, e.Value?.ToString())"
                                                                                           @onkeydown="(e) => OnItemCodeKeyDown(index, e)"
                                                                                           @onfocus="() => OnItemCodeFocus(index)"
                                                                                           @onblur="() => OnItemCodeBlur(index)"
                                                                                           placeholder="Search or type item code…" autocomplete="off" />
                                                                                    @if (lineState.ShowProductDropdown && lineState.FilteredProducts.Any())
                                                                                    {
                                                                                        <div class="dropdown-autocomplete" @onmousedown:preventDefault>
                                                                                            @foreach (var product in lineState.FilteredProducts.Take(10))
                                                                                            {
                                                                                                var isSelected = lineState.SuggestedProduct?.ItemCode ==
                                                                                                product.ItemCode;
                                                                                                var displayPrice = GetPriceForItem(product.ItemCode, product.Price);
                                                                                                var isCustomerPrice =
                                                                                                customerPriceListPrices.ContainsKey(product.ItemCode ?? "");
                                                                                                <div class="dropdown-item @(isSelected ? "selected" : "")"
                                                                                                     @onmousedown="() => SelectProduct(index, product)">
                                                                                                    <div class="d-flex justify-content-between align-items-center">
                                                                                                        <div>
                                                                                                            <div style="font-weight:600; font-size:.85rem;">
                                                                                                                @product.ItemCode</div>
                                                                                                                <small
                                                                                                                    style="@(isSelected ? "color:rgba(255,255,255,.7);" : "color:#6b7280;")">@TruncateName(product.ItemName,
                                                                                                                                                                                        30)</small>
                                                                                                                </div>
                                                                                                                <span
                                                                                                                    style="font-size:.78rem; font-weight:600; padding:.15rem .45rem; border-radius:5px; @(isSelected ? "background:rgba(255,255,255,.2); color:#fff;" : (isCustomerPrice ? "background:#d1fae5; color:#065f46;" : "background:#dbeafe; color:#1e40af;"))">
                                                                                                                    @displayPrice.ToString("N2")
                                                                                                                    @if (isCustomerPrice)
                                                                                                                    {
                                                                                                                        <i class="bi bi-check-circle ms-1"></i>
                                                                                                                    }
                                                                                                                </span>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    }
                                                                                                    @if (lineState.FilteredProducts.Count > 10)
                                                                                                    {
                                                                                                        <div class="dropdown-item"
                                                                                                             style="color:#9ca3af; text-align:center; font-size:.82rem;">
                                                                                                            +@(lineState.FilteredProducts.Count - 10) more…
                                                                                                        </div>
                                                                                                    }
                                                                                                </div>
                                                                                            }
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                                <div class="col-md-5">
                                                                                    <div class="field-group">
                                                                                        <label class="field-label">Description</label>
                                                                                        @if (!string.IsNullOrEmpty(line.ItemDescription))
                                                                                        {
                                                                                            <div class="product-selected-info">
                                                                                                <i class="bi bi-box-seam me-2"
                                                                                                   style="color:#2563eb;"></i>@line.ItemDescription
                                                                                            </div>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <input type="text" class="form-control form-control-line"
                                                                                                   placeholder="Select an item above" readonly />
                                                                                        }
                                                                                    </div>
                                                                                </div>
                                                                                <div class="col-md-3">
                                                                                    <div class="field-group">
                                                                                        <label class="field-label">Warehouse <span
                                                                                            style="color:#ef4444;">*</span></label>
                                                                                            <select
                                                                                                class="form-select form-select-line @(lineErrors.ContainsKey("Warehouse") ? "validation-error" : "")"
                                                                                                @bind="line.WarehouseCode">
                                                                                                <option value="">— Select —</option>
                                                                                                @foreach (var wh in cachedWarehouses)
                                                                                                {
                                                                                                    <option value="@wh.WarehouseCode">@wh.WarehouseCode</option>
                                                                                                }
                                                                                            </select>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>

                                                                                <!-- Row 2: Quantity, Price, Discount, Batch, Cost Centre -->
                                                                                <div class="row g-3">
                                                                                    <div class="col-6 col-md-2">
                                                                                        <div class="field-group">
                                                                                            <label class="field-label">Quantity <span
                                                                                                style="color:#ef4444;">*</span></label>
                                                                                                <input type="number"
                                                                                                       class="form-control form-control-line @(lineErrors.ContainsKey("Quantity") ? "validation-error" : "")"
                                                                                                       value="@line.Quantity"
                                                                                                       @onchange="(e) => OnQuantityChange(index, e.Value?.ToString())"
                                                                                                       min="0.001" step="0.001" placeholder="0" />
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="col-6 col-md-2">
                                                                                            <div class="field-group">
                                                                                                <label class="field-label">Unit Price</label>
                                                                                                <input type="number" class="form-control form-control-line"
                                                                                                       @bind="line.UnitPrice" min="0" step="0.01" placeholder="0.00" />
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="col-6 col-md-2">
                                                                                            <div class="field-group">
                                                                                                <label class="field-label">Discount %</label>
                                                                                                <input type="number" class="form-control form-control-line"
                                                                                                       @bind="line.DiscountPercent" min="0" max="100" placeholder="0" />
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="col-6 col-md-3">
                                                                                            <div class="field-group">
                                                                                                <label class="field-label">Batch #
                                                                                                    <span class="batch-required-badge ms-1">Auto FEFO</span>
                                                                                                </label>
                                                                                                <input type="text" class="form-control form-control-line"
                                                                                                       @bind="line.BatchNumber" placeholder="Leave empty for auto"
                                                                                                       title="Leave empty for automatic batch selection using FEFO (First Expiry First Out)" />
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="col-12 col-md-3">
                                                                                            <div class="field-group">
                                                                                                <label class="field-label">Cost Centre</label>
                                                                                                <MudAutocomplete T="CostCentreDto" Value="GetLineCostCentre(line)"
                                                                                                                 ValueChanged="@(cc => OnLineCostCentreChanged(index, cc))"
                                                                                                                 SearchFunc="SearchCostCentresAsync"
                                                                                                                 ToStringFunc="@(cc => cc == null ? "" : $"{cc.CenterCode} - {TruncateName(cc.CenterName, 15)}")"
                                                                                                                 Placeholder="— Default —" Dense="true" Variant="Variant.Outlined"
                                                                                                                 Margin="Margin.Dense" Clearable="true" ResetValueOnEmptyText="true"
                                                                                                                 CoerceText="false" Class="form-select-line" />
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            }
                                                                        </div>

                                                                        <!-- Add Line Button at Bottom -->
                                                                        <div style="text-align:center; margin-top:1.25rem;">
                                                                            <MudButton Class="btn-add-line" OnClick="AddLine">
                                                                                <i class="bi bi-plus-lg"></i>Add Another Line
                                                                            </MudButton>
                                                                        </div>
                                                                    }
                        else
                                                                    {
                                                                        <div class="empty-lines-placeholder">
                                                                            <div class="empty-ico"><i class="bi bi-inbox"></i></div>
                                                                            <p>No invoice lines yet</p>
                                                                            <div class="empty-hint">Add your first product line to start building the invoice</div>
                                                                            <MudButton Class="btn-add-first" OnClick="AddLine">
                                                                                <i class="bi bi-plus-lg"></i>Add First Line
                                                                            </MudButton>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <!-- ━━━ Right Column: Summary Sidebar ━━━ -->
                                                        <div class="col-lg-4">
                                                            <div class="summary-section">
                                                                <div class="summary-card">

                                                                    <!-- Validation Checklist -->
                                                                    <div class="summary-hdr">
                                                                        <i class="bi bi-shield-check" style="color:#2563eb;"></i>
                                                                        <h6>Validation Checklist</h6>
                                                                    </div>
                                                                    <div style="padding:.85rem 1.15rem; border-bottom:1px solid #f3f4f6;">
                                                                        <ul style="list-style:none; padding:0; margin:0; font-size:.85rem;">
                                                                            <li style="display:flex; align-items:center; gap:.5rem; padding:.25rem 0;">
                                                                                <span
                                                                                    style="width:20px; height:20px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.7rem; @(selectedBusinessPartner != null ? "background:#d1fae5; color:#059669;" : "background:#fef2f2; color:#ef4444;")">
                                                                                    <i class="bi @(selectedBusinessPartner != null ? "bi-check" : "bi-x")"></i>
                                                                                </span>
                                                                                Customer selected
                                                                            </li>
                                                                            <li style="display:flex; align-items:center; gap:.5rem; padding:.25rem 0;">
                                                                                <span
                                                                                    style="width:20px; height:20px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.7rem; @(invoice.Lines.Any() ? "background:#d1fae5; color:#059669;" : "background:#fef2f2; color:#ef4444;")">
                                                                                    <i class="bi @(invoice.Lines.Any() ? "bi-check" : "bi-x")"></i>
                                                                                </span>
                                                                                Line items added
                                                                            </li>
                                                                            <li style="display:flex; align-items:center; gap:.5rem; padding:.25rem 0;">
                                                                                <span
                                                                                    style="width:20px; height:20px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.7rem; @(invoice.Lines.All(l => !string.IsNullOrEmpty(l.ItemCode) && l.Quantity > 0) && invoice.Lines.Any() ? "background:#d1fae5; color:#059669;" : "background:#fef2f2; color:#ef4444;")">
                                                                                    <i
                                                                                    class="bi @(invoice.Lines.All(l => !string.IsNullOrEmpty(l.ItemCode) && l.Quantity > 0) && invoice.Lines.Any() ? "bi-check" : "bi-x")"></i>
                                                                                </span>
                                                                                All lines complete
                                                                            </li>
                                                                        </ul>
                                                                    </div>

                                                                    <!-- Summary -->
                                                                    <div class="summary-hdr" style="border-bottom:none;">
                                                                        <i class="bi bi-calculator" style="color:#2563eb;"></i>
                                                                        <h6>Invoice Summary</h6>
                                                                    </div>
                                                                    <div class="summary-body" style="padding-top:0;">
                                                                        <div class="sum-line">
                                                                            <span class="sum-label"><i class="bi bi-list-ul me-1"
                                                                                                           style="color:#2563eb;"></i>Lines</span>
                                                                                <span class="sum-value">@invoice.Lines.Count</span>
                                                                            </div>
                                                                            <div class="sum-line">
                                                                                <span class="sum-label"><i class="bi bi-cash me-1"
                                                                                                               style="color:#059669;"></i>Subtotal</span>
                                                                                    <span class="sum-value">@CalculateSubtotal().ToString("N2")</span>
                                                                                </div>
                                                                                <div class="sum-line">
                                                                                    <span class="sum-label"><i class="bi bi-percent me-1"
                                                                                                                   style="color:#d97706;"></i>Discount</span>
                                                                                        <span class="sum-value"
                                                                                              style="color:#ef4444;">-@CalculateTotalDiscount().ToString("N2")</span>
                                                                                    </div>

                                                                                    <hr class="sum-divider" />
                                                                                    <div class="sum-total">
                                                                                        <span class="total-label">Total</span>
                                                                                        <div style="text-align:right;">
                                                                                            <span class="total-value">@CalculateTotal().ToString("N2")</span>
                                                                                            <div style="font-size:.75rem; color:#6b7280;">@invoice.DocCurrency</div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>

                                                                                <!-- Actions -->
                                                                                <div style="padding:0 1.15rem 1.15rem;">
                                                                                    <div style="display:flex; align-items:center; gap:.5rem; margin-bottom:.75rem;">
                                                                                        <input type="checkbox" id="notifyCustomerEmail" @bind="notifyCustomerByEmail"
                                                                                               style="accent-color:#2563eb;" />
                                                                                        <label for="notifyCustomerEmail"
                                                                                               style="font-size:.85rem; color:#374151; margin:0; cursor:pointer;">
                                                                                            Email customer notification
                                                                                        </label>
                                                                                    </div>

                                                                                    <MudButton Class="btn-execute" OnClick="SubmitInvoice" Disabled="@isSubmitting">
                                                                                        @if (isSubmitting)
                                                                                        {
                                                                                            <span class="spinner-border spinner-border-sm"></span>
                                                                                            <span>Creating…</span>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <i class="bi bi-check-circle-fill"></i>
                                                                                            <span>Create Invoice</span>
                                                                                        }
                                                                                    </MudButton>
                                                                                    <MudButton Class="btn-secondary-action" OnClick="ClearForm" Disabled="@isSubmitting">
                                                                                        <i class="bi bi-arrow-counterclockwise"></i> Clear Form
                                                                                    </MudButton>

                                                                                    <!-- Validation Errors -->
                                                                                    @if (validationErrors.Any() || lineValidationErrors.Any())
                                                                                    {
                                                                                        <div
                                                                                            style="background:#fef2f2; border:1px solid #fecaca; border-radius:8px; padding:.65rem .85rem; margin-bottom:.75rem;">
                                                                                            <div style="font-size:.78rem; font-weight:600; color:#991b1b; margin-bottom:.35rem;">
                                                                                                <i class="bi bi-exclamation-triangle me-1"></i>Please fix the following:
                                                                                            </div>
                                                                                            <ul style="list-style:none; padding:0; margin:0; font-size:.78rem; color:#991b1b;">
                                                                                                @foreach (var error in validationErrors.Values)
                                                                                                {
                                                                                                    <li><i class="bi bi-dot"></i>@error</li>
                                                                                                }
                                                                                                @foreach (var lineError in lineValidationErrors)
                                                                                                {
                                                                                                    foreach (var error in lineError.Value.Values)
                                                                                                    {
                                                                                                        <li><i class="bi bi-dot"></i>Line @(lineError.Key + 1): @error</li>
                                                                                                    }
                                                                                                }
                                                                                            </ul>
                                                                                        </div>
                                                                                    }

                                                                                    <div class="info-hint">
                                                                                        <i class="bi bi-info-circle" style="flex-shrink:0; margin-top:1px;"></i>
                                                                                        <span>Invoices are posted directly to SAP Business One. Ensure all details are correct
                                                                                            before submitting.</span>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>

                                                                                <!-- Data Status Card -->
                                                                                <div class="summary-card" style="margin-top:1rem;">
                                                                                    <div class="summary-hdr">
                                                                                        <i class="bi bi-database" style="color:#6b7280;"></i>
                                                                                        <h6 style="font-size:.85rem; color:#6b7280;">Cached Data Status</h6>
                                                                                    </div>
                                                                                    <div style="padding:.65rem 1.15rem;">
                                                                                        <div class="row g-1">
                                                                                            <div class="col-6">
                                                                                                <div class="ds-item"><i class="bi bi-people"
                                                                                                                            style="color:#2563eb;"></i>@allBusinessPartners.Count customers</div>
                                                                                                </div>
                                                                                                <div class="col-6">
                                                                                                    <div class="ds-item"><i class="bi bi-box"
                                                                                                                                style="color:#059669;"></i>@cachedProducts.Count products</div>
                                                                                                    </div>
                                                                                                    <div class="col-6">
                                                                                                        <div class="ds-item"><i class="bi bi-building"
                                                                                                                                    style="color:#0ea5e9;"></i>@cachedWarehouses.Count warehouses</div>
                                                                                                        </div>
                                                                                                        <div class="col-6">
                                                                                                            <div class="ds-item"><i class="bi bi-diagram-3"
                                                                                                                                        style="color:#d97706;"></i>@cachedCostCentres.Count cost centres</div>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                        @if (lastCacheRefresh.HasValue)
                                                                                                        {
                                                                                                            <div style="font-size:.75rem; color:#9ca3af; margin-top:.35rem;">
                                                                                                                <i class="bi bi-clock me-1"></i>Last sync: @lastCacheRefresh.Value.ToString("HH:mm:ss")
                                                                                                            </div>
                                                                                                        }
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            </div>

@code {
    private CreateInvoiceRequest invoice = new()
    {
        DocCurrency = "USD",
        Lines = new List<CreateInvoiceLineRequest>()
    };

    private string? successMessage;
    private string? errorMessage;
    private bool isSubmitting = false;
    private bool notifyCustomerByEmail = true;
    private string? warehouseCode = "01";
    private string? defaultCostCentre;
    private CostCentreDto? selectedDefaultCostCentre;

    // Loading states

    private bool isLoadingMasterData = true;
    private bool isRefreshingCache = false;
    private DateTime? lastCacheRefresh;

    // Cached data
    private List<ProductDto> cachedProducts = new();
    private List<WarehouseDto> cachedWarehouses = new();
    private List<CostCentreDto> cachedCostCentres = new();

    // Line state tracking for product autocomplete
    private Dictionary<int, LineState> lineStates = new();

    // Validation
    private Dictionary<string, string> validationErrors = new();
    private Dictionary<int, Dictionary<string, string>> lineValidationErrors = new();

    private class LineState
    {
        public string SearchTerm { get; set; } = string.Empty;
        public bool ShowProductDropdown { get; set; } = false;
        public List<ProductDto> FilteredProducts { get; set; } = new();
        public ProductDto? SuggestedProduct { get; set; } = null;
        public string SuggestionSuffix { get; set; } = string.Empty;
    }

    // Business Partner fields
    private List<BusinessPartnerDto> allBusinessPartners = new();
    private BusinessPartnerDto? selectedBusinessPartner;
    private string? bpSearchTerm;
    private bool showBPDropdown = false;
    private bool isLoadingBPs = true;

    // Customer price list for dynamic pricing
    private Dictionary<string, decimal> customerPriceListPrices = new();
    private int? customerPriceListNum;
    private bool isLoadingCustomerPrices = false;

    private bool IsCacheReady => CacheService.IsCacheReady;

    private IEnumerable<BusinessPartnerDto> filteredBusinessPartners
    {
        get
        {
            if (string.IsNullOrWhiteSpace(bpSearchTerm))
                return allBusinessPartners.Take(50); // Show first 50 when empty

            var search = bpSearchTerm.ToLowerInvariant();
            return allBusinessPartners.Where(bp =>
            (bp.CardCode?.ToLowerInvariant().Contains(search) ?? false) ||
            (bp.CardName?.ToLowerInvariant().Contains(search) ?? false));
        }
    }

    private bool _hasInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasInitialized)
        {
            _hasInitialized = true;

            try
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                Logger.LogInformation("Auth state fetched, user authenticated: {IsAuthenticated}",
                authState.User?.Identity?.IsAuthenticated ?? false);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to get auth state during initialization");
            }

            // Check if cache is already ready
            if (CacheService.IsCacheReady)
            {
                Logger.LogInformation("Cache is ready, loading from static cache...");
                isLoadingBPs = false;
                isLoadingMasterData = false;
            }

            await LoadAllMasterDataAsync();
            StateHasChanged();
        }
    }

    private async Task LoadAllMasterDataAsync()
    {
        var showLoading = !CacheService.IsCacheReady;
        if (showLoading)
        {
            isLoadingBPs = true;
            isLoadingMasterData = true;
            StateHasChanged();
        }

        // Use a timeout for slow API calls - don't block the UI forever
        var timeout = TimeSpan.FromSeconds(15);

        try
        {
            // Load data SEQUENTIALLY to avoid EF Core DbContext concurrency issues.
            // Each cache getter creates its own DbContext, but background sync tasks
            // can overlap if multiple getters run in parallel, causing
            // "A second operation was started on this context instance" errors.

            // 1. Warehouses - usually fast
            await LoadWithTimeoutAsync(
            "Warehouses",
            async () => cachedWarehouses = await CacheService.GetWarehousesAsync(),
            timeout
            );

            // 2. Cost Centres - usually fast and rarely change
            await LoadWithTimeoutAsync(
            "Cost Centres",
            async () => cachedCostCentres = await CacheService.GetCostCentresAsync(),
            timeout
            );

            // Update UI - warehouses and cost centres are loaded
            isLoadingMasterData = cachedWarehouses.Count == 0;
            StateHasChanged();

            // 3. Business Partners - can be slow
            await LoadWithTimeoutAsync(
            "Business Partners",
            async () =>
            {
                allBusinessPartners = await CacheService.GetBusinessPartnersAsync();
                isLoadingBPs = false;
                await InvokeAsync(StateHasChanged);
            },
            timeout
            );

            // 4. Products - can be slow
            await LoadWithTimeoutAsync(
            "Products",
            async () =>
            {
                cachedProducts = await CacheService.GetProductsAsync();
                isLoadingMasterData = false;
                await InvokeAsync(StateHasChanged);
            },
            timeout
            );

            lastCacheRefresh = CacheService.GetLastRefreshTime("BusinessPartners") ?? CacheService.GetLastRefreshTime("Warehouses");

            Logger.LogInformation("Loaded master data: {BPCount} customers, {ProductCount} products, {WHCount} warehouses, {CCCount} cost centres",
            allBusinessPartners.Count, cachedProducts.Count, cachedWarehouses.Count, cachedCostCentres.Count);

            if (allBusinessPartners.Count == 0 && cachedProducts.Count == 0 && cachedWarehouses.Count == 0)
            {
                errorMessage = "No master data available. The backend API may be slow or unavailable. Please try clicking 'Refresh'.";
            }
            else if (allBusinessPartners.Count == 0 || cachedProducts.Count == 0)
            {
                // Partial data loaded - show a warning but let user proceed
                var missing = new List<string>();
                if (allBusinessPartners.Count == 0) missing.Add("customers");
                if (cachedProducts.Count == 0) missing.Add("products");
                errorMessage = $"Some data is still loading ({string.Join(", ", missing)}). You may need to click 'Refresh' or wait.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading master data");
            errorMessage = $"Failed to load master data: {ex.Message}. Please ensure the backend API is running.";
        }
        finally
        {
            isLoadingBPs = false;
            isLoadingMasterData = false;
            StateHasChanged();
        }
    }

    private async Task LoadWithTimeoutAsync(string dataName, Func<Task> loadAction, TimeSpan timeout)
    {
        try
        {
            using var cts = new CancellationTokenSource(timeout);
            var loadTask = loadAction();
            var completedTask = await Task.WhenAny(loadTask, Task.Delay(timeout, cts.Token));

            if (completedTask == loadTask)
            {
                // Task completed, cancel the delay
                await cts.CancelAsync();
                await loadTask; // Propagate any exceptions
                Logger.LogDebug("{DataName} loaded successfully", dataName);
            }
            else
            {
                // Timeout occurred
                Logger.LogWarning("{DataName} load timed out after {Timeout}s - will continue with cached data", dataName,
                timeout.TotalSeconds);
            }
        }
        catch (OperationCanceledException)
        {
            // This is expected when we cancel the delay task
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading {DataName}", dataName);
            // Don't throw - allow other data to load
        }
    }

    private async Task RefreshMasterData()
    {
        isRefreshingCache = true;
        errorMessage = null;
        try
        {
            CacheService.InvalidateCache();
            await LoadAllMasterDataAsync();
            successMessage = "Master data refreshed successfully!";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error refreshing master data");
            errorMessage = "Failed to refresh master data. Please try again.";
        }
        finally
        {
            isRefreshingCache = false;
        }
    }

    private string TruncateName(string? name, int maxLength)
    {
        if (string.IsNullOrEmpty(name)) return "";
        return name.Length <= maxLength ? name : name.Substring(0, maxLength) + "...";
    }

    private void ApplyCostCentreToAllLines()
    {
        if (!string.IsNullOrEmpty(defaultCostCentre))
        {
            foreach (var line in invoice.Lines)
            {
                line.CostCentreCode = defaultCostCentre;
            }
            StateHasChanged();
        }
    }

    // Cost Centre MudAutocomplete helpers
    private async Task<IEnumerable<CostCentreDto>> SearchCostCentresAsync(string? searchText, CancellationToken
    cancellationToken)
    {
        await Task.CompletedTask; // Make async to match MudAutocomplete signature

        var activeCostCentres = cachedCostCentres.Where(c => c.IsActive);

        if (string.IsNullOrWhiteSpace(searchText))
        {
            return activeCostCentres.Take(20);
        }

        var search = searchText.ToLowerInvariant();
        return activeCostCentres
        .Where(cc =>
        (cc.CenterCode?.ToLowerInvariant().Contains(search) ?? false) ||
        (cc.CenterName?.ToLowerInvariant().Contains(search) ?? false))
        .Take(20);
    }

    private void OnDefaultCostCentreChanged(CostCentreDto? costCentre)
    {
        selectedDefaultCostCentre = costCentre;
        defaultCostCentre = costCentre?.CenterCode;
        ApplyCostCentreToAllLines();
    }

    private CostCentreDto? GetLineCostCentre(CreateInvoiceLineRequest line)
    {
        if (string.IsNullOrEmpty(line.CostCentreCode))
            return null;

        return cachedCostCentres.FirstOrDefault(cc => cc.CenterCode == line.CostCentreCode);
    }

    private void OnLineCostCentreChanged(int index, CostCentreDto? costCentre)
    {
        if (index >= 0 && index < invoice.Lines.Count)
        {
            invoice.Lines[index].CostCentreCode = costCentre?.CenterCode;
            StateHasChanged();
        }
    }

    // Line state management for product autocomplete
    private LineState GetLineState(int index)
    {
        if (!lineStates.ContainsKey(index))
        {
            lineStates[index] = new LineState();
        }
        return lineStates[index];
    }

    private Dictionary<string, string> GetLineValidationErrors(int index)
    {
        return lineValidationErrors.TryGetValue(index, out var errors) ? errors : new Dictionary<string, string>();
    }

    private void OnItemCodeInput(int index, string? value)
    {
        var line = invoice.Lines[index];
        line.ItemCode = value ?? string.Empty;

        var state = GetLineState(index);
        state.SearchTerm = value ?? string.Empty;
        state.SuggestedProduct = null;
        state.SuggestionSuffix = string.Empty;

        // Clear validation error when user starts typing
        if (lineValidationErrors.TryGetValue(index, out var errors))
        {
            errors.Remove("ItemCode");
        }

        if (string.IsNullOrWhiteSpace(value))
        {
            state.FilteredProducts = new List<ProductDto>();
            state.ShowProductDropdown = false;
            return;
        }

        var searchLower = value.ToLowerInvariant();
        var searchUpper = value.ToUpperInvariant();

        state.FilteredProducts = cachedProducts.Where(p =>
        (p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false) ||
        (p.ItemCode?.ToLowerInvariant().Contains(searchLower) ?? false) ||
        (p.ItemName?.ToLowerInvariant().Contains(searchLower) ?? false) ||
        (p.BarCode?.ToLowerInvariant().Contains(searchLower) ?? false)
        ).OrderByDescending(p => p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false)
        .ThenBy(p => p.ItemCode)
        .ToList();

        var exactMatch = state.FilteredProducts.FirstOrDefault(p =>
        p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false);

        if (exactMatch != null && !string.IsNullOrEmpty(exactMatch.ItemCode))
        {
            state.SuggestedProduct = exactMatch;
            state.SuggestionSuffix = exactMatch.ItemCode.Substring(value.Length);
        }

        state.ShowProductDropdown = state.FilteredProducts.Any();
        StateHasChanged();
    }

    private void OnItemCodeKeyDown(int index, KeyboardEventArgs e)
    {
        var state = GetLineState(index);

        if ((e.Key == "Tab" || e.Key == "ArrowRight") && state.SuggestedProduct != null)
        {
            if (e.Key == "Tab" || !string.IsNullOrEmpty(state.SuggestionSuffix))
            {
                SelectProduct(index, state.SuggestedProduct);
            }
        }
        else if (e.Key == "ArrowDown" && state.ShowProductDropdown && state.FilteredProducts.Any())
        {
            var currentIndex = state.SuggestedProduct != null
            ? state.FilteredProducts.IndexOf(state.SuggestedProduct)
            : -1;
            var nextIndex = Math.Min(currentIndex + 1, state.FilteredProducts.Count - 1);
            state.SuggestedProduct = state.FilteredProducts[nextIndex];
            if (state.SuggestedProduct?.ItemCode != null)
            {
                var line = invoice.Lines[index];
                var searchUpper = line.ItemCode?.ToUpperInvariant() ?? "";
                if (state.SuggestedProduct.ItemCode.ToUpperInvariant().StartsWith(searchUpper))
                {
                    state.SuggestionSuffix = state.SuggestedProduct.ItemCode.Substring(line.ItemCode?.Length ?? 0);
                }
                else
                {
                    state.SuggestionSuffix = string.Empty;
                }
            }
            StateHasChanged();
        }
        else if (e.Key == "ArrowUp" && state.ShowProductDropdown && state.FilteredProducts.Any())
        {
            var currentIndex = state.SuggestedProduct != null
            ? state.FilteredProducts.IndexOf(state.SuggestedProduct)
            : state.FilteredProducts.Count;
            var prevIndex = Math.Max(currentIndex - 1, 0);
            state.SuggestedProduct = state.FilteredProducts[prevIndex];
            if (state.SuggestedProduct?.ItemCode != null)
            {
                var line = invoice.Lines[index];
                var searchUpper = line.ItemCode?.ToUpperInvariant() ?? "";
                if (state.SuggestedProduct.ItemCode.ToUpperInvariant().StartsWith(searchUpper))
                {
                    state.SuggestionSuffix = state.SuggestedProduct.ItemCode.Substring(line.ItemCode?.Length ?? 0);
                }
                else
                {
                    state.SuggestionSuffix = string.Empty;
                }
            }
            StateHasChanged();
        }
        else if (e.Key == "Enter" && state.SuggestedProduct != null)
        {
            SelectProduct(index, state.SuggestedProduct);
        }
        else if (e.Key == "Escape")
        {
            state.ShowProductDropdown = false;
            state.SuggestedProduct = null;
            state.SuggestionSuffix = string.Empty;
            StateHasChanged();
        }
    }

    private void OnItemCodeFocus(int index)
    {
        var state = GetLineState(index);
        if (!string.IsNullOrEmpty(state.SearchTerm) || cachedProducts.Any())
        {
            state.ShowProductDropdown = true;
            if (string.IsNullOrEmpty(state.SearchTerm))
            {
                state.FilteredProducts = cachedProducts.Take(15).ToList();
            }
        }
    }

    private async Task OnItemCodeBlur(int index)
    {
        await Task.Delay(200);
        var state = GetLineState(index);
        state.ShowProductDropdown = false;
        state.SuggestionSuffix = string.Empty;
        StateHasChanged();
    }

    private void OnQuantityChange(int index, string? value)
    {
        var line = invoice.Lines[index];

        if (decimal.TryParse(value, out var quantity))
        {
            // Prevent negative quantities
            if (quantity < 0)
            {
                quantity = 0;
                errorMessage = "Quantity cannot be negative. Value has been reset to 0.";
            }
            line.Quantity = quantity;
        }
        else
        {
            line.Quantity = 0;
        }

        // Clear validation error when user changes value
        if (lineValidationErrors.TryGetValue(index, out var errors))
        {
            errors.Remove("Quantity");
        }

        StateHasChanged();
    }

    private void SelectProduct(int index, ProductDto product)
    {
        var line = invoice.Lines[index];
        line.ItemCode = product.ItemCode ?? string.Empty;
        line.ItemDescription = product.ItemName ?? string.Empty;

        // Use price from customer's price list if available, otherwise use default product price
        line.UnitPrice = GetPriceForItem(product.ItemCode, product.Price);

        line.WarehouseCode = !string.IsNullOrEmpty(warehouseCode) ? warehouseCode : (product.DefaultWarehouse ?? "01");

        // Apply default cost centre if set
        if (!string.IsNullOrEmpty(defaultCostCentre))
        {
            line.CostCentreCode = defaultCostCentre;
        }

        var state = GetLineState(index);
        state.ShowProductDropdown = false;
        state.SearchTerm = product.ItemCode ?? string.Empty;
        state.SuggestedProduct = null;
        state.SuggestionSuffix = string.Empty;

        // Clear validation errors for this line
        if (lineValidationErrors.TryGetValue(index, out var errors))
        {
            errors.Remove("ItemCode");
        }

        StateHasChanged();
    }

    private async Task SelectBusinessPartnerAsync(BusinessPartnerDto bp)
    {
        selectedBusinessPartner = bp;
        invoice.CardCode = bp.CardCode ?? string.Empty;
        bpSearchTerm = bp.DisplayName;
        showBPDropdown = false;

        if (!string.IsNullOrEmpty(bp.Currency))
        {
            invoice.DocCurrency = bp.Currency;
        }

        // Clear validation error
        validationErrors.Remove("Customer");

        // Load prices from customer's price list if available
        if (bp.PriceListNum.HasValue && bp.PriceListNum.Value > 0)
        {
            await LoadCustomerPriceList(bp.PriceListNum.Value);
        }
        else
        {
            // Reset to default product prices
            customerPriceListPrices.Clear();
            customerPriceListNum = null;
        }
    }

    private void SelectBusinessPartner(BusinessPartnerDto bp)
    {
        _ = SelectBusinessPartnerAsync(bp);
    }

    private void ClearSelectedBP()
    {
        selectedBusinessPartner = null;
        invoice.CardCode = string.Empty;
        bpSearchTerm = null;
        customerPriceListPrices.Clear();
        customerPriceListNum = null;
    }

    private async Task LoadCustomerPriceList(int priceListNum)
    {
        isLoadingCustomerPrices = true;
        StateHasChanged();

        try
        {
            Logger.LogInformation("Loading prices from customer price list {PriceListNum}", priceListNum);

            var response = await PriceService.GetPricesByPriceListAsync(priceListNum);

            if (response?.Prices != null && response.Prices.Any())
            {
                customerPriceListPrices.Clear();
                foreach (var price in response.Prices)
                {
                    if (!string.IsNullOrEmpty(price.ItemCode))
                    {
                        customerPriceListPrices[price.ItemCode] = price.Price;
                    }
                }
                customerPriceListNum = priceListNum;

                Logger.LogInformation("Loaded {Count} prices from customer price list {PriceListNum}",
                customerPriceListPrices.Count, priceListNum);
            }
            else
            {
                Logger.LogWarning("No prices found for price list {PriceListNum}", priceListNum);
                customerPriceListPrices.Clear();
                customerPriceListNum = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading customer price list {PriceListNum}", priceListNum);
            customerPriceListPrices.Clear();
            customerPriceListNum = null;
        }
        finally
        {
            isLoadingCustomerPrices = false;
            StateHasChanged();
        }
    }

    private decimal GetPriceForItem(string? itemCode, decimal defaultPrice)
    {
        if (string.IsNullOrEmpty(itemCode))
            return defaultPrice;

        // If customer has a price list with this item, use that price
        if (customerPriceListPrices.TryGetValue(itemCode, out var customerPrice))
        {
            return customerPrice;
        }

        // Fall back to default product price
        return defaultPrice;
    }

    private async Task OnBPSearchBlur()
    {
        await Task.Delay(200);
        showBPDropdown = false;
    }

    private void AddLine()
    {
        var newLine = new CreateInvoiceLineRequest
        {
            Quantity = 1,
            WarehouseCode = warehouseCode ?? "01"
        };

        // Apply default cost centre if set
        if (!string.IsNullOrEmpty(defaultCostCentre))
        {
            newLine.CostCentreCode = defaultCostCentre;
        }

        invoice.Lines.Add(newLine);
    }

    private void RemoveLine(int index)
    {
        if (index >= 0 && index < invoice.Lines.Count)
        {
            invoice.Lines.RemoveAt(index);
            lineStates.Remove(index);
            lineValidationErrors.Remove(index);

            // Re-index states
            var newStates = new Dictionary<int, LineState>();
            var newErrors = new Dictionary<int, Dictionary<string, string>>();

            foreach (var kvp in lineStates.OrderBy(x => x.Key))
            {
                if (kvp.Key < index)
                {
                    newStates[kvp.Key] = kvp.Value;
                }
                else if (kvp.Key > index)
                {
                    newStates[kvp.Key - 1] = kvp.Value;
                }
            }

            foreach (var kvp in lineValidationErrors.OrderBy(x => x.Key))
            {
                if (kvp.Key < index)
                {
                    newErrors[kvp.Key] = kvp.Value;
                }
                else if (kvp.Key > index)
                {
                    newErrors[kvp.Key - 1] = kvp.Value;
                }
            }

            lineStates = newStates;
            lineValidationErrors = newErrors;
        }
    }

    private decimal CalculateLineTotal(CreateInvoiceLineRequest line)
    {
        var subtotal = line.Quantity * (line.UnitPrice ?? 0);
        var discount = subtotal * ((line.DiscountPercent ?? 0) / 100);
        return subtotal - discount;
    }

    private decimal CalculateSubtotal()
    {
        return invoice.Lines.Sum(l => l.Quantity * (l.UnitPrice ?? 0));
    }

    private decimal CalculateTotalDiscount()
    {
        return invoice.Lines.Sum(l =>
        {
            var subtotal = l.Quantity * (l.UnitPrice ?? 0);
            return subtotal * ((l.DiscountPercent ?? 0) / 100);
        });
    }

    private decimal CalculateTotal()
    {
        return invoice.Lines.Sum(l => CalculateLineTotal(l));
    }

    private bool ValidateForm()
    {
        validationErrors.Clear();
        lineValidationErrors.Clear();
        var isValid = true;

        // Validate customer
        if (string.IsNullOrWhiteSpace(invoice.CardCode))
        {
            validationErrors["Customer"] = "Please select a customer";
            isValid = false;
        }

        // Validate lines
        if (!invoice.Lines.Any())
        {
            validationErrors["Lines"] = "At least one line item is required";
            isValid = false;
        }

        for (int i = 0; i < invoice.Lines.Count; i++)
        {
            var line = invoice.Lines[i];
            var errors = new Dictionary<string, string>();

            // Item code required
            if (string.IsNullOrWhiteSpace(line.ItemCode))
            {
                errors["ItemCode"] = "Item code is required";
                isValid = false;
            }

            // Warehouse required
            if (string.IsNullOrWhiteSpace(line.WarehouseCode))
            {
                errors["Warehouse"] = "Warehouse is required";
                isValid = false;
            }

            // Quantity validation - must be positive
            if (line.Quantity <= 0)
            {
                errors["Quantity"] = "Quantity must be greater than zero";
                isValid = false;
            }

            // Batch number is optional - auto-allocated using FEFO if not specified
            // The API will handle batch selection automatically

            if (errors.Any())
            {
                lineValidationErrors[i] = errors;
            }
        }

        StateHasChanged();
        return isValid;
    }

    private async Task SubmitInvoice()
    {
        errorMessage = null;
        successMessage = null;

        if (!ValidateForm())
        {
            errorMessage = "Please fix the validation errors before submitting.";
            Logger.LogWarning("Invoice validation failed. Errors: {Errors}",
            string.Join("; ", validationErrors.Select(e => $"{e.Key}: {e.Value}")
            .Concat(lineValidationErrors.SelectMany(le => le.Value.Select(e => $"Line {le.Key + 1} {e.Key}: {e.Value}")))));
            return;
        }

        isSubmitting = true;

        try
        {
            // Log the invoice request for debugging
            Logger.LogInformation("Creating invoice for customer {CardCode} with {LineCount} lines",
            invoice.CardCode, invoice.Lines.Count);

            foreach (var (line, index) in invoice.Lines.Select((l, i) => (l, i)))
            {
                Logger.LogDebug("Line {LineNum}: ItemCode={ItemCode}, Qty={Quantity}, Price={Price}, Warehouse={Warehouse}, Batch={Batch}, Account={Account}",
                index + 1,
                line.ItemCode,
                line.Quantity,
                line.UnitPrice,
                line.WarehouseCode,
                string.IsNullOrEmpty(line.BatchNumber) ? "(auto-FEFO)" : line.BatchNumber,
                line.AccountCode ?? "(default)");

                // Log batch numbers if specified
                if (line.BatchNumbers?.Any() == true)
                {
                    foreach (var batch in line.BatchNumbers)
                    {
                        Logger.LogDebug(" Batch: {BatchNumber}, Qty: {Quantity}", batch.BatchNumber, batch.Quantity);
                    }
                }
            }

            var (success, message, createdInvoice) = await InvoiceService.CreateInvoiceAsync(invoice);

            if (success)
            {
                Logger.LogInformation("Invoice #{DocNum} (DocEntry: {DocEntry}) created successfully for customer {CardCode}",
                createdInvoice?.DocNum, createdInvoice?.DocEntry, invoice.CardCode);
                var notificationNote = await TrySendCustomerInvoiceNotificationAsync(createdInvoice);
                successMessage = $"Invoice #{createdInvoice?.DocNum} created successfully!";
                if (!string.IsNullOrWhiteSpace(notificationNote))
                {
                    successMessage = $"{successMessage} {notificationNote}";
                }

                // Auto-print invoice PDF if enabled in settings
                await TryAutoPrintInvoiceAsync(createdInvoice);

                ClearForm();
            }
            else
            {
                Logger.LogError("Failed to create invoice for customer {CardCode}. Error: {Error}",
                invoice.CardCode, message);
                errorMessage = message;
            }
        }
        catch (HttpRequestException httpEx)
        {
            Logger.LogError(httpEx, "HTTP error creating invoice for customer {CardCode}. Status: {StatusCode}",
            invoice.CardCode, httpEx.StatusCode);
            errorMessage = $"Network error: {httpEx.Message}. Please check if the API is running.";
        }
        catch (TaskCanceledException tcEx) when (tcEx.InnerException is TimeoutException)
        {
            Logger.LogError(tcEx, "Timeout creating invoice for customer {CardCode}", invoice.CardCode);
            errorMessage = "Request timed out. The server may be busy, please try again.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error creating invoice for customer {CardCode}. Exception: {ExceptionType}",
            invoice.CardCode, ex.GetType().Name);
            errorMessage = $"Error creating invoice: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task<string?> TrySendCustomerInvoiceNotificationAsync(InvoiceDto? createdInvoice)
    {
        if (!notifyCustomerByEmail)
        {
            return null;
        }

        if (createdInvoice == null)
        {
            Logger.LogWarning("Invoice created but no invoice details were returned. Skipping email notification.");
            return "Notification email skipped (invoice details unavailable).";
        }

        var cardCode = createdInvoice.CardCode ?? invoice.CardCode;
        var customerName = selectedBusinessPartner?.CardName ?? createdInvoice.CardName ?? "Customer";
        var customerEmail = selectedBusinessPartner?.Email;

        if (string.IsNullOrWhiteSpace(customerEmail) && !string.IsNullOrWhiteSpace(cardCode))
        {
            var bp = await BusinessPartnerService.GetBusinessPartnerByCodeAsync(cardCode);
            if (bp != null)
            {
                customerEmail = bp.Email;
                if (!string.IsNullOrWhiteSpace(bp.CardName))
                {
                    customerName = bp.CardName;
                }
            }
        }

        if (string.IsNullOrWhiteSpace(customerEmail))
        {
            Logger.LogWarning("No email found for customer {CardCode}. Skipping invoice notification.", cardCode);
            return "Notification email skipped (customer email missing).";
        }

        var sent = await EmailService.SendCustomerInvoiceNotificationAsync(
        customerEmail,
        customerName,
        createdInvoice.DocEntry,
        createdInvoice.DocNum.ToString(),
        createdInvoice.DocTotal);

        if (sent)
        {
            Logger.LogInformation("Invoice notification email sent to {Email} for invoice {DocNum}.",
            customerEmail, createdInvoice.DocNum);
            return "Notification email sent.";
        }

        Logger.LogWarning("Failed to send invoice notification email to {Email} for invoice {DocNum}.",
        customerEmail, createdInvoice.DocNum);
        return "Notification email failed to send.";
    }

    private async Task TryAutoPrintInvoiceAsync(InvoiceDto? createdInvoice)
    {
        try
        {
            var autoPrint = await AppSettingsService.GetValueAsync<bool>(SettingKeys.AutoPrintInvoice);
            if (!autoPrint || createdInvoice == null)
                return;

            Logger.LogInformation("Auto-printing invoice #{DocNum} (DocEntry: {DocEntry})",
            createdInvoice.DocNum, createdInvoice.DocEntry);

            var pdfBytes = await InvoiceService.GetInvoicePdfAsync(createdInvoice.DocEntry);
            if (pdfBytes == null || pdfBytes.Length == 0)
            {
                Logger.LogWarning("Failed to retrieve PDF for auto-print of invoice #{DocNum}", createdInvoice.DocNum);
                return;
            }

            var copies = await AppSettingsService.GetValueAsync<int>(SettingKeys.PrintCopies);
            if (copies < 1) copies = 1;

            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("printPdfFromBase64", base64, copies);

            Logger.LogInformation("Auto-print triggered for invoice #{DocNum} ({Copies} copies)",
            createdInvoice.DocNum, copies);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Auto-print failed for invoice. Error: {Message}", ex.Message);
            // Don't fail the invoice creation if printing fails
        }
    }

    private void ClearForm()
    {
        invoice = new CreateInvoiceRequest
        {
            DocCurrency = "USD",
            Lines = new List<CreateInvoiceLineRequest>()
        };
        lineStates.Clear();
        lineValidationErrors.Clear();
        validationErrors.Clear();
        ClearSelectedBP();
    }
