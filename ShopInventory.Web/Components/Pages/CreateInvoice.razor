@page "/invoices/create"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using ShopInventory.Web.Data
@attribute [Authorize(Roles = "Admin,Cashier")]
@inject IInvoiceService InvoiceService
@inject IProductService ProductService
@inject IPriceService PriceService
@inject IBusinessPartnerService BusinessPartnerService
@inject IEmailService EmailService
@inject IMasterDataCacheService CacheService
@inject IAppSettingsService AppSettingsService
@inject IAppSettingsProvider AppSettings
@inject IPrinterService PrinterService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject ILogger<CreateInvoice> Logger
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuditService AuditService
@rendermode InteractiveServer

<PageTitle>Create Invoice - Shop Inventory</PageTitle>

<style>
    /* â”€â”€ Page â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .ci-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* â”€â”€ Breadcrumb â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .ci-breadcrumb {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .85rem;
        color: #6b7280;
        margin-bottom: 1.25rem;
    }

    .ci-breadcrumb a {
        color: #2563eb;
        text-decoration: none;
        font-weight: 500;
    }

    .ci-breadcrumb a:hover {
        text-decoration: underline;
    }

    .ci-breadcrumb .sep {
        color: #d1d5db;
    }

    /* â”€â”€ Header â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .ci-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .ci-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .ci-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        box-shadow: 0 4px 14px rgba(37, 99, 235, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .ci-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }

    .ci-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .ci-header-actions {
        display: flex;
        gap: .5rem;
        align-items: center;
    }

    .btn-back {
        background: #fff;
        border: 1px solid #e5e7eb;
        color: #374151;
        padding: .5rem 1.1rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .85rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-back:hover {
        background: #f9fafb;
        border-color: #9ca3af;
        color: #374151;
    }

    .btn-refresh {
        background: #fff;
        border: 1px solid #e5e7eb;
        color: #374151;
        padding: .5rem 1.1rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .85rem;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        cursor: pointer;
    }

    .btn-refresh:hover:not(:disabled) {
        background: #f0fdf4;
        border-color: #059669;
        color: #059669;
    }

    .btn-refresh:disabled {
        opacity: .5;
        cursor: not-allowed;
    }

    /* â”€â”€ Section Card â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .section-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .section-card .card-hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .85rem 1.25rem;
        border-bottom: 1px solid #f3f4f6;
    }

    .section-card .card-hdr .hdr-left {
        display: flex;
        align-items: center;
        gap: .65rem;
    }

    .section-card .card-hdr .header-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .95rem;
        flex-shrink: 0;
    }

    .section-card .card-hdr h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        font-size: .95rem;
    }

    .section-card .card-body-inner {
        padding: 1.25rem;
    }

    /* â”€â”€ Alert Banners â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.success-alert {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .alert-banner .alert-body {
        flex: 1;
    }

    .alert-banner .alert-close {
        background: none;
        border: none;
        color: inherit;
        opacity: .45;
        cursor: pointer;
        padding: .2rem;
        font-size: 1rem;
    }

    .alert-banner .alert-close:hover {
        opacity: 1;
    }

    /* â”€â”€ Form Fields â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .field-label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .35rem;
    }

    .field-group {
        margin-bottom: 0.5rem;
    }

    .form-control-line,
    .form-select-line {
        font-size: 0.88rem;
        padding: 0.5rem 0.75rem;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control-line:focus,
    .form-select-line:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, .1);
    }

    .form-control-line::placeholder {
        color: #adb5bd;
    }

    /* â”€â”€ Customer Badge â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .selected-customer-badge {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 10px;
        padding: .75rem 1rem;
    }

    .bp-clear-btn {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        width: 28px;
        height: 28px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .8rem;
    }

    .bp-clear-btn:hover {
        background: #dc2626;
        color: #fff;
        border-color: #dc2626;
    }

    /* â”€â”€ Dropdown â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .dropdown-autocomplete {
        position: absolute;
        z-index: 1050;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        max-height: 280px;
        overflow-y: auto;
        width: 100%;
        box-shadow: 0 8px 25px rgba(0, 0, 0, .12);
        top: 100%;
        margin-top: 2px;
    }

    .dropdown-autocomplete .dropdown-item {
        padding: .55rem 1rem;
        cursor: pointer;
        transition: background .12s;
        font-size: .88rem;
        border-bottom: 1px solid #f9fafb;
    }

    .dropdown-autocomplete .dropdown-item:hover {
        background: #f0fdf4;
    }

    .dropdown-autocomplete .dropdown-item.selected {
        background: #2563eb;
        color: white;
    }

    /* â”€â”€ Line Items â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .line-card {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1rem 1.15rem;
        margin-bottom: .75rem;
        transition: all .2s;
        position: relative;
    }

    .line-card:hover {
        border-color: #2563eb;
        box-shadow: 0 2px 10px rgba(37, 99, 235, .08);
    }

    .line-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .75rem;
        padding-bottom: .5rem;
        border-bottom: 1px solid #e5e7eb;
    }

    .line-number {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: white;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 0.8rem;
    }

    .line-total-display {
        font-size: 1.05rem;
        font-weight: 700;
        color: #059669;
    }

    .line-remove {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        width: 28px;
        height: 28px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .8rem;
    }

    .line-remove:hover {
        background: #dc2626;
        color: #fff;
        border-color: #dc2626;
    }

    .product-selected-info {
        background: #f0f9ff;
        border: 1px solid #bae6fd;
        border-radius: 8px;
        padding: 0.5rem 0.75rem;
        font-size: 0.85rem;
        color: #0c4a6e;
    }

    /* â”€â”€ Global Settings Bar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .global-settings-bar {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: .85rem 1.15rem;
        margin-bottom: 1.25rem;
    }

    .settings-bar-header {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .75rem;
    }

    .settings-bar-header .settings-icon {
        width: 24px;
        height: 24px;
        border-radius: 6px;
        background: #e0e7ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .75rem;
    }

    .settings-bar-header>span:first-of-type {
        font-weight: 600;
        font-size: .8rem;
        color: #334155;
        letter-spacing: -.01em;
    }

    .batch-required-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        background: linear-gradient(135deg, #ecfdf5, #d1fae5);
        color: #065f46;
        font-size: .7rem;
        padding: .25rem .65rem;
        border-radius: 20px;
        font-weight: 600;
        letter-spacing: .015em;
        border: 1px solid #a7f3d0;
    }

    .settings-fields {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .settings-field-label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #64748b;
        margin-bottom: .35rem;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .settings-fields .form-select-line,
    .settings-fields ::deep .mud-input-outlined {
        background: #fff;
        border-radius: 8px;
        font-size: .82rem;
    }

    /* â”€â”€ Empty State â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .empty-lines-placeholder {
        text-align: center;
        padding: 3rem 1.5rem;
        background: linear-gradient(180deg, #f9fafb 0%, #fff 100%);
        border-radius: 12px;
        border: 2px dashed #e5e7eb;
        margin: .5rem 0;
    }

    .empty-lines-placeholder .empty-ico {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #9ca3af;
        margin-bottom: 1rem;
    }

    .empty-lines-placeholder p {
        color: #6b7280;
        font-size: .9rem;
        margin-bottom: .25rem !important;
    }

    .empty-lines-placeholder .empty-hint {
        color: #9ca3af;
        font-size: .8rem;
        margin-bottom: 1.25rem;
    }

    /* â”€â”€ Summary Sidebar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .summary-section {
        position: sticky;
        top: 1.5rem;
    }

    .summary-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .summary-hdr {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .85rem 1.15rem;
        border-bottom: 1px solid #f3f4f6;
    }

    .summary-hdr h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        font-size: .92rem;
    }

    .summary-body {
        padding: .85rem 1.15rem;
    }

    .sum-line {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .35rem 0;
    }

    .sum-label {
        color: #6b7280;
        font-size: .88rem;
        display: flex;
        align-items: center;
    }

    .sum-value {
        font-weight: 600;
        color: #1a1a2e;
        font-size: .88rem;
    }

    .sum-divider {
        border: none;
        border-top: 1px dashed #e5e7eb;
        margin: .5rem 0;
    }

    .sum-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .5rem 0;
    }

    .total-label {
        font-weight: 700;
        color: #1a1a2e;
        font-size: 1rem;
    }

    .total-value {
        font-weight: 700;
        color: #059669;
        font-size: 1.35rem;
    }

    /* â”€â”€ Action Buttons â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .btn-execute {
        width: 100%;
        padding: .7rem 1.25rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: .92rem;
        border: none;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        cursor: pointer;
        transition: all .2s;
        box-shadow: 0 2px 8px rgba(37, 99, 235, .25);
        margin-bottom: .5rem;
    }

    .btn-execute:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(37, 99, 235, .4);
    }

    .btn-execute:disabled {
        opacity: .55;
        cursor: not-allowed;
    }

    .btn-secondary-action {
        width: 100%;
        padding: .55rem 1rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .85rem;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        cursor: pointer;
        transition: all .15s;
        margin-bottom: .75rem;
    }

    .btn-secondary-action:hover:not(:disabled) {
        background: #f9fafb;
        border-color: #9ca3af;
        color: #374151;
    }

    .btn-secondary-action:disabled {
        opacity: .5;
        cursor: not-allowed;
    }

    .info-hint {
        display: flex;
        gap: .45rem;
        font-size: .78rem;
        color: #9ca3af;
        line-height: 1.4;
        padding: .5rem;
        background: #f9fafb;
        border-radius: 8px;
    }

    .btn-add-line {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        background: linear-gradient(135deg, #059669, #047857);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: .8rem;
        padding: .45rem .95rem;
        cursor: pointer;
        transition: all .2s;
        box-shadow: 0 1px 3px rgba(5, 150, 105, .25);
    }

    .btn-add-line:hover {
        background: linear-gradient(135deg, #047857, #065f46);
        color: #fff;
        box-shadow: 0 2px 6px rgba(5, 150, 105, .35);
        transform: translateY(-1px);
    }

    .btn-add-first {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: linear-gradient(135deg, #059669, #047857);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        font-size: .9rem;
        padding: .6rem 1.5rem;
        cursor: pointer;
        transition: all .2s;
        box-shadow: 0 2px 8px rgba(5, 150, 105, .25);
    }

    .btn-add-first:hover {
        background: linear-gradient(135deg, #047857, #065f46);
        box-shadow: 0 4px 14px rgba(5, 150, 105, .35);
        transform: translateY(-1px);
    }

    /* â”€â”€ Print Button â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .btn-print-invoice {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        background: #fff;
        color: #166534;
        border: 1px solid #bbf7d0;
        border-radius: 7px;
        font-weight: 600;
        font-size: .8rem;
        padding: .3rem .7rem;
        margin-left: .6rem;
        cursor: pointer;
        transition: all .15s;
        vertical-align: middle;
    }

    .btn-print-invoice:hover:not(:disabled) {
        background: #166534;
        color: #fff;
        border-color: #166534;
    }

    .btn-print-invoice:disabled {
        opacity: .55;
        cursor: not-allowed;
    }

    /* â”€â”€ Validation â”€â”€â”€â”€â”€ */
    .validation-error {
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 2px rgba(239, 68, 68, .15) !important;
    }

    /* â”€â”€ Data Status â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
    }

    .status-dot.ready {
        background: #059669;
    }

    .status-dot.loading {
        background: #d97706;
    }

    .status-dot.error {
        background: #dc2626;
    }

    .ds-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .82rem;
        color: #6b7280;
        padding: .2rem 0;
    }

    /* Modern invoice workspace refresh */
    .ci-page {
        --ci-bg: #f6f7fb;
        --ci-surface: #ffffff;
        --ci-surface-muted: #f8fafc;
        --ci-border: #e2e8f0;
        --ci-border-strong: #cbd5e1;
        --ci-text: #0f172a;
        --ci-muted: #64748b;
        --ci-subtle: #94a3b8;
        --ci-primary: #111827;
        --ci-primary-hover: #020617;
        --ci-accent: #2563eb;
        --ci-success: #047857;
        --ci-warning: #b45309;
        --ci-danger: #dc2626;
        --ci-focus: rgba(37, 99, 235, .16);
        background: var(--ci-bg);
        color: var(--ci-text);
        padding: 1.25rem;
    }

    .ci-page .container-fluid {
        max-width: 1680px;
    }

    .ci-breadcrumb {
        margin-bottom: .85rem;
        color: var(--ci-muted);
        font-size: .82rem;
    }

    .ci-breadcrumb a {
        color: var(--ci-text);
    }

    .ci-breadcrumb .sep {
        color: var(--ci-subtle);
    }

    .ci-header {
        background: var(--ci-surface);
        border: 1px solid var(--ci-border);
        border-radius: 8px;
        box-shadow: var(--shadow-sm);
        padding: 1.15rem;
        margin-bottom: 1rem;
    }

    .ci-header-icon {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        background: var(--ci-primary);
        box-shadow: none;
        font-size: 1.25rem;
    }

    .ci-header h2 {
        color: var(--ci-text);
        font-size: 1.45rem;
        font-weight: 700;
        letter-spacing: 0;
        margin-bottom: .15rem;
    }

    .ci-header p {
        color: var(--ci-muted);
        font-size: .88rem;
    }

    .ci-header-actions {
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .ci-status-pill {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        min-height: 36px;
        padding: .45rem .7rem;
        border: 1px solid var(--ci-border);
        border-radius: 8px;
        background: var(--ci-surface-muted);
        color: var(--ci-muted);
        font-size: .8rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .ci-command-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .ci-metric {
        min-height: 78px;
        display: flex;
        align-items: center;
        gap: .75rem;
        background: var(--ci-surface);
        border: 1px solid var(--ci-border);
        border-radius: 8px;
        padding: .85rem 1rem;
        box-shadow: var(--shadow-sm);
    }

    .ci-metric-icon {
        width: 38px;
        height: 38px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--ci-surface-muted);
        color: var(--ci-accent);
        flex-shrink: 0;
    }

    .ci-metric-label {
        color: var(--ci-muted);
        font-size: .75rem;
        font-weight: 600;
        letter-spacing: 0;
    }

    .ci-metric-value {
        color: var(--ci-text);
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .section-card,
    .summary-card {
        background: var(--ci-surface);
        border: 1px solid var(--ci-border);
        border-radius: 8px;
        box-shadow: var(--shadow-sm);
    }

    .section-card {
        margin-bottom: 1rem;
    }

    .section-card .card-hdr,
    .summary-hdr {
        background: var(--ci-surface-muted);
        border-bottom: 1px solid var(--ci-border);
        padding: .9rem 1rem;
    }

    .section-card .card-hdr h6,
    .summary-hdr h6 {
        color: var(--ci-text);
        font-size: .95rem;
        letter-spacing: 0;
    }

    .section-card .card-hdr .header-icon,
    .settings-bar-header .settings-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: #eef2ff !important;
        color: var(--ci-accent) !important;
    }

    .section-card .card-body-inner {
        padding: 1rem;
    }

    .field-label,
    .settings-field-label {
        color: var(--ci-muted);
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: 0;
    }

    .ci-page .form-control,
    .ci-page .form-select,
    .form-control-line,
    .form-select-line {
        min-height: 40px;
        border: 1px solid var(--ci-border-strong);
        border-radius: 8px;
        background: var(--ci-surface);
        color: var(--ci-text);
        font-size: .88rem;
        box-shadow: none;
    }

    .ci-page .form-control:focus,
    .ci-page .form-select:focus,
    .form-control-line:focus,
    .form-select-line:focus {
        border-color: var(--ci-accent);
        box-shadow: 0 0 0 3px var(--ci-focus);
    }

    .ci-page .form-control::placeholder,
    .form-control-line::placeholder {
        color: var(--ci-subtle);
    }

    .ci-page ::deep .mud-input-outlined,
    .ci-page ::deep .mud-input-control {
        border-radius: 8px;
        font-size: .88rem;
    }

    .btn-back,
    .btn-refresh,
    .btn-secondary-action {
        min-height: 38px;
        border-radius: 8px;
        border: 1px solid var(--ci-border-strong);
        background: var(--ci-surface);
        color: var(--ci-text);
        box-shadow: none;
    }

    .btn-back:hover,
    .btn-refresh:hover:not(:disabled),
    .btn-secondary-action:hover:not(:disabled) {
        background: var(--ci-surface-muted);
        border-color: var(--ci-primary);
        color: var(--ci-primary);
        transform: none;
    }

    .btn-execute,
    .btn-add-line,
    .btn-add-first {
        border-radius: 8px;
        background: var(--ci-primary);
        color: #fff;
        box-shadow: none;
    }

    .btn-execute:hover:not(:disabled),
    .btn-add-line:hover,
    .btn-add-first:hover {
        background: var(--ci-primary-hover);
        box-shadow: var(--shadow-md);
        transform: translateY(-1px);
        color: #fff;
    }

    .alert-banner {
        border-radius: 8px;
        box-shadow: var(--shadow-sm);
    }

    .selected-customer-badge {
        background: #ecfdf5;
        border-color: #a7f3d0;
        border-radius: 8px;
    }

    .global-settings-bar {
        background: var(--ci-surface-muted);
        border: 1px solid var(--ci-border);
        border-radius: 8px;
        padding: 1rem;
    }

    .settings-bar-header>span:first-of-type {
        color: var(--ci-text);
        letter-spacing: 0;
    }

    .batch-required-badge {
        border-radius: 999px;
        background: #ecfdf5;
        border-color: #a7f3d0;
        color: #047857;
        letter-spacing: 0;
    }

    .line-card {
        background: var(--ci-surface);
        border: 1px solid var(--ci-border);
        border-radius: 8px;
        padding: 1rem;
        box-shadow: none;
    }

    .line-card:hover {
        border-color: var(--ci-border-strong);
        box-shadow: var(--shadow-md);
    }

    .line-card-header {
        border-bottom: 1px solid var(--ci-border);
    }

    .line-number {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: var(--ci-primary);
    }

    .line-total-display,
    .total-value {
        color: var(--ci-success);
    }

    .line-remove,
    .bp-clear-btn {
        border-radius: 8px;
        background: #fff1f2;
        border-color: #fecdd3;
        color: var(--ci-danger);
        min-width: 0;
    }

    .line-remove:hover,
    .bp-clear-btn:hover {
        background: var(--ci-danger);
        border-color: var(--ci-danger);
        color: #fff;
    }

    .product-selected-info,
    .info-hint {
        background: var(--ci-surface-muted);
        border: 1px solid var(--ci-border);
        border-radius: 8px;
        color: var(--ci-muted);
    }

    .empty-lines-placeholder {
        background: var(--ci-surface-muted);
        border: 1px dashed var(--ci-border-strong);
        border-radius: 8px;
    }

    .empty-lines-placeholder .empty-ico {
        border-radius: 8px;
        background: var(--ci-surface);
        color: var(--ci-muted);
    }

    .summary-section {
        top: 1rem;
    }

    .summary-body {
        padding: 1rem;
    }

    .sum-label {
        color: var(--ci-muted);
    }

    .sum-value,
    .total-label {
        color: var(--ci-text);
    }

    .sum-divider {
        border-top-color: var(--ci-border);
    }

    .ds-item {
        color: var(--ci-muted);
    }

    .ci-price-chip {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        border-radius: 999px;
        padding: .18rem .5rem;
        font-size: .78rem;
        font-weight: 700;
        background: #eff6ff;
        color: #1d4ed8;
        white-space: nowrap;
    }

    .ci-price-chip.customer {
        background: #ecfdf5;
        color: #047857;
    }

    .ci-price-chip small {
        font-size: .65rem;
        font-weight: 600;
        opacity: .75;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .ci-header {
            flex-direction: column;
        }

        .ci-header-actions,
        .btn-back,
        .btn-refresh,
        .ci-status-pill {
            width: 100%;
            justify-content: center;
        }

        .ci-command-strip {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .settings-fields {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 520px) {
        .ci-page {
            padding: .8rem;
        }

        .ci-command-strip {
            grid-template-columns: 1fr;
        }

        .ci-metric {
            min-height: 64px;
        }
    }
</style>

<div class="ci-page">
    <div class="container-fluid">

        <!-- Breadcrumb -->
        <div class="ci-breadcrumb">
            <a href="/invoices">Invoices</a>
            <span class="sep">/</span>
            <span>Create New</span>
        </div>

        <!-- Header -->
        <div class="ci-header">
            <div class="ci-header-left">
                <div class="ci-header-icon"><i class="bi bi-receipt"></i></div>
                <div>
                    <h2>Create Invoice</h2>
                    <p>Create a new sales invoice with batch tracking</p>
                </div>
            </div>
            <div class="ci-header-actions">
                <div class="ci-status-pill">
                    <span
                    class="status-dot @(IsCacheReady ? "ready" : (isRefreshingCache ? "loading" : "error"))"></span>
                    <span>@(IsCacheReady ? "Data Ready" : (isRefreshingCache ? "Syncing..." : "Offline"))</span>
                </div>
                <MudButton Class="btn-refresh" OnClick="RefreshMasterData" Disabled="@isRefreshingCache">
                    @if (isRefreshingCache)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-clockwise"></i>
                    }
                    Refresh
                </MudButton>
                <a href="/invoices" class="btn-back"><i class="bi bi-arrow-left"></i> Back</a>
            </div>
        </div>

        <div class="ci-command-strip">
            <div class="ci-metric">
                <span class="ci-metric-icon"><i class="bi bi-list-check"></i></span>
                <div>
                    <div class="ci-metric-label">Lines</div>
                    <div class="ci-metric-value">@invoice.Lines.Count</div>
                </div>
            </div>
            <div class="ci-metric">
                <span class="ci-metric-icon"><i class="bi bi-cash-stack"></i></span>
                <div>
                    <div class="ci-metric-label">Subtotal</div>
                    <div class="ci-metric-value">@CalculateSubtotal().ToString("N2") @invoice.DocCurrency</div>
                </div>
            </div>
            <div class="ci-metric">
                <span class="ci-metric-icon"><i class="bi bi-percent"></i></span>
                <div>
                    <div class="ci-metric-label">VAT 15.5%</div>
                    <div class="ci-metric-value">@CalculateVatAmount().ToString("N2")</div>
                </div>
            </div>
            <div class="ci-metric">
                <span class="ci-metric-icon"><i class="bi bi-receipt-cutoff"></i></span>
                <div>
                    <div class="ci-metric-label">Invoice Total</div>
                    <div class="ci-metric-value">@CalculateTotalInclVat().ToString("N2") @invoice.DocCurrency</div>
                </div>
            </div>
        </div>

        <!-- Alerts -->
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert-banner success-alert">
                <i class="bi bi-check-circle-fill"></i>
                <div class="alert-body">
                    @successMessage
                    @if (lastCreatedInvoice != null)
                    {
                        <button class="btn-print-invoice" @onclick="OpenPrintDialog" disabled="@isPrinting">
                            <i class="bi bi-printer-fill"></i> Print Invoice
                        </button>
                    }
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="DismissSuccess" Class="alert-close"
                               Size="Size.Small" />
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner error-alert">
                <i class="bi bi-exclamation-octagon-fill"></i>
                <div class="alert-body">@((MarkupString)errorMessage)</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => errorMessage = null" Class="alert-close"
                               Size="Size.Small" />
            </div>
        }

        <div class="row g-4">
            <!-- â”â”â” Left Column â”â”â” -->
            <div class="col-lg-8">

                <!-- â”€â”€ Customer Section â”€â”€ -->
                <div class="section-card">
                    <div class="card-hdr">
                        <div class="hdr-left">
                            <div class="header-icon" style="background:#d1fae5; color:#059669;"><i
                                class="bi bi-person-fill"></i></div>
                                <h6>Customer Information</h6>
                            </div>
                        </div>
                        <div class="card-body-inner">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="field-label">Customer <span style="color:#ef4444;">*</span></label>
                                    @if (isLoadingBPs)
                                    {
                                        <div class="d-flex align-items-center gap-2" style="padding:.4rem 0;">
                                            <div class="spinner-border spinner-border-sm text-primary"></div>
                                            <span style="color:#6b7280; font-size:.85rem;">Loading customers...</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <MudAutocomplete T="BusinessPartnerDto" Value="selectedBusinessPartner"
                                                         ValueChanged="OnSelectedBusinessPartnerChangedAsync"
                                                         SearchFunc="SearchBusinessPartnersAsync"
                                                         ToStringFunc="@(bp => bp == null ? string.Empty : bp.DisplayName)"
                                                         Placeholder="Search by code or name..." Dense="true" Variant="Variant.Outlined"
                                                         Margin="Margin.Dense" ResetValueOnEmptyText="true" ShowProgressIndicator="true"
                                                         MaxItems="15" DebounceInterval="150" MinCharacters="0" Immediate="true"
                                                         Clearable="true" Disabled="@isLoadingBPs" Class="w-100" />

                                        @if (selectedBusinessPartner != null)
                                        {
                                            <div class="selected-customer-badge" style="margin-top:.75rem;">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div>
                                                        <div style="font-weight:700; color:#065f46;">
                                                            <i class="bi bi-check-circle-fill me-1" style="color:#059669;"></i>
                                                            @selectedBusinessPartner.CardCode
                                                        </div>
                                                        <div style="font-size:.85rem; color:#065f46; opacity:.8;">
                                                            @selectedBusinessPartner.CardName</div>
                                                            @if (!string.IsNullOrEmpty(selectedBusinessPartner.Phone1))
                                                            {
                                                                <div
                                                                    style="font-size:.82rem; color:#065f46; opacity:.7; margin-top:.25rem;">
                                                                    <i class="bi bi-telephone me-1"></i>@selectedBusinessPartner.Phone1
                                                                </div>
                                                            }
                                                            @if (customerPriceListNum.HasValue)
                                                            {
                                                                <div
                                                                    style="font-size:.82rem; color:#065f46; opacity:.7; margin-top:.25rem;">
                                                                    <i class="bi bi-tags me-1"></i>Price List #@customerPriceListNum
                                                                    @if (isLoadingCustomerPrices)
                                                                    {
                                                                        <span class="spinner-border spinner-border-sm ms-1"></span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span
                                                                            style="background:#d1fae5; color:#065f46; font-size:.7rem; padding:.1rem .4rem; border-radius:4px; font-weight:600; margin-left:.25rem;">
                                                                            @customerPriceListPrices.Count items
                                                                        </span>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                        <MudButton ButtonType="ButtonType.Button" Class="bp-clear-btn"
                                                                   OnClick="ClearSelectedBP">
                                                            <i class="bi bi-x"></i>
                                                        </MudButton>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        @if (validationErrors.ContainsKey("Customer"))
                                        {
                                            <div style="color:#ef4444; font-size:.78rem; margin-top:.2rem;">
                                                @validationErrors["Customer"]</div>
                                            }
                                        </div>
                                        <div class="col-md-6">
                                            <label class="field-label">Customer Reference</label>
                                            <input type="text" class="form-control form-control-line" @bind="invoice.NumAtCard"
                                                   placeholder="PO / Reference number" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="field-label">Currency</label>
                                            <select class="form-select form-select-line" @bind="invoice.DocCurrency">
                                                <option value="USD">USD - US Dollar</option>
                                                <option value="ZIG">ZIG - Zimbabwe Gold</option>
                                            </select>
                                        </div>
                                        <div class="col-md-8">
                                            <label class="field-label">Comments</label>
                                            <input type="text" class="form-control form-control-line" @bind="invoice.Comments"
                                                   placeholder="Optional notes" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- â”€â”€ Invoice Lines Section â”€â”€ -->
                            <div class="section-card">
                                <div class="card-hdr">
                                    <div class="hdr-left">
                                        <div class="header-icon" style="background:#dbeafe; color:#2563eb;"><i
                                            class="bi bi-list-ul"></i></div>
                                            <h6>Invoice Lines</h6>
                                        </div>
                                        <MudButton Class="btn-add-line" OnClick="AddLine">
                                            <i class="bi bi-plus-lg me-1"></i>Add Line
                                        </MudButton>
                                    </div>
                                    <div class="card-body-inner">
                                        <!-- Global Settings Bar -->
                                        <div class="global-settings-bar">
                                            <div class="settings-bar-header">
                                                <div class="settings-icon"><i class="bi bi-sliders2"></i></div>
                                                <span>Defaults</span>
                                                <span class="batch-required-badge ms-auto">
                                                    <i class="bi bi-stars me-1"></i>Auto Batch (FEFO)
                                                </span>
                                            </div>
                                            <div class="settings-fields">
                                                <div>
                                                    <label class="settings-field-label">Default Warehouse</label>
                                                    <MudAutocomplete T="WarehouseDto" Value="GetSelectedDefaultWarehouse()"
                                                                     ValueChanged="OnDefaultWarehouseChangedAsync" SearchFunc="SearchWarehousesAsync"
                                                                     ToStringFunc="@(warehouse => warehouse == null ? string.Empty : warehouse.DisplayName)"
                                                                     Placeholder="Select Warehouse" Dense="true" Variant="Variant.Outlined"
                                                                     Margin="Margin.Dense" ResetValueOnEmptyText="true" ShowProgressIndicator="true"
                                                                     MaxItems="20" DebounceInterval="150" MinCharacters="0" Immediate="true"
                                                                     Clearable="true" Class="form-select-line" />
                                                </div>
                                                <div>
                                                    <label class="settings-field-label">Default Cost Centre</label>
                                                    <MudAutocomplete T="CostCentreDto" Value="selectedDefaultCostCentre"
                                                                     ValueChanged="OnDefaultCostCentreChanged" SearchFunc="SearchCostCentresAsync"
                                                                     ToStringFunc="@(cc => cc == null ? "" : $"{cc.CenterCode} - {TruncateName(cc.CenterName, 25)}")"
                                                                     Placeholder="Select Cost Centre" Dense="true" Variant="Variant.Outlined"
                                                                     Margin="Margin.Dense" Clearable="true" ResetValueOnEmptyText="true"
                                                                     CoerceText="false" Class="form-select-line" />
                                                </div>
                                            </div>
                                        </div>

                                        @if (isLoadingMasterData)
                                        {
                                            <div style="text-align:center; padding:2.5rem 1rem;">
                                                <div class="spinner-border text-primary" role="status" style="width:2rem; height:2rem;">
                                                </div>
                                                <p style="color:#6b7280; margin-top:.75rem; margin-bottom:0; font-size:.88rem;">Loading
                                                    products and warehouses...</p>
                                                </div>
                                            }
                        else if (invoice.Lines.Any())
                                            {
                                                <div>
                                                    @for (int i = 0; i < invoice.Lines.Count; i++)
                                                    {
                                                        var index = i;
                                                        var line = invoice.Lines[index];
                                                        var lineState = GetLineState(index);
                                                        var lineErrors = GetLineValidationErrors(index);

                                                        <div class="line-card">
                                                            <!-- Line Header -->
                                                            <div class="line-card-header">
                                                                <div class="d-flex align-items-center gap-2">
                                                                    <div class="line-number">@(index + 1)</div>
                                                                    @if (!string.IsNullOrEmpty(line.ItemDescription))
                                                                    {
                                                                        <span style="font-weight:600; color:#1a1a2e;">@line.ItemCode</span>
                                                                        <span style="color:#d1d5db;">/</span>
                                                                        <span
                                                                            style="color:#6b7280; font-size:.85rem;">@TruncateName(line.ItemDescription,
                                                                                                                                                                                                                                                                                                                                                            40)</span>
                                                                        }
                                        else
                                                                        {
                                                                            <span style="color:#9ca3af; font-size:.85rem;">New Line Item</span>
                                                                        }
                                                                    </div>
                                                                    <div class="d-flex align-items-center gap-3">
                                                                        <div class="line-total-display" style="text-align:right; line-height:1.3;">
                                                                            <div>@GetDisplayLineTotal(line).ToString("N2")</div>
                                                                            <div style="font-size:.7rem; color:#6b7280; font-weight:400;">
                                                                                @AlternatePriceLabel:
                                                                                @GetAlternateLineTotal(line).ToString("N2")</div>
                                                                            </div>
                                                                            <MudButton Class="line-remove" OnClick="() => RemoveLine(index)"
                                                                                       title="Remove line">
                                                                                <i class="bi bi-x"></i>
                                                                            </MudButton>
                                                                        </div>
                                                                    </div>

                                                                    <!-- Row 1: Product Selection -->
                                                                    <div class="row g-3 mb-3">
                                                                        <div class="col-md-4">
                                                                            <div class="field-group">
                                                                                <label class="field-label">Item Code <span
                                                                                    style="color:#ef4444;">*</span></label>
                                                                                    <MudAutocomplete T="ProductDto" Value="GetSelectedLineProduct(line)"
                                                                                                     ValueChanged="(product) => OnLineProductChangedAsync(index, product)"
                                                                                                     SearchFunc="SearchProductsAsync"
                                                                                                     ToStringFunc="@(product => product == null ? string.Empty : product.ItemCode ?? string.Empty)"
                                                                                                     Placeholder="Search by code or name..." Dense="true"
                                                                                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                                                                                     ResetValueOnEmptyText="true" ShowProgressIndicator="true" MaxItems="15"
                                                                                                     DebounceInterval="150" MinCharacters="0" Immediate="true"
                                                                                                     Clearable="true" Class="w-100">
                                                                                        <ItemTemplate>
                                                                                            @{
                                                                                                var displayPrice = GetDisplayPrice(GetPriceForItem(context.ItemCode,
                                                        context.Price));
                                                                                                var isCustomerPrice =
                                                        customerPriceListPrices.ContainsKey(context.ItemCode ??
                                                        string.Empty);
                                                                                            }
                                                                                            <div
                                                                                                class="d-flex justify-content-between align-items-center py-1 w-100">
                                                                                                <div class="d-flex flex-column">
                                                                                                    <span
                                                                                                    style="font-weight:600; font-size:.85rem;">@context.ItemCode</span>
                                                                                                    <small
                                                                                                        style="color:#6b7280;">@TruncateName(context.ItemName,
                                                                                                                                                                        30)</small>
                                                                                                    </div>
                                                                                                    <span
                                                                                                        class="ci-price-chip @(isCustomerPrice ? "customer" : "standard")">
                                                                                                        @displayPrice.ToString("N2")
                                                                                                        <small>@DisplayPriceLabel</small>
                                                                                                        @if (isCustomerPrice)
                                                                                                        {
                                                                                                            <i class="bi bi-check-circle ms-1"></i>
                                                                                                        }
                                                                                                    </span>
                                                                                                </div>
                                                                                            </ItemTemplate>
                                                                                        </MudAutocomplete>
                                                                                        @if (lineErrors.ContainsKey("ItemCode"))
                                                                                        {
                                                                                            <div style="color:#ef4444; font-size:.72rem; margin-top:.15rem;">
                                                                                                @lineErrors["ItemCode"]</div>
                                                                                            }
                                                                                        </div>
                                                                                    </div>
                                                                                    <div class="col-md-5">
                                                                                        <div class="field-group">
                                                                                            <label class="field-label">Description</label>
                                                                                            @if (!string.IsNullOrEmpty(line.ItemDescription))
                                                                                            {
                                                                                                <div class="product-selected-info">
                                                                                                    <i class="bi bi-box-seam me-2"
                                                                                                       style="color:#2563eb;"></i>@line.ItemDescription
                                                                                                </div>
                                                                                            }
                                                                                            else
                                                                                            {
                                                                                                <input type="text" class="form-control form-control-line"
                                                                                                       placeholder="Select an item above" readonly />
                                                                                            }
                                                                                        </div>
                                                                                    </div>
                                                                                    <div class="col-md-3">
                                                                                        <div class="field-group">
                                                                                            <label class="field-label">Warehouse <span
                                                                                                style="color:#ef4444;">*</span></label>
                                                                                                <MudAutocomplete T="WarehouseDto" Value="GetSelectedLineWarehouse(line)"
                                                                                                                 ValueChanged="(warehouse) => OnLineWarehouseChangedAsync(index, warehouse)"
                                                                                                                 SearchFunc="SearchWarehousesAsync"
                                                                                                                 ToStringFunc="@(warehouse => warehouse == null ? string.Empty : warehouse.DisplayName)"
                                                                                                                 Placeholder="Select" Dense="true" Variant="Variant.Outlined"
                                                                                                                 Margin="Margin.Dense" ResetValueOnEmptyText="true"
                                                                                                                 ShowProgressIndicator="true" MaxItems="20" DebounceInterval="150"
                                                                                                                 MinCharacters="0" Immediate="true" Clearable="true" Class="w-100" />
                                                                                                @if (lineErrors.ContainsKey("Warehouse"))
                                                                                                {
                                                                                                    <div style="color:#ef4444; font-size:.72rem; margin-top:.15rem;">
                                                                                                        @lineErrors["Warehouse"]</div>
                                                                                                    }
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>

                                                                                        <!-- Row 2: Quantity, Price, Discount, Batch, Cost Centre -->
                                                                                        <div class="row g-3">
                                                                                            <div class="col-6 col-md-2">
                                                                                                <div class="field-group">
                                                                                                    <label class="field-label">Quantity <span
                                                                                                        style="color:#ef4444;">*</span></label>
                                                                                                        <input type="number"
                                                                                                               class="form-control form-control-line @(lineErrors.ContainsKey("Quantity") ? "validation-error" : "")"
                                                                                                               value="@line.Quantity"
                                                                                                               @onchange="(e) => OnQuantityChange(index, e.Value?.ToString())"
                                                                                                               min="0.001" step="0.001" placeholder="0" />
                                                                                                    </div>
                                                                                                </div>
                                                                                                <div class="col-6 col-md-2">
                                                                                                    <div class="field-group">
                                                                                                        <label class="field-label">Unit Price <span
                                                                                                            style="color:#ef4444;">*</span></label>
                                                                                                            <input type="number"
                                                                                                                   class="form-control form-control-line @(lineErrors.ContainsKey("UnitPrice") ? "validation-error" : "")"
                                                                                                                   value="@(line.UnitPrice ?? 0)"
                                                                                                                   @onchange="(e) => OnUnitPriceChange(index, e.Value?.ToString())" min="0"
                                                                                                                   step="0.01" placeholder="0.00" />
                                                                                                            @if (line.UnitPrice.HasValue && line.UnitPrice.Value > 0)
                                                                                                            {
                                                                                                                <div style="font-size:.72rem; color:#6b7280; margin-top:.15rem;">incl. VAT:
                                                                                                                    @((line.UnitPrice.Value * (1 + VatRate)).ToString("N3"))</div>
                                                                                                                }
                                                                                                                @if (lineErrors.ContainsKey("UnitPrice"))
                                                                                                                {
                                                                                                                    <div style="color:#ef4444; font-size:.72rem; margin-top:.15rem;">
                                                                                                                        @lineErrors["UnitPrice"]</div>
                                                                                                                    }
                                                                                                                </div>
                                                                                                            </div>
                                                                                                            <div class="col-6 col-md-4">
                                                                                                                <div class="field-group">
                                                                                                                    <label class="field-label">Batch
                                                                                                                        <span class="batch-required-badge ms-1">Auto FEFO</span>
                                                                                                                    </label>
                                                                                                                    <input type="text" class="form-control form-control-line"
                                                                                                                           value="Auto-allocated (FEFO)" readonly
                                                                                                                           style="background-color:#f3f4f6; cursor:default; color:#6b7280;" />
                                                                                                                </div>
                                                                                                            </div>
                                                                                                            <div class="col-12 col-md-4">
                                                                                                                <div class="field-group">
                                                                                                                    <label class="field-label">Cost Centre</label>
                                                                                                                    <input type="text" class="form-control form-control-line"
                                                                                                                           value="@GetLineCostCentreDisplay(line)" readonly
                                                                                                                           style="background-color:#f3f4f6; cursor:default;" />
                                                                                                                </div>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                }
                                                                                            </div>

                                                                                            <!-- Add Line Button at Bottom -->
                                                                                            <div style="text-align:center; margin-top:1.25rem;">
                                                                                                <MudButton Class="btn-add-line" OnClick="AddLine">
                                                                                                    <i class="bi bi-plus-lg"></i>Add Another Line
                                                                                                </MudButton>
                                                                                            </div>
                                                                                        }
                        else
                                                                                        {
                                                                                            <div class="empty-lines-placeholder">
                                                                                                <div class="empty-ico"><i class="bi bi-inbox"></i></div>
                                                                                                <p>No invoice lines yet</p>
                                                                                                <div class="empty-hint">Add your first product line to start building the invoice</div>
                                                                                                <MudButton Class="btn-add-first" OnClick="AddLine">
                                                                                                    <i class="bi bi-plus-lg"></i>Add First Line
                                                                                                </MudButton>
                                                                                            </div>
                                                                                        }
                                                                                    </div>
                                                                                </div>
                                                                            </div>

                                                                            <!-- â”â”â” Right Column: Summary Sidebar â”â”â” -->
                                                                            <div class="col-lg-4">
                                                                                <div class="summary-section">
                                                                                    <div class="summary-card">

                                                                                        <!-- Validation Checklist -->
                                                                                        <div class="summary-hdr">
                                                                                            <i class="bi bi-shield-check" style="color:#2563eb;"></i>
                                                                                            <h6>Validation Checklist</h6>
                                                                                        </div>
                                                                                        <div style="padding:.85rem 1.15rem; border-bottom:1px solid #f3f4f6;">
                                                                                            <ul style="list-style:none; padding:0; margin:0; font-size:.85rem;">
                                                                                                <li style="display:flex; align-items:center; gap:.5rem; padding:.25rem 0;">
                                                                                                    <span
                                                                                                        style="width:20px; height:20px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.7rem; @(selectedBusinessPartner != null ? "background:#d1fae5; color:#059669;" : "background:#fef2f2; color:#ef4444;")">
                                                                                                        <i class="bi @(selectedBusinessPartner != null ? "bi-check" : "bi-x")"></i>
                                                                                                    </span>
                                                                                                    Customer selected
                                                                                                </li>
                                                                                                <li style="display:flex; align-items:center; gap:.5rem; padding:.25rem 0;">
                                                                                                    <span
                                                                                                        style="width:20px; height:20px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.7rem; @(invoice.Lines.Any() ? "background:#d1fae5; color:#059669;" : "background:#fef2f2; color:#ef4444;")">
                                                                                                        <i class="bi @(invoice.Lines.Any() ? "bi-check" : "bi-x")"></i>
                                                                                                    </span>
                                                                                                    Line items added
                                                                                                </li>
                                                                                                <li style="display:flex; align-items:center; gap:.5rem; padding:.25rem 0;">
                                                                                                    <span
                                                                                                        style="width:20px; height:20px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.7rem; @(invoice.Lines.All(l => !string.IsNullOrEmpty(l.ItemCode) && l.Quantity > 0) && invoice.Lines.Any() ? "background:#d1fae5; color:#059669;" : "background:#fef2f2; color:#ef4444;")">
                                                                                                        <i
                                                                                                        class="bi @(invoice.Lines.All(l => !string.IsNullOrEmpty(l.ItemCode) && l.Quantity > 0) && invoice.Lines.Any() ? "bi-check" : "bi-x")"></i>
                                                                                                    </span>
                                                                                                    All lines complete
                                                                                                </li>
                                                                                            </ul>
                                                                                        </div>

                                                                                        <!-- Summary -->
                                                                                        <div class="summary-hdr" style="border-bottom:none;">
                                                                                            <i class="bi bi-calculator" style="color:#2563eb;"></i>
                                                                                            <h6>Invoice Summary</h6>
                                                                                        </div>
                                                                                        <div class="summary-body" style="padding-top:0;">
                                                                                            <div class="sum-line">
                                                                                                <span class="sum-label"><i class="bi bi-list-ul me-1"
                                                                                                                               style="color:#2563eb;"></i>Lines</span>
                                                                                                    <span class="sum-value">@invoice.Lines.Count</span>
                                                                                                </div>
                                                                                                <div class="sum-line">
                                                                                                    <span class="sum-label"><i class="bi bi-cash me-1" style="color:#059669;"></i>Subtotal
                                                                                                        (excl. VAT)</span>
                                                                                                        <span class="sum-value">@CalculateSubtotal().ToString("N2")</span>
                                                                                                    </div>
                                                                                                    <div class="sum-line">
                                                                                                        <span class="sum-label"><i class="bi bi-percent me-1" style="color:#f59e0b;"></i>VAT
                                                                                                            (15.5%)</span>
                                                                                                            <span class="sum-value">@CalculateVatAmount().ToString("N2")</span>
                                                                                                        </div>
                                                                                                        <hr class="sum-divider" />
                                                                                                        <div class="sum-total">
                                                                                                            <span class="total-label">Total (incl. VAT)</span>
                                                                                                            <div style="text-align:right;">
                                                                                                                <span class="total-value">@CalculateTotalInclVat().ToString("N2")</span>
                                                                                                                <div style="font-size:.75rem; color:#6b7280;">@invoice.DocCurrency</div>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>

                                                                                                    <!-- Actions -->
                                                                                                    <div style="padding:0 1.15rem 1.15rem;">
                                                                                                        <div style="display:flex; align-items:center; gap:.5rem; margin-bottom:.75rem;">
                                                                                                            <input type="checkbox" id="notifyCustomerEmail" @bind="notifyCustomerByEmail"
                                                                                                                   style="accent-color:#2563eb;" />
                                                                                                            <label for="notifyCustomerEmail"
                                                                                                                   style="font-size:.85rem; color:#374151; margin:0; cursor:pointer;">
                                                                                                                Email customer notification
                                                                                                            </label>
                                                                                                        </div>

                                                                                                        <MudButton Class="btn-execute" OnClick="SubmitInvoice" Disabled="@isSubmitting">
                                                                                                            @if (isSubmitting)
                                                                                                            {
                                                                                                                <span class="spinner-border spinner-border-sm"></span>
                                                                                                                <span>Creating...</span>
                                                                                                            }
                                                                                                            else
                                                                                                            {
                                                                                                                <i class="bi bi-check-circle-fill"></i>
                                                                                                                <span>Create Invoice</span>
                                                                                                            }
                                                                                                        </MudButton>
                                                                                                        <MudButton Class="btn-secondary-action" OnClick="ClearForm" Disabled="@isSubmitting">
                                                                                                            <i class="bi bi-arrow-counterclockwise"></i> Clear Form
                                                                                                        </MudButton>

                                                                                                        <!-- Validation Errors -->
                                                                                                        @if (validationErrors.Any() || lineValidationErrors.Any())
                                                                                                        {
                                                                                                            <div
                                                                                                                style="background:#fef2f2; border:1px solid #fecaca; border-radius:8px; padding:.65rem .85rem; margin-bottom:.75rem;">
                                                                                                                <div style="font-size:.78rem; font-weight:600; color:#991b1b; margin-bottom:.35rem;">
                                                                                                                    <i class="bi bi-exclamation-triangle me-1"></i>Please fix the following:
                                                                                                                </div>
                                                                                                                <ul style="list-style:none; padding:0; margin:0; font-size:.78rem; color:#991b1b;">
                                                                                                                    @foreach (var error in validationErrors.Values)
                                                                                                                    {
                                                                                                                        <li><i class="bi bi-dot"></i>@error</li>
                                                                                                                    }
                                                                                                                    @foreach (var lineError in lineValidationErrors)
                                                                                                                    {
                                                                                                                        foreach (var error in lineError.Value.Values)
                                                                                                                        {
                                                                                                                            <li><i class="bi bi-dot"></i>Line @(lineError.Key + 1): @error</li>
                                                                                                                        }
                                                                                                                    }
                                                                                                                </ul>
                                                                                                            </div>
                                                                                                        }

                                                                                                        <div class="info-hint">
                                                                                                            <i class="bi bi-info-circle" style="flex-shrink:0; margin-top:1px;"></i>
                                                                                                            <span>Invoices are posted directly to SAP Business One. Ensure all details are correct
                                                                                                                before submitting.</span>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>

                                                                                                    <!-- Data Status Card -->
                                                                                                    <div class="summary-card" style="margin-top:1rem;">
                                                                                                        <div class="summary-hdr">
                                                                                                            <i class="bi bi-database" style="color:#6b7280;"></i>
                                                                                                            <h6 style="font-size:.85rem; color:#6b7280;">Cached Data Status</h6>
                                                                                                        </div>
                                                                                                        <div style="padding:.65rem 1.15rem;">
                                                                                                            <div class="row g-1">
                                                                                                                <div class="col-6">
                                                                                                                    <div class="ds-item"><i class="bi bi-people"
                                                                                                                                                style="color:#2563eb;"></i>@allBusinessPartners.Count customers</div>
                                                                                                                    </div>
                                                                                                                    <div class="col-6">
                                                                                                                        <div class="ds-item"><i class="bi bi-box"
                                                                                                                                                    style="color:#059669;"></i>@cachedProducts.Count products</div>
                                                                                                                        </div>
                                                                                                                        <div class="col-6">
                                                                                                                            <div class="ds-item"><i class="bi bi-building"
                                                                                                                                                        style="color:#0ea5e9;"></i>@cachedWarehouses.Count warehouses</div>
                                                                                                                            </div>
                                                                                                                            <div class="col-6">
                                                                                                                                <div class="ds-item"><i class="bi bi-diagram-3"
                                                                                                                                                            style="color:#d97706;"></i>@cachedCostCentres.Count cost centres</div>
                                                                                                                                </div>
                                                                                                                            </div>
                                                                                                                            @if (lastCacheRefresh.HasValue)
                                                                                                                            {
                                                                                                                                <div style="font-size:.75rem; color:#9ca3af; margin-top:.35rem;">
                                                                                                                                    <i class="bi bi-clock me-1"></i>Last sync: @lastCacheRefresh.Value.ToString("HH:mm:ss")
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </div>

                                                                                                <!-- â”€â”€ Print Dialog â”€â”€ -->
                                                                                                <MudDialog @bind-Visible="showPrintDialog"
                                                                                                           Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true }">
                                                                                                    <TitleContent>
                                                                                                        <div style="display:flex; align-items:center; gap:.6rem;">
                                                                                                            <i class="bi bi-printer-fill" style="font-size:1.2rem; color:#2563eb;"></i>
                                                                                                            <MudText Typo="Typo.h6" Style="font-weight:600;">Print Invoice #@(lastCreatedInvoice?.DocNum)</MudText>
                                                                                                        </div>
                                                                                                    </TitleContent>
                                                                                                    <DialogContent>
                                                                                                        <div style="padding:.5rem 0;">
                                                                                                            <!-- Printer Selection -->
                                                                                                            <div class="field-group" style="margin-bottom:1rem;">
                                                                                                                <label class="field-label">Printer</label>
                                                                                                                @if (savedPrinters.Any())
                                                                                                                {
                                                                                                                    <select class="form-select-line w-100" @bind="selectedPrinterName">
                                                                                                                        <option value="">System Default</option>
                                                                                                                        @foreach (var printer in savedPrinters)
                                                                                                                        {
                                                                                                                            <option value="@printer">@printer</option>
                                                                                                                        }
                                                                                                                    </select>
                                                                                                                    <div style="font-size:.75rem; color:#6b7280; margin-top:.25rem;">
                                                                                                                        <i class="bi bi-info-circle me-1"></i>Select your printer, then confirm in the browser print dialog.
                                                                                                                    </div>
                                                                                                                }
                                                                                                                else
                                                                                                                {
                                                                                                                    <div style="font-size:.85rem; color:#6b7280; padding:.5rem; background:#f9fafb; border-radius:8px;">
                                                                                                                        No saved printers. Add one below or use the browser print dialog to choose.
                                                                                                                    </div>
                                                                                                                }
                                                                                                            </div>

                                                                                                            <!-- Add New Printer -->
                                                                                                            <div class="field-group" style="margin-bottom:1rem;">
                                                                                                                <label class="field-label">Add Printer</label>
                                                                                                                <div style="display:flex; gap:.4rem;">
                                                                                                                    <select class="form-select-line flex-grow-1" @bind="newPrinterName">
                                                                                                                        <option value="">-- Select a printer to add --</option>
                                                                                                                        @foreach (var printer in installedPrinters.Where(p => !savedPrinters.Contains(p)))
                                                                                                                        {
                                                                                                                            <option value="@printer">@printer</option>
                                                                                                                        }
                                                                                                                    </select>
                                                                                                                    <button class="btn-add-line" @onclick="AddPrinter"
                                                                                                                            disabled="@string.IsNullOrWhiteSpace(newPrinterName)">
                                                                                                                        <i class="bi bi-plus-lg"></i> Add
                                                                                                                    </button>
                                                                                                                </div>
                                                                                                            </div>

                                                                                                            @if (savedPrinters.Any())
                                                                                                            {
                                                                                                                <div class="field-group" style="margin-bottom:1rem;">
                                                                                                                    <label class="field-label">Saved Printers</label>
                                                                                                                    <div style="display:flex; flex-wrap:wrap; gap:.4rem;">
                                                                                                                        @foreach (var printer in savedPrinters)
                                                                                                                        {
                                                                                                                            <span
                                                                                                                                style="display:inline-flex; align-items:center; gap:.3rem; background:#f0f9ff; border:1px solid #bae6fd; border-radius:20px; padding:.2rem .6rem .2rem .75rem; font-size:.8rem; color:#0c4a6e;">
                                                                                                                                @printer
                                                                                                                                <button
                                                                                                                                    style="background:none; border:none; color:#dc2626; cursor:pointer; padding:0 .15rem; font-size:.9rem; line-height:1;"
                                                                                                                                    @onclick="() => RemovePrinter(printer)" title="Remove">
                                                                                                                                    &times;
                                                                                                                                </button>
                                                                                                                            </span>
                                                                                                                        }
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            }

                                                                                                            <!-- Copies -->
                                                                                                            <div class="field-group" style="margin-bottom:.5rem;">
                                                                                                                <label class="field-label">Number of Copies</label>
                                                                                                                <input type="number" class="form-control-line" style="width:100px;" min="1" max="10"
                                                                                                                       @bind="printCopies" />
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </DialogContent>
                                                                                                    <DialogActions>
                                                                                                        <MudButton OnClick="DownloadInvoicePdf" Disabled="@isPrinting" StartIcon="@Icons.Material.Filled.Download"
                                                                                                                   Variant="Variant.Text">
                                                                                                            Download PDF
                                                                                                        </MudButton>
                                                                                                        <MudButton OnClick="() => showPrintDialog = false" Variant="Variant.Text">Cancel</MudButton>
                                                                                                        <MudButton OnClick="ExecutePrint" Disabled="@isPrinting" Color="Color.Primary" Variant="Variant.Filled"
                                                                                                                   StartIcon="@Icons.Material.Filled.Print">
                                                                                                            @if (isPrinting)
                                                                                                            {
                                                                                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                                                                                            }
                                                                                                            Print
                                                                                                        </MudButton>
                                                                                                    </DialogActions>
                                                                                                </MudDialog>

@code {
    private CreateInvoiceRequest invoice = new()
    {
        DocCurrency = "USD",
        Lines = new List<CreateInvoiceLineRequest>()
    };

    private string? successMessage;
    private string? errorMessage;
    private bool isSubmitting = false;
    private bool isPrinting = false;
    private bool notifyCustomerByEmail = true;
    private InvoiceDto? lastCreatedInvoice;

    // Print dialog state
    private bool showPrintDialog = false;
    private List<string> savedPrinters = new();
    private List<string> installedPrinters = new();
    private string selectedPrinterName = "";
    private string newPrinterName = "";
    private int printCopies = 1;
    private string? warehouseCode = "01";
    private string? defaultCostCentre;
    private CostCentreDto? selectedDefaultCostCentre;

    // VAT rate (15.5%)
    private const decimal VatRate = 0.155m;

    // Loading states

    private bool isLoadingMasterData = true;
    private bool isRefreshingCache = false;
    private DateTime? lastCacheRefresh;

    // Cached data
    private List<ProductDto> cachedProducts = new();
    private List<WarehouseDto> cachedWarehouses = new();
    private List<CostCentreDto> cachedCostCentres = new();

    // Line state tracking for product autocomplete
    private Dictionary<int, LineState> lineStates = new();

    // Validation
    private Dictionary<string, string> validationErrors = new();
    private Dictionary<int, Dictionary<string, string>> lineValidationErrors = new();

    private class LineState
    {
        public string SearchTerm { get; set; } = string.Empty;
        public bool ShowProductDropdown { get; set; } = false;
        public List<ProductDto> FilteredProducts { get; set; } = new();
        public ProductDto? SuggestedProduct { get; set; } = null;
        public string SuggestionSuffix { get; set; } = string.Empty;
    }

    // Business Partner fields
    private List<BusinessPartnerDto> allBusinessPartners = new();
