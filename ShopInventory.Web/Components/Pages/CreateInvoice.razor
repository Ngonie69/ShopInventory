    // Line state management for product autocomplete
    private LineState GetLineState(int index)
    {
        if (!lineStates.ContainsKey(index))
        {
            lineStates[index] = new LineState();
        }
        return lineStates[index];
    }

    private Dictionary<string, string> GetLineValidationErrors(int index)
    {
        return lineValidationErrors.TryGetValue(index, out var errors) ? errors : new Dictionary<string, string>();
    }

    private void OnItemCodeInput(int index, string? value)
    {
        var line = invoice.Lines[index];
        line.ItemCode = value ?? string.Empty;

        var state = GetLineState(index);
        state.SearchTerm = value ?? string.Empty;
        state.SuggestedProduct = null;
        state.SuggestionSuffix = string.Empty;

        // Clear validation error when user starts typing
        if (lineValidationErrors.TryGetValue(index, out var errors))
        {
            errors.Remove("ItemCode");
        }

        if (string.IsNullOrWhiteSpace(value))
        {
            state.FilteredProducts = new List<ProductDto>();
            state.ShowProductDropdown = false;
            return;
        }

        var searchLower = value.ToLowerInvariant();
        var searchUpper = value.ToUpperInvariant();

        state.FilteredProducts = cachedProducts.Where(p =>
        (p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false) ||
        (p.ItemCode?.ToLowerInvariant().Contains(searchLower) ?? false) ||
        (p.ItemName?.ToLowerInvariant().Contains(searchLower) ?? false) ||
        (p.BarCode?.ToLowerInvariant().Contains(searchLower) ?? false)
        ).OrderByDescending(p => p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false)
        .ThenBy(p => p.ItemCode)
        .ToList();

        var exactMatch = state.FilteredProducts.FirstOrDefault(p =>
        p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false);

        if (exactMatch != null && !string.IsNullOrEmpty(exactMatch.ItemCode))
        {
            state.SuggestedProduct = exactMatch;
            state.SuggestionSuffix = exactMatch.ItemCode.Substring(value.Length);
        }

        state.ShowProductDropdown = state.FilteredProducts.Any();
    }

    private async Task OnItemCodeKeyDown(int index, KeyboardEventArgs e)
    {
        var state = GetLineState(index);

        if ((e.Key == "Tab" || e.Key == "ArrowRight") && state.SuggestedProduct != null)
        {
            if (e.Key == "Tab" || !string.IsNullOrEmpty(state.SuggestionSuffix))
            {
                await SelectProduct(index, state.SuggestedProduct);
            }
        }
        else if (e.Key == "ArrowDown" && state.ShowProductDropdown && state.FilteredProducts.Any())
        {
            var currentIndex = state.SuggestedProduct != null
            ? state.FilteredProducts.IndexOf(state.SuggestedProduct)
            : -1;
            var nextIndex = Math.Min(currentIndex + 1, state.FilteredProducts.Count - 1);
            state.SuggestedProduct = state.FilteredProducts[nextIndex];
            if (state.SuggestedProduct?.ItemCode != null)
            {
                var line = invoice.Lines[index];
                var searchUpper = line.ItemCode?.ToUpperInvariant() ?? "";
                if (state.SuggestedProduct.ItemCode.ToUpperInvariant().StartsWith(searchUpper))
                {
                    state.SuggestionSuffix = state.SuggestedProduct.ItemCode.Substring(line.ItemCode?.Length ?? 0);
                }
                else
                {
                    state.SuggestionSuffix = string.Empty;
                }
            }
        }
        else if (e.Key == "ArrowUp" && state.ShowProductDropdown && state.FilteredProducts.Any())
        {
            var currentIndex = state.SuggestedProduct != null
            ? state.FilteredProducts.IndexOf(state.SuggestedProduct)
            : state.FilteredProducts.Count;
            var prevIndex = Math.Max(currentIndex - 1, 0);
            state.SuggestedProduct = state.FilteredProducts[prevIndex];
            if (state.SuggestedProduct?.ItemCode != null)
            {
                var line = invoice.Lines[index];
                var searchUpper = line.ItemCode?.ToUpperInvariant() ?? "";
                if (state.SuggestedProduct.ItemCode.ToUpperInvariant().StartsWith(searchUpper))
                {
                    state.SuggestionSuffix = state.SuggestedProduct.ItemCode.Substring(line.ItemCode?.Length ?? 0);
                }
                else
                {
                    state.SuggestionSuffix = string.Empty;
                }
            }
        }
        else if (e.Key == "Enter" && state.SuggestedProduct != null)
        {
            await SelectProduct(index, state.SuggestedProduct);
        }
        else if (e.Key == "Escape")
        {
            state.ShowProductDropdown = false;
            state.SuggestedProduct = null;
            state.SuggestionSuffix = string.Empty;
        }
    }

    private void OnItemCodeFocus(int index)
    {
        var state = GetLineState(index);
        if (!string.IsNullOrEmpty(state.SearchTerm) || cachedProducts.Any())
        {
            state.ShowProductDropdown = true;
            if (string.IsNullOrEmpty(state.SearchTerm))
            {
                state.FilteredProducts = cachedProducts.Take(15).ToList();
            }
        }
    }

    private async Task OnItemCodeBlur(int index)
    {
        await Task.Delay(200);
        var state = GetLineState(index);
        state.ShowProductDropdown = false;
        state.SuggestionSuffix = string.Empty;
    }

    private void OnQuantityChange(int index, string? value)
    {
        var line = invoice.Lines[index];

        if (decimal.TryParse(value, out var quantity))
        {
            // Prevent negative quantities
            if (quantity < 0)
            {
                quantity = 0;
                errorMessage = "Quantity cannot be negative. Value has been reset to 0.";
            }
            line.Quantity = quantity;
        }
        else
        {
            line.Quantity = 0;
        }

        // Clear validation error when user changes value
        if (lineValidationErrors.TryGetValue(index, out var errors))
        {
            errors.Remove("Quantity");
        }
    }

    private void OnUnitPriceChange(int index, string? value)
    {
        var line = invoice.Lines[index];

        if (decimal.TryParse(value, out var price))
        {
            if (price < 0)
            {
                price = 0;
                errorMessage = "Unit price cannot be negative. Value has been reset to 0.";
            }
            line.UnitPrice = price;
        }
        else
        {
            line.UnitPrice = 0;
        }
    }

    private async Task SelectProduct(int index, ProductDto product)
    {
        var line = invoice.Lines[index];
        line.ItemCode = product.ItemCode ?? string.Empty;
        line.ItemDescription = product.ItemName ?? string.Empty;

        // Use price from customer's price list if available, otherwise use default product price
        line.UnitPrice = GetPriceForItem(product.ItemCode, product.Price);

        // If price is still 0, fetch from the price API
        if (line.UnitPrice == 0 && !string.IsNullOrEmpty(product.ItemCode))
        {
            try
            {
                var priceInfo = await PriceService.GetPriceByItemCodeAsync(product.ItemCode);
                if (priceInfo != null)
                {
                    var currency = invoice.DocCurrency ?? AppSettings.DefaultCurrency;
                    line.UnitPrice = currency.Equals("USD", StringComparison.OrdinalIgnoreCase)
                        ? priceInfo.UsdPrice ?? 0
                        : priceInfo.ZigPrice ?? priceInfo.UsdPrice ?? 0;
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to fetch price for item {ItemCode}", product.ItemCode);
            }
        }

        line.WarehouseCode = !string.IsNullOrEmpty(warehouseCode) ? warehouseCode : (product.DefaultWarehouse ??
AppSettings.DefaultWarehouse);

        // Apply default cost centre if set
        if (!string.IsNullOrEmpty(defaultCostCentre))
        {
            line.CostCentreCode = defaultCostCentre;
        }

        var state = GetLineState(index);
        state.ShowProductDropdown = false;
        state.SearchTerm = product.ItemCode ?? string.Empty;
        state.SuggestedProduct = null;
        state.SuggestionSuffix = string.Empty;

        // Clear validation errors for this line
        if (lineValidationErrors.TryGetValue(index, out var errors))
        {
            errors.Remove("ItemCode");
        }
    }

    private async Task SelectBusinessPartnerAsync(BusinessPartnerDto bp)
    {
        selectedBusinessPartner = bp;
        invoice.CardCode = bp.CardCode ?? string.Empty;

        if (!string.IsNullOrEmpty(bp.Currency))
        {
            invoice.DocCurrency = bp.Currency;
        }

        // Clear validation error
        validationErrors.Remove("Customer");

        // Clear old prices immediately before loading new ones
        customerPriceListPrices.Clear();
        customerPriceListNum = null;

        // Load prices using the BP's assigned price list number (available from cached data)
        if (bp.PriceListNum.HasValue && bp.PriceListNum.Value > 0 && !string.IsNullOrEmpty(bp.CardCode))
        {
            Logger.LogInformation("BP {CardCode} has price list {PriceListNum}, loading directly", bp.CardCode,
bp.PriceListNum.Value);
            await LoadBusinessPartnerPrices(bp.CardCode);
        }
        else if (!string.IsNullOrEmpty(bp.CardCode))
        {
            // PriceListNum not in cached data - look up from SAP via API
            Logger.LogInformation("BP {CardCode} has no cached PriceListNum, fetching from SAP", bp.CardCode);
            await LoadBusinessPartnerPrices(bp.CardCode);
        }

        // Update prices on any existing lines to reflect the customer's price list
        UpdateExistingLinePrices();
        StateHasChanged();
    }

    private void ClearSelectedBP()
    {
        selectedBusinessPartner = null;
        invoice.CardCode = string.Empty;
        customerPriceListPrices.Clear();
        customerPriceListNum = null;
    }

    private void UpdateExistingLinePrices()
    {
        foreach (var line in invoice.Lines)
        {
            if (!string.IsNullOrEmpty(line.ItemCode))
            {
                var product = cachedProducts.FirstOrDefault(p => p.ItemCode == line.ItemCode);
                var defaultPrice = product?.Price ?? line.UnitPrice ?? 0;
                line.UnitPrice = GetPriceForItem(line.ItemCode, defaultPrice);
            }
        }
    }

    private async Task LoadCustomerPriceList(int priceListNum)
    {
        isLoadingCustomerPrices = true;
        StateHasChanged();

        try
        {
            Logger.LogInformation("Loading prices from customer price list {PriceListNum}", priceListNum);

            // Check in-memory cache first (shared across circuits)
            var cachedPrices = await CacheService.GetPricesByPriceListAsync(priceListNum);
            if (cachedPrices.Count > 0)
            {
                customerPriceListPrices = new Dictionary<string, decimal>(cachedPrices);
                customerPriceListNum = priceListNum;
                Logger.LogInformation("Loaded {Count} prices for price list {PriceListNum} from cache",
                cachedPrices.Count, priceListNum);
                return;
            }

            // Cache miss - fetch from API
            var response = await PriceService.GetPricesByPriceListAsync(priceListNum);

            if (response?.Prices != null && response.Prices.Any())
            {
                customerPriceListPrices.Clear();
                foreach (var price in response.Prices)
                {
                    if (!string.IsNullOrEmpty(price.ItemCode))
                    {
                        customerPriceListPrices[price.ItemCode] = price.Price;
                    }
                }
                customerPriceListNum = priceListNum;

                // Store in cache for next time
                CacheService.StorePriceListPrices(priceListNum, new Dictionary<string, decimal>(customerPriceListPrices));

                Logger.LogInformation("Loaded {Count} prices from customer price list {PriceListNum} (API) and cached",
                customerPriceListPrices.Count, priceListNum);
            }
            else
            {
                Logger.LogWarning("No prices found for price list {PriceListNum}", priceListNum);
                customerPriceListPrices.Clear();
                customerPriceListNum = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading customer price list {PriceListNum}", priceListNum);
            customerPriceListPrices.Clear();
            customerPriceListNum = null;
        }
        finally
        {
            isLoadingCustomerPrices = false;
            StateHasChanged();
        }
    }

    private async Task LoadBusinessPartnerPrices(string cardCode)
    {
        isLoadingCustomerPrices = true;
        StateHasChanged();

        try
        {
            Logger.LogInformation("Loading prices for business partner {CardCode}", cardCode);

            var response = await PriceService.GetPricesByBusinessPartnerAsync(cardCode);

            if (response?.Prices != null && response.Prices.Any())
            {
                customerPriceListPrices.Clear();
                foreach (var price in response.Prices)
                {
                    if (!string.IsNullOrEmpty(price.ItemCode))
                    {
                        customerPriceListPrices[price.ItemCode] = price.Price;
                    }
                }
                customerPriceListNum = response.PriceListNum;

                // Store in cache for next time
                if (response.PriceListNum > 0)
                {
                    CacheService.StorePriceListPrices(response.PriceListNum, new Dictionary<string, decimal>(customerPriceListPrices));
                }

                Logger.LogInformation("Loaded {Count} prices for business partner {CardCode} (price list {PriceListNum})",
                    customerPriceListPrices.Count, cardCode, response.PriceListNum);
            }
            else
            {
                Logger.LogWarning("No prices returned from API for business partner {CardCode}, trying cached price list", cardCode);

                // Fallback: use PriceListNum from the cached BP data
                if (selectedBusinessPartner?.PriceListNum is > 0)
                {
                    await LoadCustomerPriceListFallback(selectedBusinessPartner.PriceListNum.Value);
                }
                else
                {
                    customerPriceListPrices.Clear();
                    customerPriceListNum = null;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading prices for business partner {CardCode}, trying cached price list", cardCode);

            // Fallback: use PriceListNum from the cached BP data
            if (selectedBusinessPartner?.PriceListNum is > 0)
            {
                await LoadCustomerPriceListFallback(selectedBusinessPartner.PriceListNum.Value);
            }
            else
            {
                customerPriceListPrices.Clear();
                customerPriceListNum = null;
            }
        }
        finally
        {
            isLoadingCustomerPrices = false;
            StateHasChanged();
        }
    }

    private async Task LoadCustomerPriceListFallback(int priceListNum)
    {
        try
        {
            Logger.LogInformation("Fallback: loading prices from price list {PriceListNum}", priceListNum);

            // Try in-memory cache first
            var cachedPrices = await CacheService.GetPricesByPriceListAsync(priceListNum);
            if (cachedPrices.Count > 0)
            {
                customerPriceListPrices = new Dictionary<string, decimal>(cachedPrices);
                customerPriceListNum = priceListNum;
                Logger.LogInformation("Fallback: loaded {Count} prices from cache for price list {PriceListNum}", cachedPrices.Count,
priceListNum);
                return;
            }

            // Try API without going through BP endpoint
            var response = await PriceService.GetPricesByPriceListAsync(priceListNum);
            if (response?.Prices != null && response.Prices.Any())
            {
                customerPriceListPrices.Clear();
                foreach (var price in response.Prices)
                {
                    if (!string.IsNullOrEmpty(price.ItemCode))
                    {
                        customerPriceListPrices[price.ItemCode] = price.Price;
                    }
                }
                customerPriceListNum = priceListNum;
                CacheService.StorePriceListPrices(priceListNum, new Dictionary<string, decimal>(customerPriceListPrices));
                Logger.LogInformation("Fallback: loaded {Count} prices from API for price list {PriceListNum}",
customerPriceListPrices.Count, priceListNum);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fallback price loading also failed for price list {PriceListNum}", priceListNum);
        }
    }

    private decimal GetPriceForItem(string? itemCode, decimal defaultPrice)
    {
        if (string.IsNullOrEmpty(itemCode))
            return defaultPrice;

        // If customer has a price list with this item, use that price
        if (customerPriceListPrices.TryGetValue(itemCode, out var customerPrice))
        {
            return customerPrice;
        }

        // Fall back to default product price
        return defaultPrice;
    }

    private decimal GetDisplayPrice(decimal amount)
    {
        return AppSettings.ShowPricesWithTax ? amount * (1 + VatRate) : amount;
    }

    private decimal GetDisplayLineTotal(CreateInvoiceLineRequest line)
    {
        return AppSettings.ShowPricesWithTax ? CalculateLineTotalInclVat(line) : CalculateLineTotal(line);
    }

    private decimal GetAlternateLineTotal(CreateInvoiceLineRequest line)
    {
        return AppSettings.ShowPricesWithTax ? CalculateLineTotal(line) : CalculateLineTotalInclVat(line);
    }

    private string DisplayPriceLabel => AppSettings.ShowPricesWithTax ? "incl. VAT" : "excl. VAT";

    private string AlternatePriceLabel => AppSettings.ShowPricesWithTax ? "excl. VAT" : "incl. VAT";

    private void AddLine()
    {
        var newLine = new CreateInvoiceLineRequest
        {
            Quantity = 1,
            WarehouseCode = warehouseCode ?? "01"
        };

        // Apply default cost centre if set
        if (!string.IsNullOrEmpty(defaultCostCentre))
        {
            newLine.CostCentreCode = defaultCostCentre;
        }

        invoice.Lines.Add(newLine);
    }

    private void RemoveLine(int index)
    {
        if (index >= 0 && index < invoice.Lines.Count)
        {
            invoice.Lines.RemoveAt(index);
            lineStates.Remove(index);
            lineValidationErrors.Remove(index);

            // Re-index states
            var newStates = new Dictionary<int, LineState>();
            var newErrors = new Dictionary<int, Dictionary<string, string>>();

            foreach (var kvp in lineStates.OrderBy(x => x.Key))
            {
                if (kvp.Key < index)
                {
                    newStates[kvp.Key] = kvp.Value;
                }
                else if (kvp.Key > index)
                {
                    newStates[kvp.Key - 1] = kvp.Value;
                }
            }

            foreach (var kvp in lineValidationErrors.OrderBy(x => x.Key))
            {
                if (kvp.Key < index)
                {
                    newErrors[kvp.Key] = kvp.Value;
                }
                else if (kvp.Key > index)
                {
                    newErrors[kvp.Key - 1] = kvp.Value;
                }
            }

            lineStates = newStates;
            lineValidationErrors = newErrors;
        }
    }

    private decimal CalculateLineTotal(CreateInvoiceLineRequest line)
    {
        return line.Quantity * (line.UnitPrice ?? 0);
    }

    private decimal CalculateSubtotal()
    {
        return invoice.Lines.Sum(l => l.Quantity * (l.UnitPrice ?? 0));
    }

    private decimal CalculateTotal()
    {
        return invoice.Lines.Sum(l => CalculateLineTotal(l));
    }

    private decimal CalculateVatAmount()
    {
        return CalculateSubtotal() * VatRate;
    }

    private decimal CalculateTotalInclVat()
    {
        return CalculateSubtotal() * (1 + VatRate);
    }

    private decimal CalculateLineTotalInclVat(CreateInvoiceLineRequest line)
    {
        return CalculateLineTotal(line) * (1 + VatRate);
    }

    private bool ValidateForm()
    {
        validationErrors.Clear();
        lineValidationErrors.Clear();
        var isValid = true;

        // Validate customer
        if (string.IsNullOrWhiteSpace(invoice.CardCode))
        {
            validationErrors["Customer"] = "Please select a customer";
            isValid = false;
        }

        // Validate lines
        if (!invoice.Lines.Any())
        {
            validationErrors["Lines"] = "At least one line item is required";
            isValid = false;
        }

        for (int i = 0; i < invoice.Lines.Count; i++)
        {
            var line = invoice.Lines[i];
            var errors = new Dictionary<string, string>();

            // Item code required
            if (string.IsNullOrWhiteSpace(line.ItemCode))
            {
                errors["ItemCode"] = "Item code is required";
                isValid = false;
            }

            // Warehouse required
            if (string.IsNullOrWhiteSpace(line.WarehouseCode))
            {
                errors["Warehouse"] = "Warehouse is required";
                isValid = false;
            }

            // Quantity validation - must be positive
            if (line.Quantity <= 0)
            {
                errors["Quantity"] = "Quantity must be greater than zero";
                isValid = false;
            }

            // Unit price validation - must be greater than zero
            if (!line.UnitPrice.HasValue || line.UnitPrice.Value <= 0)
            {
                errors["UnitPrice"] = "Unit price must be greater than zero";
                isValid = false;
            }

            // Batch number is optional - auto-allocated using FEFO if not specified
            // The API will handle batch selection automatically

            if (errors.Any())
            {
                lineValidationErrors[i] = errors;
            }
        }

        return isValid;
    }

    private async Task SubmitInvoice()
    {
        errorMessage = null;
        successMessage = null;

        if (!ValidateForm())
        {
            errorMessage = "Please fix the validation errors before submitting.";
            Logger.LogWarning("Invoice validation failed. Errors: {Errors}",
            string.Join("; ", validationErrors.Select(e => $"{e.Key}: {e.Value}")
            .Concat(lineValidationErrors.SelectMany(le => le.Value.Select(e => $"Line {le.Key + 1} {e.Key}: {e.Value}")))));
            return;
        }

        isSubmitting = true;

        try
        {
            // Log the invoice request for debugging
            Logger.LogInformation("Creating invoice for customer {CardCode} with {LineCount} lines",
            invoice.CardCode, invoice.Lines.Count);

            foreach (var (line, index) in invoice.Lines.Select((l, i) => (l, i)))
            {
                Logger.LogDebug("Line {LineNum}: ItemCode={ItemCode}, Qty={Quantity}, Price={Price}, Warehouse={Warehouse}, Batch={Batch}, Account={Account}",
                index + 1,
                line.ItemCode,
                line.Quantity,
                line.UnitPrice,
                line.WarehouseCode,
                string.IsNullOrEmpty(line.BatchNumber) ? "(auto-FEFO)" : line.BatchNumber,
                line.AccountCode ?? "(default)");

                // Log batch numbers if specified
                if (line.BatchNumbers?.Any() == true)
                {
                    foreach (var batch in line.BatchNumbers)
                    {
                        Logger.LogDebug(" Batch: {BatchNumber}, Qty: {Quantity}", batch.BatchNumber, batch.Quantity);
                    }
                }
            }

            var (success, message, createdInvoice, fiscalization) = await InvoiceService.CreateInvoiceAsync(invoice);

            if (success)
            {
                Logger.LogInformation("Invoice #{DocNum} (DocEntry: {DocEntry}) created successfully for customer {CardCode}",
                createdInvoice?.DocNum, createdInvoice?.DocEntry, invoice.CardCode);

                var postCreateInvoice = createdInvoice;
                var postCreateNotifyByEmail = notifyCustomerByEmail;
                var postCreateCardCode = createdInvoice?.CardCode ?? invoice.CardCode;
                var postCreateCustomerName = selectedBusinessPartner?.CardName ?? createdInvoice?.CardName ?? "Customer";
                var postCreateCustomerEmail = selectedBusinessPartner?.Email;

                // Build success message with fiscalisation status
                if (fiscalization?.Queued == true)
                {
                    successMessage = $"Invoice #{createdInvoice?.DocNum} created successfully. Fiscalisation is running in the background.";
                }
                else if (fiscalization != null && fiscalization.Success)
                {
                    successMessage = $"Invoice #{createdInvoice?.DocNum} created and fiscalised successfully! Receipt: {fiscalization.ReceiptGlobalNo}";
                }
                else if (fiscalization != null && fiscalization.Skipped)
                {
                    successMessage = $"Invoice #{createdInvoice?.DocNum} created successfully! (Fiscalisation skipped)";
                }
                else if (fiscalization != null && !fiscalization.Success)
                {
                    successMessage = $"Invoice #{createdInvoice?.DocNum} created successfully!";
                    errorMessage = $"Fiscalisation failed: {fiscalization.Message ?? "Unknown error"}. The invoice was posted to SAP but not fiscalised.";
                }
                else
                {
                    successMessage = $"Invoice #{createdInvoice?.DocNum} created successfully!";
                }

                // Store reference for manual print button
                lastCreatedInvoice = createdInvoice;

                ClearForm();
                QueueInvoicePostCreateWork(
                    postCreateInvoice,
                    postCreateNotifyByEmail,
                    postCreateCardCode,
                    postCreateCustomerName,
                    postCreateCustomerEmail);
            }
            else
            {
                Logger.LogError("Failed to create invoice for customer {CardCode}. Error: {Error}",
                invoice.CardCode, message);
                errorMessage = message;
                // Audit log: invoice creation failed
                await AuditService.LogAsync(AuditActions.CreateInvoice, "Invoice", invoice.CardCode, null, false, message);
            }
        }
        catch (HttpRequestException httpEx)
        {
            Logger.LogError(httpEx, "HTTP error creating invoice for customer {CardCode}. Status: {StatusCode}",
            invoice.CardCode, httpEx.StatusCode);
            errorMessage = $"Network error: {httpEx.Message}. Please check if the API is running.";
        }
        catch (TaskCanceledException tcEx) when (tcEx.InnerException is TimeoutException)
        {
            Logger.LogError(tcEx, "Timeout creating invoice for customer {CardCode}", invoice.CardCode);
            errorMessage = "Request timed out. The server may be busy, please try again.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error creating invoice for customer {CardCode}. Exception: {ExceptionType}",
            invoice.CardCode, ex.GetType().Name);
            errorMessage = $"Error creating invoice: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void QueueInvoicePostCreateWork(
        InvoiceDto? createdInvoice,
        bool notifyByEmail,
        string? cardCode,
        string customerName,
        string? customerEmail)
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                var notificationNote = await TrySendCustomerInvoiceNotificationAsync(
                    createdInvoice,
                    notifyByEmail,
                    cardCode,
                    customerName,
                    customerEmail);

                if (!string.IsNullOrWhiteSpace(notificationNote) && !string.IsNullOrWhiteSpace(successMessage))
                {
                    successMessage = $"{successMessage} {notificationNote}";
                    StateHasChanged();
                }

                await TryAutoPrintInvoiceAsync(createdInvoice);
                await AuditService.LogAsync(AuditActions.CreateInvoice, "Invoice", createdInvoice?.DocNum.ToString());
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Invoice post-create work failed for invoice {DocNum}", createdInvoice?.DocNum);
            }
        });
    }

    private async Task<string?> TrySendCustomerInvoiceNotificationAsync(
        InvoiceDto? createdInvoice,
        bool notifyByEmail,
        string? cardCode,
        string customerName,
        string? customerEmail)
    {
        if (!notifyByEmail)
        {
            return null;
        }

        if (createdInvoice == null)
        {
            Logger.LogWarning("Invoice created but no invoice details were returned. Skipping email notification.");
            return "Notification email skipped (invoice details unavailable).";
        }

        cardCode ??= createdInvoice.CardCode;
        customerName = string.IsNullOrWhiteSpace(customerName)
            ? createdInvoice.CardName ?? "Customer"
            : customerName;

        if (string.IsNullOrWhiteSpace(customerEmail) && !string.IsNullOrWhiteSpace(cardCode))
        {
            var bp = await BusinessPartnerService.GetBusinessPartnerByCodeAsync(cardCode);
            if (bp != null)
            {
                customerEmail = bp.Email;
                if (!string.IsNullOrWhiteSpace(bp.CardName))
                {
                    customerName = bp.CardName;
                }
            }
        }

        if (string.IsNullOrWhiteSpace(customerEmail))
        {
            Logger.LogWarning("No email found for customer {CardCode}. Skipping invoice notification.", cardCode);
            return "Notification email skipped (customer email missing).";
        }

        var sent = await EmailService.SendCustomerInvoiceNotificationAsync(
        customerEmail,
        customerName,
        createdInvoice.DocEntry,
        createdInvoice.DocNum.ToString(),
        createdInvoice.DocTotal);

        if (sent)
        {
            Logger.LogInformation("Invoice notification email sent to {Email} for invoice {DocNum}.",
            customerEmail, createdInvoice.DocNum);
            return "Notification email sent.";
        }

        Logger.LogWarning("Failed to send invoice notification email to {Email} for invoice {DocNum}.",
        customerEmail, createdInvoice.DocNum);
        return "Notification email failed to send.";
    }

    private async Task TryAutoPrintInvoiceAsync(InvoiceDto? createdInvoice)
    {
        try
        {
            var autoPrint = await AppSettingsService.GetValueAsync<bool>(SettingKeys.AutoPrintInvoice);
            if (!autoPrint || createdInvoice == null)
                return;

            Logger.LogInformation("Auto-printing invoice #{DocNum} (DocEntry: {DocEntry})",
            createdInvoice.DocNum, createdInvoice.DocEntry);

            var pdfBytes = await InvoiceService.GetInvoicePdfAsync(createdInvoice.DocEntry);
            if (pdfBytes == null || pdfBytes.Length == 0)
            {
                Logger.LogWarning("Failed to retrieve PDF for auto-print of invoice #{DocNum}", createdInvoice.DocNum);
                return;
            }

            var copies = await AppSettingsService.GetValueAsync<int>(SettingKeys.PrintCopies);
            copies = Math.Clamp(copies, 1, 10);

            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("printPdfFromBase64", base64, copies);

            Logger.LogInformation("Auto-print triggered for invoice #{DocNum} ({Copies} copies)",
            createdInvoice.DocNum, copies);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Auto-print failed for invoice. Error: {Message}", ex.Message);
            // Don't fail the invoice creation if printing fails
        }
    }

    private void DismissSuccess()
    {
        successMessage = null;
        lastCreatedInvoice = null;
    }

    private async Task OpenPrintDialog()
    {
        if (lastCreatedInvoice == null)
            return;

        // Load saved printers and default copies from settings
        try
        {
            installedPrinters = PrinterService.GetInstalledPrinters();

            var savedPrintersJson = await AppSettingsService.GetValueAsync<string>(SettingKeys.SavedPrinters);
            if (!string.IsNullOrWhiteSpace(savedPrintersJson))
            {
                savedPrinters = (System.Text.Json.JsonSerializer.Deserialize<List<string>>(savedPrintersJson) ?? new())
                    .Where(printer => !string.IsNullOrWhiteSpace(printer))
                    .Select(printer => printer.Trim())
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(printer => printer, StringComparer.OrdinalIgnoreCase)
                    .ToList();
            }

            var defaultPrinter = await AppSettingsService.GetValueAsync<string>(SettingKeys.PrinterName);
            var knownPrinters = savedPrinters.Concat(installedPrinters);
            selectedPrinterName = !string.IsNullOrWhiteSpace(defaultPrinter) && knownPrinters.Contains(defaultPrinter,
StringComparer.OrdinalIgnoreCase)
            ? defaultPrinter
            : "";

            if (!string.IsNullOrWhiteSpace(selectedPrinterName) && !savedPrinters.Contains(selectedPrinterName,
StringComparer.OrdinalIgnoreCase))
            {
                savedPrinters.Add(selectedPrinterName);
                savedPrinters = savedPrinters.OrderBy(printer => printer, StringComparer.OrdinalIgnoreCase).ToList();
                await SavePrinterList();
            }

            printCopies = await AppSettingsService.GetValueAsync<int>(SettingKeys.PrintCopies);
            printCopies = Math.Clamp(printCopies, 1, 10);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error loading printer settings");
            savedPrinters = new();
            printCopies = 1;
        }

        newPrinterName = "";
        showPrintDialog = true;
    }

    private async Task AddPrinter()
    {
        var name = newPrinterName?.Trim();
        if (string.IsNullOrWhiteSpace(name) || savedPrinters.Contains(name, StringComparer.OrdinalIgnoreCase))
            return;

        savedPrinters.Add(name);
        selectedPrinterName = name;
        newPrinterName = "";
        await SavePrinterList();
    }

    private void OnNewPrinterKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = AddPrinter();
        }
    }

    private async Task RemovePrinter(string name)
    {
        savedPrinters.RemoveAll(printer => string.Equals(printer, name, StringComparison.OrdinalIgnoreCase));
        if (string.Equals(selectedPrinterName, name, StringComparison.OrdinalIgnoreCase))
            selectedPrinterName = "";
        await SavePrinterList();
    }

    private async Task SavePrinterList()
    {
        try
        {
            savedPrinters = savedPrinters
                .Where(printer => !string.IsNullOrWhiteSpace(printer))
                .Select(printer => printer.Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(printer => printer, StringComparer.OrdinalIgnoreCase)
                .ToList();
            var json = System.Text.Json.JsonSerializer.Serialize(savedPrinters);
            await AppSettingsService.SaveSettingAsync(SettingKeys.SavedPrinters, json);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error saving printer list");
        }
    }

    private async Task ExecutePrint()
    {
        if (lastCreatedInvoice == null || isPrinting)
            return;

        isPrinting = true;
        try
        {
            printCopies = Math.Clamp(printCopies, 1, 10);

            // Save selected printer as default
            await AppSettingsService.SaveSettingAsync(SettingKeys.PrinterName, selectedPrinterName ?? string.Empty);
            await AppSettingsService.SaveSettingAsync(SettingKeys.PrintCopies, printCopies.ToString());

            var pdfBytes = await InvoiceService.GetInvoicePdfAsync(lastCreatedInvoice.DocEntry);
            if (pdfBytes == null || pdfBytes.Length == 0)
            {
                errorMessage = "Failed to retrieve invoice PDF for printing.";
                return;
            }

            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("printPdfFromBase64", base64, printCopies);

            Logger.LogInformation("Print triggered for invoice #{DocNum} ({Copies} copies, Printer: {Printer})",
            lastCreatedInvoice.DocNum, printCopies, selectedPrinterName ?? "System Default");

            showPrintDialog = false;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Print failed for invoice. Error: {Message}", ex.Message);
            errorMessage = $"Print failed: {ex.Message}";
        }
        finally
        {
            isPrinting = false;
        }
    }

    private async Task DownloadInvoicePdf()
    {
        if (lastCreatedInvoice == null || isPrinting)
            return;

        isPrinting = true;
        try
        {
            var pdfBytes = await InvoiceService.GetInvoicePdfAsync(lastCreatedInvoice.DocEntry);
            if (pdfBytes == null || pdfBytes.Length == 0)
            {
                errorMessage = "Failed to retrieve invoice PDF.";
                return;
            }

            var base64 = Convert.ToBase64String(pdfBytes);
            var fileName = $"Invoice_{lastCreatedInvoice.DocNum}.pdf";
            await JS.InvokeVoidAsync("downloadPdfFromBase64", base64, fileName);

            Logger.LogInformation("PDF downloaded for invoice #{DocNum}", lastCreatedInvoice.DocNum);
            showPrintDialog = false;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "PDF download failed for invoice. Error: {Message}", ex.Message);
            errorMessage = $"Download failed: {ex.Message}";
        }
        finally
        {
            isPrinting = false;
        }
    }

    private void ClearForm()
    {
        invoice = new CreateInvoiceRequest
        {
            DocCurrency = AppSettings.DefaultCurrency,
            Lines = new List<CreateInvoiceLineRequest>()
        };
        lineStates.Clear();
        lineValidationErrors.Clear();
        validationErrors.Clear();
        ClearSelectedBP();
    }
