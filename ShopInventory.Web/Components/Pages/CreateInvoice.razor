    private Task OnLineWarehouseChangedAsync(int index, WarehouseDto? warehouse)
    {
        if (index < 0 || index >= invoice.Lines.Count)
        {
            return Task.CompletedTask;
        }

        invoice.Lines[index].WarehouseCode = warehouse?.WarehouseCode ?? string.Empty;

        if (lineValidationErrors.TryGetValue(index, out var errors))
        {
            errors.Remove("Warehouse");
        }

        return Task.CompletedTask;
    }

    private async Task OnLineProductChangedAsync(int index, ProductDto? product)
    {
        if (index < 0 || index >= invoice.Lines.Count)
        {
            return;
        }

        if (product is null)
        {
            var line = invoice.Lines[index];
            line.ItemCode = string.Empty;
            line.ItemDescription = string.Empty;
            line.UnitPrice = null;

            if (lineValidationErrors.TryGetValue(index, out var errors))
            {
                errors.Remove("ItemCode");
            }

            return;
        }

        await SelectProduct(index, product);
    }
