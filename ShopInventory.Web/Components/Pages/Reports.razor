    private bool isExporting;
    private string errorMessage = "";
    private DateTime fromDate = DateTime.UtcNow.AddDays(-30);
    private DateTime toDate = DateTime.UtcNow;
    private int topProductsCount = 10;
    private string currentUsername = "Unknown";
    private string currentUserRole = "User";
    private HashSet<string> loadingTabs = new();

    private SalesSummaryReport? salesReport;
    private TopProductsReport? topProductsReport;
    private StockSummaryReport? stockReport;
    private PaymentSummaryReport? paymentReport;
    private TopCustomersReport? topCustomersReport;
    private LowStockAlertReport? lowStockReport;
    private OrderFulfillmentReport? fulfillmentReport;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUser();
        try { await AuditService.LogAsync("ViewReports", currentUsername, currentUserRole, "Report", null, "Accessed reports page", "/reports"); } catch { }
        await LoadReports();
    }

    private async Task LoadCurrentUser()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            currentUsername = authState.User.Identity?.Name ?? "Unknown";
            currentUserRole = authState.User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ??
            "User";
        }
        catch { }
    }

    private void SetActiveTab(string tab) { activeTab = tab; }
    private bool IsTabLoading(string tab) => loadingTabs.Contains(tab);
    private string GetTabLabel(string tab) => tabs.FirstOrDefault(t => t.Key == tab)?.Label ?? tab;
    private bool HasActiveData() => salesReport != null || topProductsReport != null || stockReport != null || paymentReport
    != null || topCustomersReport != null || lowStockReport != null || fulfillmentReport != null;

    private async Task LoadReports()
    {
        if (isLoading) return;
        isLoading = true;
        errorMessage = "";
        loadingTabs = new HashSet<string> { "sales", "products", "stock", "payments", "customers", "alerts", "fulfillment" };
        await InvokeAsync(StateHasChanged);

        var errors = new System.Collections.Concurrent.ConcurrentBag<string>();
        var _loadingTabs = new System.Collections.Concurrent.ConcurrentDictionary<string, byte>(
            loadingTabs.Select(t => new KeyValuePair<string, byte>(t, 0)));

        // Batch 1: Sales, Stock, Payments (most commonly viewed, limited parallelism)
        var batch1 = new (string Tab, Func<Task> Action)[]
        {
            ("sales", async () => { salesReport = await ReportService.GetSalesSummaryAsync(fromDate, toDate); }),
            ("stock", async () => { stockReport = await ReportService.GetStockSummaryAsync(); }),
            ("payments", async () => { paymentReport = await ReportService.GetPaymentSummaryAsync(fromDate, toDate); })
        };

        // Batch 2: Products, Customers, Alerts, Fulfillment
        var batch2 = new (string Tab, Func<Task> Action)[]
        {
            ("products", async () => { topProductsReport = await ReportService.GetTopProductsAsync(fromDate, toDate, topProductsCount); }),
            ("customers", async () => { topCustomersReport = await ReportService.GetTopCustomersAsync(fromDate, toDate, 10); }),
            ("alerts", async () => { lowStockReport = await ReportService.GetLowStockAlertsAsync(); }),
            ("fulfillment", async () => { fulfillmentReport = await ReportService.GetOrderFulfillmentAsync(fromDate, toDate); })
        };

        try
        {
            foreach (var batch in new[] { batch1, batch2 })
            {
                var loadTasks = batch.Select(async t =>
                {
                    try { await t.Action(); }
                    catch (Exception ex) { errors.Add($"{t.Tab}: {ex.Message}"); }
                    finally
                    {
                        _loadingTabs.TryRemove(t.Tab, out _);
                        loadingTabs = new HashSet<string>(_loadingTabs.Keys);
                        await InvokeAsync(StateHasChanged);
                    }
                });

                await Task.WhenAll(loadTasks);
            }

            if (!errors.IsEmpty) errorMessage = $"Some reports had issues: {string.Join("; ", errors)}";
            try { await AuditService.LogAsync("GenerateReports", currentUsername, currentUserRole, "Report", null, $"Generated reports from {fromDate:yyyy-MM-dd} to {toDate:yyyy-MM-dd}", "/reports"); } catch { }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load reports: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            loadingTabs.Clear();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadTopProducts()
    {
        loadingTabs.Add("products");
        StateHasChanged();
        try { topProductsReport = await ReportService.GetTopProductsAsync(fromDate, toDate, topProductsCount); }
        finally { loadingTabs.Remove("products"); StateHasChanged(); }
    }

    private void OnQuickSelectChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int days))
        {
            fromDate = DateTime.UtcNow.AddDays(-days);
            toDate = DateTime.UtcNow;
        }
    }

    private async Task ExportToExcel(string tab)
    {
        isExporting = true;
        StateHasChanged();
        try
        {
            byte[]? bytes = tab switch
            {
                "sales" when salesReport != null => ExportService.ExportSalesSummaryToExcel(salesReport),
                "products" when topProductsReport != null => ExportService.ExportTopProductsToExcel(topProductsReport),
                "stock" when stockReport != null => ExportService.ExportStockSummaryToExcel(stockReport),
                "payments" when paymentReport != null => ExportService.ExportPaymentSummaryToExcel(paymentReport),
                "customers" when topCustomersReport != null => ExportService.ExportTopCustomersToExcel(topCustomersReport),
                "alerts" when lowStockReport != null => ExportService.ExportLowStockAlertsToExcel(lowStockReport),
                "fulfillment" when fulfillmentReport != null => ExportService.ExportOrderFulfillmentToExcel(fulfillmentReport),
                _ => null
            };
            if (bytes != null)
            {
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("downloadFile", $"Report_{tab}_{DateTime.Now:yyyyMMdd_HHmm}.xlsx", base64);
            }
        }
        catch (Exception ex) { errorMessage = $"Export failed: {ex.Message}"; }
        finally { isExporting = false; StateHasChanged(); }
    }

    private async Task ExportToPdf(string tab)
    {
        isExporting = true;
        StateHasChanged();
        try
        {
            string? html = tab switch
            {
                "sales" when salesReport != null => BuildSalesPdfHtml(),
                "products" when topProductsReport != null => BuildProductsPdfHtml(),
                "stock" when stockReport != null => BuildStockPdfHtml(),
                "payments" when paymentReport != null => BuildPaymentsPdfHtml(),
                "customers" when topCustomersReport != null => BuildCustomersPdfHtml(),
                "alerts" when lowStockReport != null => BuildAlertsPdfHtml(),
                "fulfillment" when fulfillmentReport != null => BuildFulfillmentPdfHtml(),
                _ => null
            };
            if (html != null) await JS.InvokeVoidAsync("printReportHtml", html);
        }
        catch (Exception ex) { errorMessage = $"PDF export failed: {ex.Message}"; }
        finally { isExporting = false; StateHasChanged(); }
    }

    private string BuildSalesPdfHtml()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("<div class='kpi-row'>");
        sb.Append($"<div class='kpi'><h3>{salesReport!.TotalInvoices}</h3><p>Total Invoices</p></div>");
        sb.Append($"<div class='kpi'><h3>${salesReport.TotalSalesUSD:N2}</h3><p>Sales (USD)</p></div>");
        sb.Append($"<div class='kpi'><h3>ZIG {salesReport.TotalSalesZIG:N2}</h3><p>Sales (ZIG)</p></div>");
        sb.Append($"<div class='kpi'><h3>{salesReport.UniqueCustomers}</h3><p>Unique Customers</p></div>");
        sb.Append("</div>");
        sb.Append("<table><thead><tr><th>Date</th><th>Invoices</th><th>USD Sales</th><th>ZIG Sales</th></tr></thead><tbody>");
        foreach (var d in salesReport.DailySales.OrderByDescending(d => d.Date))
            sb.Append($"<tr><td>{d.Date:ddd, dd MMM yyyy}</td><td class='text-end'>{d.InvoiceCount}</td><td class='text-end'>${d.TotalSalesUSD:N2}</td><td class='text-end'>ZIG {d.TotalSalesZIG:N2}</td></tr>");
        sb.Append($"</tbody><tfoot><tr style='font-weight:bold;background:#e8eaf6'><td>Total</td><td class='text-end'>{salesReport.TotalInvoices}</td><td class='text-end'>${salesReport.TotalSalesUSD:N2}</td><td class='text-end'>ZIG {salesReport.TotalSalesZIG:N2}</td></tr></tfoot></table>");
        return ExportService.GeneratePrintableHtml("Sales Summary Report", sb.ToString(), fromDate, toDate);
    }

    private string BuildProductsPdfHtml()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("<table><thead><tr><th>Rank</th><th>Code</th><th>Product</th><th>Qty Sold</th><th>Orders</th><th>Revenue (USD)</th><th>Revenue (ZIG)</th></tr></thead><tbody>");
        foreach (var p in topProductsReport!.TopProducts)
            sb.Append($"<tr><td>{p.Rank}</td><td>{p.ItemCode}</td><td>{p.ItemName}</td><td class='text-end'>{p.TotalQuantitySold:N0}</td><td class='text-end'>{p.TimesOrdered}</td><td class='text-end'>${p.TotalRevenueUSD:N2}</td><td class='text-end'>ZIG {p.TotalRevenueZIG:N2}</td></tr>");
        sb.Append("</tbody></table>");
        return ExportService.GeneratePrintableHtml("Top Products Report", sb.ToString(), fromDate, toDate);
    }

    private string BuildStockPdfHtml()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("<div class='kpi-row'>");
        sb.Append($"<div class='kpi'><h3>{stockReport!.TotalProducts:N0}</h3><p>Total Products</p></div>");
        sb.Append($"<div class='kpi'><h3>{stockReport.ProductsInStock:N0}</h3><p>In Stock</p></div>");
        sb.Append($"<div class='kpi'><h3>{stockReport.ProductsOutOfStock:N0}</h3><p>Out of Stock</p></div>");
        sb.Append($"<div class='kpi'><h3>{stockReport.ProductsBelowReorderLevel:N0}</h3><p>Below Reorder</p></div>");
        sb.Append("</div>");
        sb.Append("<table><thead><tr><th>Warehouse</th><th>Products</th><th>Total Qty</th></tr></thead><tbody>");
        foreach (var w in stockReport.StockByWarehouse.OrderByDescending(w => w.TotalQuantity))
            sb.Append($"<tr><td><strong>{w.WarehouseCode}</strong> - {w.WarehouseName}</td><td class='text-end'>{w.ProductCount}</td><td class='text-end'>{w.TotalQuantity:N0}</td></tr>");
        sb.Append("</tbody></table>");
        return ExportService.GeneratePrintableHtml("Stock Summary Report", sb.ToString());
    }

    private string BuildPaymentsPdfHtml()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("<div class='kpi-row'>");
        sb.Append($"<div class='kpi'><h3>{paymentReport!.TotalPayments}</h3><p>Total Payments</p></div>");
        sb.Append($"<div class='kpi'><h3>${paymentReport.TotalAmountUSD:N2}</h3><p>Total (USD)</p></div>");
        sb.Append($"<div class='kpi'><h3>ZIG {paymentReport.TotalAmountZIG:N2}</h3><p>Total (ZIG)</p></div>");
        sb.Append("</div>");
        sb.Append("<h3 style='font-size:14px;margin-top:20px;'>Payment Methods</h3>");
        sb.Append("<table><thead><tr><th>Method</th><th>Count</th><th>USD</th><th>ZIG</th><th>%</th></tr></thead><tbody>");
        foreach (var m in paymentReport.PaymentsByMethod)
            sb.Append($"<tr><td>{m.PaymentMethod}</td><td class='text-end'>{m.PaymentCount}</td><td class='text-end'>${m.TotalAmountUSD:N2}</td><td class='text-end'>ZIG {m.TotalAmountZIG:N2}</td><td class='text-end'>{m.PercentageOfTotal:N1}%</td></tr>");
        sb.Append("</tbody></table>");
        sb.Append("<h3 style='font-size:14px;margin-top:20px;'>Daily Breakdown</h3>");
        sb.Append("<table><thead><tr><th>Date</th><th>Count</th><th>USD</th><th>ZIG</th></tr></thead><tbody>");
        foreach (var d in paymentReport.DailyPayments.OrderByDescending(d => d.Date))
            sb.Append($"<tr><td>{d.Date:dd MMM yyyy}</td><td class='text-end'>{d.PaymentCount}</td><td class='text-end'>${d.TotalAmountUSD:N2}</td><td class='text-end'>ZIG {d.TotalAmountZIG:N2}</td></tr>");
        sb.Append("</tbody></table>");
        return ExportService.GeneratePrintableHtml("Payment Summary Report", sb.ToString(), fromDate, toDate);
    }

    private string BuildCustomersPdfHtml()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("<table><thead><tr><th>Rank</th><th>Customer</th><th>Invoices</th><th>Purchases (USD)</th><th>Purchases (ZIG)</th><th>Payments (USD)</th><th>Balance (USD)</th></tr></thead><tbody>");
        foreach (var c in topCustomersReport!.TopCustomers)
        {
            var balStyle = c.OutstandingBalanceUSD > 0 ? "color:#c62828;font-weight:bold" : "color:#2e7d32";
            sb.Append($"<tr><td>{c.Rank}</td><td><strong>{c.CardName}</strong><br/><small>{c.CardCode}</small></td><td class='text-end'>{c.InvoiceCount}</td><td class='text-end'>${c.TotalPurchasesUSD:N2}</td><td class='text-end'>ZIG {c.TotalPurchasesZIG:N2}</td><td class='text-end'>${c.TotalPaymentsUSD:N2}</td><td class='text-end' style='{balStyle}'>${c.OutstandingBalanceUSD:N2}</td></tr>");
        }
        sb.Append("</tbody></table>");
        return ExportService.GeneratePrintableHtml("Top Customers Report", sb.ToString(), fromDate, toDate);
    }

    private string BuildAlertsPdfHtml()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("<div class='kpi-row'>");
        sb.Append($"<div class='kpi'><h3>{lowStockReport!.TotalAlerts}</h3><p>Total Alerts</p></div>");
        sb.Append($"<div class='kpi' style='border-color:#c62828'><h3 style='color:#c62828'>{lowStockReport.CriticalCount}</h3><p>Critical</p></div>");
        sb.Append($"<div class='kpi' style='border-color:#e65100'><h3 style='color:#e65100'>{lowStockReport.WarningCount}</h3><p>Warning</p></div>");
        sb.Append("</div>");
        sb.Append("<table><thead><tr><th>Status</th><th>Code</th><th>Name</th><th>Warehouse</th><th>Current</th><th>Reorder Level</th><th>Suggested Order</th></tr></thead><tbody>");
        foreach (var i in lowStockReport.Items.OrderBy(i => i.AlertLevel == "Critical" ? 0 : 1).ThenBy(i => i.CurrentStock))
            sb.Append($"<tr><td>{(i.AlertLevel == "Critical" ? "CRITICAL" :
            "WARNING")}</td><td>{i.ItemCode}</td><td>{i.ItemName}</td><td>{i.WarehouseCode}</td><td class='text-end' style='font-weight:bold;color:{(i.CurrentStock <= 0 ? "#c62828" : "#e65100")}'>{i.CurrentStock:N0}</td><td class='text-end'>{i.ReorderLevel:N0}</td><td class='text-end' style='color:#1565c0;font-weight:bold'>{i.SuggestedReorderQty:N0}</td></tr>");
        sb.Append("</tbody></table>");
        return ExportService.GeneratePrintableHtml("Low Stock Alerts Report", sb.ToString());
    }

    private string BuildFulfillmentPdfHtml()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("<div class='kpi-row'>");
        sb.Append($"<div class='kpi'><h3>{fulfillmentReport!.TotalOrders}</h3><p>Total Orders</p></div>");
        sb.Append($"<div class='kpi'><h3>{fulfillmentReport.FulfillmentRatePercent:N1}%</h3><p>Fulfillment Rate</p></div>");
        sb.Append($"<div class='kpi'><h3>{fulfillmentReport.OpenOrders}</h3><p>Open Orders</p></div>");
        sb.Append($"<div class='kpi' style='border-color:#c62828'><h3 style='color:#c62828'>${fulfillmentReport.TotalPendingValueUSD:N2}</h3><p>Pending Value</p></div>");
        sb.Append("</div>");
        sb.Append("<h3 style='font-size:14px;margin-top:20px;'>Order Details</h3>");
        sb.Append("<table><thead><tr><th>Order#</th><th>Date</th><th>Customer</th><th>Total</th><th>Status</th><th>Ordered</th><th>Delivered</th><th>Fulfillment</th><th>Overdue</th></tr></thead><tbody>");
        foreach (var o in fulfillmentReport.Orders)
            sb.Append($"<tr><td>{o.DocNum}</td><td>{o.OrderDate:dd MMM yyyy}</td><td>{o.CardName}</td><td class='text-end'>${o.OrderTotal:N2}</td><td>{o.Status}</td><td class='text-end'>{o.TotalQuantityOrdered:N0}</td><td class='text-end'>{o.TotalQuantityDelivered:N0}</td><td class='text-end'>{o.FulfillmentPercent:N1}%</td><td>{(o.IsOverdue
            ? $"{o.DaysOverdue}d overdue" : "-")}</td></tr>");
        sb.Append("</tbody></table>");
        if (fulfillmentReport.FulfillmentByCustomer.Any())
        {
            sb.Append("<h3 style='font-size:14px;margin-top:20px;'>By Customer</h3>");
            sb.Append("<table><thead><tr><th>Customer</th><th>Orders</th><th>Open</th><th>Closed</th><th>Value</th><th>Fulfillment</th></tr></thead><tbody>");
            foreach (var c in fulfillmentReport.FulfillmentByCustomer)
                sb.Append($"<tr><td>{c.CardName}</td><td class='text-end'>{c.TotalOrders}</td><td class='text-end'>{c.OpenOrders}</td><td class='text-end'>{c.ClosedOrders}</td><td class='text-end'>${c.TotalOrderValue:N2}</td><td class='text-end'>{c.FulfillmentRatePercent:N1}%</td></tr>");
            sb.Append("</tbody></table>");
        }
        return ExportService.GeneratePrintableHtml("Order Fulfillment Report", sb.ToString(), fromDate, toDate);
    }
}