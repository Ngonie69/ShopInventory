@* @formatter:off *@
@page "/reports"
@using Microsoft.AspNetCore.Authorization
@using ShopInventory.Web.Models
@using ShopInventory.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@attribute [Authorize]
@inject IReportService ReportService
@inject IReportExportService ExportService
@inject IAuditService AuditService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Reports - Shop Inventory</PageTitle>

<div class="container-fluid fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold" style="color: #1a237e;">
                <i class="bi bi-bar-chart-line me-2"></i>Reports &amp; Analytics
            </h2>
            <p class="text-muted mb-0">Real-time business insights from SAP Business One</p>
        </div>
        <div class="d-flex gap-2">
            @if (HasActiveData())
            {
                <div class="dropdown">
                    <button class="btn btn-outline-success dropdown-toggle" data-bs-toggle="dropdown"
                            disabled="@isExporting">
                        @if (isExporting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="bi bi-file-earmark-excel me-1"></i>
                        }
                        Excel
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <button class="dropdown-item" @onclick="() => ExportToExcel(activeTab)">
                                <i class="bi bi-download me-2"></i>Export Current Tab
                            </button>
                        </li>
                        <li>
                            <hr class="dropdown-divider" />
                        </li>
                        @if (salesReport != null)
                        {
                            <li><button class="dropdown-item" @onclick='() => ExportToExcel("sales")'><i
                                class="bi bi-graph-up me-2"></i>Sales Summary</button></li>
                            }
                            @if (topProductsReport != null)
                            {
                                <li><button class="dropdown-item" @onclick='() => ExportToExcel("products")'><i
                                    class="bi bi-box-seam me-2"></i>Top Products</button></li>
                                }
                                @if (stockReport != null)
                                {
                                    <li><button class="dropdown-item" @onclick='() => ExportToExcel("stock")'><i
                                        class="bi bi-boxes me-2"></i>Stock Summary</button></li>
                                    }
                                    @if (paymentReport != null)
                                    {
                                        <li><button class="dropdown-item" @onclick='() => ExportToExcel("payments")'><i
                                            class="bi bi-cash-stack me-2"></i>Payments</button></li>
                                        }
                                        @if (topCustomersReport != null)
                                        {
                                            <li><button class="dropdown-item" @onclick='() => ExportToExcel("customers")'><i
                                                class="bi bi-people me-2"></i>Top Customers</button></li>
                                            }
                                            @if (lowStockReport != null)
                                            {
                                                <li><button class="dropdown-item" @onclick='() => ExportToExcel("alerts")'><i
                                                    class="bi bi-exclamation-triangle me-2"></i>Low Stock Alerts</button></li>
                                                }
                                                @if (fulfillmentReport != null)
                                                {
                                                    <li><button class="dropdown-item" @onclick='() => ExportToExcel("fulfillment")'><i
                                                        class="bi bi-truck me-2"></i>Order Fulfillment</button></li>
                                                    }
                                                </ul>
                                            </div>
                                            <button class="btn btn-outline-danger" @onclick="() => ExportToPdf(activeTab)" disabled="@isExporting">
                                                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
                                            </button>
                                        }
                                    </div>
                                </div>

                                <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px;">
                                    <div class="card-body py-3">
                                        <div class="row g-3 align-items-end">
                                            <div class="col-md-3">
                                                <label class="form-label small fw-semibold text-uppercase text-muted">From Date</label>
                                                <input type="date" class="form-control" @bind="fromDate" style="border-radius: 8px;" />
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label small fw-semibold text-uppercase text-muted">To Date</label>
                                                <input type="date" class="form-control" @bind="toDate" style="border-radius: 8px;" />
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label small fw-semibold text-uppercase text-muted">Quick Select</label>
                                                <select class="form-select" @onchange="OnQuickSelectChanged" style="border-radius: 8px;">
                                                    <option value="7">Last 7 Days</option>
                                                    <option value="30" selected>Last 30 Days</option>
                                                    <option value="90">Last 90 Days</option>
                                                    <option value="180">Last 6 Months</option>
                                                    <option value="365">Last Year</option>
                                                </select>
                                            </div>
                                            <div class="col-md-3">
                                                <button class="btn btn-primary w-100 fw-semibold" @onclick="LoadReports" disabled="@isLoading"
                                                        style="border-radius: 8px; background: linear-gradient(135deg, #1a237e, #3949ab); border: none; padding: 0.5rem;">
                                                    @if (isLoading)
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                                        <span>Loading...</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-lightning-charge me-2"></i>
                                                        <span>Generate Reports</span>
                                                    }
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(errorMessage))
                                {
                                    <div class="alert alert-warning alert-dismissible fade show" role="alert" style="border-radius: 10px;">
                                        <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
                                        <button type="button" class="btn-close" @onclick='() => errorMessage = ""'></button>
                                    </div>
                                }

                                <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px; overflow: hidden;">
                                    <div class="card-header bg-white border-bottom-0 pt-3 pb-0 px-4">
                                        <ul class="nav nav-pills gap-1" role="tablist">
                                            @foreach (var tab in tabs)
                                            {
                                                <li class="nav-item">
                                                    <button class="nav-link px-3 py-2 @(activeTab == tab.Key ? "active" : "")"
                                                            style="border-radius: 8px 8px 0 0; @(activeTab == tab.Key ? "background: linear-gradient(135deg, #1a237e, #3949ab); color: white;" : "color: #555;")"
                                                            @onclick="() => SetActiveTab(tab.Key)">
                                                        <i class="bi @tab.Icon me-1"></i>@tab.Label
                                                        @if (tab.Key == "alerts" && lowStockReport?.TotalAlerts > 0)
                                                        {
                                                            <span class="badge bg-danger ms-1 rounded-pill">@lowStockReport.TotalAlerts</span>
                                                        }
                                                    </button>
                                                </li>
                                            }
                                        </ul>
                                    </div>

                                    <div class="card-body p-4">
                                        @if (IsTabLoading(activeTab))
                                        {
                                            <div class="text-center py-5">
                                                <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
                                                    <span class="visually-hidden">Loading...</span>
                                                </div>
                                                <p class="text-muted">Fetching @GetTabLabel(activeTab) data from SAP...</p>
                                            </div>
                                        }
                                        else if (activeTab == "sales")
                                        {
                                            @if (salesReport != null)
                                            {
                                                <div class="row g-3 mb-4">
                                                    <div class="col-md-3">
                                                        <div class="p-3 rounded-3"
                                                             style="background: linear-gradient(135deg, #e3f2fd, #bbdefb); border-left: 4px solid #1565c0;">
                                                            <p class="text-muted small mb-1 fw-semibold">TOTAL INVOICES</p>
                                                            <h3 class="fw-bold mb-0" style="color: #1565c0;">@salesReport.TotalInvoices</h3>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="p-3 rounded-3"
                                                             style="background: linear-gradient(135deg, #e8f5e9, #c8e6c9); border-left: 4px solid #2e7d32;">
                                                            <p class="text-muted small mb-1 fw-semibold">SALES (USD)</p>
                                                            <h3 class="fw-bold mb-0" style="color: #2e7d32;">$@salesReport.TotalSalesUSD.ToString("N2")</h3>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="p-3 rounded-3"
                                                             style="background: linear-gradient(135deg, #e0f7fa, #b2ebf2); border-left: 4px solid #00838f;">
                                                            <p class="text-muted small mb-1 fw-semibold">SALES (ZIG)</p>
                                                            <h3 class="fw-bold mb-0" style="color: #00838f;">ZIG @salesReport.TotalSalesZIG.ToString("N2")
                                                            </h3>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="p-3 rounded-3"
                                                             style="background: linear-gradient(135deg, #fff3e0, #ffe0b2); border-left: 4px solid #e65100;">
                                                            <p class="text-muted small mb-1 fw-semibold">UNIQUE CUSTOMERS</p>
                                                            <h3 class="fw-bold mb-0" style="color: #e65100;">@salesReport.UniqueCustomers</h3>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row g-3 mb-4">
                                                    @foreach (var currency in salesReport.SalesByCurrency.Where(c => c.InvoiceCount > 0))
                                                    {
                                                        <div class="col-md-6">
                                                            <div class="card border-0 bg-light" style="border-radius: 10px;">
                                                                <div class="card-body">
                                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                                        <span
                                                                        class="badge rounded-pill @(currency.Currency == "USD" ? "bg-success" : "bg-info") px-3">@currency.Currency</span>
                                                                        <span class="fw-semibold">@currency.InvoiceCount invoices</span>
                                                                    </div>
                                                                    <div class="d-flex justify-content-between">
                                                                        <span class="text-muted">Sales</span>
                                                                        <span class="fw-bold">@(currency.Currency == "USD" ? "$" : "ZIG ")@currency.TotalSales.ToString("N2")</span>
                                                                    </div>
                                                                    <div class="d-flex justify-content-between">
                                                                        <span class="text-muted">VAT</span>
                                                                        <span>@(currency.Currency == "USD" ? "$" : "ZIG ")@currency.TotalVat.ToString("N2")</span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                                <h6 class="fw-bold text-uppercase text-muted mb-3"><i class="bi bi-calendar3 me-2"></i>Daily Breakdown</h6>
                                                <div class="table-responsive">
                                                    <table class="table table-hover align-middle mb-0">
                                                        <thead>
                                                            <tr style="background: #f8f9fa;">
                                                                <th class="border-0 fw-semibold">Date</th>
                                                                <th class="border-0 fw-semibold text-end">Invoices</th>
                                                                <th class="border-0 fw-semibold text-end">USD Sales</th>
                                                                <th class="border-0 fw-semibold text-end">ZIG Sales</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var day in salesReport.DailySales.OrderByDescending(d => d.Date))
                                                            {
                                                                <tr>
                                                                    <td class="fw-medium">@day.Date.ToString("ddd, dd MMM yyyy")</td>
                                                                    <td class="text-end"><span class="badge bg-secondary rounded-pill">@day.InvoiceCount</span>
                                                                    </td>
                                                                    <td class="text-end fw-semibold" style="color: #2e7d32;">$@day.TotalSalesUSD.ToString("N2")
                                                                    </td>
                                                                    <td class="text-end fw-semibold" style="color: #00838f;">ZIG
                                                                        @day.TotalSalesZIG.ToString("N2")</td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                            <tfoot>
                                                                <tr style="background: #e8eaf6; font-weight: 700;">
                                                                    <td>Total</td>
                                                                    <td class="text-end">@salesReport.TotalInvoices</td>
                                                                    <td class="text-end" style="color: #2e7d32;">$@salesReport.TotalSalesUSD.ToString("N2")</td>
                                                                    <td class="text-end" style="color: #00838f;">ZIG @salesReport.TotalSalesZIG.ToString("N2")
                                                                    </td>
                                                                </tr>
                                                            </tfoot>
                                                        </table>
                                                    </div>
                                                }
            else
                                                {
                                                    <div class="text-center py-5">
                                                        <i class="bi bi-graph-up" style="font-size: 3rem; color: #bdbdbd;"></i>
                                                        <p class="mt-3 text-muted">No sales data available. Click "Generate Reports" to load.</p>
                                                    </div>
                                                }
                                            }
                                            else if (activeTab == "products")
                                            {
                                                @if (topProductsReport != null && topProductsReport.TopProducts.Any())
                                                {
                                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                                        <h6 class="fw-bold text-uppercase text-muted mb-0"><i class="bi bi-trophy me-2"></i>Top Selling Products
                                                        </h6>
                                                        <div class="d-flex align-items-center gap-2">
                                                            <label class="text-muted small">Show:</label>
                                                            <select class="form-select form-select-sm" style="width: 80px; border-radius: 8px;"
                                                                    @bind="topProductsCount" @bind:after="LoadTopProducts">
                                                                <option value="10">10</option>
                                                                <option value="20">20</option>
                                                                <option value="50">50</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="table-responsive">
                                                        <table class="table table-hover align-middle mb-0">
                                                            <thead>
                                                                <tr style="background: #f8f9fa;">
                                                                    <th class="border-0 fw-semibold" style="width: 60px;">Rank</th>
                                                                    <th class="border-0 fw-semibold">Product</th>
                                                                    <th class="border-0 fw-semibold text-end">Qty Sold</th>
                                                                    <th class="border-0 fw-semibold text-end">Orders</th>
                                                                    <th class="border-0 fw-semibold text-end">Revenue (USD)</th>
                                                                    <th class="border-0 fw-semibold text-end">Revenue (ZIG)</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var p in topProductsReport.TopProducts)
                                                                {
                                                                    <tr>
                                                                        <td>
                                                                            @if (p.Rank <= 3)
                                                                            {
                                                                                <span
                                                                                class="badge rounded-pill @(p.Rank == 1 ? "bg-warning text-dark" : p.Rank == 2 ? "bg-secondary" : "bg-dark")"
                                                                                style="width: 30px;">@p.Rank</span>
                                                                            }
                                                                            else
                                                                            {
                                                                                <span class="text-muted fw-medium ms-2">@p.Rank</span>
                                                                            }
                                                                        </td>
                                                                        <td>
                                                                            <div class="fw-semibold">@p.ItemName</div>
                                                                            <small class="text-muted font-monospace">@p.ItemCode</small>
                                                                        </td>
                                                                        <td class="text-end fw-bold">@p.TotalQuantitySold.ToString("N0")</td>
                                                                        <td class="text-end">@p.TimesOrdered</td>
                                                                        <td class="text-end fw-semibold" style="color: #2e7d32;">$@p.TotalRevenueUSD.ToString("N2")
                                                                        </td>
                                                                        <td class="text-end fw-semibold" style="color: #00838f;">ZIG
                                                                            @p.TotalRevenueZIG.ToString("N2")</td>
                                                                        </tr>
                                                                    }
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    }
            else
                                                    {
                                                        <div class="text-center py-5">
                                                            <i class="bi bi-box-seam" style="font-size: 3rem; color: #bdbdbd;"></i>
                                                            <p class="mt-3 text-muted">No product data available. Click "Generate Reports" to load.</p>
                                                        </div>
                                                    }
                                                }
                                                else if (activeTab == "stock")
                                                {
                                                    @if (stockReport != null)
                                                    {
                                                        <div class="row g-3 mb-4">
                                                            <div class="col-md-3">
                                                                <div class="p-3 rounded-3"
                                                                     style="background: linear-gradient(135deg, #e3f2fd, #bbdefb); border-left: 4px solid #1565c0;">
                                                                    <p class="text-muted small mb-1 fw-semibold">TOTAL PRODUCTS</p>
                                                                    <h3 class="fw-bold mb-0" style="color: #1565c0;">@stockReport.TotalProducts.ToString("N0")</h3>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-3">
                                                                <div class="p-3 rounded-3"
                                                                     style="background: linear-gradient(135deg, #e8f5e9, #c8e6c9); border-left: 4px solid #2e7d32;">
                                                                    <p class="text-muted small mb-1 fw-semibold">IN STOCK</p>
                                                                    <h3 class="fw-bold mb-0" style="color: #2e7d32;">@stockReport.ProductsInStock.ToString("N0")
                                                                    </h3>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-3">
                                                                <div class="p-3 rounded-3"
                                                                     style="background: linear-gradient(135deg, #fbe9e7, #ffccbc); border-left: 4px solid #c62828;">
                                                                    <p class="text-muted small mb-1 fw-semibold">OUT OF STOCK</p>
                                                                    <h3 class="fw-bold mb-0" style="color: #c62828;">@stockReport.ProductsOutOfStock.ToString("N0")
                                                                    </h3>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-3">
                                                                <div class="p-3 rounded-3"
                                                                     style="background: linear-gradient(135deg, #fff3e0, #ffe0b2); border-left: 4px solid #e65100;">
                                                                    <p class="text-muted small mb-1 fw-semibold">BELOW REORDER</p>
                                                                    <h3 class="fw-bold mb-0" style="color: #e65100;">
                                                                        @stockReport.ProductsBelowReorderLevel.ToString("N0")</h3>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <h6 class="fw-bold text-uppercase text-muted mb-3"><i class="bi bi-building me-2"></i>Stock by Warehouse
                                                            </h6>
                                                            <div class="table-responsive">
                                                                <table class="table table-hover align-middle mb-0">
                                                                    <thead>
                                                                        <tr style="background: #f8f9fa;">
                                                                            <th class="border-0 fw-semibold">Warehouse</th>
                                                                            <th class="border-0 fw-semibold text-end">Products</th>
                                                                            <th class="border-0 fw-semibold text-end">Total Quantity</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @foreach (var wh in stockReport.StockByWarehouse.OrderByDescending(w => w.TotalQuantity))
                                                                        {
                                                                            <tr>
                                                                                <td>
                                                                                    <div class="fw-semibold">@wh.WarehouseCode</div>
                                                                                    <small class="text-muted">@wh.WarehouseName</small>
                                                                                </td>
                                                                                <td class="text-end">@wh.ProductCount</td>
                                                                                <td class="text-end fw-bold">@wh.TotalQuantity.ToString("N0")</td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                    <tfoot>
                                                                        <tr style="background: #e8eaf6; font-weight: 700;">
                                                                            <td>Total</td>
                                                                            <td class="text-end">@stockReport.TotalProducts</td>
                                                                            <td class="text-end">@stockReport.StockByWarehouse.Sum(w => w.TotalQuantity).ToString("N0")
                                                                            </td>
                                                                        </tr>
                                                                    </tfoot>
                                                                </table>
                                                            </div>
                                                        }
            else
                                                        {
                                                            <div class="text-center py-5">
                                                                <i class="bi bi-boxes" style="font-size: 3rem; color: #bdbdbd;"></i>
                                                                <p class="mt-3 text-muted">No stock data available. Click "Generate Reports" to load.</p>
                                                            </div>
                                                        }
                                                    }
                                                    else if (activeTab == "payments")
                                                    {
                                                        @if (paymentReport != null)
                                                        {
                                                            <div class="row g-3 mb-4">
                                                                <div class="col-md-4">
                                                                    <div class="p-3 rounded-3"
                                                                         style="background: linear-gradient(135deg, #e3f2fd, #bbdefb); border-left: 4px solid #1565c0;">
                                                                        <p class="text-muted small mb-1 fw-semibold">TOTAL PAYMENTS</p>
                                                                        <h3 class="fw-bold mb-0" style="color: #1565c0;">@paymentReport.TotalPayments</h3>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <div class="p-3 rounded-3"
                                                                         style="background: linear-gradient(135deg, #e8f5e9, #c8e6c9); border-left: 4px solid #2e7d32;">
                                                                        <p class="text-muted small mb-1 fw-semibold">TOTAL (USD)</p>
                                                                        <h3 class="fw-bold mb-0" style="color: #2e7d32;">$@paymentReport.TotalAmountUSD.ToString("N2")
                                                                        </h3>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <div class="p-3 rounded-3"
                                                                         style="background: linear-gradient(135deg, #e0f7fa, #b2ebf2); border-left: 4px solid #00838f;">
                                                                        <p class="text-muted small mb-1 fw-semibold">TOTAL (ZIG)</p>
                                                                        <h3 class="fw-bold mb-0" style="color: #00838f;">ZIG
                                                                            @paymentReport.TotalAmountZIG.ToString("N2")</h3>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row g-4">
                                                                    <div class="col-md-5">
                                                                        <h6 class="fw-bold text-uppercase text-muted mb-3"><i class="bi bi-pie-chart me-2"></i>By Payment
                                                                            Method</h6>
                                                                            @foreach (var method in paymentReport.PaymentsByMethod)
                                                                            {
                                                                                var barColor = method.PaymentMethod switch
                                                                                {
                                                                                    "Cash" => "#4caf50",
                                                                                    "Bank Transfer" => "#2196f3",
                                                                                    "Check" => "#ff9800",
                                                                                    "Credit Card" => "#9c27b0",
                                                                                    _ => "#607d8b"
                                                                                };
                                                                                <div class="mb-3">
                                                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                                                        <div class="d-flex align-items-center gap-2">
                                                                                            <span class="rounded-circle d-inline-block"
                                                                                                  style="width: 10px; height: 10px; background: @barColor;"></span>
                                                                                            <span class="fw-medium">@method.PaymentMethod</span>
                                                                                            <span class="text-muted small">(@method.PaymentCount)</span>
                                                                                        </div>
                                                                                        <span class="fw-bold small">@method.PercentageOfTotal.ToString("N1")%</span>
                                                                                    </div>
                                                                                    <div class="progress" style="height: 8px; border-radius: 4px;">
                                                                                        <div class="progress-bar" role="progressbar"
                                                                                             style="width: @(method.PercentageOfTotal)%; background: @barColor; border-radius: 4px;">
                                                                                        </div>
                                                                                    </div>
                                                                                    <div class="d-flex justify-content-between mt-1">
                                                                                        <small class="text-muted">$@method.TotalAmountUSD.ToString("N2")</small>
                                                                                        @if (method.TotalAmountZIG > 0)
                                                                                        {
                                                                                            <small class="text-muted">ZIG @method.TotalAmountZIG.ToString("N2")</small>
                                                                                        }
                                                                                    </div>
                                                                                </div>
                                                                            }
