@page "/desktop-transactions"


@using Microsoft.AspNetCore.Authorization


@using ShopInventory.Web.Services


@attribute [Authorize(Roles = "Admin")]


@inject IDesktopIntegrationService DesktopService


@inject ISnackbar Snackbar


@inject IDialogService DialogService


@rendermode InteractiveServer





<PageTitle>Desktop Transactions - Shop Inventory</PageTitle>





<style>


    /* ─── Dashboard banner ─── */


    .dt-dashboard {


        display: grid;


        grid-template-columns: 1fr 1fr;


        gap: 1rem;


        margin-bottom: 1.5rem;


    }





    @@media (max-width: 960px) {


        .dt-dashboard { grid-template-columns: 1fr; }


    }





    .dt-queue-card {


        border-radius: 14px;


        border: 1px solid rgba(0,0,0,0.06);


        background: var(--mud-palette-surface);


        overflow: hidden;


    }





    .dt-queue-card__header {


        display: flex;


        align-items: center;


        gap: 0.5rem;


        padding: 0.75rem 1rem 0;


        font-size: 0.6875rem;


        font-weight: 700;


        text-transform: uppercase;


        letter-spacing: 0.06em;


        color: var(--mud-palette-text-secondary);


    }





    .dt-queue-card__header .mud-icon-root { font-size: 1rem; }





    .dt-pills {


        display: flex;


        flex-wrap: wrap;


        gap: 0.35rem;


        padding: 0.75rem 1rem 1rem;


    }





    .dt-pill {


        display: flex;


        align-items: center;


        gap: 0.4rem;


        padding: 0.35rem 0.75rem;


        border-radius: 20px;


        font-size: 0.75rem;


        font-weight: 600;


        cursor: pointer;


        border: 1.5px solid transparent;


        transition: all 0.2s ease;


        user-select: none;


    }





    .dt-pill:hover { transform: translateY(-1px); box-shadow: 0 2px 8px rgba(0,0,0,0.1); }


    .dt-pill:active { transform: translateY(0); }


    .dt-pill--active { border-color: currentColor !important; box-shadow: 0 2px 8px rgba(0,0,0,0.12); }





    .dt-pill__count { font-size: 1rem; font-weight: 800; line-height: 1; }





    .dt-pill--pending   { background: #fef9ec; color: #b45309; }


    .dt-pill--processing { background: #eff6ff; color: #1d4ed8; }


    .dt-pill--completed { background: #ecfdf5; color: #047857; }


    .dt-pill--failed    { background: #fef2f2; color: #dc2626; }


    .dt-pill--review    { background: #f5f3ff; color: #7c3aed; }


    .dt-pill--total     { background: var(--mud-palette-background-grey); color: var(--mud-palette-text-primary); }





    /* ─── Status chips ─── */


    .status-chip {


        padding: 3px 10px;


        border-radius: 6px;


        font-size: 0.7rem;


        font-weight: 600;


        text-transform: uppercase;


        letter-spacing: 0.03em;


        display: inline-block;


    }





    .status-pending    { background: #fef3c7; color: #92400e; }


    .status-processing { background: #dbeafe; color: #1e40af; }


    .status-completed  { background: #d1fae5; color: #065f46; }


    .status-failed     { background: #fee2e2; color: #991b1b; }


    .status-review     { background: #ede9fe; color: #5b21b6; }


    .status-cancelled  { background: #f3f4f6; color: #4b5563; }


    .status-expired    { background: #f3f4f6; color: #6b7280; }


    .status-confirmed  { background: #d1fae5; color: #065f46; }





    /* ─── Detail panel ─── */


    .dt-detail-field {


        padding: 0.75rem;


        border-radius: 8px;


        background: var(--mud-palette-background-grey);


    }





    .dt-detail-field .field-label {


        font-size: 0.6875rem;


        font-weight: 600;


        text-transform: uppercase;


        letter-spacing: 0.05em;


        color: var(--mud-palette-text-secondary);


        margin-bottom: 0.25rem;


    }





    .dt-detail-field .field-value {


        font-size: 0.9375rem;


        font-weight: 500;


        color: var(--mud-palette-text-primary);


    }





    /* ─── Expanded row ─── */


    .dt-expanded-row {


        padding: 1rem 1.5rem;


        background: var(--mud-palette-background-grey);


        border-radius: 10px;


        margin: 0.25rem 0;


    }





    .dt-expanded-row__section-title {


        font-size: 0.6875rem;


        font-weight: 700;


        text-transform: uppercase;


        letter-spacing: 0.06em;


        color: var(--mud-palette-text-secondary);


        margin-bottom: 0.5rem;


    }





    .dt-mini-grid {


        display: grid;


        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));


        gap: 0.5rem;


    }





    .dt-mini-field {


        padding: 0.5rem 0.65rem;


        border-radius: 6px;


        background: var(--mud-palette-surface);


    }





    .dt-mini-field__label {


        font-size: 0.625rem;


        font-weight: 600;


        text-transform: uppercase;


        letter-spacing: 0.05em;


        color: var(--mud-palette-text-secondary);


    }





    .dt-mini-field__value {


        font-size: 0.8125rem;


        font-weight: 600;


        color: var(--mud-palette-text-primary);


        margin-top: 0.15rem;


    }





    /* ─── Table row clickable ─── */


    .dt-clickable-row { cursor: pointer; }


    .dt-clickable-row:hover td { background: rgba(var(--mud-palette-primary-rgb), 0.04) !important; }


    /* ─── Tab header ─── */


    .dt-tab-header {


        background: var(--mud-palette-surface) !important;


        border-bottom: 1px solid rgba(0,0,0,0.08);


    }


    .dt-tab-header .mud-tab {


        text-transform: none !important;


        font-weight: 600;


        font-size: 0.8125rem;


        letter-spacing: 0;


        min-width: auto;


        padding: 10px 16px;


        color: var(--mud-palette-text-secondary);


        transition: color 0.15s ease;


    }


    .dt-tab-header .mud-tab.mud-tab-active {


        color: var(--mud-palette-primary) !important;


    }


</style>





<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">


    @* ─── Page Header ─── *@


    <div class="d-flex justify-space-between align-center mb-5">


        <div>


            <MudText Typo="Typo.h5" Style="font-weight: 700; letter-spacing: -0.025em;">


                Desktop Transactions


            </MudText>


            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">


                Manage invoices, transfers, and reservations from desktop applications


            </MudText>


        </div>


        <MudButton Variant="Variant.Filled" Color="Color.Primary"


            StartIcon="@(_isLoading ? null : Icons.Material.Outlined.Sync)"


            OnClick="RefreshAll" Disabled="@_isLoading"


            Style="border-radius: 8px; text-transform: none; font-weight: 600; padding: 8px 20px;">


            @if (_isLoading)


            {


                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Surface" Class="me-2" />


            }


            Refresh


        </MudButton>


    </div>





    @* ─── Dashboard Banner: compact pill-style stats ─── *@


    <div class="dt-dashboard">


        @if (_stats != null)


        {


            <div class="dt-queue-card">


                <div class="dt-queue-card__header">


                    <MudIcon Icon="@Icons.Material.Outlined.Receipt" />


                    Invoice Queue


                </div>


                <div class="dt-pills">


                    <div class="dt-pill dt-pill--pending" @onclick="@(() => NavigateToTab(0))" title="View pending invoices">


                        <span class="dt-pill__count">@_stats.Pending</span> Pending


                    </div>


                    <div class="dt-pill dt-pill--processing" @onclick="@(() => NavigateToTab(0))" title="View processing invoices">


                        <span class="dt-pill__count">@_stats.Processing</span> Processing


                    </div>


                    <div class="dt-pill dt-pill--completed" @onclick="@(() => NavigateToTab(0))" title="View completed invoices">


                        <span class="dt-pill__count">@_stats.Completed</span> Completed


                    </div>


                    <div class="dt-pill dt-pill--failed" @onclick="@(() => NavigateToTab(0))" title="View failed invoices">


                        <span class="dt-pill__count">@_stats.Failed</span> Failed


                    </div>


                    @if (_stats.RequiresReview > 0)


                    {


                        <div class="dt-pill dt-pill--review" @onclick="@(() => NavigateToTab(1))" title="View invoices needing review">


                            <span class="dt-pill__count">@_stats.RequiresReview</span> Review


                        </div>


                    }


                    <div class="dt-pill dt-pill--total" @onclick="@(() => NavigateToTab(0))" title="View all invoices">


                        <span class="dt-pill__count">@_stats.TotalQueued</span> Total


                    </div>


                </div>


            </div>


        }





        @if (_transferStats != null)


        {


            <div class="dt-queue-card">


                <div class="dt-queue-card__header">


                    <MudIcon Icon="@Icons.Material.Outlined.SwapHoriz" />


                    Transfer Queue


                </div>


                <div class="dt-pills">


                    <div class="dt-pill dt-pill--pending" @onclick="@(() => NavigateToTab(2))" title="View pending transfers">


                        <span class="dt-pill__count">@_transferStats.Pending</span> Pending


                    </div>


                    <div class="dt-pill dt-pill--processing" @onclick="@(() => NavigateToTab(2))" title="View processing transfers">


                        <span class="dt-pill__count">@_transferStats.Processing</span> Processing


                    </div>


                    <div class="dt-pill dt-pill--completed" @onclick="@(() => NavigateToTab(2))" title="View completed transfers">


                        <span class="dt-pill__count">@_transferStats.Completed</span> Completed


                    </div>


                    <div class="dt-pill dt-pill--failed" @onclick="@(() => NavigateToTab(2))" title="View failed transfers">


                        <span class="dt-pill__count">@_transferStats.Failed</span> Failed


                    </div>


                    @if (_transferStats.RequiresReview > 0)


                    {


                        <div class="dt-pill dt-pill--review" @onclick="@(() => NavigateToTab(3))" title="View transfers needing review">


                            <span class="dt-pill__count">@_transferStats.RequiresReview</span> Review


                        </div>


                    }


                    <div class="dt-pill dt-pill--total" @onclick="@(() => NavigateToTab(2))" title="View all transfers">


                        <span class="dt-pill__count">@_transferStats.TotalQueued</span> Total


                    </div>


                </div>


            </div>


        }


    </div>





    @* ─── Tabs ─── *@


    <MudPaper Elevation="0" Class="mt-2" Style="border: 1px solid rgba(0,0,0,0.08); border-radius: 12px; overflow: hidden;">


        <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" PanelClass="pa-4"


            @bind-ActivePanelIndex="_activeTab" Color="Color.Transparent" SliderColor="Color.Primary"
            TabHeaderClass="dt-tab-header">





            @* ═══ Invoice Queue Tab ═══ *@


            <MudTabPanel Text="Invoice Queue" Icon="@Icons.Material.Outlined.Queue" BadgeData="@_queuedInvoices?.Count"


                BadgeColor="Color.Primary">


                @if (_isLoading)


                {


                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-2" Style="border-radius: 4px;" />


                }


                else if (_queuedInvoices == null || !_queuedInvoices.Any())


                {


                    <div class="d-flex flex-column align-center justify-center py-12">


                        <MudIcon Icon="@Icons.Material.Outlined.Inbox" Style="font-size: 3rem; color: var(--mud-palette-text-disabled);" />


                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-3">No queued invoices</MudText>


                        <MudText Typo="Typo.caption" Color="Color.Secondary">Desktop invoice submissions will appear here</MudText>


                    </div>


                }


                else


                {


                    <MudDataGrid T="InvoiceQueueStatusDto" Items="@_queuedInvoices" SortMode="SortMode.Multiple"


                        Filterable="true" Hover="true" Dense="true" Bordered="false"


                        RowStyle="font-size: 0.875rem;" HeaderStyle="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;"


                        RowClick="@((DataGridRowClickEventArgs<InvoiceQueueStatusDto> args) => ToggleInvoiceExpand(args.Item))">


                        <Columns>


                            <TemplateColumn Title="" Sortable="false" Filterable="false" CellStyle="width: 40px; padding: 4px 8px;">


                                <CellTemplate>


                                    <MudIconButton Icon="@(_expandedInvoiceId == context.Item.QueueId ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"


                                        Size="Size.Small"


                                        OnClick="@(() => ToggleInvoiceExpand(context.Item))" />


                                </CellTemplate>


                            </TemplateColumn>


                            <PropertyColumn Property="x => x.ExternalReference" Title="Reference">


                                <CellTemplate>


                                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.Item.ExternalReference</MudText>


                                </CellTemplate>


                            </PropertyColumn>


                            <PropertyColumn Property="x => x.CustomerCode" Title="Customer" />


                            <PropertyColumn Property="x => x.Status" Title="Status">


                                <CellTemplate>


                                    <span class="status-chip @GetStatusClass(context.Item.Status)">@context.Item.Status</span>


                                </CellTemplate>


                            </PropertyColumn>


                            <PropertyColumn Property="x => x.TotalAmount" Title="Amount" Format="N2">


                                <CellTemplate>


                                    <MudText Typo="Typo.body2" Style="font-variant-numeric: tabular-nums;">


                                        @context.Item.Currency @context.Item.TotalAmount.ToString("N2")


                                    </MudText>


                                </CellTemplate>


                            </PropertyColumn>


                            <PropertyColumn Property="x => x.SapDocNum" Title="SAP Doc#">


                                <CellTemplate>


                                    @if (context.Item.SapDocNum.HasValue)


                                    {


                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined"


                                            Style="font-size: 0.75rem;">@context.Item.SapDocNum</MudChip>


                                    }


                                    else


                                    {


                                        <MudText Typo="Typo.caption" Color="Color.Secondary">&mdash;</MudText>


                                    }


                                </CellTemplate>


                            </PropertyColumn>


                            <PropertyColumn Property="x => x.CreatedAt" Title="Created" Format="g">


                                <CellTemplate>


                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Item.CreatedAt.ToLocalTime().ToString("g")</MudText>


                                </CellTemplate>


                            </PropertyColumn>


                            <TemplateColumn Title="Actions" Sortable="false">


                                <CellTemplate>


                                    <MudStack Row="true" Spacing="0">


                                        @if (context.Item.CanRetry)


                                        {


                                            <MudTooltip Text="Retry">


                                                <MudIconButton Icon="@Icons.Material.Outlined.Replay" Size="Size.Small"


                                                    Color="Color.Primary" OnClick="@(() => RetryInvoice(context.Item))" />


                                            </MudTooltip>


                                        }


                                        @if (context.Item.CanCancel)


                                        {


                                            <MudTooltip Text="Cancel">


                                                <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"


                                                    Color="Color.Error" OnClick="@(() => CancelQueuedInvoice(context.Item))" />


                                            </MudTooltip>


                                        }


                                    </MudStack>


                                </CellTemplate>


                            </TemplateColumn>


                        </Columns>


                        <ChildRowContent>


                            @if (_expandedInvoiceId == context.Item.QueueId)


                            {


                                <td colspan="100">


                                    <div class="dt-expanded-row">


                                        <div class="dt-expanded-row__section-title">Invoice Details</div>


                                        <div class="dt-mini-grid">


                                            <div class="dt-mini-field">


                                                <div class="dt-mini-field__label">External Reference</div>


                                                <div class="dt-mini-field__value">@context.Item.ExternalReference</div>


                                            </div>


                                            <div class="dt-mini-field">


                                                <div class="dt-mini-field__label">Reservation ID</div>


                                                <div class="dt-mini-field__value">@(string.IsNullOrEmpty(context.Item.ReservationId) ? "—" : context.Item.ReservationId)</div>


                                            </div>


                                            <div class="dt-mini-field">


                                                <div class="dt-mini-field__label">Customer</div>


                                                <div class="dt-mini-field__value">@context.Item.CustomerCode</div>


                                            </div>


                                            <div class="dt-mini-field">


                                                <div class="dt-mini-field__label">Amount</div>


                                                <div class="dt-mini-field__value">@context.Item.Currency @context.Item.TotalAmount.ToString("N2")</div>


                                            </div>


                                            <div class="dt-mini-field">


                                                <div class="dt-mini-field__label">Warehouse</div>


                                                <div class="dt-mini-field__value">@(context.Item.WarehouseCode ?? "—")</div>


                                            </div>


                                            <div class="dt-mini-field">


                                                <div class="dt-mini-field__label">SAP Document</div>


                                                <div class="dt-mini-field__value">@(context.Item.SapDocNum?.ToString() ?? "Not yet posted")</div>


                                            </div>


                                            <div class="dt-mini-field">


                                                <div class="dt-mini-field__label">SAP Doc Entry</div>


                                                <div class="dt-mini-field__value">@(context.Item.SapDocEntry ?? "—")</div>


                                            </div>


                                            <div class="dt-mini-field">


                                                <div class="dt-mini-field__label">Source System</div>


                                                <div class="dt-mini-field__value">@context.Item.SourceSystem</div>


                                            </div>


                                            <div class="dt-mini-field">


                                                <div class="dt-mini-field__label">Status</div>


                                                <div class="dt-mini-field__value"><span class="status-chip @GetStatusClass(context.Item.Status)">@context.Item.Status</span></div>


                                            </div>


                                            <div class="dt-mini-field">


                                                <div class="dt-mini-field__label">Retry Count</div>


                                                <div class="dt-mini-field__value">@context.Item.RetryCount / @context.Item.MaxRetries</div>


                                            </div>


                                            <div class="dt-mini-field">


                                                <div class="dt-mini-field__label">Created</div>


                                                <div class="dt-mini-field__value">@context.Item.CreatedAt.ToLocalTime().ToString("F")</div>


                                            </div>


                                            @if (context.Item.ProcessingStartedAt.HasValue)


                                            {


                                                <div class="dt-mini-field">


                                                    <div class="dt-mini-field__label">Processing Started</div>


                                                    <div class="dt-mini-field__value">@context.Item.ProcessingStartedAt.Value.ToLocalTime().ToString("F")</div>


                                                </div>


                                            }


                                            @if (context.Item.ProcessedAt.HasValue)


                                            {


                                                <div class="dt-mini-field">


                                                    <div class="dt-mini-field__label">Processed At</div>


                                                    <div class="dt-mini-field__value">@context.Item.ProcessedAt.Value.ToLocalTime().ToString("F")</div>


                                                </div>


                                            }


                                            @if (context.Item.NextRetryAt.HasValue)


                                            {


                                                <div class="dt-mini-field">


                                                    <div class="dt-mini-field__label">Next Retry</div>


                                                    <div class="dt-mini-field__value">@context.Item.NextRetryAt.Value.ToLocalTime().ToString("g")</div>


                                                </div>


                                            }


                                            @if (!string.IsNullOrEmpty(context.Item.FiscalDeviceNumber))


                                            {


                                                <div class="dt-mini-field">


                                                    <div class="dt-mini-field__label">Fiscal Device</div>


                                                    <div class="dt-mini-field__value">@context.Item.FiscalDeviceNumber</div>


                                                </div>


                                            }


                                            @if (!string.IsNullOrEmpty(context.Item.FiscalReceiptNumber))


                                            {


                                                <div class="dt-mini-field">


                                                    <div class="dt-mini-field__label">Fiscal Receipt</div>


                                                    <div class="dt-mini-field__value">@context.Item.FiscalReceiptNumber</div>


                                                </div>


                                            }


                                            @if (context.Item.WaitTimeSeconds > 0)


                                            {


                                                <div class="dt-mini-field">


                                                    <div class="dt-mini-field__label">Wait Time</div>


                                                    <div class="dt-mini-field__value">@FormatWaitTime(context.Item.WaitTimeSeconds)</div>


                                                </div>


                                            }


                                        </div>


                                        @if (!string.IsNullOrEmpty(context.Item.LastError))


                                        {


                                            <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined" Class="mt-3"


                                                Style="border-radius: 8px; font-size: 0.8125rem;">


                                                <strong>Last Error:</strong> @context.Item.LastError


                                            </MudAlert>


                                        }


                                        <MudStack Row="true" Spacing="2" Class="mt-3">


                                            @if (context.Item.CanRetry)


                                            {


                                                <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary"


                                                    StartIcon="@Icons.Material.Outlined.Replay"


                                                    OnClick="@(() => RetryInvoice(context.Item))"


                                                    Style="border-radius: 6px; text-transform: none; font-weight: 600;">


                                                    Retry


                                                </MudButton>


                                            }


                                            @if (context.Item.CanCancel)


                                            {


                                                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Error"


                                                    StartIcon="@Icons.Material.Outlined.Close"


                                                    OnClick="@(() => CancelQueuedInvoice(context.Item))"


                                                    Style="border-radius: 6px; text-transform: none; font-weight: 600;">


                                                    Cancel


                                                </MudButton>


                                            }


                                        </MudStack>


                                    </div>


                                </td>


                            }


                        </ChildRowContent>


                    </MudDataGrid>


                }


            </MudTabPanel>





            @* ═══ Needs Review Tab ═══ *@


            <MudTabPanel Text="Needs Review" Icon="@Icons.Material.Outlined.ErrorOutline" BadgeData="@_reviewInvoices?.Count"


                BadgeColor="Color.Error">


                @if (_isLoading)


                {


                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-2" Style="border-radius: 4px;" />


                }


                else if (_reviewInvoices == null || !_reviewInvoices.Any())


                {


                    <div class="d-flex flex-column align-center justify-center py-12">


                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 3rem; color: #10b981;" />


                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-3">All clear</MudText>


                        <MudText Typo="Typo.caption" Color="Color.Secondary">No invoices require manual review</MudText>


                    </div>


                }


                else


                {


                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-4"


                        Style="border-radius: 8px;">


                        These invoices have failed multiple times and require manual intervention.


                    </MudAlert>


                    <MudDataGrid T="InvoiceQueueStatusDto" Items="@_reviewInvoices" SortMode="SortMode.Multiple" Hover="true"


                        Dense="true" Bordered="false"


                        RowClick="@((DataGridRowClickEventArgs<InvoiceQueueStatusDto> args) => ToggleInvoiceExpand(args.Item))">


                        <Columns>


                            <TemplateColumn Title="" Sortable="false" Filterable="false" CellStyle="width: 40px; padding: 4px 8px;">


                                <CellTemplate>


                                    <MudIconButton Icon="@(_expandedInvoiceId == context.Item.QueueId ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"


                                        Size="Size.Small"


                                        OnClick="@(() => ToggleInvoiceExpand(context.Item))" />


                                </CellTemplate>


                            </TemplateColumn>


                            <PropertyColumn Property="x => x.ExternalReference" Title="Reference">


                                <CellTemplate>


                                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.Item.ExternalReference</MudText>


                                </CellTemplate>


                            </PropertyColumn>


                            <PropertyColumn Property="x => x.CustomerCode" Title="Customer" />


                            <PropertyColumn Property="x => x.TotalAmount" Title="Amount">


                                <CellTemplate>


                                    <MudText Typo="Typo.body2" Style="font-variant-numeric: tabular-nums;">


                                        @context.Item.Currency @context.Item.TotalAmount.ToString("N2")


                                    </MudText>


                                </CellTemplate>


                            </PropertyColumn>


                            <PropertyColumn Property="x => x.LastError" Title="Last Error">


                                <CellTemplate>


                                    <MudTooltip Text="@context.Item.LastError">


                                        <MudText Typo="Typo.caption"


                                            Style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #ef4444;">


