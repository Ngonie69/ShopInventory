    private async Task ShowLinkedAccountsModal(CustomerPortalUser customer)
    {
        selectedCustomer = customer;
        linkedAccountMessage = null;
        linkedAccountBP = null;
        newLinkedAccountType = "Main";
        newLinkedAccountCurrency = null;
        newLinkedAccountParent = null;
        newLinkedAccountDesc = null;
        showLinkedAccountsModal = true;

        await LoadLinkedAccounts();
    }

    private void CloseLinkedAccountsModal()
    {
        showLinkedAccountsModal = false;
        selectedCustomer = null;
        linkedAccounts = null;
    }

    private async Task LoadLinkedAccounts()
    {
        if (selectedCustomer == null) return;

        try
        {
            linkedAccounts = await LinkedAccountService.GetLinkedAccountsAsync(selectedCustomer.CardCode);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading linked accounts");
            linkedAccountMessage = "Failed to load linked accounts.";
            linkedAccountMessageIsError = true;
        }
    }

    private async Task AddLinkedAccount()
    {
        if (selectedCustomer == null || linkedAccountBP == null)
        {
            linkedAccountMessage = "Please select a business partner.";
            linkedAccountMessageIsError = true;
            return;
        }

        if (newLinkedAccountType == "Sub" && string.IsNullOrEmpty(newLinkedAccountParent))
        {
            linkedAccountMessage = "Sub accounts must have a parent Main account selected.";
            linkedAccountMessageIsError = true;
            return;
        }

        isSaving = true;

        try
        {
            var request = new LinkedAccountRequest
            {
                CardCode = linkedAccountBP.CardCode,
                CardName = linkedAccountBP.CardName ?? "",
                AccountType = newLinkedAccountType,
                Currency = newLinkedAccountCurrency,
                ParentCardCode = newLinkedAccountType == "Sub" ? newLinkedAccountParent : null,
                Description = newLinkedAccountDesc
            };

            var result = await LinkedAccountService.AddLinkedAccountAsync(selectedCustomer.CardCode, request);

            if (result.Success)
            {
                linkedAccountMessage = result.Message;
                linkedAccountMessageIsError = false;
                linkedAccounts = result.LinkedAccounts;

                // Update the customer in the list
                selectedCustomer.AccountStructure = result.AccountStructure;

                // Reset form
                linkedAccountBP = null;
                newLinkedAccountType = "Main";
                newLinkedAccountCurrency = null;
                newLinkedAccountParent = null;
                newLinkedAccountDesc = null;
            }
            else
            {
                linkedAccountMessage = result.Message;
                linkedAccountMessageIsError = true;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error adding linked account");
            linkedAccountMessage = "Failed to add linked account.";
            linkedAccountMessageIsError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task RemoveLinkedAccount(string linkedCardCode)
    {
        if (selectedCustomer == null) return;

        isSaving = true;

        try
