@page "/customer-portal-management"
@using ShopInventory.Web.Models
@using ShopInventory.Web.Services
@using ShopInventory.Web.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@attribute [Authorize(Roles = "Admin")]
@inject IBusinessPartnerService BusinessPartnerService
@inject ICustomerLinkedAccountService LinkedAccountService
@inject IDbContextFactory<WebAppDbContext> DbContextFactory
@inject IJSRuntime JS
@inject ILogger<CustomerPortalManagement> Logger
@rendermode InteractiveServer

<PageTitle>Customer Portal Management - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .cpm-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Header ──────────────────────────────────────── */
    .cpm-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .cpm-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .cpm-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0d9488, #0f766e);
        box-shadow: 0 4px 14px rgba(13, 148, 136, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .cpm-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .cpm-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .btn-cpm-gradient {
        background: linear-gradient(135deg, #0d9488, #0f766e);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 2px 8px rgba(13, 148, 136, .25);
        cursor: pointer;
    }

    .btn-cpm-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(13, 148, 136, .4);
        color: #fff;
    }

    /* ── Stat Cards ───────────────────────────────────── */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .stat-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1rem 1.15rem;
        display: flex;
        align-items: center;
        gap: .85rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        transition: transform .15s, box-shadow .15s;
    }

    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 0, 0, .06);
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        flex-shrink: 0;
    }

    .stat-icon.total {
        background: #d1fae5;
        color: #059669;
    }

    .stat-icon.active {
        background: #dcfce7;
        color: #22c55e;
    }

    .stat-icon.inactive {
        background: #f3f4f6;
        color: #6b7280;
    }

    .stat-icon.locked {
        background: #fee2e2;
        color: #ef4444;
    }

    .stat-info .stat-value {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1.1;
    }

    .stat-info .stat-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
    }

    /* ── Filter Bar ──────────────────────────────────── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        align-items: flex-end;
        padding: 1rem 1.25rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .filter-bar .filter-field {
        flex: 1;
        min-width: 140px;
    }

    .filter-bar .filter-field label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .3rem;
    }

    .filter-bar .filter-field input,
    .filter-bar .filter-field select {
        width: 100%;
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        background: #fff;
        transition: all .15s;
    }

    .filter-bar .filter-field input:focus,
    .filter-bar .filter-field select:focus {
        outline: none;
        border-color: #0d9488;
        box-shadow: 0 0 0 3px rgba(13, 148, 136, .15);
    }

    .btn-filter {
        background: #fff;
        border: 1px solid #e5e7eb;
        color: #374151;
        padding: .5rem 1rem;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .85rem;
    }

    .btn-filter:hover {
        background: #f3f4f6;
        border-color: #d1d5db;
    }

    /* ── Table ────────────────────────────────────────── */
    .cpm-table-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .06);
        overflow: hidden;
    }

    .cpm-table {
        width: 100%;
        font-size: .85rem;
        border-collapse: separate;
        border-spacing: 0;
    }

    .cpm-table th {
        background: #f8fafc;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6b7280;
        font-weight: 600;
        padding: .7rem .85rem;
        border-bottom: 2px solid #e5e7eb;
        white-space: nowrap;
    }

    .cpm-table td {
        padding: .65rem .85rem;
        border-bottom: 1px solid #f3f4f6;
        vertical-align: middle;
        color: #374151;
    }

    .cpm-table tbody tr:hover {
        background: #f8fafb;
    }

    .cpm-table tbody tr:last-child td {
        border-bottom: none;
    }

    .cpm-code {
        font-family: 'SF Mono', 'Fira Code', monospace;
        background: #f3f4f6;
        padding: .15rem .45rem;
        border-radius: 4px;
        font-size: .82rem;
        font-weight: 500;
        color: #1f2937;
    }

    .cpm-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .55rem;
        border-radius: 6px;
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .3px;
    }

    .badge-active {
        background: #dcfce7;
        color: #166534;
    }

    .badge-inactive {
        background: #f3f4f6;
        color: #6b7280;
    }

    .badge-locked {
        background: #fee2e2;
        color: #991b1b;
    }

    .badge-multi {
        background: #dbeafe;
        color: #1e40af;
    }

    .badge-single {
        background: #f3f4f6;
        color: #6b7280;
    }

    .badge-enabled {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-disabled {
        background: #f9fafb;
        color: #9ca3af;
    }

    .cpm-actions {
        display: flex;
        gap: .3rem;
        justify-content: flex-end;
    }

    .cpm-action-btn {
        width: 30px;
        height: 30px;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .8rem;
        color: #374151;
        padding: 0;
        min-width: 30px !important;
    }

    .cpm-action-btn:hover {
        background: #f3f4f6;
        border-color: #d1d5db;
    }

    .cpm-action-btn.edit:hover {
        background: #eff6ff;
        border-color: #93c5fd;
        color: #2563eb;
    }

    .cpm-action-btn.key:hover {
        background: #fffbeb;
        border-color: #fcd34d;
        color: #d97706;
    }

    .cpm-action-btn.stmt:hover {
        background: #ecfdf5;
        border-color: #6ee7b7;
        color: #059669;
    }

    .cpm-action-btn.link:hover {
        background: #eef2ff;
        border-color: #a5b4fc;
        color: #6366f1;
    }

    .cpm-action-btn.unlock:hover {
        background: #f0fdf4;
        border-color: #86efac;
        color: #22c55e;
    }

    .cpm-action-btn.delete:hover {
        background: #fef2f2;
        border-color: #fca5a5;
        color: #dc2626;
    }

    /* ── Alert ────────────────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.success-alert {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    /* ── Empty State ─────────────────────────────────── */
    .cpm-empty {
        text-align: center;
        padding: 3rem 1rem;
        color: #9ca3af;
    }

    .cpm-empty-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: .75rem;
        color: #d1d5db;
    }

    .cpm-empty h5 {
        color: #6b7280;
        font-weight: 600;
        margin-bottom: .3rem;
    }

    .cpm-empty p {
        font-size: .85rem;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .cpm-header {
            flex-direction: column;
        }

        .stat-row {
            grid-template-columns: 1fr 1fr;
        }

        .filter-bar {
            flex-direction: column;
        }

        .cpm-actions {
            flex-wrap: wrap;
        }
    }
</style>

<div class="cpm-page">
    <div class="container-fluid" style="max-width: 1400px;">

        <!-- Header -->
        <div class="cpm-header">
            <div class="cpm-header-left">
                <div class="cpm-header-icon">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <h2>Customer Portal Management</h2>
                    <p>Manage customer portal access and credentials</p>
                </div>
            </div>
            <button class="btn-cpm-gradient" @onclick="ShowCreateModal">
                <i class="bi bi-plus-circle"></i> Add Customer Account
            </button>
        </div>

        <!-- Stats -->
        <div class="stat-row">
            <div class="stat-card">
                <div class="stat-icon total"><i class="bi bi-people-fill"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@totalAccounts</div>
                    <div class="stat-label">Total Accounts</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon active"><i class="bi bi-check-circle-fill"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@activeAccounts</div>
                    <div class="stat-label">Active</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon inactive"><i class="bi bi-x-circle-fill"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@inactiveAccounts</div>
                    <div class="stat-label">Inactive</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon locked"><i class="bi bi-lock-fill"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@lockedAccounts</div>
                    <div class="stat-label">Locked</div>
                </div>
            </div>
        </div>

        <!-- Alerts -->
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert-banner success-alert">
                <i class="bi bi-check-circle-fill"></i>
                <div style="flex:1;">@successMessage</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => successMessage = null)"
                               Size="Size.Small" Style="color:inherit;opacity:.45;" />
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner error-alert">
                <i class="bi bi-exclamation-octagon-fill"></i>
                <div style="flex:1;">@errorMessage</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => errorMessage = null)" Size="Size.Small"
                               Style="color:inherit;opacity:.45;" />
            </div>
        }

        <!-- Filter Bar -->
        <div class="filter-bar">
            <div class="filter-field" style="flex:2;">
                <label>Search</label>
                <input type="text" placeholder="Search by card code, name or email…" @bind="searchTerm"
                       @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
            </div>
            <div class="filter-field" style="flex:1;">
                <label>Status</label>
                <select @bind="statusFilter" @bind:after="LoadCustomers">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                    <option value="locked">Locked</option>
                </select>
            </div>
            <button class="btn-filter" @onclick="LoadCustomers" style="margin-bottom:1px;">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </div>

        <!-- Table -->
        <div class="cpm-table-card">
            @if (isLoading)
            {
                <div style="text-align:center; padding:3rem;">
                    <div class="spinner-border" style="color:#0d9488;" role="status"></div>
                    <p style="color:#6b7280; font-size:.88rem; margin-top:.75rem;">Loading customer accounts…</p>
                </div>
            }
            else if (customers == null || !customers.Any())
            {
                <div class="cpm-empty">
                    <div class="cpm-empty-icon"><i class="bi bi-people"></i></div>
                    <h5>No Customer Accounts</h5>
                    <p>Click "Add Customer Account" to create a new customer portal account.</p>
                </div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table class="cpm-table">
                        <thead>
                            <tr>
                                <th>Card Code</th>
                                <th>Customer Name</th>
                                <th>Email</th>
                                <th>Account Type</th>
                                <th>Statements</th>
                                <th>Status</th>
                                <th>2FA</th>
                                <th>Last Login</th>
                                <th>Created</th>
                                <th style="text-align:right;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var customer in customers)
                            {
                                <tr>
                                    <td><span class="cpm-code">@customer.CardCode</span></td>
                                    <td style="font-weight:500;">@customer.CardName</td>
                                    <td>@(customer.Email ?? "—")</td>
                                    <td>
                                        @if (customer.AccountStructure == "Multi")
                                        {
                                            <span class="cpm-badge badge-multi">
                                                <i class="bi bi-diagram-3"></i> Multi
                                            </span>
                                            <div style="font-size:.72rem; color:#9ca3af; margin-top:.15rem;">
                                                @(customer.LinkedAccounts?.Count ?? 0) linked
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="cpm-badge badge-single">Single</span>
                                        }
                                    </td>
                                    <td>
                                        @if (customer.ReceiveStatements)
                                        {
                                            <span class="cpm-badge badge-enabled">
                                                <i class="bi bi-bell-fill"></i> On
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="cpm-badge badge-disabled">Off</span>
                                        }
                                    </td>
                                    <td>
                                        @if (customer.LockedUntil.HasValue && customer.LockedUntil > DateTime.UtcNow)
                                        {
                                            <span class="cpm-badge badge-locked">
                                                <i class="bi bi-lock-fill"></i> Locked
                                            </span>
                                        }
                                        else if (customer.IsActive)
                                        {
                                            <span class="cpm-badge badge-active">
                                                <i class="bi bi-check-circle"></i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="cpm-badge badge-inactive">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        @if (customer.TwoFactorEnabled)
                                        {
                                            <span class="cpm-badge badge-enabled">
                                                <i class="bi bi-shield-check"></i> On
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="color:#d1d5db;">—</span>
                                        }
                                    </td>
                                    <td style="font-size:.82rem; color:#6b7280;">
                                        @(customer.LastLoginAt?.ToString("MMM dd, yyyy HH:mm") ?? "Never")
                                    </td>
                                    <td style="font-size:.82rem; color:#6b7280;">
                                        @customer.CreatedAt.ToString("MMM dd, yyyy")
                                    </td>
                                    <td>
                                        <div class="cpm-actions">
                                            <MudButton Class="cpm-action-btn edit" title="Edit"
                                                       OnClick="@(() => ShowEditModal(customer))">
                                                <i class="bi bi-pencil"></i>
                                            </MudButton>
                                            <MudButton Class="cpm-action-btn key" title="Reset Password"
                                                       OnClick="@(() => ShowResetPasswordModal(customer))">
                                                <i class="bi bi-key"></i>
                                            </MudButton>
                                            <MudButton Class="cpm-action-btn stmt" title="Toggle Statements"
                                                       OnClick="@(() => ToggleStatementPreference(customer))">
                                                <i
                                                class="bi @(customer.ReceiveStatements ? "bi-bell-fill" : "bi-bell-slash")"></i>
                                            </MudButton>
                                            <MudButton Class="cpm-action-btn link" title="Manage Linked Accounts"
                                                       OnClick="@(() => ShowLinkedAccountsModal(customer))">
                                                <i class="bi bi-diagram-3"></i>
                                            </MudButton>
                                            @if (customer.LockedUntil.HasValue && customer.LockedUntil > DateTime.UtcNow)
                                            {
                                                <MudButton Class="cpm-action-btn unlock" title="Unlock Account"
                                                           OnClick="@(() => UnlockAccount(customer))">
                                                    <i class="bi bi-unlock"></i>
                                                </MudButton>
                                            }
                                            <MudButton Class="cpm-action-btn delete" title="Delete"
                                                       OnClick="@(() => ShowDeleteConfirmation(customer))">
                                                <i class="bi bi-trash"></i>
                                            </MudButton>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Create/Edit Customer Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header" style="background: linear-gradient(135deg, #0d9488, #0f766e); color: white;">
                    <h5 class="modal-title">
                        <i class="bi bi-person-plus me-2"></i>
                        @(isEditing ? "Edit Customer Account" : "Create Customer Account")
                    </h5>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseModal" Size="Size.Small"
                                   Style="color: white;" />
                </div>
                <div class="modal-body">
                    <EditForm Model="@formModel" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />

                        @if (!isEditing)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Select Customer</label>
                                <MudAutocomplete T="CachedBusinessPartner" Label="Search by Card Code or Name"
                                                 @bind-Value="selectedBusinessPartner" SearchFunc="@SearchCustomersFromDbAsync"
                                                 ToStringFunc="@(bp => bp == null ? string.Empty : $"{bp.CardCode} - {bp.CardName}")"
                                                 ShowProgressIndicator="true" MinCharacters="1" Immediate="true" ResetValueOnEmptyText="true"
                                                 CoerceText="false" CoerceValue="false" Variant="Variant.Outlined" Dense="true"
                                                 Margin="Margin.Dense" Clearable="true" Style="width: 100%;" Class="customer-autocomplete"
                                                 DebounceInterval="300" MaxItems="15" AdornmentIcon="@Icons.Material.Filled.Search"
                                                 AdornmentColor="Color.Primary">
                                    <ItemTemplate Context="bp">
                                        <MudText>
                                            <b>@bp.CardCode</b> - @bp.CardName
                                            @if (!string.IsNullOrEmpty(bp.Email))
                                            {
                                                <MudText Typo="Typo.caption" Class="ms-2">(@bp.Email)</MudText>
                                            }
                                        </MudText>
                                    </ItemTemplate>
                                    <NoItemsTemplate>
                                        <MudText Class="px-3 py-2">
                                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="me-1" />
                                            No customers found
                                        </MudText>
                                    </NoItemsTemplate>
                                </MudAutocomplete>
                                <small class="text-muted">Type to search customers from the database</small>
                            </div>

                            <hr />
                        }

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Card Code <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" @bind="formModel.CardCode" readonly="@isEditing" />
                                <ValidationMessage For="@(() => formModel.CardCode)" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Customer Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" @bind="formModel.CardName" />
                                <ValidationMessage For="@(() => formModel.CardName)" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" @bind="formModel.Email" />
                            <ValidationMessage For="@(() => formModel.Email)" />
                        </div>

                        @if (!isEditing)
                        {
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Password <span class="text-danger">*</span></label>
                                    <div class="input-group">
