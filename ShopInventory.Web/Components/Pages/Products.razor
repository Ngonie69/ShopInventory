@page "/products"
@using Microsoft.AspNetCore.Authorization
@using ShopInventory.Web.Services
@attribute [Authorize]
@implements IDisposable
@inject IProductService ProductService
@inject IMasterDataCacheService MasterDataCache
@inject ILogger<Products> Logger
@inject IAppSettingsProvider AppSettings
@inject IAuditService AuditService
@rendermode InteractiveServer

<PageTitle>Products - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .prod-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Header ──────────────────────────────────────── */
    .prod-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .prod-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .prod-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .prod-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .prod-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .header-chips {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .header-chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .3rem .7rem;
        border-radius: 8px;
        font-size: .78rem;
        font-weight: 600;
    }

    .header-chip.primary {
        background: #ede9fe;
        color: #7c3aed;
    }

    .header-chip.info {
        background: #dbeafe;
        color: #2563eb;
    }

    /* ── Stat Cards ───────────────────────────────────── */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .stat-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1rem 1.15rem;
        display: flex;
        align-items: center;
        gap: .85rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        transition: transform .15s, box-shadow .15s;
    }

    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 0, 0, .06);
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        flex-shrink: 0;
    }

    .stat-icon.total {
        background: #ede9fe;
        color: #7c3aed;
    }

    .stat-icon.batches {
        background: #dbeafe;
        color: #2563eb;
    }

    .stat-icon.warehouse {
        background: #d1fae5;
        color: #059669;
    }

    .stat-info .stat-value {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1.1;
        font-family: 'Space Grotesk', monospace;
    }

    .stat-info .stat-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
    }

    /* ── Search Card ─────────────────────────────────── */
    .search-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .search-card-header {
        padding: .75rem 1.25rem;
        background: linear-gradient(135deg, #667eea, #764ba2);
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .search-card-header span {
        color: #fff;
        font-weight: 600;
        font-size: .88rem;
    }

    .search-card-header i {
        color: rgba(255, 255, 255, .8);
        font-size: .95rem;
    }

    .search-card-body {
        padding: 1.25rem;
    }

    .search-grid {
        display: grid;
        grid-template-columns: 2fr 1fr auto;
        gap: .85rem;
        align-items: flex-end;
    }

    .search-field {
        display: flex;
        flex-direction: column;
    }

    .search-field label {
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .3rem;
    }

    .search-field select,
    .search-field input {
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        background: #fff;
        transition: all .15s;
    }

    .search-field select:focus,
    .search-field input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .search-actions {
        display: flex;
        gap: .5rem;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .btn-search {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-search:hover {
        opacity: .92;
        transform: translateY(-1px);
    }

    .btn-search:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    .btn-scan {
        background: #059669;
        color: #fff;
        border: none;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-scan:hover {
        opacity: .92;
        transform: translateY(-1px);
    }

    .btn-scan:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    .btn-cancel {
        background: #dc2626;
        color: #fff;
        border: none;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-clear {
        background: #fff;
        color: #6b7280;
        border: 1px solid #d1d5db;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-clear:hover {
        background: #f3f4f6;
    }

    /* ── Quick Filter ────────────────────────────────── */
    .quick-filter-bar {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: .75rem;
    }

    .quick-filter-input {
        flex: 1;
        max-width: 280px;
        padding: .45rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .85rem;
        color: #374151;
        transition: all .15s;
    }

    .quick-filter-input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .quick-filter-input::placeholder {
        color: #9ca3af;
    }

    /* ── Table ───────────────────────────────────────── */
    .prod-table-wrap {
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #fff;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .prod-table-header {
        padding: .85rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
    }

    .prod-table-header h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .92rem;
    }

    .prod-count-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #374151;
    }

    /* ── Cell Styles ─────────────────────────────────── */
    .item-code {
        font-weight: 700;
        color: #667eea;
        font-family: 'Space Grotesk', monospace;
        font-size: .85rem;
        white-space: nowrap;
    }

    .item-name {
        font-size: .875rem;
        color: #1a1a2e;
    }

    .qty-cell {
        font-weight: 600;
        font-family: 'Space Grotesk', monospace;
        font-size: .875rem;
    }

    .qty-cell.available {
        color: #059669;
    }

    .qty-cell.committed {
        color: #e65100;
    }

    .qty-cell.zero {
        color: #9ca3af;
    }

    .uom-badge {
        display: inline-flex;
        padding: .15rem .5rem;
        border-radius: 6px;
        font-size: .72rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #6b7280;
        border: 1px solid #e5e7eb;
    }

    /* ── Action Buttons ──────────────────────────────── */
    .action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .85rem;
    }

    .action-btn:hover {
        background: #ede9fe;
        color: #667eea;
        border-color: #c4b5fd;
    }

    /* ── Drawer ──────────────────────────────────────── */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        z-index: 9998;
        animation: fadeIn .2s ease;
    }

    .detail-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(640px, 95vw);
        height: 100vh;
        background: #fff;
        z-index: 9999;
        box-shadow: -8px 0 30px rgba(0, 0, 0, .12);
        display: flex;
        flex-direction: column;
        animation: slideInRight .25s ease;
    }

    .drawer-header {
        padding: 1.15rem 1.5rem;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        display: flex;
        flex-direction: column;
        gap: .5rem;
        flex-shrink: 0;
    }

    .drawer-header-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .drawer-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .drawer-header .btn-close-drawer {
        background: rgba(255, 255, 255, .15);
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s;
        font-size: 1rem;
    }

    .drawer-header .btn-close-drawer:hover {
        background: rgba(255, 255, 255, .25);
    }

    .drawer-header-chips {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
    }

    .drawer-chip {
        display: inline-flex;
        padding: .2rem .55rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
        background: rgba(255, 255, 255, .2);
        color: #fff;
    }

    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .drawer-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    /* Stock level cards */
    .stock-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .75rem;
        margin-bottom: 1.5rem;
    }

    .stock-card {
        border-radius: 10px;
        padding: .85rem;
        text-align: center;
    }

    .stock-card.in-stock {
        background: #f3f4f6;
    }

    .stock-card.available {
        background: #d1fae5;
    }

    .stock-card.committed {
        background: #fff7ed;
    }

    .stock-card .stock-card-icon {
        font-size: 1.2rem;
        margin-bottom: .25rem;
    }

    .stock-card .stock-card-label {
        font-size: .68rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6b7280;
    }

    .stock-card .stock-card-value {
        font-size: 1.3rem;
        font-weight: 700;
        font-family: 'Space Grotesk', monospace;
    }

    .stock-card.in-stock .stock-card-value {
        color: #374151;
    }

    .stock-card.available .stock-card-value {
        color: #059669;
    }

    .stock-card.committed .stock-card-value {
        color: #e65100;
    }

    /* Batch section */
    .batch-section-title {
        font-weight: 600;
        color: #1a1a2e;
        font-size: .9rem;
        margin-bottom: .75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .batch-count-chip {
        display: inline-flex;
        padding: .15rem .55rem;
        border-radius: 6px;
        font-size: .73rem;
        font-weight: 600;
        background: #dbeafe;
        color: #2563eb;
    }

    .batch-table {
        width: 100%;
        font-size: .85rem;
        border-collapse: separate;
        border-spacing: 0;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        overflow: hidden;
    }

    .batch-table th {
        background: #f8fafc;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6b7280;
        font-weight: 600;
        padding: .6rem .75rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .batch-table td {
        padding: .55rem .75rem;
        border-bottom: 1px solid #f3f4f6;
        color: #374151;
    }

    .batch-table tr:last-child td {
        border-bottom: none;
    }

    .batch-table tfoot td {
        border-top: 2px solid #e5e7eb;
        background: #eef2ff;
    }

    .batch-number {
        font-weight: 700;
        color: #667eea;
    }

    .batch-status {
        display: inline-flex;
        padding: .15rem .5rem;
        border-radius: 6px;
        font-size: .72rem;
        font-weight: 600;
    }

    .batch-status.released {
        background: #d1fae5;
        color: #065f46;
    }

    .batch-status.not-accessible {
        background: #fef3c7;
        color: #92400e;
    }

    .batch-status.locked {
        background: #fee2e2;
        color: #991b1b;
    }

    .batch-status.default {
        background: #f3f4f6;
        color: #6b7280;
    }

    /* No batch state */
    .no-batches {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 1.5rem;
        text-align: center;
    }

    .no-batches i {
        font-size: 1.5rem;
        color: #9ca3af;
        margin-bottom: .5rem;
        display: block;
    }

    .no-batches p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .btn-secondary-action {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .15s;
    }

    .btn-secondary-action:hover {
        background: #f9fafb;
    }

    /* ── Alert ───────────────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .alert-banner.warn-alert {
        background: #fffbeb;
        border: 1px solid #fde68a;
        color: #92400e;
    }

    .alert-banner.info-alert {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1e40af;
    }

    .btn-retry {
        background: #fff;
        border: 1px solid currentColor;
        color: inherit;
        padding: .3rem .75rem;
        border-radius: 6px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        margin-left: .5rem;
    }

    /* ── Empty / Loading / Initial ────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 1.8rem;
        color: #9ca3af;
    }

    .empty-state h6 {
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
    }

    .empty-state p {
        color: #9ca3af;
        font-size: .88rem;
    }

    .loading-state {
        text-align: center;
        padding: 3rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    .initial-state {
        text-align: center;
        padding: 3.5rem 1.5rem;
        background: #fff;
        border: 2px dashed #d1d5db;
        border-radius: 12px;
    }

    .initial-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(102, 126, 234, .1), rgba(118, 75, 162, .1));
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 1.8rem;
        color: #667eea;
    }

    .initial-state h6 {
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
    }

    .initial-state p {
        color: #9ca3af;
        font-size: .88rem;
        max-width: 350px;
        margin: 0 auto;
    }

    .btn-small-action {
        background: #fff;
        border: 1px solid #d1d5db;
        padding: .35rem .8rem;
        border-radius: 6px;
        font-size: .82rem;
        font-weight: 600;
        cursor: pointer;
        color: #374151;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        transition: all .15s;
    }

    .btn-small-action:hover {
        background: #f3f4f6;
        border-color: #9ca3af;
    }

    .btn-small-primary {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        padding: .35rem .8rem;
        border-radius: 6px;
        font-size: .82rem;
        font-weight: 600;
        cursor: pointer;
        color: #fff;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        transition: all .2s;
    }

    .btn-small-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(102, 126, 234, .3);
    }

    /* ── Animations ──────────────────────────────────── */
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }

        to {
            transform: translateX(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width:768px) {
        .prod-header {
            flex-direction: column;
        }

        .search-grid {
            grid-template-columns: 1fr;
        }

        .stat-row {
            grid-template-columns: 1fr 1fr;
        }

        .stock-cards {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="prod-page">
    <div class="container-fluid">

        <!-- ━━━ Header ━━━ -->
        <div class="prod-header">
            <div class="prod-header-left">
                <div class="prod-header-icon"><i class="bi bi-box-seam"></i></div>
                <div>
                    <h2>Products</h2>
                    <p>Browse and search inventory across warehouses</p>
                </div>
            </div>
            @if (products?.Any() == true)
            {
                <div class="header-chips">
                    <span class="header-chip primary"><i class="bi bi-box-seam"></i> @totalProducts products</span>
                    @if (productsWithBatches > 0)
                    {
                        <span class="header-chip info"><i class="bi bi-layers"></i> @productsWithBatches with batches</span>
                    }
                </div>
            }
        </div>

        <!-- ━━━ Alerts ━━━ -->
        @if (errorMessage != null)
        {
            <div class="alert-banner @GetAlertCssClass()">
                <i class="bi @GetAlertIcon()"></i>
                <div style="flex:1;">
                    @errorMessage
                    @if (errorSeverity == Severity.Error || errorSeverity == Severity.Warning)
                    {
                        <MudButton Class="btn-retry" OnClick="SearchProducts"><i class="bi bi-arrow-clockwise"></i> Retry
                        </MudButton>
                    }
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Style="background:none;border:none;color:inherit;opacity:.45;cursor:pointer;font-size:1rem;"
                               OnClick="() => errorMessage = null" />
            </div>
        }

        <!-- ━━━ Stat Cards ━━━ -->
        @if (products?.Any() == true)
        {
            <div class="stat-row">
                <div class="stat-card">
                    <div class="stat-icon total"><i class="bi bi-box-seam"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@totalProducts</div>
                        <div class="stat-label">Total Products</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon batches"><i class="bi bi-layers"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@productsWithBatches</div>
                        <div class="stat-label">With Batches</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon warehouse"><i class="bi bi-building"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@(selectedWarehouse?.WarehouseCode ?? "—")</div>
                        <div class="stat-label">Warehouse</div>
                    </div>
                </div>
            </div>
        }

        <!-- ━━━ Search Card ━━━ -->
        <div class="search-card">
            <div class="search-card-header">
                <i class="bi bi-funnel"></i>
                <span>Search & Filter</span>
            </div>
            <div class="search-card-body">
                <div class="search-grid">
                    <div class="search-field">
                        <label>Warehouse <span style="color:#dc2626;">*</span></label>
                        @if (isLoadingWarehouses)
                        {
                            <div
                                style="padding:.5rem;color:#6b7280;font-size:.85rem;display:flex;align-items:center;gap:.5rem;">
                                <span class="spinner-border spinner-border-sm" style="color:#667eea;"></span> Loading
                                warehouses...
                            </div>
                        }
                        else
                        {
                            <MudAutocomplete T="WarehouseDto" @bind-Value="selectedWarehouse" Label="Search warehouse..."
                                             SearchFunc="SearchWarehousesAsync"
                                             ToStringFunc="@(w => w == null ? string.Empty : $"{w.WarehouseCode} - {w.WarehouseName}")"
                                             Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense" ResetValueOnEmptyText="true"
                                             ShowProgressIndicator="true" MaxItems="20" DebounceInterval="150" Class="mt-0">
                                <ItemTemplate>
                                    <div style="display:flex;flex-direction:column;">
                                        <span style="font-weight:600;">@context.WarehouseCode</span>
                                        <small style="color:#9ca3af;">@context.WarehouseName</small>
                                    </div>
                                </ItemTemplate>
                                <NoItemsTemplate>
                                    <div style="padding:.5rem;color:#9ca3af;font-size:.85rem;">
                                        <i class="bi bi-info-circle me-1"></i>No warehouses found
                                    </div>
                                </NoItemsTemplate>
                            </MudAutocomplete>
                        }
                    </div>
                    <div class="search-field">
                        <label>Barcode</label>
                        <input type="text" @bind="barcode" placeholder="Scan or enter barcode" />
                    </div>
                    <div class="search-actions">
                        @if (isLoading)
                        {
                            <MudButton Class="btn-search" Disabled="true">
                                <span class="spinner-border spinner-border-sm"></span> Searching...
                            </MudButton>
                            <MudButton Class="btn-cancel" OnClick="CancelSearch">
                                <i class="bi bi-x-circle"></i> Cancel
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Class="btn-search" OnClick="SearchProducts" Disabled="@(selectedWarehouse == null)">
                                <i class="bi bi-search"></i> Search
                            </MudButton>
                            @if (!string.IsNullOrWhiteSpace(barcode))
                            {
                                <MudButton Class="btn-scan" OnClick="SearchByBarcode" Disabled="@(selectedWarehouse == null)">
                                    <i class="bi bi-upc-scan"></i> Scan
                                </MudButton>
                            }
                            <MudButton Class="btn-clear" OnClick="ClearSearch">
                                <i class="bi bi-x-circle"></i> Clear
                            </MudButton>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ━━━ Content ━━━ -->
        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner-border" style="color:#667eea;width:2.5rem;height:2.5rem;" role="status"></div>
                <p style="margin-top:.75rem;color:#1a1a2e;font-weight:600;">Loading products...</p>
                <p style="color:#6b7280;font-size:.85rem;">Fetching inventory for
                    <strong>@selectedWarehouse?.WarehouseCode</strong>
                </p>
                @if (_loadingElapsedSeconds > 5)
                {
                    <p style="color:#9ca3af;font-size:.8rem;margin-top:.5rem;">This is taking longer than usual
                        (@_loadingElapsedSeconds seconds)...</p>
                    }
                    @if (_loadingElapsedSeconds > 15)
                    {
                        <MudButton Class="btn-cancel" Style="margin-top:.75rem;" OnClick="CancelSearch">
                            <i class="bi bi-x-circle"></i> Cancel search
                        </MudButton>
                    }
                </div>
            }
        else if (products?.Any() == true)
            {
                <div class="prod-table-wrap">
                    <div class="prod-table-header">
                        <h6><i class="bi bi-building"></i> @selectedWarehouse?.WarehouseCode <span
                            style="font-weight:400;color:#6b7280;margin-left:.3rem;">@selectedWarehouse?.WarehouseName</span>
                        </h6>
                        <div style="display:flex;align-items:center;gap:.75rem;">
                            <input type="text" class="quick-filter-input" placeholder="Quick filter..." @bind="_searchString"
                                   @bind:event="oninput" />
                            <span class="prod-count-badge">@totalProducts products</span>
                        </div>
                    </div>
                    <MudTable @ref="@_table" Items="@products" RowsPerPage="@_pageSize" Hover="true" Striped="true" Dense="true"
                              Filter="new Func<ProductDto, bool>(_quickFilter)" OnRowClick="@OnRowClicked" T="ProductDto"
                              Elevation="0" Style="background:transparent;">
                        <HeaderContent>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<ProductDto, object>(x => x.ItemCode ?? string.Empty)">Item
                                    Code</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<ProductDto, object>(x => x.ItemName ?? string.Empty)">Item
                                        Name</MudTableSortLabel>
                                    </MudTh>
                                    <MudTh Style="text-align:right">
                                        <MudTableSortLabel SortBy="new Func<ProductDto, object>(x => x.QuantityInStock)">In Stock
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh Style="text-align:right">
                                        <MudTableSortLabel SortBy="new Func<ProductDto, object>(x => x.QuantityAvailable)">Available
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh Style="text-align:right">
                                        <MudTableSortLabel SortBy="new Func<ProductDto, object>(x => x.QuantityCommitted)">Committed
                                        </MudTableSortLabel>
                                    </MudTh>
                                    <MudTh>UoM</MudTh>
                                    <MudTh Style="width:50px"></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Item Code"><span class="item-code">@context.ItemCode</span></MudTd>
                                    <MudTd DataLabel="Item Name"><span class="item-name">@context.ItemName</span></MudTd>
                                    <MudTd DataLabel="In Stock" Style="text-align:right">
                                        <span class="qty-cell">@FormatQuantity(context.QuantityInStock, context.UoM)</span>
                                    </MudTd>
                                    <MudTd DataLabel="Available" Style="text-align:right">
                                        <span
                                            class="qty-cell @(context.QuantityAvailable > 0 ? "available" : "zero")">@FormatQuantity(context.QuantityAvailable,
                                                                                                                    context.UoM)</span>
                                        </MudTd>
                                        <MudTd DataLabel="Committed" Style="text-align:right">
                                            <span
                                                class="qty-cell @(context.QuantityCommitted > 0 ? "committed" : "zero")">@FormatQuantity(context.QuantityCommitted,
                                                                                                                            context.UoM)</span>
                                            </MudTd>
                                            <MudTd DataLabel="UoM"><span class="uom-badge">@context.UoM</span></MudTd>
                                            <MudTd>
                                                <MudButton Class="action-btn" OnClick="() => ViewProduct(context)" title="View details">
                                                    <i class="bi bi-chevron-right"></i>
                                                </MudButton>
                                            </MudTd>
                                        </RowTemplate>
                                        <PagerContent>
                                            <div class="pager-row">
                                                <div class="page-size-wrap">
                                                    <span>Show</span>
                                                    <select @bind="_pageSize">
                                                        <option value="10">10</option>
                                                        <option value="25">25</option>
                                                        <option value="50">50</option>
                                                        <option value="100">100</option>
                                                    </select>
                                                    <span>per page</span>
                                                </div>
                                                <MudPagination SelectedChanged="PageChanged"
                                                               Count="@((_table.GetFilteredItemsCount() + _table.RowsPerPage - 1) / _table.RowsPerPage)"
                                                               Class="pa-4" />
                                            </div>
                                        </PagerContent>
                                    </MudTable>
                                </div>
                            }
        else if (_hasSearched && !isLoading)
                            {
                                <div class="empty-state">
                                    <div class="empty-icon"><i class="bi bi-inbox"></i></div>
                                    <h6>No products found</h6>
                                    <p>No products found in warehouse <strong>@selectedWarehouse?.WarehouseCode</strong>. Try a different
                                        warehouse or check your connection.</p>
                                        <div style="display:flex;gap:.5rem;justify-content:center;margin-top:1rem;">
                                            <MudButton Class="btn-small-primary" OnClick="SearchProducts"><i class="bi bi-arrow-clockwise"></i>
                                                Retry</MudButton>
                                                <MudButton Class="btn-small-action" OnClick="ClearSearch"><i class="bi bi-x-circle"></i> Reset
                                                </MudButton>
                                            </div>
                                        </div>
                                    }
        else if (!isLoading)
                                    {
                                        <div class="initial-state">
                                            <div class="initial-icon"><i class="bi bi-search"></i></div>
                                            <h6>Search Products</h6>
                                            <p>Select a warehouse above and click <strong>Search</strong> to browse inventory.</p>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- ━━━ Product Detail Drawer ━━━ -->
                            @if (selectedProduct != null)
                            {
                                <div class="modal-backdrop-custom" @onclick="CloseModal"></div>
                                <div class="detail-drawer">
                                    <div class="drawer-header">
                                        <div class="drawer-header-top">
                                            <h5>@selectedProduct.ItemName</h5>
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="btn-close-drawer" OnClick="CloseModal" />
                                        </div>
                                        <div class="drawer-header-chips">
                                            <span class="drawer-chip">@selectedProduct.ItemCode</span>
                                            @if (!string.IsNullOrWhiteSpace(selectedProduct.BarCode))
                                            {
                                                <span class="drawer-chip" style="font-family:'Space Grotesk',monospace;">@selectedProduct.BarCode</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(selectedProduct.UoM))
                                            {
                                                <span class="drawer-chip">@selectedProduct.UoM</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="drawer-body">
                                        <!-- Stock Level Cards -->
                                        <div class="stock-cards">
                                            <div class="stock-card in-stock">
                                                <div class="stock-card-icon"><i class="bi bi-archive"></i></div>
                                                <div class="stock-card-label">In Stock</div>
                                                <div class="stock-card-value">@FormatQuantity(selectedProduct.QuantityInStock, selectedProduct.UoM)
                                                </div>
                                            </div>
                                            <div class="stock-card available">
                                                <div class="stock-card-icon"><i class="bi bi-check-circle"></i></div>
                                                <div class="stock-card-label">Available</div>
                                                <div class="stock-card-value">@FormatQuantity(selectedProduct.QuantityAvailable, selectedProduct.UoM)
                                                </div>
                                            </div>
                                            <div class="stock-card committed">
                                                <div class="stock-card-icon"><i class="bi bi-clock-history"></i></div>
                                                <div class="stock-card-label">Committed</div>
                                                <div class="stock-card-value">@FormatQuantity(selectedProduct.QuantityCommitted, selectedProduct.UoM)
                                                </div>
                                            </div>
                                        </div>

                                        @if (selectedProduct.ManagesBatches && selectedProduct.Batches?.Any() == true)
                                        {
                                            <div class="batch-section-title">
                                                <span><i class="bi bi-layers me-2"></i>Batch Information</span>
                                                <span class="batch-count-chip">@selectedProduct.Batches.Count batches</span>
                                            </div>

                                            <table class="batch-table">
                                                <thead>
                                                    <tr>
                                                        <th>Batch #</th>
                                                        <th style="text-align:right">Quantity</th>
                                                        <th>Status</th>
                                                        <th>Expiry</th>
                                                        <th>Manufacturing</th>
                                                        <th>Location</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var batch in selectedProduct.Batches)
                                                    {
                                                        <tr>
                                                            <td><span class="batch-number">@batch.BatchNumber</span></td>
                                                            <td style="text-align:right;font-weight:600;">@batch.Quantity</td>
                                                            <td>
                                                                <span class="batch-status @GetBatchStatusCssClass(batch.Status)">@batch.Status</span>
                                                            </td>
                                                            <td style="color:#6b7280;">@batch.ExpiryDate</td>
                                                            <td style="color:#6b7280;">@batch.ManufacturingDate</td>
                                                            <td style="color:#6b7280;">@batch.Location</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                                <tfoot>
                                                    <tr>
                                                        <td style="font-weight:700;color:#667eea;">Total</td>
                                                        <td style="text-align:right;font-weight:700;color:#667eea;">@selectedProduct.Batches.Sum(b =>
                                                                                                                                                                                                                                                                                                                                                                                                                        b.Quantity)</td>
                                                            <td colspan="4"></td>
                                                        </tr>
                                                    </tfoot>
                                                </table>
                                            }
        else if (selectedProduct.ManagesBatches)
                                            {
                                                <div class="no-batches">
                                                    <i class="bi bi-layers"></i>
                                                    <p>This product manages batches, but no batches were found.</p>
                                                </div>
                                            }
                                        </div>
                                        <div class="drawer-footer">
                                            <MudButton Class="btn-secondary-action" OnClick="CloseModal">Close</MudButton>
                                        </div>
                                    </div>
                                }

@code {
    private MudTable<ProductDto> _table = null!;
    private int _pageSize = 10;
    private List<ProductDto>? products;
    private ProductDto? selectedProduct;
    private bool isLoading = false;
    private string? errorMessage;
    private Severity errorSeverity = Severity.Error;
    private int currentPage = 1;
    private int pageSize = 20;
#pragma warning disable CS0414
    private bool hasMore = false;
#pragma warning restore CS0414
    private int totalProducts = 0;
    private int totalPages => pageSize > 0 ? (int)Math.Ceiling((double)totalProducts / pageSize) : 1;
    private int productsWithBatches = 0;
    private bool _hasSearched = false;

    private string? barcode;
    private string _searchString = string.Empty;

    // Warehouse selection
    private List<WarehouseDto> warehouses = new();
    private WarehouseDto? selectedWarehouse;
    private bool isLoadingWarehouses = true;
    private bool _hasLoadedData = false;

    // Cancellation & timing
    private CancellationTokenSource? _searchCts;
    private int _loadingElapsedSeconds = 0;
    private System.Threading.Timer? _loadingTimer;

    // Quick filter
    private Func<ProductDto, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (x.ItemCode?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (x.ItemName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (x.BarCode?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (x.ItemType?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (x.UoM?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        return false;
    };

    private void OnRowClicked(TableRowClickEventArgs<ProductDto> args)
    {
        if (args.Item is not null)
            ViewProduct(args.Item);
    }

    private void PageChanged(int i)
    {
        _table.NavigateTo(i - 1);
    }

    protected override void OnInitialized()
    {
        _pageSize = AppSettings.PageSize;
        pageSize = AppSettings.PageSize;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasLoadedData)
        {
            Logger.LogInformation("Products page: OnAfterRenderAsync - firstRender, starting data load");
            _hasLoadedData = true;
            await LoadWarehousesAsync();
            await AuditService.LogAsync(AuditActions.ViewProducts, "Product", null);
            StateHasChanged();
        }
    }

    private async Task LoadWarehousesAsync()
    {
        Logger.LogInformation("Products page: LoadWarehousesAsync started");
        isLoadingWarehouses = true;
        try
        {
            warehouses = await MasterDataCache.GetWarehousesAsync();
            Logger.LogInformation("Products page: Loaded {Count} warehouses", warehouses?.Count ?? 0);

            if (warehouses?.Any() == true)
            {
                var defaultWarehouse = warehouses.FirstOrDefault(w => w.WarehouseCode == "01")
                ?? warehouses.First();
                selectedWarehouse = defaultWarehouse;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Products page: Failed to load warehouses");
            errorMessage = $"Failed to load warehouses: {ex.Message}";
            errorSeverity = Severity.Error;
        }
        finally
        {
            isLoadingWarehouses = false;
        }
    }

    private async Task<IEnumerable<WarehouseDto>> SearchWarehousesAsync(string searchText, CancellationToken
    cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(searchText))
            return warehouses.Take(20);

        return warehouses
        .Where(w =>
        (w.WarehouseCode?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (w.WarehouseName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false))
        .Take(20);
    }

    private void StartLoadingTimer()
    {
        _loadingElapsedSeconds = 0;
        _loadingTimer?.Dispose();
        _loadingTimer = new System.Threading.Timer(async _ =>
        {
            _loadingElapsedSeconds++;
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void StopLoadingTimer()
    {
        _loadingTimer?.Dispose();
        _loadingTimer = null;
        _loadingElapsedSeconds = 0;
    }

    private void CancelSearch()
    {
        _searchCts?.Cancel();
        isLoading = false;
        StopLoadingTimer();
        errorMessage = "Search was cancelled.";
        errorSeverity = Severity.Info;
    }

    private async Task SearchProducts()
    {
        if (selectedWarehouse == null)
            return;

        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource(TimeSpan.FromSeconds(90));

        isLoading = true;
        _hasSearched = true;
        errorMessage = null;
        StartLoadingTimer();

        try
        {
            var response = await ProductService.GetProductsInWarehouseAsync(
            selectedWarehouse.WarehouseCode!);

            _searchCts?.Token.ThrowIfCancellationRequested();

            if (response?.Products != null && response.Products.Any())
            {
                products = response.Products;
                totalProducts = response.TotalProducts;
                productsWithBatches = products.Count(p => p.ManagesBatches);
                hasMore = false;
            }
            else if (response != null)
            {
                products = new List<ProductDto>();
                totalProducts = 0;
                productsWithBatches = 0;
            }
            else
            {
                products = new List<ProductDto>();
                totalProducts = 0;
                errorMessage = "No data returned. The warehouse may be empty or the server may be unavailable. Try again.";
                errorSeverity = Severity.Warning;
            }
        }
        catch (OperationCanceledException)
        {
            products = null;
            errorMessage = "Search timed out. The server is taking too long to respond. Please try again.";
            errorSeverity = Severity.Warning;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error searching products in warehouse {WarehouseCode}", selectedWarehouse.WarehouseCode);
            products = null;
            errorMessage = $"Failed to load products: {ex.Message}";
            errorSeverity = Severity.Error;
        }
        finally
        {
            isLoading = false;
            StopLoadingTimer();
        }
    }

    private async Task SearchByBarcode()
    {
        if (selectedWarehouse == null || string.IsNullOrWhiteSpace(barcode))
            return;

        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource(TimeSpan.FromSeconds(60));

        isLoading = true;
        _hasSearched = true;
        errorMessage = null;
        StartLoadingTimer();

        try
        {
            var product = await ProductService.SearchProductByBarcodeAsync(barcode, selectedWarehouse.WarehouseCode!);

            _searchCts?.Token.ThrowIfCancellationRequested();

            if (product != null)
            {
                products = new List<ProductDto> { product };
                totalProducts = 1;
                productsWithBatches = product.ManagesBatches ? 1 : 0;
                hasMore = false;
            }
            else
            {
                products = new List<ProductDto>();
                errorMessage = $"No product found with barcode \"{barcode}\" in warehouse {selectedWarehouse.WarehouseCode}.";
                errorSeverity = Severity.Warning;
            }
        }
        catch (OperationCanceledException)
        {
            products = null;
            errorMessage = "Barcode search timed out. Please try again.";
            errorSeverity = Severity.Warning;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error searching barcode {Barcode}", barcode);
            errorMessage = $"Error: {ex.Message}";
            errorSeverity = Severity.Error;
        }
        finally
        {
            isLoading = false;
            StopLoadingTimer();
        }
    }

    private void ClearSearch()
    {
        _searchCts?.Cancel();

        if (warehouses?.Any() == true)
        {
            var defaultWarehouse = warehouses.FirstOrDefault(w => w.WarehouseCode == "01")
            ?? warehouses.First();
            selectedWarehouse = defaultWarehouse;
        }
        else
        {
            selectedWarehouse = null;
        }

        barcode = null;
        products = null;
        currentPage = 1;
        _hasSearched = false;
        errorMessage = null;
        _searchString = string.Empty;
    }

    private void ViewProduct(ProductDto product)
    {
        selectedProduct = product;
    }

    private void CloseModal()
    {
        selectedProduct = null;
    }

    private static string FormatQuantity(decimal quantity, string? uomCode)
    {
        return QuantityDisplay.Format(quantity, uomCode);
    }

    private Color GetBatchStatusColor(string? status)
    {
        return status?.ToLower() switch
        {
            "released" => Color.Success,
            "not accessible" => Color.Warning,
            "locked" => Color.Error,
            _ => Color.Default
        };
    }

    private string GetBatchStatusCssClass(string? status)
    {
        return status?.ToLower() switch
        {
            "released" => "released",
            "not accessible" => "not-accessible",
            "locked" => "locked",
            _ => "default"
        };
    }

    private string GetAlertCssClass()
    {
        return errorSeverity switch
        {
            Severity.Error => "error-alert",
            Severity.Warning => "warn-alert",
            _ => "info-alert"
        };
    }

    private string GetAlertIcon()
    {
        return errorSeverity switch
        {
            Severity.Error => "bi-exclamation-octagon-fill",
            Severity.Warning => "bi-exclamation-triangle-fill",
            _ => "bi-info-circle-fill"
        };
    }

    private string GetStatusBadgeClass(string? status)
    {
        return status?.ToLower() switch
        {
            "released" => "bg-success",
            "not accessible" => "bg-warning",
            "locked" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private async Task OnPageChanged(int page)
    {
        if (page != currentPage)
        {
            currentPage = page;
            await SearchProducts();
        }
    }

    private async Task OnPageSizeChangedValue(int newPageSize)
    {
        pageSize = newPageSize;
        currentPage = 1;
        await SearchProducts();
    }

    private async Task OnPageSizeChanged()
    {
        currentPage = 1;
        await SearchProducts();
    }

    public void Dispose()
    {
        _searchCts?.Dispose();
        _loadingTimer?.Dispose();
    }
}