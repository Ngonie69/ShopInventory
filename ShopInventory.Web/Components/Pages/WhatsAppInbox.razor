@page "/whatsapp-inbox"
@implements IAsyncDisposable
@inject IWhatsAppAdminService WhatsAppService
@inject ILogger<WhatsAppInbox> Logger
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<PageTitle>WhatsApp Inbox - Shop Inventory</PageTitle>

<div class="page-shell wa-inbox-shell">
    <section class="wa-inbox-hero">
        <div>
            <div class="wa-inbox-kicker"><i class="bi bi-whatsapp"></i>OpenWA Workspace</div>
            <h2 class="mb-2">WhatsApp Operator Console</h2>
            <p class="wa-inbox-subtitle">Run the OpenWA session from inside Shop Inventory, scan QR codes when the
                gateway needs authentication, and work active WhatsApp threads with live refresh and reply controls.</p>
            </div>
            <div class="wa-inbox-hero-actions">
                <button class="btn btn-outline-success" type="button" @onclick="ToggleAutoRefresh">
                    <i class="bi bi-broadcast me-1"></i>@(autoRefreshEnabled ? "Auto Refresh On" : "Auto Refresh Off")
                </button>
                <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearchAsync"
                        disabled="@isRefreshing">
                    <i class="bi bi-x-circle me-1"></i>Clear Search
                </button>
                <button class="btn btn-primary" type="button" @onclick="RefreshAsync" disabled="@isRefreshing">
                    @if (isRefreshing)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                </button>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(actionErrorMessage))
        {
            <div class="alert alert-danger d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
                <div>
                    <strong class="d-block mb-1">WhatsApp action failed</strong>
                    <span>@actionErrorMessage</span>
                </div>
                <button class="btn btn-outline-danger" type="button" @onclick="RefreshAsync">Retry</button>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(actionInfoMessage))
        {
            <div class="alert alert-info mb-4">
                <strong class="d-block mb-1">Operator update</strong>
                <span>@actionInfoMessage</span>
            </div>
        }

        <div class="row g-4 mb-4">
            <div class="col-xl-4">
                <section class="wa-inbox-panel">
                    <div class="wa-inbox-panel-head">
                        <h3 class="wa-inbox-panel-title">Gateway Health</h3>
                        <span class="wa-inbox-status-pill @HealthStatusClass">@HealthStatusLabel</span>
                    </div>

                    <div class="wa-inbox-meta-grid">
                        <div class="wa-inbox-meta-item">
                            <span class="wa-inbox-meta-label">Host</span>
                            <span class="wa-inbox-meta-value">@(health?.BaseUrl ?? "Not configured")</span>
                        </div>
                        <div class="wa-inbox-meta-item">
                            <span class="wa-inbox-meta-label">Health Path</span>
                            <span class="wa-inbox-meta-value">@(health?.SourcePath ?? "n/a")</span>
                        </div>
                        <div class="wa-inbox-meta-item">
                            <span class="wa-inbox-meta-label">Version</span>
                            <span class="wa-inbox-meta-value">@(health?.Version ?? "Unknown")</span>
                        </div>
                        <div class="wa-inbox-meta-item">
                            <span class="wa-inbox-meta-label">Checked (CAT)</span>
                            <span class="wa-inbox-meta-value">@FormatCatTimestamp(health?.CheckedAtUtc)</span>
                        </div>
                        <div class="wa-inbox-meta-item">
                            <span class="wa-inbox-meta-label">Reported (CAT)</span>
                            <span class="wa-inbox-meta-value">@FormatCatTimestamp(health?.ReportedAtUtc)</span>
                        </div>
                    </div>
                </section>
            </div>

            <div class="col-xl-4">
                <section class="wa-inbox-panel">
                    <div class="wa-inbox-panel-head">
                        <h3 class="wa-inbox-panel-title">Session Console</h3>
                        <span class="wa-inbox-status-pill @SelectedSessionStatusClass">@SelectedSessionStatusLabel</span>
                    </div>

                    <form class="wa-inbox-create-form" @onsubmit="CreateSessionFromConsoleAsync"
                          @onsubmit:preventDefault="true">
                        <label class="wa-inbox-field-label" for="wa-create-session">New Session Name</label>
                        <input id="wa-create-session" class="form-control wa-inbox-text-input" type="text"
                               maxlength="50" placeholder="e.g. shopinventory-admin" @bind="createSessionName"
                               @bind:event="oninput"
                               disabled="@(isRefreshing || isSessionActionRunning || isCreatingSession)" />
                        <div class="wa-inbox-create-btns">
                            <button class="btn btn-primary" type="submit" disabled="@(!CanCreateSession)">
                                @if (isCreatingSession)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Create
                            </button>
                            <button class="btn btn-success" type="button"
                                    @onclick="CreateAndStartSessionFromConsoleAsync" disabled="@(!CanCreateSession)">
                                @if (isCreatingSession)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="bi bi-play-fill me-1"></i>Create + Start
                            </button>
                        </div>
                        <div class="wa-inbox-form-help">3–50 characters: letters, numbers, and hyphens only.</div>
                        @if (!string.IsNullOrWhiteSpace(createSessionValidationMessage))
                        {
                            <div class="wa-inbox-form-help is-error">@createSessionValidationMessage</div>
                        }
                    </form>

                    @if (sessions.Count == 0)
                    {
                        <p class="wa-inbox-empty-body mb-0">No OpenWA sessions are available yet. Create one here, or use Create
                            + Start to jump straight into QR authentication.</p>
                        }
                else
                        {
                            <label class="wa-inbox-field-label" for="wa-session-select">Active Session</label>
                            <select id="wa-session-select" class="form-select wa-inbox-select" value="@selectedSessionId"
                                    @onchange="OnSessionChangedAsync"
                                    disabled="@(isRefreshing || isSessionActionRunning || isCreatingSession)">
                                @foreach (var session in sessions.OrderBy(session => session.Name,
                            StringComparer.OrdinalIgnoreCase))
                                {
                                    <option value="@session.Id">@session.Name (@FormatStatusLabel(session.Status))</option>
                                }
                            </select>

                            <div class="wa-inbox-action-row">
                                <button class="btn btn-success" type="button" @onclick="StartSelectedSessionAsync"
                                        disabled="@(!CanStartSelectedSession || isRefreshing || isSessionActionRunning)">
                                    @if (isSessionActionRunning)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Start
                                </button>
                                <button class="btn btn-outline-danger" type="button" @onclick="StopSelectedSessionAsync"
                                        disabled="@(!CanStopSelectedSession || isRefreshing || isSessionActionRunning)">
                                    Stop
                                </button>
                                <button class="btn btn-outline-secondary" type="button" @onclick="RefreshSelectedSessionQrAsync"
                                        disabled="@(SelectedSession is null || isRefreshing || isQrLoading)">
                                    @if (isQrLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    QR
                                </button>
                            </div>

                            <div class="wa-inbox-meta-grid">
                                <div class="wa-inbox-meta-item">
                                    <span class="wa-inbox-meta-label">Phone</span>
                                    <span class="wa-inbox-meta-value">@(SelectedSession?.Phone ?? "Not linked")</span>
                                </div>
                                <div class="wa-inbox-meta-item">
                                    <span class="wa-inbox-meta-label">Profile Name</span>
                                    <span class="wa-inbox-meta-value">@(SelectedSession?.PushName ?? "Unknown")</span>
                                </div>
                                <div class="wa-inbox-meta-item">
                                    <span class="wa-inbox-meta-label">Connected (CAT)</span>
                                    <span class="wa-inbox-meta-value">@FormatCatTimestamp(SelectedSession?.ConnectedAt)</span>
                                </div>
                                <div class="wa-inbox-meta-item">
                                    <span class="wa-inbox-meta-label">Last Active (CAT)</span>
                                    <span class="wa-inbox-meta-value">@FormatCatTimestamp(SelectedSession?.LastActive)</span>
                                </div>
                                <div class="wa-inbox-meta-item">
                                    <span class="wa-inbox-meta-label">Updated (CAT)</span>
                                    <span class="wa-inbox-meta-value">@FormatCatTimestamp(SelectedSession?.UpdatedAt)</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(selectedSessionQr?.QrCode))
                            {
                                <div class="wa-inbox-qr-card">
                                    <img class="wa-inbox-qr-image" src="@selectedSessionQr.QrCode" alt="WhatsApp session QR code" />
                                    <div class="wa-inbox-qr-caption">Scan from WhatsApp &gt; Linked devices to authenticate this
                                        session.</div>
                                    </div>
                                }
                    else
                                {
                                    <div class="wa-inbox-note">@qrStatusMessage</div>
                                }
                            }
                        </section>
                    </div>

                    <div class="col-xl-4">
                        <section class="wa-inbox-panel">
                            <div class="wa-inbox-panel-head">
                                <h3 class="wa-inbox-panel-title">Inbox Snapshot</h3>
                                <span class="wa-inbox-page-summary">Page @currentPage of @TotalPages</span>
                            </div>

                            <div class="wa-inbox-stat-grid">
                                <div class="wa-inbox-stat-card">
                                    <span>Total Captured</span>
                                    <strong>@inbox.TotalCount</strong>
                                </div>
                                <div class="wa-inbox-stat-card">
                                    <span>Connected Sessions</span>
                                    <strong>@(health?.ConnectedSessions?.ToString() ?? "0")</strong>
                                </div>
                                <div class="wa-inbox-stat-card">
                                    <span>Unread Threads</span>
                                    <strong>@UnreadThreadCount</strong>
                                </div>
                                <div class="wa-inbox-stat-card">
                                    <span>Latest Received (CAT)</span>
                                    <strong>@LatestReceivedLabel</strong>
                                </div>
                            </div>

                            <form class="wa-inbox-toolbar" @onsubmit="ApplySearchAsync" @onsubmit:preventDefault="true">
                                <input class="wa-inbox-search" type="search"
                                       placeholder="Search by sender, session, message id, event or body" @bind="searchTerm"
                                       @bind:event="oninput" />
                                <button class="btn btn-primary" type="submit" disabled="@isRefreshing">
                                    <i class="bi bi-search me-1"></i>Search
                                </button>
                            </form>
                        </section>
                    </div>
                </div>

                @if (isLoading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-3 text-muted mb-0">Loading the WhatsApp workspace...</p>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div>
                            <strong class="d-block mb-1">Unable to load the WhatsApp workspace</strong>
                            <span>@errorMessage</span>
                        </div>
                        <button class="btn btn-outline-danger" type="button" @onclick="RefreshAsync">Retry</button>
                    </div>
                }
                else
                {
                    <div class="wa-inbox-workspace">
                        <aside class="wa-inbox-thread-column">
                            <section class="wa-inbox-panel wa-inbox-thread-panel">
                                <div class="wa-inbox-panel-head">
                                    <h3 class="wa-inbox-panel-title">Grouped Threads</h3>
                                    <span class="wa-inbox-page-summary">@UnreadThreadCount unread</span>
                                </div>

                                @if (threadOrder.Count == 0)
                                {
                                    <div class="wa-inbox-empty">
                                        <h3 class="mb-2">No threads captured yet</h3>
                                        <p class="mb-0 text-muted">Incoming and outbound WhatsApp messages will appear here after the first webhook is captured. You can still send a first message from the panel on the right.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="wa-inbox-thread-list">
                                        @foreach (var threadKey in threadOrder)
                                        {
                                            var unreadCount = GetThreadUnreadCount(threadKey);
                                            <button
                                                class="wa-inbox-thread-item @(threadKey == selectedThreadKey ? "is-selected" : string.Empty)"
                                                type="button" @onclick="() => SelectThreadAsync(threadKey)">
                                                <div class="wa-inbox-thread-item-head">
                                                    <strong>@GetThreadLabel(threadKey)</strong>
                                                    <span class="wa-inbox-thread-time">@GetThreadLatestLabel(threadKey)</span>
                                                </div>
                                                <div class="wa-inbox-thread-meta">
                                                    <span>@(GetThreadSessionName(threadKey) ?? "default")</span>
                                                    @if (unreadCount > 0)
                                                    {
                                                        <span class="wa-inbox-unread-badge">@unreadCount</span>
                                                    }
                                                </div>
                                                <p class="wa-inbox-thread-preview">@GetThreadPreview(threadKey)</p>
                                            </button>
                                        }
                                    </div>
                                }
                            </section>
                        </aside>

                        <section class="wa-inbox-conversation-column">
                            <section class="wa-inbox-panel wa-inbox-conversation-panel">
                                @if (SelectedThreadMessages.Count == 0)
                                {
                                    <div class="wa-inbox-empty">
                                        <h3 class="mb-2">Start an outbound chat</h3>
                                        <p class="mb-0 text-muted">Select a captured thread to continue an existing conversation, or enter a phone number below to send the first message.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="wa-inbox-conversation-head">
                                        <div>
                                            <div class="wa-inbox-conversation-title">@GetSelectedThreadLabel()</div>
                                            <div class="wa-inbox-conversation-subtitle">
                                                <span><i class="bi bi-chat-square-text me-1"></i>@(GetSelectedThreadChatId() ?? "No chat id")</span>
                                                <span><i class="bi bi-diagram-3 me-1"></i>@(GetSelectedThreadSessionName() ?? "default")</span>
                                            </div>
                                        </div>
                                        <div class="wa-inbox-card-badges">
                                            <span class="wa-inbox-status-pill @SelectedSessionStatusClass">@SelectedSessionStatusLabel</span>
                                        </div>
                                    </div>

                                    @if (IsReplying)
                                    {
                                        <div class="wa-inbox-reply-banner">
                                            <div>
                                                <div class="wa-inbox-reply-title">Replying to @replyToSenderLabel</div>
                                                <div class="wa-inbox-reply-preview">@replyPreviewText</div>
                                            </div>
                                            <button class="btn btn-sm btn-outline-secondary" type="button"
                                                    @onclick="ClearReplyContext">Cancel</button>
                                        </div>
                                    }

                                    <div class="wa-inbox-message-list">
                                        @foreach (var message in SelectedThreadMessages)
                                        {
                                            <article class="wa-inbox-message-bubble @(message.IsFromMe ? "is-self" : "is-other")">
                                                <div class="wa-inbox-message-head">
                                                    <div>
                                                        <div class="wa-inbox-message-sender">@GetSenderLabel(message)</div>
                                                        <div class="wa-inbox-message-time">@FormatCatTimestamp(message.OccurredAtUtc ?? message.ReceivedAtUtc)</div>
                                                    </div>

                                                    <div class="wa-inbox-card-badges">
                                                        <span class="wa-inbox-event-pill">@message.EventType</span>
                                                        <span class="wa-inbox-direction-pill @(message.IsFromMe ? "is-outbound" : "is-inbound")">@message.Direction</span>
                                                        @if (CanReplyTo(message))
                                                        {
                                                            <button class="btn btn-sm btn-outline-secondary" type="button"
                                                                    @onclick="() => BeginReply(message)">
                                                                Reply
                                                            </button>
                                                        }
                                                    </div>
                                                </div>

                                                @if (string.IsNullOrWhiteSpace(message.TextBody))
                                                {
                                                    <p class="wa-inbox-preview wa-inbox-empty-body">No text body was extracted from this event. Open the raw payload for the full webhook content.</p>
                                                }
                                                else
                                                {
                                                    <p class="wa-inbox-preview">@message.TextBody</p>
                                                }

                                                <div class="wa-inbox-message-meta">
                                                    <span><i class="bi bi-hash me-1"></i>@(message.MessageId ?? "No message id")</span>
                                                    <span><i class="bi bi-broadcast me-1"></i>@(message.MessageType ?? "Unknown type")</span>
                                                    <span><i class="bi bi-activity me-1"></i>@(message.Status ?? "No status")</span>
                                                    <span><i class="bi bi-box-arrow-in-down me-1"></i>Captured @FormatCatTimestamp(message.ReceivedAtUtc)</span>
                                                </div>

                                                <details class="wa-inbox-raw">
                                                    <summary>Raw payload</summary>
                                                    <pre>@message.RawPayload</pre>
                                                </details>
                                            </article>
                                        }
                                    </div>
                                }

                                <form class="wa-inbox-compose" @onsubmit="SendComposeAsync" @onsubmit:preventDefault="true">
                                    <div>
                                        <label class="wa-inbox-field-label" for="wa-compose-recipient">Recipient Number or Chat ID</label>
                                        <input id="wa-compose-recipient" class="form-control wa-inbox-text-input" type="text"
                                               inputmode="tel" autocomplete="off"
                                               placeholder="Leave blank to use the selected thread, or enter 263772123456"
                                               @bind="composeRecipient" @bind:event="oninput"
                                               disabled="@(isSending || IsReplying)" />
                                        <div class="wa-inbox-form-help">@(IsReplying
                                                ? "Reply target comes from the selected message thread."
                                                : "Leave this blank to use the selected thread, or enter a phone number / full chat id to start a new chat.")</div>
                                    </div>
                                    <textarea class="wa-inbox-compose-input" rows="4" placeholder="@ComposePlaceholder"
                                              @bind="composeText"></textarea>
                                    <div class="wa-inbox-compose-actions">
                                        <span class="wa-inbox-compose-hint">@ComposeHintLabel</span>
                                        <div class="wa-inbox-hero-actions">
                                            @if (IsReplying)
                                            {
                                                <button class="btn btn-outline-secondary" type="button" @onclick="ClearReplyContext">
                                                    Clear Reply
                                                </button>
                                            }
                                            <button class="btn btn-success" type="submit" disabled="@(!CanSendCompose || isSending)">
                                                @if (isSending)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                                }
                                                @(IsReplying ? "Send Reply" : "Send Message")
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </section>
                        </section>
                    </div>

                    @if (inbox.TotalCount > 0)
                    {
                        <div class="wa-inbox-pagination">
                            <button class="btn btn-outline-secondary" type="button" @onclick="PreviousPageAsync"
                                    disabled="@(currentPage <= 1 || isRefreshing)">
                                <i class="bi bi-arrow-left me-1"></i>Newer
                            </button>
                            <div class="wa-inbox-page-summary">Showing @inbox.Messages.Count of @inbox.TotalCount captured events</div>
                            <button class="btn btn-outline-secondary" type="button" @onclick="NextPageAsync"
                                    disabled="@(currentPage >= TotalPages || isRefreshing)">
                                Older<i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </div>
                    }
                }
                                    </div>

@code {
    private const int PageSize = 100;
    private static readonly TimeSpan AutoRefreshInterval = TimeSpan.FromSeconds(15);

    private readonly HashSet<int> trackedMessageIds = [];
    private readonly HashSet<int> unreadMessageIds = [];

    private bool isLoading = true;
    private bool isRefreshing;
    private bool isSending;
    private bool isQrLoading;
    private bool isSessionActionRunning;
    private bool isCreatingSession;
    private bool autoRefreshEnabled = true;

    private string? errorMessage;
    private string? actionErrorMessage;
    private string? actionInfoMessage;
    private string? createSessionValidationMessage;
    private string? selectedSessionId;
    private string? selectedThreadKey;
    private string? replyToMessageId;
    private string? replyToSenderLabel;
    private string? replyPreviewText;
    private string? qrStatusMessage = "Select a session to load the current authentication state.";
    private string searchTerm = string.Empty;
    private string createSessionName = string.Empty;
    private string composeRecipient = string.Empty;
    private string composeText = string.Empty;
    private int currentPage = 1;

    private PeriodicTimer? autoRefreshTimer;
    private CancellationTokenSource? autoRefreshCancellationTokenSource;
    private Task? autoRefreshTask;

    private WhatsAppHealthModel? health;
    private WhatsAppQrCodeModel? selectedSessionQr;
    private WhatsAppInboxResponseModel inbox = new() { Page = 1, PageSize = PageSize };
    private List<WhatsAppSessionModel> sessions = [];
    private Dictionary<string, List<WhatsAppInboxItemModel>> threadMap = new(StringComparer.Ordinal);
    private List<string> threadOrder = [];

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(inbox.TotalCount / (double)Math.Max(inbox.PageSize, 1)));

    private WhatsAppSessionModel? SelectedSession => sessions.FirstOrDefault(session => session.Id == selectedSessionId);

    private IReadOnlyList<WhatsAppInboxItemModel> SelectedThreadMessages =>
        !string.IsNullOrWhiteSpace(selectedThreadKey) && threadMap.TryGetValue(selectedThreadKey, out var messages)
            ? messages
            : Array.Empty<WhatsAppInboxItemModel>();

    private int UnreadThreadCount => threadOrder.Count(threadKey => GetThreadUnreadCount(threadKey) > 0);

    private string HealthStatusLabel => FormatStatusLabel(health?.Status);

    private string HealthStatusClass => GetStatusClass(health?.Status);

    private string SelectedSessionStatusLabel => FormatStatusLabel(SelectedSession?.Status);

    private string SelectedSessionStatusClass => GetStatusClass(SelectedSession?.Status);

    private string LatestReceivedLabel => inbox.Messages.Count == 0
        ? "None"
        : FormatCatTimestamp(inbox.Messages.Max(message => message.ReceivedAtUtc));

    private bool IsReplying => !string.IsNullOrWhiteSpace(replyToMessageId);

    private bool CanStartSelectedSession => SelectedSession is not null && IsStartableStatus(SelectedSession.Status);

    private bool CanStopSelectedSession => SelectedSession is not null && IsStoppableStatus(SelectedSession.Status);

    private bool CanCreateSession => !isRefreshing
        && !isSessionActionRunning
        && !isCreatingSession
        && ValidateSessionName(createSessionName) is null;

    private bool CanSendCompose => !isSending
        && SelectedSession is not null
        && string.Equals(SelectedSession.Status, "ready", StringComparison.OrdinalIgnoreCase)
        && !string.IsNullOrWhiteSpace(ResolveComposeChatId(out _))
        && !string.IsNullOrWhiteSpace(composeText);

    private string ComposePlaceholder => SelectedSession is null
        ? "Choose an OpenWA session before sending."
        : IsReplying
            ? "Type a WhatsApp reply..."
            : !string.IsNullOrWhiteSpace(composeRecipient)
                ? "Type the first WhatsApp message for this recipient..."
                : SelectedThreadMessages.Count == 0
                    ? "Enter a phone number above or select a thread to start sending"
                    : "Type a WhatsApp message...";

    private string ComposeHintLabel
    {
        get
        {
            if (SelectedSession is null)
            {
                return "Choose an OpenWA session.";
            }

            if (!string.Equals(SelectedSession.Status, "ready", StringComparison.OrdinalIgnoreCase))
            {
                return "Session must be ready before sending.";
            }

            var chatId = ResolveComposeChatId(out var validationMessage);
            if (string.IsNullOrWhiteSpace(chatId))
            {
                return validationMessage ?? "Select a thread or enter a phone number.";
            }

            if (IsReplying)
            {
                return $"Reply will send to {chatId}.";
            }

            if (!string.IsNullOrWhiteSpace(composeRecipient))
            {
                return $"New chat will send to {chatId}.";
            }

            return autoRefreshEnabled
                ? $"Selected thread will send to {chatId}. Live refresh every {AutoRefreshInterval.TotalSeconds:0} seconds."
                : $"Selected thread will send to {chatId}.";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(resetTracker: true);
        StartAutoRefreshLoop();
    }

    public async ValueTask DisposeAsync()
    {
        autoRefreshCancellationTokenSource?.Cancel();
        autoRefreshTimer?.Dispose();

        if (autoRefreshTask is not null)
        {
            try
            {
                await autoRefreshTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        autoRefreshCancellationTokenSource?.Dispose();
    }

    private async Task RefreshAsync()
    {
        await LoadAsync();
    }

    private async Task ApplySearchAsync()
    {
        currentPage = 1;
        await LoadAsync(resetTracker: true);
    }

    private async Task ClearSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            return;
        }

        searchTerm = string.Empty;
        currentPage = 1;
        await LoadAsync(resetTracker: true);
    }

    private async Task PreviousPageAsync()
    {
        if (currentPage <= 1)
        {
            return;
        }

        currentPage--;
        await LoadAsync(resetTracker: true);
    }

    private async Task NextPageAsync()
    {
        if (currentPage >= TotalPages)
        {
            return;
        }

        currentPage++;
        await LoadAsync(resetTracker: true);
    }

    private void ToggleAutoRefresh()
    {
        autoRefreshEnabled = !autoRefreshEnabled;
    }

    private async Task OnSessionChangedAsync(ChangeEventArgs args)
    {
        selectedSessionId = args.Value?.ToString();
        actionErrorMessage = null;
        actionInfoMessage = null;
        createSessionValidationMessage = null;
        ClearReplyContext();
        await TryLoadSelectedSessionQrAsync();
    }

    private async Task CreateSessionFromConsoleAsync()
    {
        await CreateSessionInternalAsync(startAfterCreate: false);
    }

    private async Task CreateAndStartSessionFromConsoleAsync()
    {
        await CreateSessionInternalAsync(startAfterCreate: true);
    }

    private async Task CreateSessionInternalAsync(bool startAfterCreate)
    {
        if (isCreatingSession)
        {
            return;
        }

        var validationError = ValidateSessionName(createSessionName);
        if (!string.IsNullOrWhiteSpace(validationError))
        {
            createSessionValidationMessage = validationError;
            return;
        }

        var trimmedSessionName = createSessionName.Trim();
        isCreatingSession = true;
        actionErrorMessage = null;
        actionInfoMessage = null;
        createSessionValidationMessage = null;

        try
        {
            var session = await WhatsAppService.CreateSessionAsync(trimmedSessionName);
            createSessionName = string.Empty;
            selectedSessionId = session.Id;

            if (!startAfterCreate)
            {
                actionInfoMessage = $"Session {session.Name} was created. Start it to request a QR code.";
                await LoadAsync();
                return;
            }

            try
            {
                var startedSession = await WhatsAppService.StartSessionAsync(session.Id);
                selectedSessionId = startedSession.Id;
                actionInfoMessage = $"Session {startedSession.Name} was created and started. Use QR when the session reaches QR READY.";
            }
            catch (Exception startEx)
            {
                Logger.LogWarning(startEx, "Failed to start newly created WhatsApp session {SessionId}", session.Id);
                actionErrorMessage = $"Session {session.Name} was created, but starting it failed. {startEx.Message}";
            }

            await LoadAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to create WhatsApp session {SessionName}", trimmedSessionName);
            actionErrorMessage = ex.Message;
        }
        finally
        {
            isCreatingSession = false;
        }
    }

    private async Task StartSelectedSessionAsync()
    {
        if (SelectedSession is null || isSessionActionRunning)
        {
            return;
        }

        isSessionActionRunning = true;
        actionErrorMessage = null;
        actionInfoMessage = null;

        try
        {
            await WhatsAppService.StartSessionAsync(SelectedSession.Id);
            actionInfoMessage = $"Session {SelectedSession.Name} start was sent to OpenWA.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to start WhatsApp session {SessionId}", SelectedSession.Id);
            actionErrorMessage = ex.Message;
        }
        finally
        {
            isSessionActionRunning = false;
        }
    }

    private async Task StopSelectedSessionAsync()
    {
        if (SelectedSession is null || isSessionActionRunning)
        {
            return;
        }

        isSessionActionRunning = true;
        actionErrorMessage = null;
        actionInfoMessage = null;

        try
        {
            await WhatsAppService.StopSessionAsync(SelectedSession.Id);
            actionInfoMessage = $"Session {SelectedSession.Name} stop was sent to OpenWA.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to stop WhatsApp session {SessionId}", SelectedSession.Id);
            actionErrorMessage = ex.Message;
        }
        finally
        {
            isSessionActionRunning = false;
        }
    }

    private async Task RefreshSelectedSessionQrAsync()
    {
        await TryLoadSelectedSessionQrAsync();
    }

    private async Task SelectThreadAsync(string threadKey)
    {
        selectedThreadKey = threadKey;
        actionErrorMessage = null;
        actionInfoMessage = null;
        ClearReplyContext();
        TrySelectSessionForThread(threadKey);
        MarkSelectedThreadAsRead();
        await TryLoadSelectedSessionQrAsync();
