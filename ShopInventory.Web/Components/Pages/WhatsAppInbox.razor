    private void BeginReply(WhatsAppInboxItemModel message)
    {
        replyToMessageId = message.MessageId;
        replyToSenderLabel = GetSenderLabel(message);
        replyPreviewText = string.IsNullOrWhiteSpace(message.TextBody)
            ? "Replying to a captured WhatsApp event"
            : message.TextBody.Length <= 120
                ? message.TextBody
                : $"{message.TextBody[..117]}...";
        actionErrorMessage = null;
        actionInfoMessage = null;
    }

    private void ClearReplyContext()
    {
        replyToMessageId = null;
        replyToSenderLabel = null;
        replyPreviewText = null;
    }

    private async Task SendComposeAsync()
    {
        var selectedSession = SelectedSession;
        var chatId = ResolveComposeChatId(out _);
        if (!CanSendCompose || selectedSession is null || string.IsNullOrWhiteSpace(chatId))
        {
            return;
        }

        var trimmedText = composeText.Trim();
        if (string.IsNullOrWhiteSpace(trimmedText))
        {
            return;
        }

        isSending = true;
        actionErrorMessage = null;
        actionInfoMessage = null;
        var wasReply = IsReplying;
        var usedManualRecipient = !wasReply && !string.IsNullOrWhiteSpace(composeRecipient);

        try
        {
            if (wasReply && !string.IsNullOrWhiteSpace(replyToMessageId))
            {
                await WhatsAppService.ReplyAsync(selectedSession.Id, chatId, replyToMessageId, trimmedText);
            }
            else
            {
                await WhatsAppService.SendTextAsync(selectedSession.Id, chatId, trimmedText);
            }

            composeText = string.Empty;
            ClearReplyContext();
            actionInfoMessage = wasReply
                ? "Reply submitted to OpenWA. It will appear here after the webhook is captured."
                : usedManualRecipient
                    ? $"Message to {chatId} was submitted to OpenWA. It will appear here after the webhook is captured."
                    : "Message submitted to OpenWA. It will appear here after the webhook is captured.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to send WhatsApp message for session {SessionId}", selectedSession.Id);
            actionErrorMessage = ex.Message;
        }
        finally
        {
            isSending = false;
        }
    }

    private string? ResolveComposeChatId(out string? validationMessage)
    {
        validationMessage = null;

        if (IsReplying)
        {
            var replyChatId = GetSelectedThreadChatId();
            if (!string.IsNullOrWhiteSpace(replyChatId))
            {
                return replyChatId;
            }

            validationMessage = "The selected reply target is missing a chat id.";
            return null;
        }

        if (!string.IsNullOrWhiteSpace(composeRecipient))
        {
            return NormalizeComposeRecipient(composeRecipient, out validationMessage);
        }

        var threadChatId = GetSelectedThreadChatId();
        if (!string.IsNullOrWhiteSpace(threadChatId))
        {
            return threadChatId;
        }

        validationMessage = "Select a thread or enter a phone number.";
        return null;
    }

    private static string? NormalizeComposeRecipient(string value, out string? validationMessage)
    {
        validationMessage = null;
        var trimmedValue = value.Trim();

        if (string.IsNullOrWhiteSpace(trimmedValue))
        {
            validationMessage = "Enter a phone number or chat id.";
            return null;
        }

        if (TryNormalizeFullChatId(trimmedValue, out var normalizedChatId))
        {
            return normalizedChatId;
        }

        var digits = ExtractDigits(trimmedValue);
        if (string.IsNullOrWhiteSpace(digits))
        {
            validationMessage = "Use digits only for phone numbers, or a full chat id ending in @c.us or @g.us.";
            return null;
        }

        if (digits.Length < 10 || digits.Length > 15)
        {
            validationMessage = "Phone numbers must contain 10 to 15 digits.";
            return null;
        }

        return $"{digits}@c.us";
    }

    private static bool TryNormalizeFullChatId(string value, out string? normalizedChatId)
    {
        normalizedChatId = null;

        var lowerValue = value.ToLowerInvariant();
        if (!lowerValue.EndsWith("@c.us", StringComparison.Ordinal)
            && !lowerValue.EndsWith("@g.us", StringComparison.Ordinal))
        {
            return false;
        }

        var atIndex = value.IndexOf('@');
        if (atIndex <= 0)
        {
            return false;
        }

        var idPart = value[..atIndex];
        foreach (var character in idPart)
        {
            if (!char.IsDigit(character))
            {
                return false;
            }
        }

        normalizedChatId = $"{idPart}{lowerValue[atIndex..]}";
        return true;
    }

    private static string ExtractDigits(string value)
    {
        var digits = new char[value.Length];
        var count = 0;

        foreach (var character in value)
        {
            if (char.IsDigit(character))
            {
                digits[count++] = character;
                continue;
            }

            if (char.IsWhiteSpace(character) || character is '+' or '-' or '(' or ')')
            {
                continue;
            }

            return string.Empty;
        }

        return new string(digits, 0, count);
    }

    private async Task LoadAsync(bool resetTracker = false)
    {
        if (isRefreshing)
        {
            return;
        }

        isRefreshing = true;
        errorMessage = null;

        try
        {
            health = await WhatsAppService.GetHealthAsync();

            string? loadWarningMessage = null;

            try
            {
                sessions = await WhatsAppService.GetSessionsAsync();
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to load WhatsApp sessions");
                sessions = [];
                loadWarningMessage = ex.Message;
            }

            try
            {
                inbox = await WhatsAppService.GetInboxAsync(currentPage, PageSize, searchTerm);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to load WhatsApp inbox items");
                inbox = new WhatsAppInboxResponseModel
                {
                    Page = currentPage,
                    PageSize = PageSize
                };

                loadWarningMessage ??= ex.Message;
            }

            if (!string.IsNullOrWhiteSpace(loadWarningMessage) && string.IsNullOrWhiteSpace(actionErrorMessage))
            {
                actionErrorMessage = loadWarningMessage;
            }

            SynchronizeSelectedSession();
            UpdateUnreadTracking(resetTracker || currentPage != 1);
            RebuildThreads();
            await TryLoadSelectedSessionQrAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load WhatsApp inbox page");
            errorMessage = ex.Message;
            sessions = [];
            threadMap.Clear();
            threadOrder = [];
            selectedSessionId = null;
            selectedThreadKey = null;
            selectedSessionQr = null;
            qrStatusMessage = "Unable to load the session QR state right now.";
            inbox = new WhatsAppInboxResponseModel
            {
                Page = currentPage,
                PageSize = PageSize
            };
        }
        finally
        {
            isLoading = false;
            isRefreshing = false;
        }
    }

    private async Task TryLoadSelectedSessionQrAsync()
    {
        var selectedSession = SelectedSession;
        selectedSessionQr = null;

        if (selectedSession is null)
        {
            qrStatusMessage = sessions.Count == 0
                ? "Create a session to begin linking WhatsApp."
                : "Select a session to load the current authentication state.";
            return;
        }

        if (string.Equals(selectedSession.Status, "ready", StringComparison.OrdinalIgnoreCase))
        {
            qrStatusMessage = "This session is authenticated and ready to send messages.";
            return;
        }

        if (!string.Equals(selectedSession.Status, "qr_ready", StringComparison.OrdinalIgnoreCase))
        {
            qrStatusMessage = $"Session status is {FormatStatusLabel(selectedSession.Status)}. Refresh again to check for a QR code.";
            return;
        }

        isQrLoading = true;

        try
        {
            selectedSessionQr = await WhatsAppService.TryGetSessionQrCodeAsync(selectedSession.Id);
            qrStatusMessage = selectedSessionQr is null
                ? "QR code is not available yet. Refresh again in a moment."
                : "Scan this QR code from WhatsApp > Linked devices.";
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load QR code for WhatsApp session {SessionId}", selectedSession.Id);
            qrStatusMessage = "Unable to load the QR code right now.";
        }
        finally
        {
            isQrLoading = false;
        }
    }

    private void SynchronizeSelectedSession()
    {
        if (sessions.Count == 0)
        {
            selectedSessionId = null;
            return;
        }

        if (!string.IsNullOrWhiteSpace(selectedSessionId) && sessions.Any(session => session.Id == selectedSessionId))
        {
            return;
        }

        selectedSessionId = sessions
            .OrderByDescending(session => string.Equals(session.Status, "ready", StringComparison.OrdinalIgnoreCase))
            .ThenBy(session => session.Name, StringComparer.OrdinalIgnoreCase)
            .Select(session => session.Id)
            .FirstOrDefault();
    }

    private void UpdateUnreadTracking(bool resetTracker)
    {
        if (resetTracker)
        {
            trackedMessageIds.Clear();
            unreadMessageIds.Clear();
        }

        if (trackedMessageIds.Count == 0)
        {
            trackedMessageIds.UnionWith(inbox.Messages.Select(message => message.Id));
            return;
        }

        foreach (var message in inbox.Messages.Where(message => !trackedMessageIds.Contains(message.Id)))
        {
            trackedMessageIds.Add(message.Id);
            if (!message.IsFromMe)
            {
                unreadMessageIds.Add(message.Id);
            }
        }
    }

    private void RebuildThreads()
    {
        threadMap = inbox.Messages
            .GroupBy(GetThreadKey)
            .ToDictionary(
                group => group.Key,
                group => group.OrderBy(message => message.OccurredAtUtc ?? message.ReceivedAtUtc).ToList(),
                StringComparer.Ordinal);

        threadOrder = threadMap
            .OrderByDescending(entry => entry.Value.Max(message => message.OccurredAtUtc ?? message.ReceivedAtUtc))
            .Select(entry => entry.Key)
            .ToList();

        if (!string.IsNullOrWhiteSpace(selectedThreadKey) && !threadMap.ContainsKey(selectedThreadKey))
        {
            selectedThreadKey = null;
            ClearReplyContext();
        }

        if (string.IsNullOrWhiteSpace(selectedThreadKey) && threadOrder.Count > 0)
        {
            selectedThreadKey = threadOrder[0];
        }

        TrySelectSessionForThread(selectedThreadKey);
        MarkSelectedThreadAsRead();
    }

    private void MarkSelectedThreadAsRead()
    {
        if (string.IsNullOrWhiteSpace(selectedThreadKey) || !threadMap.TryGetValue(selectedThreadKey, out var messages))
        {
            return;
        }

        foreach (var message in messages.Where(message => !message.IsFromMe))
        {
            unreadMessageIds.Remove(message.Id);
        }
    }

    private void TrySelectSessionForThread(string? threadKey)
    {
        if (string.IsNullOrWhiteSpace(threadKey))
        {
            return;
        }

        var sessionName = GetThreadSessionName(threadKey);
        if (string.IsNullOrWhiteSpace(sessionName))
        {
            return;
        }

        var matchingSession = sessions.FirstOrDefault(session => string.Equals(session.Name, sessionName,
StringComparison.OrdinalIgnoreCase));
        if (matchingSession is not null)
        {
            selectedSessionId = matchingSession.Id;
        }
    }

    private int GetThreadUnreadCount(string threadKey)
    {
        return threadMap.TryGetValue(threadKey, out var messages)
            ? messages.Count(message => unreadMessageIds.Contains(message.Id))
            : 0;
    }

    private string GetThreadLabel(string threadKey)
    {
        if (!threadMap.TryGetValue(threadKey, out var messages) || messages.Count == 0)
        {
            return "Unknown thread";
        }

        var latestMessage = messages[^1];
        return GetSenderLabel(latestMessage);
    }

    private string GetSelectedThreadLabel()
    {
        return string.IsNullOrWhiteSpace(selectedThreadKey)
            ? "Unknown thread"
            : GetThreadLabel(selectedThreadKey);
    }

    private string? GetSelectedThreadChatId()
    {
        return string.IsNullOrWhiteSpace(selectedThreadKey)
            ? null
            : GetThreadChatId(selectedThreadKey);
    }

    private string? GetSelectedThreadSessionName()
    {
        return string.IsNullOrWhiteSpace(selectedThreadKey)
            ? null
            : GetThreadSessionName(selectedThreadKey);
    }

    private string? GetThreadChatId(string threadKey)
    {
        return threadMap.TryGetValue(threadKey, out var messages)
            ? messages.Select(message => message.ChatId).LastOrDefault(chatId => !string.IsNullOrWhiteSpace(chatId))
            : null;
    }

    private string? GetThreadSessionName(string threadKey)
    {
        return threadMap.TryGetValue(threadKey, out var messages)
            ? messages.Select(message => message.SessionName).LastOrDefault(sessionName => !string.IsNullOrWhiteSpace(sessionName))
            : null;
    }

    private string GetThreadLatestLabel(string threadKey)
    {
        return threadMap.TryGetValue(threadKey, out var messages) && messages.Count > 0
            ? FormatCatTimestamp(messages[^1].OccurredAtUtc ?? messages[^1].ReceivedAtUtc)
            : "n/a";
    }

    private string GetThreadPreview(string threadKey)
    {
        if (!threadMap.TryGetValue(threadKey, out var messages) || messages.Count == 0)
        {
            return "No captured preview";
        }

        var latestMessage = messages[^1];
        return string.IsNullOrWhiteSpace(latestMessage.TextBody)
            ? "No text body captured for the latest event"
            : latestMessage.TextBody;
    }

    private static string GetThreadKey(WhatsAppInboxItemModel message)
    {
        var sessionName = string.IsNullOrWhiteSpace(message.SessionName) ? "default" : message.SessionName.Trim();
        var chatId = !string.IsNullOrWhiteSpace(message.ChatId)
            ? message.ChatId.Trim()
            : !string.IsNullOrWhiteSpace(message.SenderNumber)
                ? message.SenderNumber.Trim()
                : $"event-{message.Id}";

        return $"{sessionName}::{chatId}";
    }

    private bool CanReplyTo(WhatsAppInboxItemModel message)
    {
        return !message.IsFromMe
            && !string.IsNullOrWhiteSpace(message.MessageId)
            && !string.IsNullOrWhiteSpace(GetSelectedThreadChatId())
            && SelectedSession is not null
            && string.Equals(SelectedSession.Status, "ready", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsStartableStatus(string? status)
    {
        return (status ?? string.Empty).ToLowerInvariant() switch
        {
            "created" or "disconnected" or "failed" => true,
            _ => false
        };
    }

    private static bool IsStoppableStatus(string? status)
    {
        return (status ?? string.Empty).ToLowerInvariant() switch
        {
            "initializing" or "qr_ready" or "authenticating" or "ready" => true,
            _ => false
        };
    }

    private static string? ValidateSessionName(string? value)
    {
        var trimmedValue = value?.Trim() ?? string.Empty;

        if (trimmedValue.Length < 3 || trimmedValue.Length > 50)
        {
            return "Session name must be between 3 and 50 characters.";
        }

        foreach (var character in trimmedValue)
        {
            if (!char.IsLetterOrDigit(character) && character != '-')
            {
                return "Session name can only contain letters, numbers, and hyphens.";
            }
        }

        return null;
    }

    private void StartAutoRefreshLoop()
    {
        autoRefreshCancellationTokenSource = new CancellationTokenSource();
        autoRefreshTimer = new PeriodicTimer(AutoRefreshInterval);
        autoRefreshTask = RunAutoRefreshLoopAsync(autoRefreshCancellationTokenSource.Token);
    }

    private async Task RunAutoRefreshLoopAsync(CancellationToken cancellationToken)
    {
        if (autoRefreshTimer is null)
        {
            return;
        }

        try
        {
            while (await autoRefreshTimer.WaitForNextTickAsync(cancellationToken))
            {
                if (!autoRefreshEnabled || isRefreshing || isSending || isSessionActionRunning)
                {
                    continue;
                }

                await InvokeAsync(() => LoadAsync());
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private static string GetSenderLabel(WhatsAppInboxItemModel message)
    {
        if (!string.IsNullOrWhiteSpace(message.SenderDisplayName) && !string.IsNullOrWhiteSpace(message.SenderNumber))
        {
            return $"{message.SenderDisplayName} ({message.SenderNumber})";
        }

        return message.SenderDisplayName
            ?? message.SenderNumber
            ?? message.ChatId
            ?? "Unknown sender";
    }

    private static string FormatStatusLabel(string? status)
    {
        return string.IsNullOrWhiteSpace(status)
            ? "UNKNOWN"
            : status.Replace('_', ' ').ToUpperInvariant();
    }

    private static string GetStatusClass(string? status)
    {
        return (status ?? string.Empty).ToLowerInvariant() switch
        {
            "ok" or "healthy" or "ready" => "is-ok",
            "warning" or "degraded" or "qr_ready" or "initializing" or "authenticating" => "is-warning",
            _ => "is-error"
        };
    }

    private static string FormatCatTimestamp(DateTime? utcDateTime)
    {
        if (!utcDateTime.HasValue)
        {
            return "n/a";
        }

        var utcValue = utcDateTime.Value.Kind == DateTimeKind.Utc
            ? utcDateTime.Value
            : DateTime.SpecifyKind(utcDateTime.Value, DateTimeKind.Utc);

        return IAuditService.ToCAT(utcValue).ToString("dd MMM yyyy HH:mm");
    }
}