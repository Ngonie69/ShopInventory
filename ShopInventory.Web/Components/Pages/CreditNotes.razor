@page "/credit-notes"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Cashier")]
@inject ICreditNoteService CreditNoteService
@inject IMasterDataCacheService CacheService
@inject NavigationManager NavigationManager
@inject IAppSettingsProvider AppSettings
@inject IAuditService AuditService
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Credit Notes - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .cn-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Header ──────────────────────────────────────── */
    .cn-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .cn-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .cn-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .cn-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .cn-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .btn-cn-gradient {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 2px 8px rgba(102, 126, 234, .25);
        cursor: pointer;
    }

    .btn-cn-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .4);
        color: #fff;
    }

    /* ── Filter Bar ──────────────────────────────────── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        align-items: flex-end;
        padding: 1rem 1.25rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .filter-bar .filter-field {
        flex: 1;
        min-width: 140px;
    }

    .filter-bar .filter-field label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .3rem;
    }

    .filter-bar .filter-field input,
    .filter-bar .filter-field select {
        width: 100%;
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        background: #fff;
        transition: all .15s;
    }

    .filter-bar .filter-field input:focus,
    .filter-bar .filter-field select:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .filter-actions-row {
        display: flex;
        gap: .5rem;
        align-items: flex-end;
    }

    .btn-search {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-search:hover {
        opacity: .92;
        transform: translateY(-1px);
    }

    .btn-clear {
        background: #fff;
        color: #6b7280;
        border: 1px solid #d1d5db;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-clear:hover {
        background: #f3f4f6;
    }

    /* ── Table ───────────────────────────────────────── */
    .cn-table-wrap {
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #fff;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .cn-table-header {
        padding: .85rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
    }

    .cn-table-header h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .92rem;
    }

    .cn-count-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #374151;
    }

    /* ── Status & Type Badges ────────────────────────── */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .73rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-badge.draft {
        background: #f3f4f6;
        color: #6b7280;
    }

    .status-badge.pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-badge.approved {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.applied {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-badge.partial {
        background: #e0e7ff;
        color: #3730a3;
    }

    .status-badge.cancelled {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-badge.voided {
        background: #f3f4f6;
        color: #374151;
    }

    .type-badge {
        display: inline-flex;
        align-items: center;
        padding: .15rem .55rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
    }

    .type-badge.return {
        background: #e0e7ff;
        color: #3730a3;
    }

    .type-badge.refund {
        background: #d1fae5;
        color: #065f46;
    }

    .type-badge.adjustment {
        background: #fef3c7;
        color: #92400e;
    }

    .type-badge.cancellation {
        background: #fee2e2;
        color: #991b1b;
    }

    /* ── Cell Styles ─────────────────────────────────── */
    .cn-number {
        font-weight: 700;
        color: #667eea;
        font-family: 'Space Grotesk', monospace;
        font-size: .88rem;
    }

    .customer-info .name {
        font-weight: 600;
        font-size: .85rem;
        color: #1a1a2e;
    }

    .customer-info .code {
        font-size: .75rem;
        color: #9ca3af;
        font-family: 'Space Grotesk', monospace;
    }

    .amount-cell {
        font-weight: 700;
        color: #1a1a2e;
        font-family: 'Space Grotesk', monospace;
        font-size: .88rem;
    }

    .balance-cell {
        font-weight: 700;
        font-family: 'Space Grotesk', monospace;
        font-size: .88rem;
    }

    .balance-cell.has-balance {
        color: #d97706;
    }

    .balance-cell.zero {
        color: #059669;
    }

    /* ── Action Buttons ──────────────────────────────── */
    .action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .85rem;
    }

    .action-btn:hover {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }

    .action-btn.view:hover {
        background: #ede9fe;
        color: #667eea;
        border-color: #c4b5fd;
    }

    .action-btn.approve:hover {
        background: #d1fae5;
        color: #059669;
        border-color: #6ee7b7;
    }

    .action-btn.delete:hover {
        background: #fee2e2;
        color: #dc2626;
        border-color: #fca5a5;
    }

    /* ── Drawer ──────────────────────────────────────── */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        z-index: 9998;
        animation: fadeIn .2s ease;
    }

    .detail-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(640px, 95vw);
        height: 100vh;
        background: #fff;
        z-index: 9999;
        box-shadow: -8px 0 30px rgba(0, 0, 0, .12);
        display: flex;
        flex-direction: column;
        animation: slideInRight .25s ease;
    }

    .drawer-header {
        padding: 1.15rem 1.5rem;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }

    .drawer-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .drawer-header .btn-close-drawer {
        background: rgba(255, 255, 255, .15);
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s;
        font-size: 1rem;
    }

    .drawer-header .btn-close-drawer:hover {
        background: rgba(255, 255, 255, .25);
    }

    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .drawer-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
        margin-bottom: 1.25rem;
    }

    .detail-item .detail-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
        margin-bottom: .15rem;
    }

    .detail-item .detail-value {
        font-size: .92rem;
        font-weight: 600;
        color: #1a1a2e;
    }

    .detail-section-title {
        font-weight: 600;
        color: #1a1a2e;
        font-size: .9rem;
        margin-bottom: .75rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    /* ── Lines Table ─────────────────────────────────── */
    .lines-table {
        width: 100%;
        font-size: .85rem;
        border-collapse: separate;
        border-spacing: 0;
    }

    .lines-table th {
        background: #f8fafc;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6b7280;
        font-weight: 600;
        padding: .6rem .75rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .lines-table td {
        padding: .55rem .75rem;
        border-bottom: 1px solid #f3f4f6;
        color: #374151;
    }

    .lines-table tr:last-child td {
        border-bottom: none;
    }

    .lines-table tfoot td {
        border-top: 2px solid #e5e7eb;
        background: #f8fafc;
    }

    /* Total Banner */
    .total-banner {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.25rem;
    }

    .total-banner .total-label {
        font-size: .9rem;
        font-weight: 500;
    }

    .total-banner .total-value {
        font-size: 1.4rem;
        font-weight: 700;
    }

    /* ── Create Modal ────────────────────────────────── */
    .create-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .5);
        z-index: 10000;
        display: flex;
        justify-content: center;
        align-items: center;
        animation: fadeIn .2s ease;
        padding: 1rem;
    }

    .create-modal {
        background: #fff;
        border-radius: 14px;
        width: min(900px, 95vw);
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
        animation: scaleIn .25s ease;
    }

    .create-modal-header {
        padding: 1.15rem 1.5rem;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .create-modal-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1rem;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .create-modal-header .btn-close-modal {
        background: #f3f4f6;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #6b7280;
        transition: all .15s;
        font-size: .9rem;
    }

    .create-modal-header .btn-close-modal:hover {
        background: #e5e7eb;
        color: #374151;
    }

    .create-modal-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .create-modal-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    .form-field {
        display: flex;
        flex-direction: column;
    }

    .form-field.full {
        grid-column: span 2;
    }

    .form-field label {
        font-size: .75rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: .25rem;
    }

    .form-field input,
    .form-field select,
    .form-field textarea {
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        transition: all .15s;
    }

    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .form-field .checkbox-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem 0;
    }

    .btn-create {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-create:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
    }

    .btn-create:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    .btn-secondary-action {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .15s;
    }

    .btn-secondary-action:hover {
        background: #f9fafb;
    }

    /* ── Line Items Section ───────────────────────── */
    .line-items-section {
        margin-top: 1rem;
    }

    .line-items-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .5rem;
    }

    .line-items-header label {
        font-size: .75rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .4px;
    }

    .btn-add-line {
        background: #f0f4ff;
        border: 1px dashed #667eea;
        color: #667eea;
        padding: .3rem .75rem;
        border-radius: 6px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
    }

    .btn-add-line:hover {
        background: #e0e7ff;
    }

    .line-items-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
    }

    .line-items-table thead th {
        background: #f9fafb;
        padding: .45rem .5rem;
        text-align: left;
        font-weight: 600;
        color: #6b7280;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .3px;
        border-bottom: 1px solid #e5e7eb;
    }

    .line-items-table tbody td {
        padding: .35rem .35rem;
        border-bottom: 1px solid #f3f4f6;
        vertical-align: middle;
    }

    .line-items-table input {
        width: 100%;
        padding: .35rem .5rem;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: .82rem;
        color: #374151;
        transition: border-color .15s;
    }

    .line-items-table input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 2px rgba(102, 126, 234, .12);
    }

    .line-items-table input[type="number"] {
        text-align: right;
    }

    .btn-remove-line {
        background: none;
        border: none;
        color: #ef4444;
        cursor: pointer;
        padding: .2rem;
        border-radius: 4px;
        font-size: .9rem;
        transition: background .15s;
    }

    .btn-remove-line:hover {
        background: #fef2f2;
    }

    .line-total-cell {
        font-weight: 600;
        color: #374151;
        text-align: right;
        padding-right: .5rem;
        white-space: nowrap;
    }

    .line-items-empty {
        text-align: center;
        padding: 1rem;
        color: #9ca3af;
        font-size: .85rem;
    }

    .line-items-summary {
        display: flex;
        justify-content: flex-end;
        margin-top: .5rem;
        padding-top: .5rem;
        border-top: 2px solid #e5e7eb;
    }

    .line-items-summary .summary-label {
        font-weight: 600;
        color: #374151;
        font-size: .88rem;
        margin-right: .75rem;
    }

    .line-items-summary .summary-value {
        font-weight: 700;
        color: #1a1a2e;
        font-size: .92rem;
    }

    .validation-hint {
        color: #ef4444;
        font-size: .75rem;
        margin-top: .25rem;
    }

    /* ── Customer badge & Dropdowns ──────────────────── */
    .cn-selected-customer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 8px;
        padding: .5rem .75rem;
    }

    .cn-bp-clear {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        width: 26px;
        height: 26px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .8rem;
    }

    .cn-bp-clear:hover {
        background: #dc2626;
        color: #fff;
        border-color: #dc2626;
    }

    .cn-dropdown {
        position: absolute;
        z-index: 10001;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        max-height: 250px;
        overflow-y: auto;
        width: 100%;
        box-shadow: 0 8px 25px rgba(0, 0, 0, .12);
        margin-top: 2px;
    }

    .cn-dropdown-item {
        padding: .45rem .75rem;
        cursor: pointer;
        transition: background .12s;
        font-size: .85rem;
        border-bottom: 1px solid #f9fafb;
    }

    .cn-dropdown-item:hover {
        background: #f0fdf4;
    }

    .line-items-table select {
        width: 100%;
        padding: .35rem .4rem;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: .82rem;
        color: #374151;
        background: #fff;
    }

    .line-items-table select:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 2px rgba(102, 126, 234, .12);
    }

    /* Reason highlight */
    .reason-box {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: .75rem 1rem;
        margin-bottom: 1rem;
    }

    .reason-box strong {
        color: #374151;
        font-size: .82rem;
    }

    .reason-box p {
        margin: 0;
        color: #1a1a2e;
        font-size: .88rem;
    }

    /* ── Empty / Loading ─────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 1.8rem;
        color: #9ca3af;
    }

    .empty-state h6 {
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
    }

    .empty-state p {
        color: #9ca3af;
        font-size: .88rem;
    }

    .loading-state {
        text-align: center;
        padding: 3rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    /* ── Alert ───────────────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    /* ── Animations ──────────────────────────────────── */
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }

        to {
            transform: translateX(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@media (max-width:768px) {
        .cn-header {
            flex-direction: column;
        }

        .filter-bar {
            flex-direction: column;
        }

        .detail-grid,
        .form-grid {
            grid-template-columns: 1fr;
        }

        .form-field.full {
            grid-column: span 1;
        }
    }
</style>

<div class="cn-page">
    <div class="container-fluid">

        <!-- ━━━ Header ━━━ -->
        <div class="cn-header">
            <div class="cn-header-left">
                <div class="cn-header-icon"><i class="bi bi-file-earmark-minus"></i></div>
                <div>
                    <h2>Credit Notes</h2>
                    <p>Manage customer credits and adjustments</p>
                </div>
            </div>
            <MudButton Class="btn-cn-gradient" Href="/credit-notes/create">
                <i class="bi bi-plus-lg"></i> New Credit Note
            </MudButton>
        </div>

        <!-- ━━━ Alerts ━━━ -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner error-alert">
                <i class="bi bi-exclamation-octagon-fill"></i>
                <div style="flex:1;">@errorMessage</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => errorMessage = null" Size="Size.Small"
                               Style="color:inherit;opacity:.45;" />
            </div>
        }

        <!-- ━━━ Filter Bar ━━━ -->
        <div class="filter-bar">
            <div class="filter-field">
                <label>Credit Note #</label>
                <input type="text" @bind="creditNoteNumberFilter" @bind:event="oninput" @bind:after="OnFilterChanged"
                       placeholder="e.g., CN-001" />
            </div>
            <div class="filter-field">
                <label>Customer</label>
                <input type="text" @bind="customerFilter" @bind:event="oninput" @bind:after="OnFilterChanged"
                       placeholder="Customer code" />
            </div>
            <div class="filter-field">
                <label>Status</label>
                <select @bind="statusFilter" @bind:after="OnFilterChanged">
                    <option value="">All Statuses</option>
                    @foreach (CreditNoteStatus status in Enum.GetValues(typeof(CreditNoteStatus)))
                    {
                        <option value="@(((int)status).ToString())">@status</option>
                    }
                </select>
            </div>
            <div class="filter-field">
                <label>From Date</label>
                <MudDatePicker Date="fromDate" DateChanged="@((DateTime? d) => { fromDate = d; OnFilterChanged(); })"
                               Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="@AppSettings.DateFormat"
                               Editable="true" />
            </div>
            <div class="filter-field">
                <label>To Date</label>
                <MudDatePicker Date="toDate" DateChanged="@((DateTime? d) => { toDate = d; OnFilterChanged(); })"
                               Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="@AppSettings.DateFormat"
                               Editable="true" />
            </div>
            <div class="filter-actions-row">
                <MudButton Class="btn-clear" OnClick="ClearFilter">
                    <i class="bi bi-x-circle"></i> Clear
                </MudButton>
            </div>
        </div>

        <!-- ━━━ Content ━━━ -->
        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner-border" style="color:#667eea;width:2.5rem;height:2.5rem;" role="status"></div>
                <p style="margin-top:.75rem;color:#6b7280;font-weight:500;">Loading credit notes...</p>
            </div>
        }
        else if (creditNotes?.Any() == true)
        {
            <div class="cn-table-wrap">
                <div class="cn-table-header">
                    <h6><i class="bi bi-table"></i> Credit Notes</h6>
                    <span class="cn-count-badge">@totalCount total</span>
                </div>
                <MudTable @ref="@_table" Items="@creditNotes" RowsPerPage="@_pageSize" Hover="true" Striped="true"
                          Dense="true" Filter="new Func<CreditNoteDto, bool>(_quickFilter)" Breakpoint="Breakpoint.Sm"
                          Loading="@isLoading" LoadingProgressColor="Color.Primary" T="CreditNoteDto" Elevation="0"
                          Style="background:transparent;">
                    <HeaderContent>
                        <MudTh>Credit Note #</MudTh>
                        <MudTh>Customer</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Reason</MudTh>
                        <MudTh Style="text-align:right">Total</MudTh>
                        <MudTh Style="text-align:right">Balance</MudTh>
                        <MudTh Style="width:100px">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Credit Note #"><span
                            class="cn-number">@FormatCreditNoteNumber(context.CreditNoteNumber)</span></MudTd>
                            <MudTd DataLabel="Customer">
                                <div class="customer-info">
                                    <span class="name">@context.CardName</span>
                                    <span class="code">@context.CardCode</span>
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Date"><span
                                style="font-size:.85rem;color:#374151;">@context.CreditNoteDate.ToString("dd MMM yyyy")</span></MudTd>
                                <MudTd DataLabel="Type">
                                    <span class="type-badge @GetTypeCssClass(context.Type)">@context.TypeName</span>
                                </MudTd>
                                <MudTd DataLabel="Status">
                                    <span class="status-badge @GetStatusCssClass(context.Status)">@context.StatusName</span>
                                </MudTd>
                                <MudTd DataLabel="Reason">
                                    <span title="@context.Reason"
                                          style="font-size:.85rem;color:#6b7280;">@TruncateText(context.Reason, 30)</span>
                                </MudTd>
                                <MudTd DataLabel="Total" Style="text-align:right">
                                    <span class="amount-cell">@context.DocTotal.ToString("N2")</span>
                                </MudTd>
                                <MudTd DataLabel="Balance" Style="text-align:right">
                                    <span
                                    class="balance-cell @(context.Balance > 0 ? "has-balance" : "zero")">@context.Balance.ToString("N2")</span>
                                </MudTd>
                                <MudTd DataLabel="Actions">
                                    <div style="display:flex;gap:.3rem;">
                                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                       OnClick="() => ViewCreditNote(context)" Title="View Details" Class="action-btn view"
                                                       Size="Size.Small" />
                                        @if (context.Status == CreditNoteStatus.Pending)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                           OnClick="() => ApproveCreditNote(context.Id)" Title="Approve" Class="action-btn approve"
                                                           Size="Size.Small" />
                                        }
                                        @if (context.Status == CreditNoteStatus.Draft || context.Status ==
                                                                                                                                                    CreditNoteStatus.Cancelled)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           OnClick="() => DeleteCreditNote(context.Id)" Title="Delete" Class="action-btn delete"
                                                           Size="Size.Small" />
                                        }
                                    </div>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <div class="pager-row">
                                    <div class="page-size-wrap">
                                        <span>Show</span>
                                        <select @bind="_pageSize">
                                            <option value="10">10</option>
                                            <option value="25">25</option>
                                            <option value="50">50</option>
                                            <option value="100">100</option>
                                        </select>
                                        <span>per page</span>
                                    </div>
                                    <MudPagination SelectedChanged="PageChanged"
                                                   Count="@((_table.GetFilteredItemsCount() + _table.RowsPerPage - 1) / _table.RowsPerPage)"
                                                   Class="pa-4" />
                                </div>
                            </PagerContent>
                        </MudTable>
                    </div>
                }
        else
                {
                    <div class="empty-state">
                        <div class="empty-icon"><i class="bi bi-file-earmark-minus"></i></div>
                        <h6>No credit notes found</h6>
                        <p>Create a new credit note or adjust your filters.</p>
                    </div>
                }
            </div>
        </div>

        <!-- ━━━ View Credit Note Drawer ━━━ -->
        @if (selectedCreditNote != null)
        {
            <div class="modal-backdrop-custom" @onclick="() => selectedCreditNote = null"></div>
            <div class="detail-drawer">
                <div class="drawer-header">
                    <h5><i class="bi bi-file-earmark-minus me-2"></i>Credit Note: @selectedCreditNote.CreditNoteNumber</h5>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => selectedCreditNote = null"
                                   Class="btn-close-drawer" Size="Size.Small" />
                </div>
                <div class="drawer-body">
                    <div class="detail-grid">
                        <div class="detail-item">
                            <div class="detail-label">Customer</div>
                            <div class="detail-value">@selectedCreditNote.CardCode — @selectedCreditNote.CardName</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Date</div>
                            <div class="detail-value">@selectedCreditNote.CreditNoteDate.ToString("dd MMM yyyy")</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Type</div>
                            <div class="detail-value"><span
                                class="type-badge @GetTypeCssClass(selectedCreditNote.Type)">@selectedCreditNote.TypeName</span>
                            </div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Status</div>
                            <div class="detail-value"><span
                                class="status-badge @GetStatusCssClass(selectedCreditNote.Status)">@selectedCreditNote.StatusName</span>
                            </div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Currency</div>
                            <div class="detail-value">@selectedCreditNote.Currency</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Restock Items</div>
                            <div class="detail-value">@(selectedCreditNote.RestockItems ? "Yes" : "No")</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(selectedCreditNote.Reason))
                    {
                        <div class="reason-box">
                            <strong>Reason</strong>
                            <p>@selectedCreditNote.Reason</p>
                        </div>
                    }

                    @if (selectedCreditNote.Lines?.Any() == true)
                    {
                        <div class="detail-section-title"><i class="bi bi-list-ul"></i> Credit Note Lines</div>
                        <table class="lines-table">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Description</th>
                                    <th style="text-align:right">Qty</th>
                                    <th style="text-align:right">Unit Price</th>
                                    <th style="text-align:right">Total</th>
                                    <th style="text-align:center">Restocked</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in selectedCreditNote.Lines)
                                {
                                    <tr>
                                        <td><span style="font-weight:600;color:#667eea;">@line.ItemCode</span></td>
                                        <td>@line.ItemDescription</td>
                                        <td style="text-align:right;font-weight:600;">@line.Quantity</td>
                                        <td style="text-align:right;">@line.UnitPrice.ToString("N2")</td>
                                        <td style="text-align:right;font-weight:600;">@line.LineTotal.ToString("N2")</td>
                                        <td style="text-align:center;">
                                            @if (line.IsRestocked)
                                            {
                                                <i class="bi bi-check-circle-fill" style="color:#059669;"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-dash-circle" style="color:#d1d5db;"></i>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="4" style="text-align:right;font-weight:600;">Subtotal:</td>
                                    <td style="text-align:right;font-weight:600;">@selectedCreditNote.SubTotal.ToString("N2")</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td colspan="4" style="text-align:right;font-weight:600;">Tax:</td>
                                    <td style="text-align:right;">@selectedCreditNote.TaxAmount.ToString("N2")</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="total-banner">
                            <span class="total-label">Total</span>
                            <span class="total-value">@selectedCreditNote.DocTotal.ToString("N2")</span>
                        </div>
                    }
                </div>
                <div class="drawer-footer">
                    <MudButton Class="btn-secondary-action" OnClick="() => selectedCreditNote = null">Close</MudButton>
                </div>
            </div>
        }

        <!-- ━━━ Create Credit Note Modal ━━━ -->
        @if (showCreateModal)
        {
            <div class="create-modal-overlay" @onclick="() => showCreateModal = false">
                <div class="create-modal" @onclick:stopPropagation="true">
                    <div class="create-modal-header">
                        <h5><i class="bi bi-plus-circle"></i> New Credit Note</h5>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => showCreateModal = false"
                                       Class="btn-close-modal" Size="Size.Small" />
                    </div>
                    <div class="create-modal-body">
                        <div class="form-grid">
                            <div class="form-field full">
                                <label>Customer *</label>
                                @if (selectedBusinessPartner != null)
                                {
                                    <div class="cn-selected-customer">
                                        <div>
                                            <span style="font-weight:700;color:#065f46;"><i class="bi bi-check-circle-fill"
                                                                                                style="color:#059669;margin-right:.3rem;"></i>@selectedBusinessPartner.CardCode</span>
                                                <span style="color:#6b7280;margin-left:.5rem;">@selectedBusinessPartner.CardName</span>
                                            </div>
                                            <button type="button" class="cn-bp-clear" @onclick="ClearSelectedBP"><i
                                                class="bi bi-x"></i></button>
                                            </div>
                                        }
                                else
                                        {
                                            <div style="position:relative;">
                                                <input type="text" value="@bpSearchTerm" @oninput="OnBPSearchInput"
                                                       @onfocus="() => showBPDropdown = true" @onblur="OnBPSearchBlur"
                                                       placeholder="Search by code or name…" autocomplete="off" />
                                                @if (showBPDropdown && filteredBusinessPartners.Any())
                                                {
                                                    <div class="cn-dropdown" @onmousedown:preventDefault>
                                                        @foreach (var bp in filteredBusinessPartners.Take(15))
                                                        {
                                                            <div class="cn-dropdown-item" @onmousedown="() => SelectBusinessPartner(bp)">
                                                                <strong>@bp.CardCode</strong> — <span style="color:#6b7280;">@bp.CardName</span>
                                                            </div>
                                                        }
                                                        @if (filteredBusinessPartners.Count() > 15)
                                                        {
                                                            <div class="cn-dropdown-item" style="color:#9ca3af;text-align:center;font-size:.82rem;">
                                                                @filteredBusinessPartners.Count() total — type more to filter
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <div class="form-field">
                                        <label>Type</label>
                                        <select @bind="newCreditNote.Type">
                                            @foreach (CreditNoteType type in Enum.GetValues(typeof(CreditNoteType)))
                                            {
                                                <option value="@type">@type</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-field">
                                        <label>Currency</label>
                                        <select @bind="newCreditNote.Currency">
                                            <option value="USD">USD</option>
                                            <option value="ZIG">ZIG</option>
                                        </select>
                                    </div>
                                    <div class="form-field full">
                                        <label>Reason *</label>
                                        <textarea @bind="newCreditNote.Reason" rows="2" placeholder="Reason for credit note"></textarea>
                                    </div>
                                    <div class="form-field">
                                        <label>Options</label>
                                        <div class="checkbox-row">
                                            <input type="checkbox" @bind="newCreditNote.RestockItems" id="restockCheck" />
                                            <label for="restockCheck" style="text-transform:none;font-size:.88rem;color:#374151;">Restock
                                                Items</label>
                                            </div>
                                        </div>
                                        <div class="form-field">
                                            <label>Restock Warehouse</label>
                                            <select @bind="newCreditNote.RestockWarehouseCode">
                                                <option value="">— Select —</option>
                                                @foreach (var wh in cachedWarehouses)
                                                {
                                                    <option value="@wh.WarehouseCode">@wh.WarehouseCode</option>
                                                }
                                            </select>
                                        </div>
                                    </div>

                                    <!-- Line Items Section -->
                                    <div class="line-items-section">
                                        <div class="line-items-header">
                                            <label>Line Items *</label>
                                            <button type="button" class="btn-add-line" @onclick="AddLine">
                                                <i class="bi bi-plus-lg"></i> Add Item
                                            </button>
                                        </div>
                                        @if (newCreditNote.Lines.Count > 0)
                                        {
                                            <div style="overflow-x:auto;">
                                                <table class="line-items-table">
                                                    <thead>
                                                        <tr>
                                                            <th style="min-width:120px;">Item Code</th>
                                                            <th style="min-width:150px;">Description</th>
                                                            <th style="min-width:75px;">Qty</th>
                                                            <th style="min-width:90px;">Unit Price</th>
                                                            <th style="min-width:70px;">Disc %</th>
                                                            <th style="min-width:70px;">Tax %</th>
                                                            <th style="min-width:100px;">Warehouse</th>
                                                            <th style="min-width:80px; text-align:right;">Line Total</th>
                                                            <th style="width:36px;"></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @for (int i = 0; i < newCreditNote.Lines.Count; i++)
                                                        {
                                                            var idx = i;
                                                            var line = newCreditNote.Lines[idx];
                                                            var lineState = GetCnLineState(idx);
                                                            <tr>
                                                                <td style="position:relative;">
                                                                    <input type="text" value="@line.ItemCode"
                                                                           @oninput="(e) => OnCnItemCodeInput(idx, e.Value?.ToString())"
                                                                           @onfocus="() => OnCnItemCodeFocus(idx)" @onblur="() => OnCnItemCodeBlur(idx)"
                                                                           placeholder="Search item…" autocomplete="off" />
                                                                    @if (lineState.ShowDropdown && lineState.FilteredProducts.Any())
                                                                    {
                                                                        <div class="cn-dropdown" style="top:100%;left:0;min-width:260px;"
                                                                             @onmousedown:preventDefault>
                                                                            @foreach (var product in lineState.FilteredProducts.Take(10))
                                                                            {
                                                                                <div class="cn-dropdown-item"
                                                                                     @onmousedown="() => SelectCnProduct(idx, product)">
                                                                                    <div style="font-weight:600;font-size:.82rem;">@product.ItemCode</div>
                                                                                    <small style="color:#6b7280;">@TruncateText(product.ItemName, 30)</small>
                                                                                    <span
                                                                                    style="float:right;font-size:.75rem;font-weight:600;color:#2563eb;">@product.Price.ToString("N2")</span>
                                                                                </div>
                                                                            }
                                                                            @if (lineState.FilteredProducts.Count > 10)
                                                                            {
                                                                                <div class="cn-dropdown-item"
                                                                                     style="color:#9ca3af;text-align:center;font-size:.8rem;">
                                                                                    +@(lineState.FilteredProducts.Count - 10) more…
                                                                                </div>
                                                                            }
                                                                        </div>
                                                                    }
                                                                </td>
                                                                <td>
                                                                    @if (!string.IsNullOrEmpty(line.ItemDescription))
                                                                    {
                                                                        <span style="font-size:.82rem;color:#374151;">@TruncateText(line.ItemDescription,
                                                                                                                                                                                                25)</span>
                                                                        }
                                                            else
                                                                        {
                                                                            <span style="font-size:.8rem;color:#9ca3af;">—</span>
                                                                        }
                                                                    </td>
                                                                    <td><input type="number" @bind="line.Quantity" min="0.0001" step="1" /></td>
                                                                    <td><input type="number" @bind="line.UnitPrice" min="0" step="0.01" /></td>
                                                                    <td><input type="number" @bind="line.DiscountPercent" min="0" max="100" step="0.01" />
                                                                    </td>
                                                                    <td><input type="number" @bind="line.TaxPercent" min="0" max="100" step="0.01" /></td>
                                                                    <td>
                                                                        <select @bind="line.WarehouseCode">
                                                                            <option value="">—</option>
                                                                            @foreach (var wh in cachedWarehouses)
                                                                            {
                                                                                <option value="@wh.WarehouseCode">@wh.WarehouseCode</option>
                                                                            }
                                                                        </select>
                                                                    </td>
                                                                    <td class="line-total-cell">@CalculateLineTotal(line).ToString("N2")</td>
                                                                    <td>
                                                                        <button type="button" class="btn-remove-line" @onclick="() => RemoveLine(idx)">
                                                                            <i class="bi bi-trash"></i>
                                                                        </button>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                                <div class="line-items-summary">
                                                    <span class="summary-label">Grand Total:</span>
                                                    <span class="summary-value">@CalculateGrandTotal().ToString("N2")</span>
                                                </div>
                                            }
                                else
                                            {
                                                <div class="line-items-empty">
                                                    <i class="bi bi-box"></i> No items added yet. Click <strong>Add Item</strong> to begin.
                                                </div>
                                            }
                                            @if (showLineItemsError)
                                            {
                                                <div class="validation-hint">At least one line item with a valid item code and quantity is required.
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="create-modal-footer">
                                        <MudButton Class="btn-secondary-action" OnClick="() => showCreateModal = false">Cancel</MudButton>
                                        <MudButton Class="btn-create" OnClick="CreateCreditNote" Disabled="@isCreating">
                                            @if (isCreating)
                                            {
                                                <span class="spinner-border spinner-border-sm"></span>
                                            }
                                            <span>Create Credit Note</span>
                                        </MudButton>
                                    </div>
                                </div>
                            </div>
                        }

@code {
    private MudTable<CreditNoteDto>? _table;
    private int _pageSize = 10;
    private List<CreditNoteDto>? creditNotes;
    private CreditNoteDto? selectedCreditNote;
    private bool isLoading = true;
    private bool isCreating = false;
    private bool showCreateModal = false;
    private string? errorMessage;

    // Filters
    private string? creditNoteNumberFilter;
    private string? customerFilter;
    private string? statusFilter;
    private DateTime? fromDate;
    private DateTime? toDate;

    // Debounce timer
    private System.Timers.Timer? debounceTimer;
    private const int DebounceDelay = 400;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10000;
    private int totalPages = 1;
    private int totalCount = 0;

    // New credit note
    private CreateCreditNoteRequest newCreditNote = new();
    private bool showLineItemsError = false;

    // Master data caches
    private List<ProductDto> cachedProducts = new();
    private List<WarehouseDto> cachedWarehouses = new();
    private List<BusinessPartnerDto> allBusinessPartners = new();
    private bool isMasterDataLoaded = false;

    // Business partner autocomplete
    private BusinessPartnerDto? selectedBusinessPartner;
    private string? bpSearchTerm;
    private bool showBPDropdown = false;

    // Line item product autocomplete state
    private Dictionary<int, CnLineState> cnLineStates = new();

    private class CnLineState
    {
        public string SearchTerm { get; set; } = string.Empty;
        public bool ShowDropdown { get; set; } = false;
        public List<ProductDto> FilteredProducts { get; set; } = new();
    }

    private IEnumerable<BusinessPartnerDto> filteredBusinessPartners
    {
        get
        {
            if (string.IsNullOrWhiteSpace(bpSearchTerm)) return allBusinessPartners.Take(20);
            var s = bpSearchTerm.ToLowerInvariant();
            return allBusinessPartners.Where(bp =>
                (bp.CardCode?.ToLowerInvariant().Contains(s) ?? false) ||
                (bp.CardName?.ToLowerInvariant().Contains(s) ?? false)).Take(50);
        }
    }

    private bool _quickFilter(CreditNoteDto note)
    {
        if (!string.IsNullOrWhiteSpace(creditNoteNumberFilter)
        && !(note.CreditNoteNumber?.Contains(creditNoteNumberFilter, StringComparison.OrdinalIgnoreCase) == true))
            return false;
        return true;
    }

    private void PageChanged(int i)
    {
        _table.NavigateTo(i - 1);
    }

    protected override async Task OnInitializedAsync()
    {
        // Default date range to current month so SAP queries are always date-filtered
        fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        toDate = DateTime.Today;
        await LoadCreditNotes();
        _ = LoadMasterDataAsync();
        await AuditService.LogAsync(AuditActions.ViewCreditNotes, "CreditNote", null);
    }

    private async Task LoadMasterDataAsync()
    {
        try
        {
            var productsTask = CacheService.GetProductsAsync();
            var warehousesTask = CacheService.GetWarehousesAsync();
            var bpTask = CacheService.GetBusinessPartnersAsync();
            await Task.WhenAll(productsTask, warehousesTask, bpTask);
            cachedProducts = await productsTask ?? new();
            cachedWarehouses = await warehousesTask ?? new();
            allBusinessPartners = await bpTask ?? new();
            isMasterDataLoaded = true;
            await InvokeAsync(StateHasChanged);
        }
        catch { /* master data load failure is non-fatal */ }
    }

    private async Task LoadCreditNotes()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            CreditNoteStatus? status = null;
            if (!string.IsNullOrEmpty(statusFilter) && int.TryParse(statusFilter, out var statusInt))
            {
                status = (CreditNoteStatus)statusInt;
            }

            var response = await CreditNoteService.GetCreditNotesAsync(currentPage, pageSize, status, customerFilter, fromDate,
            toDate);
            if (response != null)
            {
                creditNotes = response.CreditNotes;
                totalCount = response.TotalCount;
                totalPages = response.TotalPages;
            }
            else
            {
                errorMessage = "Failed to load credit notes.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnFilterChanged()
    {
        debounceTimer?.Stop();
        debounceTimer?.Dispose();

        debounceTimer = new System.Timers.Timer(DebounceDelay);
        debounceTimer.Elapsed += async (sender, e) =>
        {
            debounceTimer?.Stop();
            await InvokeAsync(async () =>
    {
        currentPage = 1;
        await LoadCreditNotes();
        StateHasChanged();
    });
        };
        debounceTimer.AutoReset = false;
        debounceTimer.Start();
    }

    private async Task ClearFilter()
    {
        creditNoteNumberFilter = null;
        customerFilter = null;
        statusFilter = null;
        fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        toDate = DateTime.Today;
        currentPage = 1;
        await LoadCreditNotes();
    }

    private void ViewCreditNote(CreditNoteDto note)
    {
        selectedCreditNote = note;
    }

    private async Task ApproveCreditNote(int id)
    {
        var result = await CreditNoteService.ApproveAsync(id);
        if (result != null)
        {
            await AuditService.LogAsync(AuditActions.ApproveCreditNote, "CreditNote", id.ToString());
            await LoadCreditNotes();
        }
    }

    private async Task DeleteCreditNote(int id)
    {
        var success = await CreditNoteService.DeleteCreditNoteAsync(id);
        if (success)
        {
            await AuditService.LogAsync(AuditActions.DeleteCreditNote, "CreditNote", id.ToString());
            await LoadCreditNotes();
        }
    }

    // ── Business Partner Selection ──
    private void OnBPSearchInput(ChangeEventArgs e)
    {
        bpSearchTerm = e.Value?.ToString();
        showBPDropdown = true;
    }

    private void SelectBusinessPartner(BusinessPartnerDto bp)
    {
        selectedBusinessPartner = bp;
        newCreditNote.CardCode = bp.CardCode ?? string.Empty;
        newCreditNote.CardName = bp.CardName;
        bpSearchTerm = null;
        showBPDropdown = false;
    }

    private void ClearSelectedBP()
    {
        selectedBusinessPartner = null;
        newCreditNote.CardCode = string.Empty;
        newCreditNote.CardName = null;
        bpSearchTerm = null;
    }

    private async Task OnBPSearchBlur()
    {
        await Task.Delay(150);
        showBPDropdown = false;
    }

    // ── Line Item Product Autocomplete ──
    private CnLineState GetCnLineState(int index)
    {
        if (!cnLineStates.ContainsKey(index))
            cnLineStates[index] = new CnLineState();
        return cnLineStates[index];
    }

    private void OnCnItemCodeInput(int index, string? value)
    {
        var line = newCreditNote.Lines[index];
        line.ItemCode = value ?? string.Empty;

        var state = GetCnLineState(index);
        state.SearchTerm = value ?? string.Empty;

        if (string.IsNullOrWhiteSpace(value))
        {
            state.FilteredProducts.Clear();
            state.ShowDropdown = false;
            line.ItemDescription = null;
            return;
        }

        var searchLower = value.ToLowerInvariant();
        var searchUpper = value.ToUpperInvariant();
        state.FilteredProducts = cachedProducts.Where(p =>
            (p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false) ||
            (p.ItemCode?.ToLowerInvariant().Contains(searchLower) ?? false) ||
            (p.ItemName?.ToLowerInvariant().Contains(searchLower) ?? false) ||
            (p.BarCode?.ToLowerInvariant().Contains(searchLower) ?? false))
            .OrderByDescending(p => p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false)
            .ThenBy(p => p.ItemCode)
            .ToList();

        state.ShowDropdown = state.FilteredProducts.Any();
    }

    private void OnCnItemCodeFocus(int index)
    {
        var state = GetCnLineState(index);
        if (!string.IsNullOrWhiteSpace(state.SearchTerm) && state.FilteredProducts.Any())
            state.ShowDropdown = true;
    }

    private async Task OnCnItemCodeBlur(int index)
    {
        await Task.Delay(150);
        var state = GetCnLineState(index);
        state.ShowDropdown = false;
    }

    private void SelectCnProduct(int index, ProductDto product)
    {
        var line = newCreditNote.Lines[index];
        line.ItemCode = product.ItemCode ?? string.Empty;
        line.ItemDescription = product.ItemName;
        line.UnitPrice = product.Price;
        if (string.IsNullOrEmpty(line.WarehouseCode))
            line.WarehouseCode = product.DefaultWarehouse;

        var state = GetCnLineState(index);
        state.SearchTerm = line.ItemCode;
        state.ShowDropdown = false;
    }

    // ── Line Management ──
    private void AddLine()
    {
        newCreditNote.Lines.Add(new CreateCreditNoteLineRequest());
        showLineItemsError = false;
    }

    private void RemoveLine(int index)
    {
        if (index >= 0 && index < newCreditNote.Lines.Count)
        {
            newCreditNote.Lines.RemoveAt(index);
            cnLineStates.Remove(index);
            // Re-key remaining states
            var newStates = new Dictionary<int, CnLineState>();
            foreach (var kvp in cnLineStates)
            {
                var newKey = kvp.Key > index ? kvp.Key - 1 : kvp.Key;
                newStates[newKey] = kvp.Value;
            }
            cnLineStates = newStates;
        }
    }

    private decimal CalculateLineTotal(CreateCreditNoteLineRequest line)
    {
        var subtotal = line.Quantity * line.UnitPrice;
        var afterDiscount = subtotal * (1m - line.DiscountPercent / 100m);
        var tax = afterDiscount * (line.TaxPercent / 100m);
        return afterDiscount + tax;
    }

    private decimal CalculateGrandTotal()
    {
        return newCreditNote.Lines.Sum(l => CalculateLineTotal(l));
    }

    private async Task CreateCreditNote()
    {
        if (string.IsNullOrEmpty(newCreditNote.CardCode) || string.IsNullOrEmpty(newCreditNote.Reason))
        {
            return;
        }

        if (newCreditNote.Lines.Count == 0 || !newCreditNote.Lines.Any(l => !string.IsNullOrWhiteSpace(l.ItemCode) && l.Quantity
> 0))
        {
            showLineItemsError = true;
            return;
        }

        showLineItemsError = false;
        isCreating = true;
        try
        {
            var result = await CreditNoteService.CreateCreditNoteAsync(newCreditNote);
            if (result != null)
            {
                showCreateModal = false;
                newCreditNote = new();
                selectedBusinessPartner = null;
                bpSearchTerm = null;
                cnLineStates.Clear();
                await LoadCreditNotes();
            }
        }
        finally
        {
            isCreating = false;
        }
    }

    private string GetStatusCssClass(CreditNoteStatus status) => status switch
    {
        CreditNoteStatus.Draft => "draft",
        CreditNoteStatus.Pending => "pending",
        CreditNoteStatus.Approved => "approved",
        CreditNoteStatus.Applied => "applied",
        CreditNoteStatus.PartiallyApplied => "partial",
        CreditNoteStatus.Cancelled => "cancelled",
        CreditNoteStatus.Voided => "voided",
        _ => "draft"
    };

    private string GetTypeCssClass(CreditNoteType type) => type switch
    {
        CreditNoteType.Return => "return",
        CreditNoteType.Refund => "refund",
        CreditNoteType.Adjustment => "adjustment",
        CreditNoteType.Cancellation => "cancellation",
        _ => ""
    };

    private string TruncateText(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "—";
        return text.Length <= maxLength ? text : text.Substring(0, maxLength) + "...";
    }

    private string FormatCreditNoteNumber(string? creditNoteNumber)
    {
        if (string.IsNullOrEmpty(creditNoteNumber)) return "—";
        if (creditNoteNumber.StartsWith("SAP-CN", StringComparison.OrdinalIgnoreCase))
        {
            return creditNoteNumber.Substring(6).TrimStart('-', ' ');
        }
        return creditNoteNumber;
    }

    public void Dispose()
    {
        debounceTimer?.Stop();
        debounceTimer?.Dispose();
    }
}