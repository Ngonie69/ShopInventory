@page "/credit-notes"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Cashier")]
@inject ICreditNoteService CreditNoteService
@inject NavigationManager NavigationManager
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Credit Notes - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .cn-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Header ──────────────────────────────────────── */
    .cn-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .cn-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .cn-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .cn-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .cn-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .btn-cn-gradient {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 2px 8px rgba(102, 126, 234, .25);
        cursor: pointer;
    }

    .btn-cn-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .4);
        color: #fff;
    }

    /* ── Filter Bar ──────────────────────────────────── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        align-items: flex-end;
        padding: 1rem 1.25rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .filter-bar .filter-field {
        flex: 1;
        min-width: 140px;
    }

    .filter-bar .filter-field label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .3rem;
    }

    .filter-bar .filter-field input,
    .filter-bar .filter-field select {
        width: 100%;
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        background: #fff;
        transition: all .15s;
    }

    .filter-bar .filter-field input:focus,
    .filter-bar .filter-field select:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .filter-actions-row {
        display: flex;
        gap: .5rem;
        align-items: flex-end;
    }

    .btn-search {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-search:hover {
        opacity: .92;
        transform: translateY(-1px);
    }

    .btn-clear {
        background: #fff;
        color: #6b7280;
        border: 1px solid #d1d5db;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-clear:hover {
        background: #f3f4f6;
    }

    /* ── Table ───────────────────────────────────────── */
    .cn-table-wrap {
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #fff;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .cn-table-header {
        padding: .85rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
    }

    .cn-table-header h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .92rem;
    }

    .cn-count-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #374151;
    }

    /* ── Status & Type Badges ────────────────────────── */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .73rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-badge.draft {
        background: #f3f4f6;
        color: #6b7280;
    }

    .status-badge.pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-badge.approved {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.applied {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-badge.partial {
        background: #e0e7ff;
        color: #3730a3;
    }

    .status-badge.cancelled {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-badge.voided {
        background: #f3f4f6;
        color: #374151;
    }

    .type-badge {
        display: inline-flex;
        align-items: center;
        padding: .15rem .55rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
    }

    .type-badge.return {
        background: #e0e7ff;
        color: #3730a3;
    }

    .type-badge.refund {
        background: #d1fae5;
        color: #065f46;
    }

    .type-badge.adjustment {
        background: #fef3c7;
        color: #92400e;
    }

    .type-badge.cancellation {
        background: #fee2e2;
        color: #991b1b;
    }

    /* ── Cell Styles ─────────────────────────────────── */
    .cn-number {
        font-weight: 700;
        color: #667eea;
        font-family: 'Space Grotesk', monospace;
        font-size: .88rem;
    }

    .customer-info .name {
        font-weight: 600;
        font-size: .85rem;
        color: #1a1a2e;
    }

    .customer-info .code {
        font-size: .75rem;
        color: #9ca3af;
        font-family: 'Space Grotesk', monospace;
    }

    .amount-cell {
        font-weight: 700;
        color: #1a1a2e;
        font-family: 'Space Grotesk', monospace;
        font-size: .88rem;
    }

    .balance-cell {
        font-weight: 700;
        font-family: 'Space Grotesk', monospace;
        font-size: .88rem;
    }

    .balance-cell.has-balance {
        color: #d97706;
    }

    .balance-cell.zero {
        color: #059669;
    }

    /* ── Action Buttons ──────────────────────────────── */
    .action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .85rem;
    }

    .action-btn:hover {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }

    .action-btn.view:hover {
        background: #ede9fe;
        color: #667eea;
        border-color: #c4b5fd;
    }

    .action-btn.approve:hover {
        background: #d1fae5;
        color: #059669;
        border-color: #6ee7b7;
    }

    .action-btn.delete:hover {
        background: #fee2e2;
        color: #dc2626;
        border-color: #fca5a5;
    }

    /* ── Drawer ──────────────────────────────────────── */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        z-index: 9998;
        animation: fadeIn .2s ease;
    }

    .detail-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(640px, 95vw);
        height: 100vh;
        background: #fff;
        z-index: 9999;
        box-shadow: -8px 0 30px rgba(0, 0, 0, .12);
        display: flex;
        flex-direction: column;
        animation: slideInRight .25s ease;
    }

    .drawer-header {
        padding: 1.15rem 1.5rem;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }

    .drawer-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .drawer-header .btn-close-drawer {
        background: rgba(255, 255, 255, .15);
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s;
        font-size: 1rem;
    }

    .drawer-header .btn-close-drawer:hover {
        background: rgba(255, 255, 255, .25);
    }

    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .drawer-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
        margin-bottom: 1.25rem;
    }

    .detail-item .detail-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
        margin-bottom: .15rem;
    }

    .detail-item .detail-value {
        font-size: .92rem;
        font-weight: 600;
        color: #1a1a2e;
    }

    .detail-section-title {
        font-weight: 600;
        color: #1a1a2e;
        font-size: .9rem;
        margin-bottom: .75rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    /* ── Lines Table ─────────────────────────────────── */
    .lines-table {
        width: 100%;
        font-size: .85rem;
        border-collapse: separate;
        border-spacing: 0;
    }

    .lines-table th {
        background: #f8fafc;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6b7280;
        font-weight: 600;
        padding: .6rem .75rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .lines-table td {
        padding: .55rem .75rem;
        border-bottom: 1px solid #f3f4f6;
        color: #374151;
    }

    .lines-table tr:last-child td {
        border-bottom: none;
    }

    .lines-table tfoot td {
        border-top: 2px solid #e5e7eb;
        background: #f8fafc;
    }

    /* Total Banner */
    .total-banner {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.25rem;
    }

    .total-banner .total-label {
        font-size: .9rem;
        font-weight: 500;
    }

    .total-banner .total-value {
        font-size: 1.4rem;
        font-weight: 700;
    }

    /* ── Create Modal ────────────────────────────────── */
    .create-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .5);
        z-index: 10000;
        display: flex;
        justify-content: center;
        align-items: center;
        animation: fadeIn .2s ease;
        padding: 1rem;
    }

    .create-modal {
        background: #fff;
        border-radius: 14px;
        width: min(600px, 95vw);
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
        animation: scaleIn .25s ease;
    }

    .create-modal-header {
        padding: 1.15rem 1.5rem;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .create-modal-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1rem;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .create-modal-header .btn-close-modal {
        background: #f3f4f6;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #6b7280;
        transition: all .15s;
        font-size: .9rem;
    }

    .create-modal-header .btn-close-modal:hover {
        background: #e5e7eb;
        color: #374151;
    }

    .create-modal-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .create-modal-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    .form-field {
        display: flex;
        flex-direction: column;
    }

    .form-field.full {
        grid-column: span 2;
    }

    .form-field label {
        font-size: .75rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: .25rem;
    }

    .form-field input,
    .form-field select,
    .form-field textarea {
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        transition: all .15s;
    }

    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .form-field .checkbox-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem 0;
    }

    .btn-create {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-create:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
    }

    .btn-create:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    .btn-secondary-action {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .15s;
    }

    .btn-secondary-action:hover {
        background: #f9fafb;
    }

    /* Reason highlight */
    .reason-box {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: .75rem 1rem;
        margin-bottom: 1rem;
    }

    .reason-box strong {
        color: #374151;
        font-size: .82rem;
    }

    .reason-box p {
        margin: 0;
        color: #1a1a2e;
        font-size: .88rem;
    }

    /* ── Empty / Loading ─────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 1.8rem;
        color: #9ca3af;
    }

    .empty-state h6 {
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
    }

    .empty-state p {
        color: #9ca3af;
        font-size: .88rem;
    }

    .loading-state {
        text-align: center;
        padding: 3rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    /* ── Alert ───────────────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    /* ── Animations ──────────────────────────────────── */
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }

        to {
            transform: translateX(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@media (max-width:768px) {
        .cn-header {
            flex-direction: column;
        }

        .filter-bar {
            flex-direction: column;
        }

        .detail-grid,
        .form-grid {
            grid-template-columns: 1fr;
        }

        .form-field.full {
            grid-column: span 1;
        }
    }
</style>

<div class="cn-page">
    <div class="container-fluid">

        <!-- ━━━ Header ━━━ -->
        <div class="cn-header">
            <div class="cn-header-left">
                <div class="cn-header-icon"><i class="bi bi-file-earmark-minus"></i></div>
                <div>
                    <h2>Credit Notes</h2>
                    <p>Manage customer credits and adjustments</p>
                </div>
            </div>
            <button class="btn-cn-gradient" @onclick="@(() => showCreateModal = true)">
                <i class="bi bi-plus-lg"></i> New Credit Note
            </button>
        </div>

        <!-- ━━━ Alerts ━━━ -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner error-alert">
                <i class="bi bi-exclamation-octagon-fill"></i>
                <div style="flex:1;">@errorMessage</div>
                <button style="background:none;border:none;color:inherit;opacity:.45;cursor:pointer;font-size:1rem;"
                        @onclick="() => errorMessage = null"><i class="bi bi-x-lg"></i></button>
            </div>
        }

        <!-- ━━━ Filter Bar ━━━ -->
        <div class="filter-bar">
            <div class="filter-field">
                <label>Credit Note #</label>
                <input type="text" @bind="creditNoteNumberFilter" @bind:event="oninput" @bind:after="OnFilterChanged"
                       placeholder="e.g., CN-001" />
            </div>
            <div class="filter-field">
                <label>Customer</label>
                <input type="text" @bind="customerFilter" @bind:event="oninput" @bind:after="OnFilterChanged"
                       placeholder="Customer code" />
            </div>
            <div class="filter-field">
                <label>Status</label>
                <select @bind="statusFilter" @bind:after="OnFilterChanged">
                    <option value="">All Statuses</option>
                    @foreach (CreditNoteStatus status in Enum.GetValues(typeof(CreditNoteStatus)))
                    {
                        <option value="@(((int)status).ToString())">@status</option>
                    }
                </select>
            </div>
            <div class="filter-field">
                <label>From Date</label>
                <input type="date" @bind="fromDate" @bind:after="OnFilterChanged" />
            </div>
            <div class="filter-field">
                <label>To Date</label>
                <input type="date" @bind="toDate" @bind:after="OnFilterChanged" />
            </div>
            <div class="filter-actions-row">
                <button class="btn-clear" @onclick="ClearFilter">
                    <i class="bi bi-x-circle"></i> Clear
                </button>
            </div>
        </div>

        <!-- ━━━ Content ━━━ -->
        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner-border" style="color:#667eea;width:2.5rem;height:2.5rem;" role="status"></div>
                <p style="margin-top:.75rem;color:#6b7280;font-weight:500;">Loading credit notes...</p>
            </div>
        }
        else if (creditNotes?.Any() == true)
        {
            <div class="cn-table-wrap">
                <div class="cn-table-header">
                    <h6><i class="bi bi-table"></i> Credit Notes</h6>
                    <span class="cn-count-badge">@totalCount total</span>
                </div>
                <MudTable @ref="@_table" Items="@creditNotes" RowsPerPage="10" Hover="true" Striped="true" Dense="true"
                          Filter="new Func<CreditNoteDto, bool>(_quickFilter)" Breakpoint="Breakpoint.Sm" Loading="@isLoading"
                          LoadingProgressColor="Color.Primary" T="CreditNoteDto" Elevation="0" Style="background:transparent;">
                    <HeaderContent>
                        <MudTh>Credit Note #</MudTh>
                        <MudTh>Customer</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Reason</MudTh>
                        <MudTh Style="text-align:right">Total</MudTh>
                        <MudTh Style="text-align:right">Balance</MudTh>
                        <MudTh Style="width:100px">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Credit Note #"><span
                            class="cn-number">@FormatCreditNoteNumber(context.CreditNoteNumber)</span></MudTd>
                            <MudTd DataLabel="Customer">
                                <div class="customer-info">
                                    <span class="name">@context.CardName</span>
                                    <span class="code">@context.CardCode</span>
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Date"><span
                                style="font-size:.85rem;color:#374151;">@context.CreditNoteDate.ToString("dd MMM yyyy")</span></MudTd>
                                <MudTd DataLabel="Type">
                                    <span class="type-badge @GetTypeCssClass(context.Type)">@context.TypeName</span>
                                </MudTd>
                                <MudTd DataLabel="Status">
                                    <span class="status-badge @GetStatusCssClass(context.Status)">@context.StatusName</span>
                                </MudTd>
                                <MudTd DataLabel="Reason">
                                    <span title="@context.Reason"
                                          style="font-size:.85rem;color:#6b7280;">@TruncateText(context.Reason, 30)</span>
                                </MudTd>
                                <MudTd DataLabel="Total" Style="text-align:right">
                                    <span class="amount-cell">@context.DocTotal.ToString("N2")</span>
                                </MudTd>
                                <MudTd DataLabel="Balance" Style="text-align:right">
                                    <span
                                    class="balance-cell @(context.Balance > 0 ? "has-balance" : "zero")">@context.Balance.ToString("N2")</span>
                                </MudTd>
                                <MudTd DataLabel="Actions">
                                    <div style="display:flex;gap:.3rem;">
                                        <button class="action-btn view" @onclick="() => ViewCreditNote(context)"
                                                title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        @if (context.Status == CreditNoteStatus.Pending)
                                        {
                                            <button class="action-btn approve" @onclick="() => ApproveCreditNote(context.Id)"
                                                    title="Approve">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        }
                                        @if (context.Status == CreditNoteStatus.Draft || context.Status ==
                                                                    CreditNoteStatus.Cancelled)
                                        {
                                            <button class="action-btn delete" @onclick="() => DeleteCreditNote(context.Id)"
                                                    title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        }
                                    </div>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudPagination SelectedChanged="PageChanged"
                                               Count="@((_table.GetFilteredItemsCount() + _table.RowsPerPage - 1) / _table.RowsPerPage)"
                                               Class="pa-4" />
                            </PagerContent>
                        </MudTable>
                    </div>
                }
        else
                {
                    <div class="empty-state">
                        <div class="empty-icon"><i class="bi bi-file-earmark-minus"></i></div>
                        <h6>No credit notes found</h6>
                        <p>Create a new credit note or adjust your filters.</p>
                    </div>
                }
            </div>
        </div>

        <!-- ━━━ View Credit Note Drawer ━━━ -->
        @if (selectedCreditNote != null)
        {
            <div class="modal-backdrop-custom" @onclick="() => selectedCreditNote = null"></div>
            <div class="detail-drawer">
                <div class="drawer-header">
                    <h5><i class="bi bi-file-earmark-minus me-2"></i>Credit Note: @selectedCreditNote.CreditNoteNumber</h5>
                    <button class="btn-close-drawer" @onclick="() => selectedCreditNote = null"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="drawer-body">
                    <div class="detail-grid">
                        <div class="detail-item">
                            <div class="detail-label">Customer</div>
                            <div class="detail-value">@selectedCreditNote.CardCode — @selectedCreditNote.CardName</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Date</div>
                            <div class="detail-value">@selectedCreditNote.CreditNoteDate.ToString("dd MMM yyyy")</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Type</div>
                            <div class="detail-value"><span
                                class="type-badge @GetTypeCssClass(selectedCreditNote.Type)">@selectedCreditNote.TypeName</span>
                            </div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Status</div>
                            <div class="detail-value"><span
                                class="status-badge @GetStatusCssClass(selectedCreditNote.Status)">@selectedCreditNote.StatusName</span>
                            </div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Currency</div>
                            <div class="detail-value">@selectedCreditNote.Currency</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Restock Items</div>
                            <div class="detail-value">@(selectedCreditNote.RestockItems ? "Yes" : "No")</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(selectedCreditNote.Reason))
                    {
                        <div class="reason-box">
                            <strong>Reason</strong>
                            <p>@selectedCreditNote.Reason</p>
                        </div>
                    }

                    @if (selectedCreditNote.Lines?.Any() == true)
                    {
                        <div class="detail-section-title"><i class="bi bi-list-ul"></i> Credit Note Lines</div>
                        <table class="lines-table">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Description</th>
                                    <th style="text-align:right">Qty</th>
                                    <th style="text-align:right">Unit Price</th>
                                    <th style="text-align:right">Total</th>
                                    <th style="text-align:center">Restocked</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in selectedCreditNote.Lines)
                                {
                                    <tr>
                                        <td><span style="font-weight:600;color:#667eea;">@line.ItemCode</span></td>
                                        <td>@line.ItemDescription</td>
                                        <td style="text-align:right;font-weight:600;">@line.Quantity</td>
                                        <td style="text-align:right;">@line.UnitPrice.ToString("N2")</td>
                                        <td style="text-align:right;font-weight:600;">@line.LineTotal.ToString("N2")</td>
                                        <td style="text-align:center;">
                                            @if (line.IsRestocked)
                                            {
                                                <i class="bi bi-check-circle-fill" style="color:#059669;"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-dash-circle" style="color:#d1d5db;"></i>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="4" style="text-align:right;font-weight:600;">Subtotal:</td>
                                    <td style="text-align:right;font-weight:600;">@selectedCreditNote.SubTotal.ToString("N2")</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td colspan="4" style="text-align:right;font-weight:600;">Tax:</td>
                                    <td style="text-align:right;">@selectedCreditNote.TaxAmount.ToString("N2")</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="total-banner">
                            <span class="total-label">Total</span>
                            <span class="total-value">@selectedCreditNote.DocTotal.ToString("N2")</span>
                        </div>
                    }
                </div>
                <div class="drawer-footer">
                    <button class="btn-secondary-action" @onclick="() => selectedCreditNote = null">Close</button>
                </div>
            </div>
        }

        <!-- ━━━ Create Credit Note Modal ━━━ -->
        @if (showCreateModal)
        {
            <div class="create-modal-overlay" @onclick="() => showCreateModal = false">
                <div class="create-modal" @onclick:stopPropagation="true">
                    <div class="create-modal-header">
                        <h5><i class="bi bi-plus-circle"></i> New Credit Note</h5>
                        <button class="btn-close-modal" @onclick="() => showCreateModal = false"><i class="bi bi-x-lg"></i></button>
                    </div>
                    <div class="create-modal-body">
                        <div class="form-grid">
                            <div class="form-field">
                                <label>Customer Code *</label>
                                <input type="text" @bind="newCreditNote.CardCode" placeholder="e.g., C001" />
                            </div>
                            <div class="form-field">
                                <label>Customer Name</label>
                                <input type="text" @bind="newCreditNote.CardName" />
                            </div>
                            <div class="form-field">
                                <label>Type</label>
                                <select @bind="newCreditNote.Type">
                                    @foreach (CreditNoteType type in Enum.GetValues(typeof(CreditNoteType)))
                                    {
                                        <option value="@type">@type</option>
                                    }
                                </select>
                            </div>
                            <div class="form-field">
                                <label>Currency</label>
                                <select @bind="newCreditNote.Currency">
                                    <option value="USD">USD</option>
                                    <option value="ZIG">ZIG</option>
                                </select>
                            </div>
                            <div class="form-field full">
                                <label>Reason *</label>
                                <textarea @bind="newCreditNote.Reason" rows="2" placeholder="Reason for credit note"></textarea>
                            </div>
                            <div class="form-field">
                                <label>Options</label>
                                <div class="checkbox-row">
                                    <input type="checkbox" @bind="newCreditNote.RestockItems" id="restockCheck" />
                                    <label for="restockCheck" style="text-transform:none;font-size:.88rem;color:#374151;">Restock
                                        Items</label>
                                    </div>
                                </div>
                                <div class="form-field">
                                    <label>Restock Warehouse</label>
                                    <input type="text" @bind="newCreditNote.RestockWarehouseCode" placeholder="Warehouse code" />
                                </div>
                            </div>
                        </div>
                        <div class="create-modal-footer">
                            <button class="btn-secondary-action" @onclick="() => showCreateModal = false">Cancel</button>
                            <button class="btn-create" @onclick="CreateCreditNote" disabled="@isCreating">
                                @if (isCreating)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                <span>Create Credit Note</span>
                            </button>
                        </div>
                    </div>
                </div>
            }

@code {
    private MudTable<CreditNoteDto>? _table;
    private List<CreditNoteDto>? creditNotes;
    private CreditNoteDto? selectedCreditNote;
    private bool isLoading = true;
    private bool isCreating = false;
    private bool showCreateModal = false;
    private string? errorMessage;

    // Filters
    private string? creditNoteNumberFilter;
    private string? customerFilter;
    private string? statusFilter;
    private DateTime? fromDate;
    private DateTime? toDate;

    // Debounce timer
    private System.Timers.Timer? debounceTimer;
    private const int DebounceDelay = 400;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalPages = 1;
    private int totalCount = 0;

    // New credit note
    private CreateCreditNoteRequest newCreditNote = new();

    private bool _quickFilter(CreditNoteDto note)
    {
        if (!string.IsNullOrWhiteSpace(creditNoteNumberFilter)
        && !(note.CreditNoteNumber?.Contains(creditNoteNumberFilter, StringComparison.OrdinalIgnoreCase) == true))
            return false;
        return true;
    }

    private void PageChanged(int i)
    {
        _table.NavigateTo(i - 1);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadCreditNotes();
    }

    private async Task LoadCreditNotes()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            CreditNoteStatus? status = null;
            if (!string.IsNullOrEmpty(statusFilter) && int.TryParse(statusFilter, out var statusInt))
            {
                status = (CreditNoteStatus)statusInt;
            }

            var response = await CreditNoteService.GetCreditNotesAsync(currentPage, pageSize, status, customerFilter, fromDate,
            toDate);
            if (response != null)
            {
                creditNotes = response.CreditNotes;
                totalCount = response.TotalCount;
                totalPages = response.TotalPages;
            }
            else
            {
                errorMessage = "Failed to load credit notes.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnFilterChanged()
    {
        debounceTimer?.Stop();
        debounceTimer?.Dispose();

        debounceTimer = new System.Timers.Timer(DebounceDelay);
        debounceTimer.Elapsed += async (sender, e) =>
        {
            debounceTimer?.Stop();
            await InvokeAsync(async () =>
    {
            currentPage = 1;
            await LoadCreditNotes();
            StateHasChanged();
        });
        };
        debounceTimer.AutoReset = false;
        debounceTimer.Start();
    }

    private async Task ClearFilter()
    {
        creditNoteNumberFilter = null;
        customerFilter = null;
        statusFilter = null;
        fromDate = null;
        toDate = null;
        currentPage = 1;
        await LoadCreditNotes();
    }

    private void ViewCreditNote(CreditNoteDto note)
    {
        selectedCreditNote = note;
    }

    private async Task ApproveCreditNote(int id)
    {
        var result = await CreditNoteService.ApproveAsync(id);
        if (result != null)
        {
            await LoadCreditNotes();
        }
    }

    private async Task DeleteCreditNote(int id)
    {
        var success = await CreditNoteService.DeleteCreditNoteAsync(id);
        if (success)
        {
            await LoadCreditNotes();
        }
    }

    private async Task CreateCreditNote()
    {
        if (string.IsNullOrEmpty(newCreditNote.CardCode) || string.IsNullOrEmpty(newCreditNote.Reason))
        {
            return;
        }

        isCreating = true;
        try
        {
            var result = await CreditNoteService.CreateCreditNoteAsync(newCreditNote);
            if (result != null)
            {
                showCreateModal = false;
                newCreditNote = new();
                await LoadCreditNotes();
            }
        }
        finally
        {
            isCreating = false;
        }
    }

    private string GetStatusCssClass(CreditNoteStatus status) => status switch
    {
        CreditNoteStatus.Draft => "draft",
        CreditNoteStatus.Pending => "pending",
        CreditNoteStatus.Approved => "approved",
        CreditNoteStatus.Applied => "applied",
        CreditNoteStatus.PartiallyApplied => "partial",
        CreditNoteStatus.Cancelled => "cancelled",
        CreditNoteStatus.Voided => "voided",
        _ => "draft"
    };

    private string GetTypeCssClass(CreditNoteType type) => type switch
    {
        CreditNoteType.Return => "return",
        CreditNoteType.Refund => "refund",
        CreditNoteType.Adjustment => "adjustment",
        CreditNoteType.Cancellation => "cancellation",
        _ => ""
    };

    private string TruncateText(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "—";
        return text.Length <= maxLength ? text : text.Substring(0, maxLength) + "...";
    }

    private string FormatCreditNoteNumber(string? creditNoteNumber)
    {
        if (string.IsNullOrEmpty(creditNoteNumber)) return "—";
        if (creditNoteNumber.StartsWith("SAP-CN", StringComparison.OrdinalIgnoreCase))
        {
            return creditNoteNumber.Substring(6).TrimStart('-', ' ');
        }
        return creditNoteNumber;
    }

    public void Dispose()
    {
        debounceTimer?.Stop();
        debounceTimer?.Dispose();
    }
}