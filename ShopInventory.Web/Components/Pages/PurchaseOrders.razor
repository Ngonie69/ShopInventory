@page "/purchase-orders"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Manager")]
@inject IPurchaseOrderService PurchaseOrderService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Purchase Orders - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .po-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Header ──────────────────────────────────────── */
    .po-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .po-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .po-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #059669, #0d9488);
        box-shadow: 0 4px 14px rgba(5, 150, 105, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .po-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .po-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .btn-po-gradient {
        background: linear-gradient(135deg, #059669, #0d9488);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 2px 8px rgba(5, 150, 105, .25);
        cursor: pointer;
    }

    .btn-po-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(5, 150, 105, .4);
        color: #fff;
    }

    /* ── Stat Cards ───────────────────────────────────── */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .stat-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1rem 1.15rem;
        display: flex;
        align-items: center;
        gap: .85rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        transition: transform .15s, box-shadow .15s;
    }

    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 0, 0, .06);
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        flex-shrink: 0;
    }

    .stat-icon.total {
        background: #d1fae5;
        color: #059669;
    }

    .stat-icon.draft {
        background: #f3f4f6;
        color: #6b7280;
    }

    .stat-icon.pending {
        background: #fef3c7;
        color: #d97706;
    }

    .stat-icon.approved {
        background: #dbeafe;
        color: #2563eb;
    }

    .stat-icon.received {
        background: #ede9fe;
        color: #7c3aed;
    }

    .stat-info .stat-value {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1.1;
    }

    .stat-info .stat-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
    }

    /* ── Filter Bar ──────────────────────────────────── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        align-items: flex-end;
        padding: 1rem 1.25rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .filter-bar .filter-field {
        flex: 1;
        min-width: 140px;
    }

    .filter-bar .filter-field label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .3rem;
    }

    .filter-bar .filter-field input,
    .filter-bar .filter-field select {
        width: 100%;
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        background: #fff;
        transition: all .15s;
    }

    .filter-bar .filter-field input:focus,
    .filter-bar .filter-field select:focus {
        outline: none;
        border-color: #059669;
        box-shadow: 0 0 0 3px rgba(5, 150, 105, .15);
    }

    .filter-actions-row {
        display: flex;
        gap: .5rem;
        align-items: flex-end;
    }

    .btn-search {
        background: linear-gradient(135deg, #059669, #0d9488);
        color: #fff;
        border: none;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-search:hover {
        opacity: .92;
        transform: translateY(-1px);
    }

    .btn-clear {
        background: #fff;
        color: #6b7280;
        border: 1px solid #d1d5db;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-clear:hover {
        background: #f3f4f6;
    }

    /* ── Table ───────────────────────────────────────── */
    .po-table-wrap {
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #fff;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .po-table-header {
        padding: .85rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
    }

    .po-table-header h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .92rem;
    }

    .po-count-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #374151;
    }

    /* ── Status Badges ───────────────────────────────── */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .73rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-badge.draft {
        background: #f3f4f6;
        color: #6b7280;
    }

    .status-badge.pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-badge.approved {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.partial {
        background: #e0e7ff;
        color: #3730a3;
    }

    .status-badge.received {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-badge.cancelled {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-badge.on-hold {
        background: #374151;
        color: #fff;
    }

    /* ── Cell Styles ─────────────────────────────────── */
    .doc-number {
        font-weight: 700;
        color: #059669;
        font-size: .88rem;
    }

    .supplier-info .name {
        font-weight: 600;
        font-size: .85rem;
        color: #1a1a2e;
        display: block;
    }

    .supplier-info .code {
        font-size: .75rem;
        color: #9ca3af;
        display: block;
    }

    .amount-cell {
        font-weight: 700;
        color: #1a1a2e;
        font-size: .88rem;
    }

    /* ── Action Buttons ──────────────────────────────── */
    .action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .85rem;
    }

    .action-btn:hover {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }

    .action-btn.view:hover {
        background: #d1fae5;
        color: #059669;
        border-color: #6ee7b7;
    }

    .action-btn.edit:hover {
        background: #fef3c7;
        color: #d97706;
        border-color: #fbbf24;
    }

    .action-btn.submit:hover {
        background: #dbeafe;
        color: #2563eb;
        border-color: #93c5fd;
    }

    .action-btn.approve:hover {
        background: #d1fae5;
        color: #059669;
        border-color: #6ee7b7;
    }

    .action-btn.receive:hover {
        background: #ede9fe;
        color: #7c3aed;
        border-color: #c4b5fd;
    }

    .action-btn.delete:hover {
        background: #fee2e2;
        color: #dc2626;
        border-color: #fca5a5;
    }

    /* ── Drawer ──────────────────────────────────────── */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        z-index: 9998;
        animation: fadeIn .2s ease;
    }

    .detail-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(640px, 95vw);
        height: 100vh;
        background: #fff;
        z-index: 9999;
        box-shadow: -8px 0 30px rgba(0, 0, 0, .12);
        display: flex;
        flex-direction: column;
        animation: slideInRight .25s ease;
    }

    .drawer-header {
        padding: 1.15rem 1.5rem;
        background: linear-gradient(135deg, #059669, #0d9488);
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }

    .drawer-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .drawer-header .btn-close-drawer {
        background: rgba(255, 255, 255, .15);
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s;
        font-size: 1rem;
    }

    .drawer-header .btn-close-drawer:hover {
        background: rgba(255, 255, 255, .25);
    }

    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .drawer-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
        margin-bottom: 1.25rem;
    }

    .detail-item .detail-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
        margin-bottom: .15rem;
    }

    .detail-item .detail-value {
        font-size: .92rem;
        font-weight: 600;
        color: #1a1a2e;
    }

    .detail-section-title {
        font-weight: 600;
        color: #1a1a2e;
        font-size: .9rem;
        margin-bottom: .75rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    /* ── Lines Table ─────────────────────────────────── */
    .lines-table {
        width: 100%;
        font-size: .85rem;
        border-collapse: separate;
        border-spacing: 0;
    }

    .lines-table th {
        background: #f8fafc;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6b7280;
        font-weight: 600;
        padding: .6rem .75rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .lines-table td {
        padding: .55rem .75rem;
        border-bottom: 1px solid #f3f4f6;
        color: #374151;
    }

    .lines-table tr:last-child td {
        border-bottom: none;
    }

    .lines-table tfoot td {
        border-top: 2px solid #e5e7eb;
        background: #f8fafc;
    }

    .total-banner {
        background: linear-gradient(135deg, #059669, #0d9488);
        color: #fff;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.25rem;
    }

    .total-banner .total-label {
        font-size: .9rem;
        font-weight: 500;
    }

    .total-banner .total-value {
        font-size: 1.4rem;
        font-weight: 700;
    }

    /* ── Receive Modal ───────────────────────────────── */
    .receive-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .5);
        z-index: 10000;
        display: flex;
        justify-content: center;
        align-items: center;
        animation: fadeIn .2s ease;
        padding: 1rem;
    }

    .receive-modal {
        background: #fff;
        border-radius: 14px;
        width: min(750px, 95vw);
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
        animation: scaleIn .25s ease;
    }

    .receive-modal-header {
        padding: 1.15rem 1.5rem;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: linear-gradient(135deg, #059669, #0d9488);
        border-radius: 14px 14px 0 0;
        color: #fff;
    }

    .receive-modal-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .receive-modal-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .receive-modal-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
    }

    /* ── Empty / Loading ─────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #d1fae5;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 1.8rem;
        color: #059669;
    }

    .empty-state h6 {
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
    }

    .empty-state p {
        color: #9ca3af;
        font-size: .88rem;
    }

    .loading-state {
        text-align: center;
        padding: 3rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    /* ── Alert ───────────────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .alert-banner.success-alert {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .btn-secondary-action {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .15s;
    }

    .btn-secondary-action:hover {
        background: #f9fafb;
    }

    .btn-action {
        background: linear-gradient(135deg, #059669, #0d9488);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-action:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(5, 150, 105, .3);
    }

    .btn-action:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    /* ── Animations ──────────────────────────────────── */
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }

        to {
            transform: translateX(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@media (max-width:768px) {
        .po-header {
            flex-direction: column;
        }

        .filter-bar {
            flex-direction: column;
        }

        .stat-row {
            grid-template-columns: 1fr 1fr;
        }

        .detail-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="po-page">
    <div class="container-fluid">

        <!-- ━━━ Header ━━━ -->
        <div class="po-header">
            <div class="po-header-left">
                <div class="po-header-icon"><i class="bi bi-bag-check"></i></div>
                <div>
                    <h2>Purchase Orders</h2>
                    <p>Manage supplier orders and goods receipt</p>
                </div>
            </div>
            <a class="btn-po-gradient" href="/purchase-orders/create">
                <i class="bi bi-plus-lg"></i> New Purchase Order
            </a>
        </div>

        <!-- ━━━ Alerts ━━━ -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner error-alert">
                <i class="bi bi-exclamation-octagon-fill"></i>
                <div style="flex:1;">@errorMessage</div>
                <button style="background:none;border:none;color:inherit;opacity:.45;cursor:pointer;font-size:1rem;"
                        @onclick="() => errorMessage = null"><i class="bi bi-x-lg"></i></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert-banner success-alert">
                <i class="bi bi-check-circle-fill"></i>
                <div style="flex:1;">@successMessage</div>
                <button style="background:none;border:none;color:inherit;opacity:.45;cursor:pointer;font-size:1rem;"
                        @onclick="() => successMessage = null"><i class="bi bi-x-lg"></i></button>
            </div>
        }

        <!-- ━━━ Stat Cards ━━━ -->
        @if (orders?.Any() == true)
        {
            <div class="stat-row">
                <div class="stat-card">
                    <div class="stat-icon total"><i class="bi bi-bag-check"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@totalCount</div>
                        <div class="stat-label">Total Orders</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon draft"><i class="bi bi-pencil-square"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@orders.Count(o => o.Status == PurchaseOrderStatus.Draft)</div>
                        <div class="stat-label">Drafts</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon pending"><i class="bi bi-clock-history"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@orders.Count(o => o.Status == PurchaseOrderStatus.Pending)</div>
                        <div class="stat-label">Pending Approval</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon approved"><i class="bi bi-check-circle"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@orders.Count(o => o.Status == PurchaseOrderStatus.Approved || o.Status ==
                                                    PurchaseOrderStatus.PartiallyReceived)</div>
                            <div class="stat-label">Approved</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon received"><i class="bi bi-box-seam"></i></div>
                        <div class="stat-info">
                            <div class="stat-value">@orders.Count(o => o.Status == PurchaseOrderStatus.Received)</div>
                            <div class="stat-label">Received</div>
                        </div>
                    </div>
                </div>
            }

            <!-- ━━━ Filter Bar ━━━ -->
            <div class="filter-bar">
                <div class="filter-field">
                    <label>Supplier Code</label>
                    <input type="text" @bind="supplierFilter" placeholder="e.g., V001" />
                </div>
                <div class="filter-field">
                    <label>Status</label>
                    <select @bind="statusFilter">
                        <option value="">All Statuses</option>
                        @foreach (PurchaseOrderStatus status in Enum.GetValues(typeof(PurchaseOrderStatus)))
                        {
                            <option value="@(((int)status).ToString())">@status</option>
                        }
                    </select>
                </div>
                <div class="filter-field">
                    <label>From Date</label>
                    <input type="date" @bind="fromDate" />
                </div>
                <div class="filter-field">
                    <label>To Date</label>
                    <input type="date" @bind="toDate" />
                </div>
                <div class="filter-actions-row">
                    <button class="btn-search" @onclick="ApplyFilter">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <button class="btn-clear" @onclick="ClearFilter">
                        <i class="bi bi-x-circle"></i> Clear
                    </button>
                </div>
            </div>

            <!-- ━━━ Content ━━━ -->
            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner-border" style="color:#059669;width:2.5rem;height:2.5rem;" role="status"></div>
                    <p style="margin-top:.75rem;color:#6b7280;font-weight:500;">Loading purchase orders...</p>
                </div>
            }
            else if (orders?.Any() == true)
            {
                <div class="po-table-wrap">
                    <div class="po-table-header">
                        <h6><i class="bi bi-table"></i> Purchase Orders</h6>
                        <span class="po-count-badge">@totalCount total</span>
                    </div>
                    <MudTable @ref="@_table" Items="@orders" RowsPerPage="10" Hover="true" Striped="true" Dense="true"
                              Breakpoint="Breakpoint.Sm" Loading="@isLoading" LoadingProgressColor="Color.Primary"
                              T="PurchaseOrderDto" Elevation="0" Style="background:transparent;">
                        <HeaderContent>
                            <MudTh>Order #</MudTh>
                            <MudTh>Supplier</MudTh>
                            <MudTh>Order Date</MudTh>
                            <MudTh>Delivery Date</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Currency</MudTh>
                            <MudTh Style="text-align:right">Total</MudTh>
                            <MudTh Style="width:140px">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Order #"><span class="doc-number">@context.OrderNumber</span></MudTd>
                            <MudTd DataLabel="Supplier">
                                <div class="supplier-info">
                                    <span class="name">@(context.CardName ?? context.CardCode)</span>
                                    <span class="code">@context.CardCode</span>
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Order Date">
                                <span style="font-size:.85rem;color:#374151;">@context.OrderDate.ToString("dd MMM yyyy")</span>
                            </MudTd>
                            <MudTd DataLabel="Delivery Date">
                                <span style="font-size:.85rem;color:#374151;">@(context.DeliveryDate?.ToString("dd MMM yyyy") ??
                                                                "—")</span>
                                </MudTd>
                                <MudTd DataLabel="Status">
                                    <span class="status-badge @GetStatusCssClass(context.Status)">@context.StatusName</span>
                                </MudTd>
                                <MudTd DataLabel="Currency">
                                    <span style="font-size:.85rem;color:#6b7280;">@context.Currency</span>
                                </MudTd>
                                <MudTd DataLabel="Total" Style="text-align:right">
                                    <span class="amount-cell">@context.DocTotal.ToString("N2")</span>
                                </MudTd>
                                <MudTd DataLabel="Actions">
                                    <div style="display:flex;gap:.3rem;">
                                        <button class="action-btn view" @onclick="() => ViewOrder(context)" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        @if (context.Status == PurchaseOrderStatus.Draft)
                                        {
                                            <button class="action-btn edit" @onclick="() => EditOrder(context)" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="action-btn submit" @onclick="() => SubmitForApproval(context.Id)"
                                                    title="Submit for Approval">
                                                <i class="bi bi-send"></i>
                                            </button>
                                        }
                                        @if (context.Status == PurchaseOrderStatus.Pending)
                                        {
                                            <button class="action-btn approve" @onclick="() => ApproveOrder(context.Id)"
                                                    title="Approve">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        }
                                        @if (context.Status == PurchaseOrderStatus.Approved || context.Status ==
                                                                    PurchaseOrderStatus.PartiallyReceived)
                                        {
                                            <button class="action-btn receive" @onclick="() => ShowReceiveModal(context)"
                                                    title="Receive Goods">
                                                <i class="bi bi-box-seam"></i>
                                            </button>
                                        }
                                        @if (context.Status == PurchaseOrderStatus.Draft || context.Status ==
                                                                    PurchaseOrderStatus.Cancelled)
                                        {
                                            <button class="action-btn delete" @onclick="() => DeleteOrder(context.Id)" title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        }
                                    </div>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudPagination SelectedChanged="PageChanged"
                                               Count="@((_table.GetFilteredItemsCount() + _table.RowsPerPage - 1) / _table.RowsPerPage)"
                                               Class="pa-4" />
                            </PagerContent>
                        </MudTable>
                    </div>
                }
        else
                {
                    <div class="empty-state">
                        <div class="empty-icon"><i class="bi bi-bag-x"></i></div>
                        <h6>No purchase orders found</h6>
                        <p>Create a new purchase order or adjust your filters to find existing ones.</p>
                        <a class="btn-po-gradient" href="/purchase-orders/create" style="margin-top:1rem;display:inline-flex;">
                            <i class="bi bi-plus-lg"></i> Create Purchase Order
                        </a>
                    </div>
                }
            </div>
        </div>

        <!-- ━━━ Detail Drawer ━━━ -->
        @if (selectedOrder != null)
        {
            <div class="modal-backdrop-custom" @onclick="() => selectedOrder = null"></div>
            <div class="detail-drawer">
                <div class="drawer-header">
                    <h5><i class="bi bi-bag-check me-2"></i>PO: @selectedOrder.OrderNumber</h5>
                    <button class="btn-close-drawer" @onclick="() => selectedOrder = null">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="drawer-body">
                    <div class="detail-grid">
                        <div class="detail-item">
                            <div class="detail-label">Supplier Code</div>
                            <div class="detail-value">@selectedOrder.CardCode</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Supplier Name</div>
                            <div class="detail-value">@(selectedOrder.CardName ?? "—")</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Order Date</div>
                            <div class="detail-value">@selectedOrder.OrderDate.ToString("dd MMM yyyy")</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Delivery Date</div>
                            <div class="detail-value">@(selectedOrder.DeliveryDate?.ToString("dd MMM yyyy") ?? "Not set")</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Status</div>
                            <div class="detail-value">
                                <span class="status-badge @GetStatusCssClass(selectedOrder.Status)">@selectedOrder.StatusName</span>
                            </div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Currency</div>
                            <div class="detail-value">@selectedOrder.Currency</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Supplier Ref</div>
                            <div class="detail-value">@(selectedOrder.SupplierRefNo ?? "—")</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Warehouse</div>
                            <div class="detail-value">@(selectedOrder.WarehouseCode ?? "—")</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Created By</div>
                            <div class="detail-value">@(selectedOrder.CreatedByUserName ?? "System")</div>
                        </div>
                        @if (selectedOrder.ApprovedByUserName != null)
                        {
                            <div class="detail-item">
                                <div class="detail-label">Approved By</div>
                                <div class="detail-value">@selectedOrder.ApprovedByUserName <small
                                    style="color:#9ca3af;">(@(selectedOrder.ApprovedDate?.ToString("dd MMM yyyy") ?? ""))</small>
                                </div>
                            </div>
                        }
                    </div>

                    @if (selectedOrder.Lines?.Any() == true)
                    {
                        <div class="detail-section-title"><i class="bi bi-list-ul"></i> Order Lines</div>
                        <table class="lines-table">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Description</th>
                                    <th style="text-align:right">Ordered</th>
                                    <th style="text-align:right">Received</th>
                                    <th style="text-align:right">Remaining</th>
                                    <th style="text-align:right">Unit Price</th>
                                    <th style="text-align:right">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in selectedOrder.Lines)
                                {
                                    <tr>
                                        <td><strong>@line.ItemCode</strong></td>
                                        <td>@line.ItemDescription</td>
                                        <td style="text-align:right">@line.Quantity</td>
                                        <td style="text-align:right">@line.QuantityReceived</td>
                                        <td style="text-align:right">
                                            @if (line.QuantityRemaining > 0)
                                            {
                                                <span style="color:#d97706;font-weight:600;">@line.QuantityRemaining</span>
                                            }
                                            else
                                            {
                                                <span style="color:#059669;font-weight:600;">0</span>
                                            }
                                        </td>
                                        <td style="text-align:right">@line.UnitPrice.ToString("N2")</td>
                                        <td style="text-align:right;font-weight:600;">@line.LineTotal.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="6" style="text-align:right;font-weight:600;">Subtotal:</td>
                                    <td style="text-align:right;font-weight:600;">@selectedOrder.SubTotal.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td colspan="6" style="text-align:right;font-weight:600;">Tax:</td>
                                    <td style="text-align:right;font-weight:600;">@selectedOrder.TaxAmount.ToString("N2")</td>
                                </tr>
                                @if (selectedOrder.DiscountAmount > 0)
                                {
                                    <tr>
                                        <td colspan="6" style="text-align:right;font-weight:600;">Discount:</td>
                                        <td style="text-align:right;font-weight:600;color:#dc2626;">
                                            -@selectedOrder.DiscountAmount.ToString("N2")</td>
                                        </tr>
                                    }
                                </tfoot>
                            </table>

                            <div class="total-banner">
                                <span class="total-label">Total Amount</span>
                                <span class="total-value">@selectedOrder.Currency @selectedOrder.DocTotal.ToString("N2")</span>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(selectedOrder.Comments))
                        {
                            <div class="detail-section-title mt-3"><i class="bi bi-chat-left-text"></i> Comments</div>
                            <pre
                            style="white-space:pre-wrap;font-size:.85rem;background:#f8fafc;padding:.75rem;border-radius:8px;border:1px solid #e5e7eb;color:#374151;">@selectedOrder.Comments</pre>
                        }
                    </div>
                    <div class="drawer-footer">
                        <button class="btn-secondary-action" @onclick="() => selectedOrder = null">Close</button>
                    </div>
                </div>
            }

            <!-- ━━━ Receive Goods Modal ━━━ -->
            @if (showReceiveModal && receiveOrder != null)
            {
                <div class="receive-modal-overlay">
                    <div class="receive-modal">
                        <div class="receive-modal-header">
                            <h5><i class="bi bi-truck"></i> Receive Goods — @receiveOrder.OrderNumber</h5>
                            <button class="btn-close-drawer" @onclick="CloseReceiveModal">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                        <div class="receive-modal-body">
                            <div class="alert-banner"
                                 style="background:#eff6ff;border:1px solid #bfdbfe;color:#1e40af;margin-bottom:1rem;">
                                <i class="bi bi-info-circle-fill"></i>
                                <span>Enter the quantity received for each line item. Leave at 0 for items not yet received.</span>
                            </div>

                            @if (!string.IsNullOrEmpty(receiveError))
                            {
                                <div class="alert-banner error-alert">
                                    <i class="bi bi-exclamation-octagon-fill"></i>
                                    <span>@receiveError</span>
                                </div>
                            }

                            <table class="lines-table">
                                <thead>
                                    <tr>
                                        <th>Item</th>
                                        <th>Description</th>
                                        <th style="text-align:right">Ordered</th>
                                        <th style="text-align:right">Already Received</th>
                                        <th style="text-align:right">Remaining</th>
                                        <th style="width:120px;">Receive Qty</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < receiveOrder.Lines.Count; i++)
                                    {
                                        var line = receiveOrder.Lines[i];
                                        var remaining = line.Quantity - line.QuantityReceived;
                                        var idx = i;
                                        <tr>
                                            <td><strong>@line.ItemCode</strong></td>
                                            <td>@line.ItemDescription</td>
                                            <td style="text-align:right">@line.Quantity</td>
                                            <td style="text-align:right">@line.QuantityReceived</td>
                                            <td style="text-align:right">@remaining</td>
                                            <td>
                                                @if (remaining > 0)
                                                {
                                                    <input type="number" class="form-control form-control-sm" min="0" max="@remaining"
                                                           step="any" @bind="receiveQuantities[idx]"
                                                           style="border-radius:8px;border:1px solid #d1d5db;" />
                                                }
                                                else
                                                {
                                                    <span style="color:#059669;font-weight:600;font-size:.85rem;">Complete</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                            <div style="margin-top:1rem;">
                                <label
                                style="font-size:.75rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.4px;display:block;margin-bottom:.25rem;">Comments</label>
                                <textarea class="form-control" @bind="receiveComments" rows="2"
                                          placeholder="Optional receiving notes..."
                                          style="border-radius:8px;border:1px solid #d1d5db;font-size:.88rem;"></textarea>
                            </div>
                        </div>
                        <div class="receive-modal-footer">
                            <button class="btn-secondary-action" @onclick="CloseReceiveModal">Cancel</button>
                            <button class="btn-action" @onclick="ReceiveGoods" disabled="@isReceiving">
                                @if (isReceiving)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                <i class="bi bi-box-seam"></i> Confirm Receipt
                            </button>
                        </div>
                    </div>
                </div>
            }

@code {
    private MudTable<PurchaseOrderDto>? _table;
    private List<PurchaseOrderDto>? orders;
    private PurchaseOrderDto? selectedOrder;
    private bool isLoading = true;
    private string? errorMessage;
    private string? successMessage;

    // Filters
    private string? supplierFilter;
    private string? statusFilter;
    private DateTime? fromDate;
    private DateTime? toDate;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 50;
    private int totalPages = 1;
    private int totalCount = 0;

    // Receive goods
    private bool showReceiveModal = false;
    private PurchaseOrderDto? receiveOrder;
    private List<decimal> receiveQuantities = new();
    private string? receiveComments;
    private string? receiveError;
    private bool isReceiving = false;

    private void PageChanged(int i)
    {
        _table?.NavigateTo(i - 1);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            PurchaseOrderStatus? status = null;
            if (!string.IsNullOrEmpty(statusFilter) && int.TryParse(statusFilter, out var statusInt))
            {
                status = (PurchaseOrderStatus)statusInt;
            }

            var response = await PurchaseOrderService.GetPurchaseOrdersAsync(currentPage, pageSize, status, supplierFilter,
            fromDate, toDate);
            if (response != null)
            {
                orders = response.Orders;
                totalCount = response.TotalCount;
                totalPages = response.TotalPages;
            }
            else
            {
                orders = new();
                errorMessage = "Failed to load purchase orders. The API may be unavailable.";
            }
        }
        catch (Exception ex)
        {
            orders = new();
            errorMessage = $"Error loading purchase orders: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilter()
    {
        currentPage = 1;
        await LoadOrders();
    }

    private async Task ClearFilter()
    {
        supplierFilter = null;
        statusFilter = null;
        fromDate = null;
        toDate = null;
        currentPage = 1;
        await LoadOrders();
    }

    private void ViewOrder(PurchaseOrderDto order)
    {
        selectedOrder = order;
    }

    private void EditOrder(PurchaseOrderDto order)
    {
        NavigationManager.NavigateTo($"/purchase-orders/create?editId={order.Id}");
    }

    private async Task SubmitForApproval(int id)
    {
        try
        {
            var result = await PurchaseOrderService.UpdateStatusAsync(id, PurchaseOrderStatus.Pending, "Submitted for approval");
            if (result != null)
            {
                successMessage = "Purchase order submitted for approval.";
                await LoadOrders();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to submit for approval: {ex.Message}";
        }
    }

    private async Task ApproveOrder(int id)
    {
        try
        {
            var result = await PurchaseOrderService.ApproveAsync(id);
            if (result != null)
            {
                successMessage = "Purchase order approved successfully.";
                await LoadOrders();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to approve: {ex.Message}";
        }
    }

    private void ShowReceiveModal(PurchaseOrderDto order)
    {
        receiveOrder = order;
        receiveQuantities = order.Lines.Select(_ => 0m).ToList();
        receiveComments = null;
        receiveError = null;
        showReceiveModal = true;
    }

    private void CloseReceiveModal()
    {
        showReceiveModal = false;
        receiveOrder = null;
    }

    private async Task ReceiveGoods()
    {
        if (receiveOrder == null) return;

        receiveError = null;
        var linesToReceive = new List<ReceivePurchaseOrderLineRequest>();

        for (int i = 0; i < receiveOrder.Lines.Count; i++)
        {
            if (receiveQuantities[i] > 0)
            {
                linesToReceive.Add(new ReceivePurchaseOrderLineRequest
                {
                    LineNum = receiveOrder.Lines[i].LineNum,
                    ItemCode = receiveOrder.Lines[i].ItemCode,
                    QuantityReceived = receiveQuantities[i]
                });
            }
        }

        if (!linesToReceive.Any())
        {
            receiveError = "Please enter quantity for at least one line item.";
            return;
        }

        isReceiving = true;
        try
        {
            var request = new ReceivePurchaseOrderRequest
            {
                Lines = linesToReceive,
                Comments = receiveComments
            };

            var result = await PurchaseOrderService.ReceiveItemsAsync(receiveOrder.Id, request);
            if (result != null)
            {
                showReceiveModal = false;
                receiveOrder = null;
                successMessage = "Goods received successfully!";
                await LoadOrders();
            }
            else
            {
                receiveError = "Failed to receive items. Please try again.";
            }
        }
        catch (Exception ex)
        {
            receiveError = $"Error: {ex.Message}";
        }
        finally
        {
            isReceiving = false;
        }
    }

    private async Task DeleteOrder(int id)
    {
        try
        {
            var success = await PurchaseOrderService.DeletePurchaseOrderAsync(id);
            if (success)
            {
                successMessage = "Purchase order deleted.";
                await LoadOrders();
            }
            else
            {
                errorMessage = "Failed to delete purchase order.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting: {ex.Message}";
        }
    }

    private string GetStatusCssClass(PurchaseOrderStatus status) => status switch
    {
        PurchaseOrderStatus.Draft => "draft",
        PurchaseOrderStatus.Pending => "pending",
        PurchaseOrderStatus.Approved => "approved",
        PurchaseOrderStatus.PartiallyReceived => "partial",
        PurchaseOrderStatus.Received => "received",
        PurchaseOrderStatus.Cancelled => "cancelled",
        PurchaseOrderStatus.OnHold => "on-hold",
        _ => "draft"
    };
}