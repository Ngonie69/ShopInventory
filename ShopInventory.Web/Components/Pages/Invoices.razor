@page "/invoices"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using ShopInventory.Web.Models
@using ShopInventory.Web.Services
@attribute [Authorize(Roles = "Admin,Cashier")]
@inject IInvoiceService InvoiceService
@inject ICreditNoteService CreditNoteService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IAppSettingsProvider AppSettings
@inject IAuditService AuditService
@rendermode InteractiveServer

<PageTitle>Invoices - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .inv-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Header ──────────────────────────────────────── */
    .inv-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .inv-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .inv-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .inv-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .inv-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .inv-header-actions {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .btn-inv-gradient {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 2px 8px rgba(102, 126, 234, .25);
    }

    .btn-inv-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .4);
        color: #fff;
    }

    /* ── Stat Cards ──────────────────────────────────── */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: .85rem;
        border: 1px solid #e5e7eb;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        transition: box-shadow .2s;
    }

    .stat-card:hover {
        box-shadow: 0 4px 14px rgba(0, 0, 0, .08);
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .stat-icon.purple {
        background: #ede9fe;
        color: #7c3aed;
    }

    .stat-icon.blue {
        background: #dbeafe;
        color: #2563eb;
    }

    .stat-icon.amber {
        background: #fef3c7;
        color: #d97706;
    }

    .stat-icon.green {
        background: #d1fae5;
        color: #059669;
    }

    .stat-info .stat-value {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1.2;
    }

    .stat-info .stat-label {
        font-size: .78rem;
        color: #6b7280;
        font-weight: 500;
    }

    /* ── Filter Bar ──────────────────────────────────── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        align-items: flex-end;
        padding: 1rem 1.25rem;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        margin-bottom: 1.25rem;
    }

    .filter-bar .filter-field {
        flex: 1;
        min-width: 160px;
    }

    .filter-bar .filter-field label {
        display: block;
        font-size: .75rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .3rem;
    }

    .filter-actions-row {
        display: flex;
        gap: .5rem;
        align-items: flex-end;
    }

    .btn-search {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-search:hover {
        opacity: .92;
        transform: translateY(-1px);
    }

    .btn-search:disabled {
        opacity: .5;
        cursor: not-allowed;
    }

    .btn-clear {
        background: #fff;
        color: #6b7280;
        border: 1px solid #d1d5db;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
    }

    .btn-clear:hover {
        background: #f3f4f6;
    }

    /* ── Table ───────────────────────────────────────── */
    .inv-table-wrap {
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        background: #fff;
        overflow: hidden;
    }

    .customer-info {
        display: flex;
        flex-direction: column;
    }

    .customer-info .name {
        font-weight: 600;
        font-size: .88rem;
        color: #1a1a2e;
    }

    .customer-info .code {
        font-size: .78rem;
        color: #9ca3af;
    }

    .doc-num-cell {
        font-weight: 700;
        color: #667eea;
        font-size: .92rem;
    }

    .amount-cell {
        font-weight: 700;
        color: #1a1a2e;
        font-size: .92rem;
    }

    .vat-cell {
        color: #6b7280;
        font-size: .88rem;
    }

    .currency-badge {
        display: inline-flex;
        align-items: center;
        gap: .2rem;
        padding: .15rem .55rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #374151;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .73rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-badge.open {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.closed {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-badge.partial {
        background: #fef3c7;
        color: #92400e;
    }

    /* ── Alerts ──────────────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.success-alert {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .alert-banner.warn-alert {
        background: #fffbeb;
        border: 1px solid #fde68a;
        color: #92400e;
    }

    .alert-banner.info-alert {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1e40af;
    }

    .alert-banner .alert-body {
        flex: 1;
    }

    .alert-banner .alert-close {
        background: none;
        border: none;
        color: inherit;
        opacity: .45;
        cursor: pointer;
        padding: .2rem;
        font-size: 1rem;
    }

    .alert-banner .alert-close:hover {
        opacity: 1;
    }

    /* ── Empty State ─────────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 1.8rem;
        color: #9ca3af;
    }

    .empty-state h6 {
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
    }

    .empty-state p {
        color: #9ca3af;
        font-size: .88rem;
        margin-bottom: 1rem;
    }

    /* ── Invoice Detail Drawer ───────────────────────── */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        z-index: 9998;
        animation: fadeIn .2s ease;
    }

    .detail-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(640px, 95vw);
        height: 100vh;
        background: #fff;
        z-index: 9999;
        box-shadow: -8px 0 30px rgba(0, 0, 0, .12);
        display: flex;
        flex-direction: column;
        animation: slideInRight .25s ease;
    }

    .drawer-header {
        padding: 1.15rem 1.5rem;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }

    .drawer-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .drawer-header .btn-close-drawer {
        background: rgba(255, 255, 255, .15);
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s;
        font-size: 1rem;
    }

    .drawer-header .btn-close-drawer:hover {
        background: rgba(255, 255, 255, .25);
    }

    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .drawer-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    /* Detail Grid */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .detail-item .detail-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
        margin-bottom: .2rem;
    }

    .detail-item .detail-value {
        font-size: .92rem;
        font-weight: 600;
        color: #1a1a2e;
    }

    .detail-section-title {
        font-weight: 600;
        color: #1a1a2e;
        font-size: .9rem;
        margin-bottom: .75rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    /* Lines Table */
    .lines-table {
        width: 100%;
        font-size: .85rem;
        border-collapse: separate;
        border-spacing: 0;
    }

    .lines-table th {
        background: #f8fafc;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6b7280;
        font-weight: 600;
        padding: .6rem .75rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .lines-table td {
        padding: .55rem .75rem;
        border-bottom: 1px solid #f3f4f6;
        color: #374151;
    }

    .lines-table tr:last-child td {
        border-bottom: none;
    }

    .lines-table tfoot td {
        border-top: 2px solid #e5e7eb;
        background: #f8fafc;
    }

    /* Total Banner */
    .total-banner {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.25rem;
    }

    .total-banner .total-label {
        font-size: .9rem;
        font-weight: 500;
    }

    .total-banner .total-value {
        font-size: 1.4rem;
        font-weight: 700;
    }

    /* Credit Note Warning */
    .cn-warning {
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: 10px;
        padding: .85rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1.25rem;
    }

    .cn-warning-icon {
        color: #d97706;
        font-size: 1.1rem;
        flex-shrink: 0;
        margin-top: .1rem;
    }

    .cn-warning-body {
        flex: 1;
        font-size: .88rem;
        color: #92400e;
    }

    .cn-warning-body strong {
        color: #78350f;
    }

    .cn-view-link {
        background: none;
        border: none;
        color: #d97706;
        font-weight: 600;
        cursor: pointer;
        padding: 0;
        font-size: .85rem;
        text-decoration: underline;
    }

    .cn-view-link:hover {
        color: #b45309;
    }

    /* ── Credit Note Modal ───────────────────────────── */
    .cn-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .5);
        z-index: 10000;
        display: flex;
        justify-content: center;
        align-items: center;
        animation: fadeIn .2s ease;
        padding: 1rem;
    }

    .cn-modal {
        background: #fff;
        border-radius: 14px;
        width: min(700px, 95vw);
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
        animation: scaleIn .25s ease;
    }

    .cn-modal-header {
        padding: 1.15rem 1.5rem;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .cn-modal-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1rem;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .cn-modal-header .btn-close-modal {
        background: #f3f4f6;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #6b7280;
        transition: all .15s;
        font-size: .9rem;
    }

    .cn-modal-header .btn-close-modal:hover {
        background: #e5e7eb;
        color: #374151;
    }

    .cn-modal-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .cn-modal-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
    }

    .btn-warning-action {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border: none;
        color: #fff;
        padding: .5rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-warning-action:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(217, 119, 6, .3);
    }

    .btn-warning-action:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .btn-secondary-action {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .5rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .15s;
    }

    .btn-secondary-action:hover {
        background: #f9fafb;
    }

    /* Credit note line selection table */
    .cn-lines-table {
        width: 100%;
        font-size: .85rem;
        border-collapse: separate;
        border-spacing: 0;
    }

    .cn-lines-table th {
        background: #f8fafc;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6b7280;
        font-weight: 600;
        padding: .55rem .65rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .cn-lines-table td {
        padding: .5rem .65rem;
        border-bottom: 1px solid #f3f4f6;
    }

    .cn-lines-table tr.selected-row {
        background: #fef3c7;
    }

    .cn-lines-table tfoot td {
        border-top: 2px solid #e5e7eb;
        background: #fffbeb;
        font-weight: 700;
    }

    .cn-qty-input {
        width: 72px;
        padding: .3rem .5rem;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: .85rem;
        text-align: right;
    }

    .cn-qty-input:focus {
        outline: none;
        border-color: #f59e0b;
        box-shadow: 0 0 0 2px rgba(245, 158, 11, .2);
    }

    .cn-qty-input:disabled {
        background: #f3f4f6;
        color: #9ca3af;
    }

    /* Progress overlay */
    .cn-progress-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, .95);
        z-index: 10;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border-radius: 14px;
    }

    .progress-ring-wrap {
        position: relative;
        margin-bottom: 1rem;
    }

    .progress-ring-wrap .ring-label {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 1.3rem;
        font-weight: 700;
        color: #d97706;
    }

    .progress-dots {
        display: flex;
        justify-content: center;
        gap: .4rem;
        margin-bottom: .75rem;
    }

    .progress-dots .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        animation: pulse 1.2s infinite;
    }

    .progress-dots .dot:nth-child(1) {
        background: #667eea;
        animation-delay: 0s;
    }

    .progress-dots .dot:nth-child(2) {
        background: #f59e0b;
        animation-delay: .2s;
    }

    .progress-dots .dot:nth-child(3) {
        background: #059669;
        animation-delay: .4s;
    }

    /* ── Toast ───────────────────────────────────────── */
    .toast-banner {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 10100;
        min-width: 320px;
        max-width: 420px;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        box-shadow: 0 8px 30px rgba(0, 0, 0, .15);
        animation: slideUp .3s ease;
    }

    .toast-banner.success {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .toast-banner.error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .toast-banner .toast-icon {
        font-size: 1.1rem;
        flex-shrink: 0;
        margin-top: .1rem;
    }

    .toast-banner .toast-body {
        flex: 1;
        font-size: .88rem;
        font-weight: 500;
    }

    .toast-banner .toast-close {
        background: none;
        border: none;
        color: inherit;
        opacity: .45;
        cursor: pointer;
        font-size: .9rem;
    }

    .toast-banner .toast-close:hover {
        opacity: 1;
    }

    /* ── Animations ──────────────────────────────────── */
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }

        to {
            transform: translateX(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@keyframes pulse {

        0%,
        100% {
            opacity: .3;
            transform: scale(.8);
        }

        50% {
            opacity: 1;
            transform: scale(1);
        }
    }

    /* ── Responsive ──────────────────────────────────── */
    @@media (max-width:768px) {
        .stat-row {
            grid-template-columns: 1fr 1fr;
        }

        .detail-grid {
            grid-template-columns: 1fr;
        }

        .inv-header {
            flex-direction: column;
        }
    }
</style>

<div class="inv-page">
    <div class="container-fluid">

        <!-- ━━━ Header ━━━ -->
        <div class="inv-header">
            <div class="inv-header-left">
                <div class="inv-header-icon"><i class="bi bi-receipt"></i></div>
                <div>
                    <h2>Invoices</h2>
                    <p>View and manage sales invoices</p>
                </div>
            </div>
            <div class="inv-header-actions">
                <a href="/invoices/create" class="btn-inv-gradient">
                    <i class="bi bi-plus-lg"></i> Create Invoice
                </a>
            </div>
        </div>

        <!-- ━━━ Alerts ━━━ -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner error-alert">
                <i class="bi bi-exclamation-octagon-fill"></i>
                <div class="alert-body">@errorMessage</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Class="alert-close" OnClick="() => errorMessage = null"
                               Size="Size.Small" />
            </div>
        }

        <!-- ━━━ Stat Cards ━━━ -->
        <div class="stat-row">
            <div class="stat-card">
                <div class="stat-icon purple"><i class="bi bi-receipt-cutoff"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@(invoices?.Count ?? 0)</div>
                    <div class="stat-label">Invoices Loaded</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue"><i class="bi bi-cash-coin"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@((invoices?.Sum(i => i.DocTotal) ?? 0).ToString("N0"))</div>
                    <div class="stat-label">Total Value</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon amber"><i class="bi bi-people-fill"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@(invoices?.Select(i => i.CardCode).Distinct().Count() ?? 0)</div>
                    <div class="stat-label">Unique Customers</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="bi bi-percent"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@((invoices?.Sum(i => i.VatSum) ?? 0).ToString("N0"))</div>
                    <div class="stat-label">Total VAT</div>
                </div>
            </div>
        </div>

        <!-- ━━━ Filter Bar ━━━ -->
        <div class="filter-bar">
            <div class="filter-field">
                <label>Doc Number</label>
                <MudNumericField T="int?" @bind-Value="docNumSearch" @bind-Value:after="OnDocNumChanged"
                                 Placeholder="e.g. 123" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                                 Immediate="true" Class="mt-0" />
            </div>
            <div class="filter-field">
                <label>Customer Code</label>
                <MudTextField T="string" @bind-Value="customerCode" @bind-Value:after="OnCustomerCodeChanged"
                              Placeholder="e.g. C001" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                              Immediate="true" Class="mt-0" />
            </div>
            <div class="filter-field" style="min-width:150px;">
                <label>From Date</label>
                <FlexibleDatePicker Label="From" @bind-Date="fromDate" Variant="Variant.Outlined" />
            </div>
            <div class="filter-field" style="min-width:150px;">
                <label>To Date</label>
                <FlexibleDatePicker Label="To" @bind-Date="toDate" Variant="Variant.Outlined" />
            </div>
            <div class="filter-actions-row">
                <MudButton Class="btn-search" OnClick="ApplyFilter" Disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    else
                    {
                        <i class="bi bi-search"></i>
                    }
                    Search
                </MudButton>
                <MudButton Class="btn-clear" OnClick="ClearFilter"><i class="bi bi-x-lg"></i> Clear</MudButton>
            </div>
        </div>

        <!-- ━━━ Table ━━━ -->
        @if (isLoading)
        {
            <div class="empty-state">
                <div class="spinner-border text-primary" role="status"
                     style="width:2.5rem;height:2.5rem;color:#667eea !important;"></div>
                <p class="mt-3 text-muted">Loading invoices…</p>
            </div>
        }
        else if (invoices?.Any() == true)
        {
            <div class="inv-table-wrap">
                <MudTable @ref="@_table" Items="@invoices" RowsPerPage="@_pageSize" Hover="true" Dense="true"
                          Breakpoint="Breakpoint.Sm" LoadingProgressColor="Color.Primary"
                          Filter="new Func<InvoiceDto, bool>(_quickFilter)" OnRowClick="@OnInvoiceRowClicked" T="InvoiceDto"
                          Elevation="0">
                    <ToolBarContent>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600; color:#1a1a2e;">
                            <i class="bi bi-list-ul me-1"></i> @invoices.Count invoice(s)
                        </MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="_searchString" Placeholder="Quick filter…" Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>Doc #</MudTh>
                        <MudTh>Customer</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Due Date</MudTh>
                        <MudTh>Currency</MudTh>
                        <MudTh Style="text-align:right">VAT</MudTh>
                        <MudTh Style="text-align:right">Total</MudTh>
                        <MudTh Style="width:60px;text-align:center;">View</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Doc #">
                            <span class="doc-num-cell">#@context.DocNum</span>
                        </MudTd>
                        <MudTd DataLabel="Customer">
                            <div class="customer-info">
                                <span class="name">@context.CardName</span>
                                <span class="code">@context.CardCode</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Date">@FormatDate(context.DocDate)</MudTd>
                        <MudTd DataLabel="Due Date">@FormatDate(context.DocDueDate)</MudTd>
                        <MudTd DataLabel="Currency"><span class="currency-badge">@context.DocCurrency</span></MudTd>
                        <MudTd DataLabel="VAT" Style="text-align:right"><span
                            class="vat-cell">@context.VatSum.ToString("N2")</span></MudTd>
                            <MudTd DataLabel="Total" Style="text-align:right"><span
                                class="amount-cell">@context.DocTotal.ToString("N2")</span></MudTd>
                                <MudTd DataLabel="View" Style="text-align:center;">
                                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary"
                                                   OnClick="@(() => ViewInvoice(context.DocEntry))" />
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <div class="pager-row">
                                    <div class="page-size-wrap">
                                        <span>Show</span>
                                        <select @bind="_pageSize">
                                            <option value="10">10</option>
                                            <option value="25">25</option>
                                            <option value="50">50</option>
                                            <option value="100">100</option>
                                        </select>
                                        <span>per page</span>
                                    </div>
                                    <MudPagination SelectedChanged="PageChanged"
                                                   Count="@((_table.GetFilteredItemsCount() + _table.RowsPerPage - 1) / _table.RowsPerPage)"
                                                   Class="pa-4" />
                                </div>
                            </PagerContent>
                        </MudTable>
                    </div>
                }
        else if (!isLoading)
                {
                    <div class="empty-state">
                        <div class="empty-icon"><i class="bi bi-receipt"></i></div>
                        <h6>No Invoices Found</h6>
                        <p>No invoices match your filters. Try adjusting your search criteria.</p>
                        <a href="/invoices/create" class="btn-inv-gradient"><i class="bi bi-plus-lg"></i> Create Invoice</a>
                    </div>
                }
            </div>
        </div>

        <!-- ━━━ Invoice Detail Drawer ━━━ -->
        @if (selectedInvoice != null && !showCreateCreditNoteModal && !showExistingCreditNotesModal)
        {
            <div class="modal-backdrop-custom" @onclick="CloseModal"></div>
            <div class="detail-drawer">
                <div class="drawer-header">
                    <h5><i class="bi bi-receipt me-2"></i>Invoice #@selectedInvoice.DocNum</h5>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Class="btn-close-drawer" OnClick="CloseModal"
                                   Size="Size.Small" />
                </div>
                <div class="drawer-body">
                    <!-- Credit Note Warning -->
                    @if (existingCreditNotes?.HasExistingCreditNotes == true)
                    {
                        <div class="cn-warning">
                            <i class="bi bi-exclamation-triangle-fill cn-warning-icon"></i>
                            <div class="cn-warning-body">
                                <strong>@existingCreditNotes.CreditNotes.Count credit note(s)</strong> totaling
                                <strong>@existingCreditNotes.TotalCreditedAmount.ToString("N2") @selectedInvoice.DocCurrency</strong>
                                already exist for this invoice.
                                <MudButton Class="cn-view-link" OnClick="ShowExistingCreditNotes">View Details</MudButton>
                            </div>
                        </div>
                    }

                    <!-- Detail Grid -->
                    <div class="detail-grid">
                        <div class="detail-item">
                            <div class="detail-label">Customer</div>
                            <div class="detail-value">@selectedInvoice.CardName</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Customer Code</div>
                            <div class="detail-value">@selectedInvoice.CardCode</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Document Date</div>
                            <div class="detail-value">@FormatDate(selectedInvoice.DocDate)</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Due Date</div>
                            <div class="detail-value">@FormatDate(selectedInvoice.DocDueDate)</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Doc Entry</div>
                            <div class="detail-value">@selectedInvoice.DocEntry</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Currency</div>
                            <div class="detail-value">@selectedInvoice.DocCurrency</div>
                        </div>
                        @if (!string.IsNullOrEmpty(selectedInvoice.NumAtCard))
                        {
                            <div class="detail-item">
                                <div class="detail-label">Reference</div>
                                <div class="detail-value">@selectedInvoice.NumAtCard</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(selectedInvoice.Comments))
                        {
                            <div class="detail-item">
                                <div class="detail-label">Comments</div>
                                <div class="detail-value" style="font-weight:400;">@selectedInvoice.Comments</div>
                            </div>
                        }
                    </div>

                    <!-- Invoice Lines -->
                    @if (selectedInvoice.Lines?.Any() == true)
                    {
                        <div class="detail-section-title"><i class="bi bi-list-check" style="color:#667eea;"></i> Invoice Lines</div>
                        <div style="border:1px solid #e5e7eb; border-radius:10px; overflow:hidden; margin-bottom:1rem;">
                            <table class="lines-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Item Code</th>
                                        <th>Description</th>
                                        <th>Warehouse</th>
                                        <th style="text-align:right;">Qty</th>
                                        <th style="text-align:right;">Price</th>
                                        <th style="text-align:right;">Disc %</th>
                                        <th style="text-align:right;">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var line in selectedInvoice.Lines)
                                    {
                                        <tr>
                                            <td>@line.LineNum</td>
                                            <td><strong>@line.ItemCode</strong></td>
                                            <td>@line.ItemDescription</td>
                                            <td>@line.WarehouseCode</td>
                                            <td style="text-align:right;">@line.Quantity</td>
                                            <td style="text-align:right;">@line.UnitPrice.ToString("N2")</td>
                                            <td style="text-align:right;">@line.DiscountPercent%</td>
                                            <td style="text-align:right; font-weight:600;">@line.LineTotal.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="7" style="text-align:right; font-weight:600; color:#6b7280;">VAT</td>
                                        <td style="text-align:right; font-weight:600;">@selectedInvoice.VatSum.ToString("N2")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }

                    <!-- Total Banner -->
                    <div class="total-banner">
                        <span class="total-label">Invoice Total</span>
                        <span class="total-value">@selectedInvoice.DocCurrency @selectedInvoice.DocTotal.ToString("N2")</span>
                    </div>
                </div>
                <div class="drawer-footer">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="DownloadInvoicePdf"
                               Disabled="@isPdfLoading">
                        <i class="bi bi-download me-1"></i> Download PDF
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="PrintInvoicePdf" Disabled="@isPdfLoading">
                        <i class="bi bi-printer me-1"></i> Print
                    </MudButton>
                    <MudButton Class="btn-warning-action" OnClick="OpenCreateCreditNoteModal">
                        <i class="bi bi-file-earmark-minus"></i> Create Credit Note
                    </MudButton>
                    <MudButton Class="btn-secondary-action" OnClick="CloseModal"><i class="bi bi-x-lg me-1"></i>Close</MudButton>
                </div>
            </div>
        }

        <!-- ━━━ Existing Credit Notes Modal ━━━ -->
        @if (showExistingCreditNotesModal && existingCreditNotes != null)
        {
            <div class="cn-modal-overlay" @onclick="() => showExistingCreditNotesModal = false">
                <div class="cn-modal" @onclick:stopPropagation="true">
                    <div class="cn-modal-header">
                        <h5><i class="bi bi-file-earmark-minus" style="color:#d97706;"></i> Credit Notes — Invoice
                            #@selectedInvoice?.DocNum</h5>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="btn-close-modal"
                                           OnClick="() => showExistingCreditNotesModal = false" Size="Size.Small" />
                        </div>
                        <div class="cn-modal-body">
                            <div class="alert-banner info-alert" style="margin-bottom:1rem;">
                                <i class="bi bi-info-circle-fill"></i>
                                <div class="alert-body">
                                    <strong>Total Credited:</strong> @existingCreditNotes.TotalCreditedAmount.ToString("N2")
                                    @selectedInvoice?.DocCurrency
                                </div>
                            </div>
                            <div style="border:1px solid #e5e7eb; border-radius:10px; overflow:hidden;">
                                <table class="lines-table">
                                    <thead>
                                        <tr>
                                            <th>Credit Note #</th>
                                            <th>Date</th>
                                            <th>Type</th>
                                            <th>Status</th>
                                            <th>Reason</th>
                                            <th style="text-align:right;">Amount</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cn in existingCreditNotes.CreditNotes)
                                        {
                                            <tr>
                                                <td><strong>@cn.CreditNoteNumber</strong></td>
                                                <td>@cn.CreditNoteDate.ToString("dd MMM yyyy")</td>
                                                <td><span class="status-badge open">@cn.TypeName</span></td>
                                                <td><span class="status-badge @GetCreditNoteStatusClass(cn.Status)">@cn.StatusName</span>
                                                </td>
                                                <td>@TruncateText(cn.Reason, 30)</td>
                                                <td style="text-align:right; font-weight:600;">@cn.DocTotal.ToString("N2")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="cn-modal-footer">
                            <MudButton Class="btn-secondary-action" OnClick="() => showExistingCreditNotesModal = false">Close
                            </MudButton>
                        </div>
                    </div>
                </div>
            }

            <!-- ━━━ Create Credit Note Modal ━━━ -->
            @if (showCreateCreditNoteModal && selectedInvoice != null)
            {
                <div class="cn-modal-overlay">
                    <div class="cn-modal" style="position:relative;" @onclick:stopPropagation="true">
                        @if (isCreatingCreditNote)
                        {
                            <div class="cn-progress-overlay">
                                <div class="progress-dots">
                                    <div class="dot"></div>
                                    <div class="dot"></div>
                                    <div class="dot"></div>
                                </div>
                                <div class="progress-ring-wrap">
                                    <svg width="100" height="100" viewBox="0 0 100 100">
                                        <circle cx="50" cy="50" r="42" fill="none" stroke="#e9ecef" stroke-width="7" />
                                        <circle cx="50" cy="50" r="42" fill="none" stroke="#f59e0b" stroke-width="7" stroke-linecap="round"
                                                stroke-dasharray="@(264 * creditNoteProgress / 100) 264"
                                                style="transform:rotate(-90deg);transform-origin:center;transition:stroke-dasharray .3s ease;" />
                                    </svg>
                                    <span class="ring-label">@creditNoteProgress%</span>
                                </div>
                                <h6 style="color:#d97706; font-weight:600; margin-bottom:.3rem;">
                                    <i class="bi bi-cloud-upload me-1"></i>Posting to SAP
                                </h6>
                                <p style="color:#6b7280; font-size:.88rem; margin-bottom:.15rem;">@creditNoteProgressMessage</p>
                                <small style="color:#9ca3af;">Please wait while the credit note is being created…</small>
                            </div>
                        }

                        <div class="cn-modal-header">
                            <h5><i class="bi bi-file-earmark-minus" style="color:#d97706;"></i> Create Credit Note — Invoice
                                #@selectedInvoice.DocNum</h5>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Class="btn-close-modal"
                                               OnClick="() => showCreateCreditNoteModal = false" Disabled="@isCreatingCreditNote" Size="Size.Small" />
                            </div>
                            <div class="cn-modal-body">
                                @if (existingCreditNotes?.HasExistingCreditNotes == true)
                                {
                                    <div class="alert-banner warn-alert" style="margin-bottom:1rem;">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                        <div class="alert-body">
                                            <strong>Warning:</strong> This invoice already has @existingCreditNotes.CreditNotes.Count credit
                                            note(s)
                                            totaling @existingCreditNotes.TotalCreditedAmount.ToString("N2") @selectedInvoice.DocCurrency.
                                        </div>
                                    </div>
                                }

                                <div style="margin-bottom:1.25rem;">
                                    <label
                                        style="display:block;font-size:.75rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-bottom:.4rem;">
                                        Reason for Credit Note *
                                    </label>
                                    <textarea
                                    style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:.6rem .85rem;font-size:.9rem;resize:vertical;min-height:80px;"
                                    @bind="creditNoteReason" placeholder="Enter the reason for creating this credit note…"
                                    disabled="@isCreatingCreditNote"></textarea>
                                </div>

                                <div class="detail-section-title"><i class="bi bi-list-check" style="color:#d97706;"></i> Select Items to
                                    Credit</div>
                                    <div style="border:1px solid #e5e7eb; border-radius:10px; overflow:hidden;">
                                        <table class="cn-lines-table">
                                            <thead>
                                                <tr>
                                                    <th style="width:36px;">
                                                        <input type="checkbox" @bind="selectAllLines" @bind:after="ToggleAllLines"
                                                               disabled="@isCreatingCreditNote" style="cursor:pointer;" />
                                                    </th>
                                                    <th>Item</th>
                                                    <th>Description</th>
                                                    <th style="text-align:right;">Qty</th>
                                                    <th style="text-align:right;">Credit Qty</th>
                                                    <th style="text-align:right;">Price</th>
                                                    <th style="text-align:right;">Total</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (creditNoteLines != null)
                                                {
                                                    @foreach (var line in creditNoteLines)
                                                    {
                                                        <tr class="@(line.IsSelected ? "selected-row" : "")">
                                                            <td>
                                                                <input type="checkbox" @bind="line.IsSelected" disabled="@isCreatingCreditNote"
                                                                       style="cursor:pointer;" />
                                                            </td>
                                                            <td><strong>@line.ItemCode</strong></td>
                                                            <td>@line.ItemDescription</td>
                                                            <td style="text-align:right;">@line.OriginalQuantity</td>
                                                            <td style="text-align:right;">
                                                                <input type="number" class="cn-qty-input" @bind="line.CreditQuantity" min="0"
                                                                       max="@line.OriginalQuantity" step="0.01"
                                                                       disabled="@(!line.IsSelected || isCreatingCreditNote)" />
                                                            </td>
                                                            <td style="text-align:right;">@line.UnitPrice.ToString("N2")</td>
                                                            <td style="text-align:right; font-weight:600;">
                                                                @((line.IsSelected ? line.CreditQuantity * line.UnitPrice : 0).ToString("N2"))
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                            <tfoot>
                                                <tr>
                                                    <td colspan="6" style="text-align:right;">Credit Note Total:</td>
                                                    <td style="text-align:right;">@CalculateCreditNoteTotal().ToString("N2")</td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                                <div class="cn-modal-footer">
                                    <MudButton Class="btn-secondary-action" OnClick="() => showCreateCreditNoteModal = false"
                                               Disabled="@isCreatingCreditNote">Cancel</MudButton>
                                    <MudButton Class="btn-warning-action" OnClick="CreateCreditNote"
                                               Disabled="@(isCreatingCreditNote || string.IsNullOrWhiteSpace(creditNoteReason) || !HasSelectedLines())">
                                        @if (isCreatingCreditNote)
                                        {
                                            <span class="spinner-border spinner-border-sm"></span>
                                            <span>Posting…</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-check-lg"></i>
                                            <span>Create Credit Note</span>
                                        }
                                    </MudButton>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- ━━━ Toast Notification ━━━ -->
                    @if (!string.IsNullOrEmpty(creditNoteMessage))
                    {
                        <div class="toast-banner @(creditNoteSuccess ? "success" : "error")">
                            <i class="bi @(creditNoteSuccess ? "bi-check-circle-fill" : "bi-exclamation-circle-fill") toast-icon"></i>
                            <div class="toast-body">@creditNoteMessage</div>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="toast-close" OnClick="() => creditNoteMessage = null"
                                           Size="Size.Small" />
                        </div>
                    }

@code {
    private MudTable<InvoiceDto> _table = null!;
    private int _pageSize = 10;
    private List<InvoiceDto>? invoices;
    private List<InvoiceDto>? allInvoices;
    private InvoiceDto? selectedInvoice;
    private bool isLoading = true;
    private string? errorMessage;
    private int currentPage = 1;
    private int pageSize = 20;
    private bool hasMore = false;
    private int totalPages = 1;
    private int totalCount = 0;
    private string _searchString = string.Empty;

    private int? docNumSearch;
    private string? customerCode;
    private DateTime? fromDate;
    private DateTime? toDate;

    private CancellationTokenSource? _debounceTokenSource;
    private const int DebounceDelayMs = 300;

    // PDF state
    private bool isPdfLoading = false;

    // Credit Note state
    private CreditNotesByInvoiceResponse? existingCreditNotes;
    private bool showExistingCreditNotesModal = false;
    private bool showCreateCreditNoteModal = false;
    private bool isCreatingCreditNote = false;
    private string? creditNoteReason;
    private List<CreditNoteLineSelection>? creditNoteLines;
    private bool selectAllLines = false;
    private string? creditNoteMessage;
    private bool creditNoteSuccess = false;
    private int creditNoteProgress = 0;
    private string creditNoteProgressMessage = "Initializing...";
    private CancellationTokenSource? _progressCancellationTokenSource;

    // Quick filter
    private Func<InvoiceDto, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        if (x.DocNum.ToString().Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.CardCode?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if (x.CardName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if (x.DocCurrency?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if ($"{x.DocEntry} {x.DocTotal}".Contains(_searchString))
            return true;
        return false;
    };

    private async Task OnInvoiceRowClicked(TableRowClickEventArgs<InvoiceDto> args)
    {
        if (args.Item is not null)
            await ViewInvoice(args.Item.DocEntry);
    }

    private void PageChanged(int i)
    {
        _table.NavigateTo(i - 1);
    }

    protected override async Task OnInitializedAsync()
    {
        pageSize = AppSettings.PageSize;
        await LoadInvoices();
        await AuditService.LogAsync(AuditActions.ViewInvoices, "Invoice", null);
    }

    private string FormatDate(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return "—";
        if (DateTime.TryParse(dateStr, out var date))
            return date.ToString("dd MMM yyyy");
        return dateStr;
    }

    private async Task LoadInvoices()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var hasFilters = docNumSearch.HasValue || !string.IsNullOrWhiteSpace(customerCode) || fromDate.HasValue ||
toDate.HasValue;
            var effectivePageSize = hasFilters ? 5000 : 100;

            var response = await InvoiceService.GetInvoicesAsync(currentPage, effectivePageSize, docNumSearch, customerCode,
fromDate,
toDate);
            if (response != null)
            {
                invoices = response.Invoices;
                allInvoices = response.Invoices;
                hasMore = response.HasMore;
                totalCount = response.TotalCount > 0 ? response.TotalCount : response.Count;
                totalPages = response.TotalPages > 0 ? response.TotalPages : (hasMore ? currentPage + 1 : currentPage);
            }
            else
            {
                errorMessage = "Failed to load invoices. Check if the API is running.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnDocNumChanged()
    {
        _debounceTokenSource?.Cancel();
        _debounceTokenSource = new CancellationTokenSource();
        try
        {
            await Task.Delay(DebounceDelayMs, _debounceTokenSource.Token);
            await FilterByDocNum();
        }
        catch (TaskCanceledException) { }
    }

    private async Task OnCustomerCodeChanged()
    {
        _debounceTokenSource?.Cancel();
        _debounceTokenSource = new CancellationTokenSource();
        try
        {
            await Task.Delay(DebounceDelayMs, _debounceTokenSource.Token);
            await FilterByCustomerCode();
        }
        catch (TaskCanceledException) { }
    }

    private async Task FilterByDocNum()
    {
        if (!docNumSearch.HasValue || docNumSearch.Value == 0)
        {
            if (string.IsNullOrWhiteSpace(customerCode))
            {
                docNumSearch = null;
                await LoadInvoices();
            }
            return;
        }

        currentPage = 1;
        await LoadInvoices();
    }

    private async Task FilterByCustomerCode()
    {
        if (string.IsNullOrWhiteSpace(customerCode))
        {
            if (!docNumSearch.HasValue)
            {
                customerCode = null;
                await LoadInvoices();
            }
            return;
        }

        currentPage = 1;
        await LoadInvoices();
    }

    private async Task ApplyFilter()
    {
        currentPage = 1;
        await LoadInvoices();
    }

    private async Task ClearFilter()
    {
        docNumSearch = null;
        customerCode = null;
        fromDate = null;
        toDate = null;
        currentPage = 1;
        totalPages = 1;
        allInvoices = null;
        await LoadInvoices();
    }

    private async Task ViewInvoice(int docEntry)
    {
        selectedInvoice = await InvoiceService.GetInvoiceByDocEntryAsync(docEntry);
        if (selectedInvoice != null)
        {
            existingCreditNotes = await CreditNoteService.GetCreditNotesForInvoiceAsync(docEntry);
            await AuditService.LogAsync(AuditActions.ViewInvoice, "Invoice", docEntry.ToString());
        }
    }

    private void CloseModal()
    {
        selectedInvoice = null;
        existingCreditNotes = null;
        showExistingCreditNotesModal = false;
        showCreateCreditNoteModal = false;
        creditNoteReason = null;
        creditNoteLines = null;
    }

    private async Task DownloadInvoicePdf()
    {
        if (selectedInvoice == null || isPdfLoading) return;
        isPdfLoading = true;
        try
        {
            var pdfBytes = await InvoiceService.GetInvoicePdfAsync(selectedInvoice.DocEntry);
            if (pdfBytes == null || pdfBytes.Length == 0)
            {
                errorMessage = "Failed to retrieve invoice PDF.";
                return;
            }
            var base64 = Convert.ToBase64String(pdfBytes);
            var fileName = $"Invoice_{selectedInvoice.DocNum}.pdf";
            await JS.InvokeVoidAsync("downloadPdfFromBase64", base64, fileName);
            await AuditService.LogAsync(AuditActions.DownloadInvoicePdf, "Invoice", selectedInvoice.DocNum.ToString());
        }
        catch (Exception ex)
        {
            errorMessage = $"Download failed: {ex.Message}";
        }
        finally
        {
            isPdfLoading = false;
        }
    }

    private async Task PrintInvoicePdf()
    {
        if (selectedInvoice == null || isPdfLoading) return;
        isPdfLoading = true;
        try
        {
            var pdfBytes = await InvoiceService.GetInvoicePdfAsync(selectedInvoice.DocEntry);
            if (pdfBytes == null || pdfBytes.Length == 0)
            {
                errorMessage = "Failed to retrieve invoice PDF for printing.";
                return;
            }
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("printPdfFromBase64", base64, 1);
            await AuditService.LogAsync(AuditActions.PrintInvoicePdf, "Invoice", selectedInvoice.DocNum.ToString());
        }
        catch (Exception ex)
        {
            errorMessage = $"Print failed: {ex.Message}";
        }
        finally
        {
            isPdfLoading = false;
        }
    }

    private void ShowExistingCreditNotes()
    {
        showExistingCreditNotesModal = true;
    }

    private void OpenCreateCreditNoteModal()
    {
        if (selectedInvoice?.Lines == null) return;

        creditNoteLines = selectedInvoice.Lines.Select(line => new CreditNoteLineSelection
        {
            ItemCode = line.ItemCode ?? "",
            ItemDescription = line.ItemDescription,
            OriginalQuantity = line.Quantity,
            CreditQuantity = line.Quantity,
            UnitPrice = line.UnitPrice,
            WarehouseCode = line.WarehouseCode,
            LineNum = line.LineNum,
            IsSelected = true
        }).ToList();

        selectAllLines = true;
        creditNoteReason = null;
        showCreateCreditNoteModal = true;
    }

    private void ToggleAllLines()
    {
        if (creditNoteLines != null)
        {
            foreach (var line in creditNoteLines)
                line.IsSelected = selectAllLines;
        }
    }

    private bool HasSelectedLines()
    {
        return creditNoteLines?.Any(l => l.IsSelected && l.CreditQuantity > 0) ?? false;
    }

    private decimal CalculateCreditNoteTotal()
    {
        if (creditNoteLines == null) return 0;
        return creditNoteLines.Where(l => l.IsSelected).Sum(l => l.CreditQuantity * l.UnitPrice);
    }

    private async Task CreateCreditNote()
    {
        if (selectedInvoice == null || creditNoteLines == null || string.IsNullOrWhiteSpace(creditNoteReason))
            return;

        isCreatingCreditNote = true;
        creditNoteMessage = null;
        creditNoteProgress = 0;
        creditNoteProgressMessage = "Initializing...";

        _progressCancellationTokenSource = new CancellationTokenSource();
        _ = SimulateSapProgressAsync(_progressCancellationTokenSource.Token);

        try
        {
            var selectedLines = creditNoteLines
            .Where(l => l.IsSelected && l.CreditQuantity > 0)
            .Select(l => new CreateCreditNoteLineRequest
            {
                ItemCode = l.ItemCode,
                ItemDescription = l.ItemDescription,
                Quantity = l.CreditQuantity,
                UnitPrice = l.UnitPrice,
                WarehouseCode = l.WarehouseCode,
                OriginalInvoiceLineId = l.LineNum
            })
            .ToList();

            var result = await CreditNoteService.CreateFromInvoiceAsync(
            selectedInvoice.DocEntry,
            selectedLines,
            creditNoteReason
            );

            _progressCancellationTokenSource?.Cancel();

            if (result.Success && result.CreditNote != null)
            {
                creditNoteProgress = 100;
                creditNoteProgressMessage = "Credit note created successfully!";
                StateHasChanged();
                await Task.Delay(500);

                creditNoteSuccess = true;
                creditNoteMessage = $"Credit Note {result.CreditNote.CreditNoteNumber} created successfully!";
                showCreateCreditNoteModal = false;

                existingCreditNotes = await CreditNoteService.GetCreditNotesForInvoiceAsync(selectedInvoice.DocEntry);
            }
            else
            {
                creditNoteSuccess = false;
                creditNoteMessage = result.ErrorMessage ?? "Failed to create credit note. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _progressCancellationTokenSource?.Cancel();
            creditNoteSuccess = false;
            creditNoteMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isCreatingCreditNote = false;
            creditNoteProgress = 0;
        }
    }

    private async Task SimulateSapProgressAsync(CancellationToken cancellationToken)
    {
        var progressSteps = new[]
        {
(10, "Validating credit note data..."),
(25, "Connecting to SAP Business One..."),
(40, "Authenticating with SAP..."),
(55, "Preparing credit note document..."),
(70, "Posting credit note to SAP..."),
(85, "Processing inventory adjustments..."),
(95, "Finalizing transaction...")
};

        try
        {
            foreach (var (progress, message) in progressSteps)
            {
                if (cancellationToken.IsCancellationRequested) return;

                while (creditNoteProgress < progress && !cancellationToken.IsCancellationRequested)
                {
                    creditNoteProgress += 2;
                    if (creditNoteProgress > progress)
                        creditNoteProgress = progress;
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(100, cancellationToken);
                }

                creditNoteProgressMessage = message;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(800, cancellationToken);
            }

            while (!cancellationToken.IsCancellationRequested)
            {
                if (creditNoteProgress >= 95)
                    creditNoteProgress = 85;
                creditNoteProgress += 1;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(300, cancellationToken);
            }
        }
        catch (TaskCanceledException) { /* Expected */ }
    }

    private string GetCreditNoteStatusClass(CreditNoteStatus status) => status switch
    {
        CreditNoteStatus.Draft => "",
        CreditNoteStatus.Pending => "partial",
        CreditNoteStatus.Approved => "open",
        CreditNoteStatus.Applied => "closed",
        CreditNoteStatus.PartiallyApplied => "partial",
        CreditNoteStatus.Cancelled => "",
        CreditNoteStatus.Voided => "",
        _ => ""
    };

    private string TruncateText(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "—";
        return text.Length <= maxLength ? text : text.Substring(0, maxLength) + "…";
    }

    private async Task OnPageChanged(int page)
    {
        if (page >= 1 && page != currentPage)
        {
            currentPage = page;
            await LoadInvoices();
        }
    }

    private async Task OnPageSizeChanged()
    {
        currentPage = 1;
        await LoadInvoices();
    }

