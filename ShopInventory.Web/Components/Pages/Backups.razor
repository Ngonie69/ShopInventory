@code {
    private List<BackupDto>? backups;
    private BackupStatsDto? stats;
    private BackupDto? backupToRestore;
    private BackupDto? backupToDelete;
    private bool isLoading = true;
    private bool isCreating = false;
    private bool isRestoring = false;
    private bool showCreateModal = false;
    private bool showRestoreModal = false;
    private bool showDeleteModal = false;
    private string? errorMessage;
    private string toastMessage = string.Empty;
    private bool toastIsError = false;

    private CreateBackupRequest newBackup = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await AuditService.LogAsync(AuditActions.ViewBackups, "Backup", null);
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var backupTask = BackupService.GetAllBackupsAsync();
            var statsTask = BackupService.GetStatsAsync();
            await Task.WhenAll(backupTask, statsTask);

            var response = await backupTask;
            stats = await statsTask;

            if (response != null)
            {
                backups = response.Backups.OrderByDescending(b => b.StartedAt).ToList();
            }
            else
            {
                errorMessage = "Failed to load backups. The API may be unavailable.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RetryLoad()
    {
        await LoadData();
    }

    private async Task CreateBackup()
    {
        isCreating = true;
        try
        {
            var result = await BackupService.CreateBackupAsync(newBackup);
            if (result != null)
            {
                showCreateModal = false;
                newBackup = new();
                ShowToast("Backup created successfully");
                await AuditService.LogAsync(AuditActions.CreateBackup, "Backup", result.Id.ToString(), $"Type: {result.BackupType}",
true);
                await LoadData();
            }
            else
            {
                ShowToast("Failed to create backup", true);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Error creating backup: {ex.Message}", true);
        }
        finally
        {
            isCreating = false;
        }
    }

    private void ConfirmRestore(BackupDto backup)
    {
        backupToRestore = backup;
        showRestoreModal = true;
    }

    private async Task RestoreBackup()
    {
        if (backupToRestore == null) return;

        isRestoring = true;
        try
        {
            var success = await BackupService.RestoreBackupAsync(backupToRestore.Id);
            if (success)
            {
                showRestoreModal = false;
                backupToRestore = null;
                ShowToast("Backup restored successfully");
                await AuditService.LogAsync(AuditActions.RestoreBackup, "Backup", backupToRestore?.Id.ToString());
                await LoadData();
            }
            else
            {
                ShowToast("Failed to restore backup", true);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Error restoring backup: {ex.Message}", true);
        }
        finally
        {
            isRestoring = false;
        }
    }

    private void ConfirmDelete(BackupDto backup)
    {
        backupToDelete = backup;
        showDeleteModal = true;
    }

    private async Task DeleteBackup()
    {
        if (backupToDelete == null) return;

        try
        {
            var success = await BackupService.DeleteBackupAsync(backupToDelete.Id);
            if (success)
            {
                showDeleteModal = false;
                backupToDelete = null;
                ShowToast("Backup deleted successfully");
                await AuditService.LogAsync(AuditActions.DeleteBackup, "Backup", backupToDelete?.Id.ToString());
                await LoadData();
            }
            else
            {
                ShowToast("Failed to delete backup", true);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Error deleting backup: {ex.Message}", true);
        }
    }

    private async Task DownloadBackup(int id)
    {
        try
        {
            var backup = backups?.FirstOrDefault(b => b.Id == id);
            if (backup == null) return;

            await JS.InvokeVoidAsync("downloadAuthenticatedFile", $"/download/backup/{id}", backup.FileName);
            await AuditService.LogAsync(AuditActions.DownloadBackup, "Backup", id.ToString());
        }
        catch (Exception ex)
        {
            ShowToast($"Error downloading backup: {ex.Message}", true);
        }
    }

    private void ShowToast(string message, bool isError = false)
    {
        toastMessage = message;
        toastIsError = isError;
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(5000);
            toastMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
        });
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Completed" => "bak-badge-green",
        "InProgress" => "bak-badge-blue",
        "Failed" => "bak-badge-red",
        _ => "bak-badge-gray"
    };

    private string GetTypeBadgeClass(string type) => type switch
    {
        "Full" => "bak-badge-purple",
        "Incremental" => "bak-badge-blue",
        "Differential" => "bak-badge-amber",
        _ => "bak-badge-gray"
    };
}