@page "/sales-orders"
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@attribute [Authorize(Roles = "Admin,Cashier")]
@inject ISalesOrderService SalesOrderService
@inject IBusinessPartnerService BusinessPartnerService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@rendermode InteractiveServer

<PageTitle>Sales Orders - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .so-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Header ──────────────────────────────────────── */
    .so-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .so-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .so-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .so-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .so-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .btn-so-gradient {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 2px 8px rgba(102, 126, 234, .25);
        cursor: pointer;
    }

    .btn-so-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .4);
        color: #fff;
    }

    /* ── Stat Cards ───────────────────────────────────── */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .stat-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1rem 1.15rem;
        display: flex;
        align-items: center;
        gap: .85rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        transition: transform .15s, box-shadow .15s;
    }

    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 0, 0, .06);
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        flex-shrink: 0;
    }

    .stat-icon.total {
        background: #ede9fe;
        color: #7c3aed;
    }

    .stat-icon.pending {
        background: #fef3c7;
        color: #d97706;
    }

    .stat-icon.approved {
        background: #d1fae5;
        color: #059669;
    }

    .stat-icon.fulfilled {
        background: #dbeafe;
        color: #2563eb;
    }

    .stat-info .stat-value {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1.1;
        font-family: 'Space Grotesk', monospace;
    }

    .stat-info .stat-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
    }

    /* ── Filter Bar ──────────────────────────────────── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        align-items: flex-end;
        padding: 1rem 1.25rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .filter-bar .filter-field {
        flex: 1;
        min-width: 140px;
    }

    .filter-bar .filter-field label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .3rem;
    }

    .filter-bar .filter-field input,
    .filter-bar .filter-field select {
        width: 100%;
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        background: #fff;
        transition: all .15s;
    }

    .filter-bar .filter-field input:focus,
    .filter-bar .filter-field select:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .filter-actions-row {
        display: flex;
        gap: .5rem;
        align-items: flex-end;
    }

    .btn-search {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-search:hover {
        opacity: .92;
        transform: translateY(-1px);
    }

    .btn-clear {
        background: #fff;
        color: #6b7280;
        border: 1px solid #d1d5db;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-clear:hover {
        background: #f3f4f6;
    }

    /* ── Table ───────────────────────────────────────── */
    .so-table-wrap {
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #fff;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .so-table-header {
        padding: .85rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
    }

    .so-table-header h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .92rem;
    }

    .so-count-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #374151;
    }

    /* ── Status Badges ───────────────────────────────── */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .73rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-badge.draft {
        background: #f3f4f6;
        color: #6b7280;
    }

    .status-badge.pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-badge.approved {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.partial {
        background: #e0e7ff;
        color: #3730a3;
    }

    .status-badge.fulfilled {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-badge.invoiced {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.cancelled {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-badge.on-hold {
        background: #374151;
        color: #fff;
    }

    /* ── Cell Styles ─────────────────────────────────── */
    .doc-number {
        font-weight: 700;
        color: #667eea;
        font-family: 'Space Grotesk', monospace;
        font-size: .88rem;
    }

    .customer-info .name {
        font-weight: 600;
        font-size: .85rem;
        color: #1a1a2e;
    }

    .customer-info .code {
        font-size: .75rem;
        color: #9ca3af;
        font-family: 'Space Grotesk', monospace;
    }

    .amount-cell {
        font-weight: 700;
        color: #1a1a2e;
        font-family: 'Space Grotesk', monospace;
        font-size: .88rem;
    }

    /* ── Action Buttons ──────────────────────────────── */
    .action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .85rem;
    }

    .action-btn:hover {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }

    .action-btn.view:hover {
        background: #ede9fe;
        color: #667eea;
        border-color: #c4b5fd;
    }

    .action-btn.approve:hover {
        background: #d1fae5;
        color: #059669;
        border-color: #6ee7b7;
    }

    .action-btn.invoice:hover {
        background: #dbeafe;
        color: #2563eb;
        border-color: #93c5fd;
    }

    .action-btn.delete:hover {
        background: #fee2e2;
        color: #dc2626;
        border-color: #fca5a5;
    }

    .sync-dot {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .78rem;
        font-weight: 600;
    }

    .sync-dot i {
        font-size: .7rem;
    }

    .sync-dot.synced {
        color: #059669;
    }

    .sync-dot.unsynced {
        color: #d97706;
    }

    /* ── Drawer ──────────────────────────────────────── */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        z-index: 9998;
        animation: fadeIn .2s ease;
    }

    .detail-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(640px, 95vw);
        height: 100vh;
        background: #fff;
        z-index: 9999;
        box-shadow: -8px 0 30px rgba(0, 0, 0, .12);
        display: flex;
        flex-direction: column;
        animation: slideInRight .25s ease;
    }

    .drawer-header {
        padding: 1.15rem 1.5rem;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }

    .drawer-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .drawer-header .btn-close-drawer {
        background: rgba(255, 255, 255, .15);
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s;
        font-size: 1rem;
    }

    .drawer-header .btn-close-drawer:hover {
        background: rgba(255, 255, 255, .25);
    }

    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .drawer-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
        margin-bottom: 1.25rem;
    }

    .detail-item .detail-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
        margin-bottom: .15rem;
    }

    .detail-item .detail-value {
        font-size: .92rem;
        font-weight: 600;
        color: #1a1a2e;
    }

    .detail-section-title {
        font-weight: 600;
        color: #1a1a2e;
        font-size: .9rem;
        margin-bottom: .75rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    /* ── Lines Table ─────────────────────────────────── */
    .lines-table {
        width: 100%;
        font-size: .85rem;
        border-collapse: separate;
        border-spacing: 0;
    }

    .lines-table th {
        background: #f8fafc;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6b7280;
        font-weight: 600;
        padding: .6rem .75rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .lines-table td {
        padding: .55rem .75rem;
        border-bottom: 1px solid #f3f4f6;
        color: #374151;
    }

    .lines-table tr:last-child td {
        border-bottom: none;
    }

    .lines-table tfoot td {
        border-top: 2px solid #e5e7eb;
        background: #f8fafc;
    }

    /* Total Banner */
    .total-banner {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.25rem;
    }

    .total-banner .total-label {
        font-size: .9rem;
        font-weight: 500;
    }

    .total-banner .total-value {
        font-size: 1.4rem;
        font-weight: 700;
    }

    /* ── Create Modal ────────────────────────────────── */
    .create-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .5);
        z-index: 10000;
        display: flex;
        justify-content: center;
        align-items: center;
        animation: fadeIn .2s ease;
        padding: 1rem;
    }

    .create-modal {
        background: #fff;
        border-radius: 14px;
        width: min(600px, 95vw);
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
        animation: scaleIn .25s ease;
    }

    .create-modal-header {
        padding: 1.15rem 1.5rem;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .create-modal-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1rem;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .create-modal-header .btn-close-modal {
        background: #f3f4f6;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #6b7280;
        transition: all .15s;
        font-size: .9rem;
    }

    .create-modal-header .btn-close-modal:hover {
        background: #e5e7eb;
        color: #374151;
    }

    .create-modal-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .create-modal-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    .form-field {
        display: flex;
        flex-direction: column;
    }

    .form-field.full {
        grid-column: span 2;
    }

    .form-field label {
        font-size: .75rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: .25rem;
    }

    .form-field input,
    .form-field select,
    .form-field textarea {
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        transition: all .15s;
    }

    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .btn-create {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-create:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
    }

    .btn-create:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    .btn-secondary-action {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .15s;
    }

    .btn-secondary-action:hover {
        background: #f9fafb;
    }

    /* ── Empty / Loading ─────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 1.8rem;
        color: #9ca3af;
    }

    .empty-state h6 {
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
    }

    .empty-state p {
        color: #9ca3af;
        font-size: .88rem;
    }

    .loading-state {
        text-align: center;
        padding: 3rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    /* ── Alert ───────────────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    /* ── Animations ──────────────────────────────────── */
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }

        to {
            transform: translateX(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@media (max-width:768px) {
        .so-header {
            flex-direction: column;
        }

        .filter-bar {
            flex-direction: column;
        }

        .stat-row {
            grid-template-columns: 1fr 1fr;
        }

        .detail-grid,
        .form-grid {
            grid-template-columns: 1fr;
        }

        .form-field.full {
            grid-column: span 1;
        }
    }
</style>

<div class="so-page">
    <div class="container-fluid">

        <!-- ━━━ Header ━━━ -->
        <div class="so-header">
            <div class="so-header-left">
                <div class="so-header-icon"><i class="bi bi-cart-check"></i></div>
                <div>
                    <h2>Sales Orders</h2>
                    <p>Track order status and fulfillment</p>
                </div>
            </div>
            <MudButton Class="btn-so-gradient" OnClick="@(() => showCreateModal = true)">
                <i class="bi bi-plus-lg"></i> New Sales Order
            </MudButton>
        </div>

        <!-- ━━━ Alerts ━━━ -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner error-alert">
                <i class="bi bi-exclamation-octagon-fill"></i>
                <div style="flex:1;">@errorMessage</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Style="background:none;border:none;color:inherit;opacity:.45;cursor:pointer;font-size:1rem;"
                               OnClick="() => errorMessage = null" />
            </div>
        }

        <!-- ━━━ Stat Cards ━━━ -->
        @if (orders?.Any() == true)
        {
            <div class="stat-row">
                <div class="stat-card">
                    <div class="stat-icon total"><i class="bi bi-cart-check"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@totalCount</div>
                        <div class="stat-label">Total Orders</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon pending"><i class="bi bi-clock-history"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@orders.Count(o => o.Status == SalesOrderStatus.Pending)</div>
                        <div class="stat-label">Pending</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon approved"><i class="bi bi-check-circle"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@orders.Count(o => o.Status == SalesOrderStatus.Approved)</div>
                        <div class="stat-label">Approved</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon fulfilled"><i class="bi bi-truck"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@orders.Count(o => o.Status == SalesOrderStatus.Fulfilled || o.Status ==
                                                    SalesOrderStatus.Invoiced)</div>
                            <div class="stat-label">Fulfilled</div>
                        </div>
                    </div>
                </div>
            }

            <!-- ━━━ Filter Bar ━━━ -->
            <div class="filter-bar">
                <div class="filter-field">
                    <label>Order Number</label>
                    <input type="text" @bind="orderNumberFilter" placeholder="e.g., SO-001" />
                </div>
                <div class="filter-field">
                    <label>Customer</label>
                    <input type="text" @bind="customerFilter" placeholder="Customer code" />
                </div>
                <div class="filter-field">
                    <label>Status</label>
                    <select @bind="statusFilter">
                        <option value="">All Statuses</option>
                        @foreach (SalesOrderStatus status in Enum.GetValues(typeof(SalesOrderStatus)))
                        {
                            <option value="@(((int)status).ToString())">@status</option>
                        }
                    </select>
                </div>
                <div class="filter-field">
                    <label>From Date</label>
                    <MudDatePicker @bind-Date="fromDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   DateFormat="dd.MM.yyyy" Editable="true" />
                </div>
                <div class="filter-field">
                    <label>To Date</label>
                    <MudDatePicker @bind-Date="toDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   DateFormat="dd.MM.yyyy" Editable="true" />
                </div>
                <div class="filter-actions-row">
                    <MudButton Class="btn-search" OnClick="ApplyFilter">
                        <i class="bi bi-search"></i> Search
                    </MudButton>
                    <MudButton Class="btn-clear" OnClick="ClearFilter">
                        <i class="bi bi-x-circle"></i> Clear
                    </MudButton>
                </div>
            </div>

            <!-- ━━━ Content ━━━ -->
            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner-border" style="color:#667eea;width:2.5rem;height:2.5rem;" role="status"></div>
                    <p style="margin-top:.75rem;color:#6b7280;font-weight:500;">Loading sales orders...</p>
                </div>
            }
            else if (orders?.Any() == true)
            {
                <div class="so-table-wrap">
                    <div class="so-table-header">
                        <h6><i class="bi bi-table"></i> Sales Orders</h6>
                        <span class="so-count-badge">@totalCount total</span>
                    </div>
                    <MudTable @ref="@_table" Items="@orders" RowsPerPage="10" Hover="true" Striped="true" Dense="true"
                              Breakpoint="Breakpoint.Sm" Loading="@isLoading" LoadingProgressColor="Color.Primary" T="SalesOrderDto"
                              Elevation="0" Style="background:transparent;">
                        <HeaderContent>
                            <MudTh>Doc Entry</MudTh>
                            <MudTh>Doc #</MudTh>
                            <MudTh>Customer</MudTh>
                            <MudTh>Order Date</MudTh>
                            <MudTh>Delivery</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Currency</MudTh>
                            <MudTh Style="text-align:right">Total</MudTh>
                            <MudTh>Synced</MudTh>
                            <MudTh Style="width:150px">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Doc Entry"><span
                                style="font-size:.85rem;color:#6b7280;">@context.SAPDocEntry</span></MudTd>
                                <MudTd DataLabel="Doc #"><span class="doc-number">@context.SAPDocNum</span></MudTd>
                                <MudTd DataLabel="Customer">
                                    <div class="customer-info">
                                        <span class="name">@context.CardName</span>
                                        <span class="code">@context.CardCode</span>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="Order Date"><span
                                    style="font-size:.85rem;color:#374151;">@context.OrderDate.ToString("dd MMM yyyy")</span>
                                </MudTd>
                                <MudTd DataLabel="Delivery"><span
                                    style="font-size:.85rem;color:#374151;">@(context.DeliveryDate?.ToString("dd MMM yyyy") ??
                                                                "—")</span></MudTd>
                                    <MudTd DataLabel="Status">
                                        <span class="status-badge @GetStatusCssClass(context.Status)">@context.StatusName</span>
                                    </MudTd>
                                    <MudTd DataLabel="Currency"><span style="font-size:.85rem;color:#6b7280;">@context.Currency</span>
                                    </MudTd>
                                    <MudTd DataLabel="Total" Style="text-align:right">
                                        <span class="amount-cell">@context.DocTotal.ToString("N2")</span>
                                    </MudTd>
                                    <MudTd DataLabel="Synced">
                                        @if (context.IsSynced)
                                        {
                                            <span class="sync-dot synced"><i class="bi bi-circle-fill"></i> Synced</span>
                                        }
                                        else
                                        {
                                            <span class="sync-dot unsynced"><i class="bi bi-circle-fill"></i> Pending</span>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Actions">
                                        <MudStack Row="true" Spacing="1">
                                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                                           Variant="Variant.Outlined" Color="Color.Primary" Title="View Details"
                                                           OnClick="() => ViewOrder(context)" />
                                            @if (context.Status == SalesOrderStatus.Approved && context.InvoiceId == null)
                                            {
                                                <MudIconButton
                                                Icon="@(convertingOrderId == context.Id ? Icons.Material.Filled.HourglassTop : Icons.Material.Filled.Receipt)"
                                                Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                                Title="Convert to Invoice" Disabled="@(convertingOrderId == context.Id)"
                                                OnClick="() => ConvertToInvoice(context)" />
                                            }
                                            @if (!context.IsSynced)
                                            {
                                                @if (context.Status == SalesOrderStatus.Pending)
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                                                                   Variant="Variant.Outlined" Color="Color.Success" Title="Approve"
                                                                   OnClick="() => ApproveOrder(context.Id)" />
                                                }
                                                @if (context.Status == SalesOrderStatus.Draft || context.Status ==
                                                                            SalesOrderStatus.Cancelled)
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                   Variant="Variant.Outlined" Color="Color.Error" Title="Delete"
                                                                   OnClick="() => DeleteOrder(context.Id)" />
                                                }
                                            }
                                        </MudStack>
                                    </MudTd>
                                </RowTemplate>
                                <PagerContent>
                                    <MudPagination SelectedChanged="PageChanged"
                                                   Count="@((_table.GetFilteredItemsCount() + _table.RowsPerPage - 1) / _table.RowsPerPage)"
                                                   Class="pa-4" />
                                </PagerContent>
                            </MudTable>
                        </div>
                    }
        else
                    {
                        <div class="empty-state">
                            <div class="empty-icon"><i class="bi bi-cart-x"></i></div>
                            <h6>No sales orders found</h6>
                            <p>Create a new order or adjust your filters to find existing ones.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- ━━━ View Order Drawer ━━━ -->
            @if (selectedOrder != null)
            {
                <div class="modal-backdrop-custom" @onclick="() => selectedOrder = null"></div>
                <div class="detail-drawer">
                    <div class="drawer-header">
                        <h5><i class="bi bi-cart-check me-2"></i>Sales Order: @selectedOrder.OrderNumber</h5>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Class="btn-close-drawer"
                                       OnClick="() => selectedOrder = null" />
                    </div>
                    <div class="drawer-body">
                        <div class="detail-grid">
                            <div class="detail-item">
                                <div class="detail-label">Customer</div>
                                <div class="detail-value">@selectedOrder.CardCode — @selectedOrder.CardName</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Order Date</div>
                                <div class="detail-value">@selectedOrder.OrderDate.ToString("dd MMM yyyy")</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Delivery Date</div>
                                <div class="detail-value">@(selectedOrder.DeliveryDate?.ToString("dd MMM yyyy") ?? "Not set")</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Status</div>
                                <div class="detail-value"><span
                                    class="status-badge @GetStatusCssClass(selectedOrder.Status)">@selectedOrder.StatusName</span>
                                </div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Currency</div>
                                <div class="detail-value">@selectedOrder.Currency</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Created By</div>
                                <div class="detail-value">@selectedOrder.CreatedByUserName</div>
                            </div>
                        </div>

                        @if (selectedOrder.Lines?.Any() == true)
                        {
                            <div class="detail-section-title"><i class="bi bi-list-ul"></i> Order Lines</div>
                            <table class="lines-table">
                                <thead>
                                    <tr>
                                        <th>Item</th>
                                        <th>Description</th>
                                        <th style="text-align:right">Qty</th>
                                        <th style="text-align:right">Unit Price</th>
                                        <th style="text-align:right">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var line in selectedOrder.Lines)
                                    {
                                        <tr>
                                            <td><span style="font-weight:600;color:#667eea;">@line.ItemCode</span></td>
                                            <td>@line.ItemDescription</td>
                                            <td style="text-align:right;font-weight:600;">@line.Quantity</td>
                                            <td style="text-align:right;">@line.UnitPrice.ToString("N2")</td>
                                            <td style="text-align:right;font-weight:600;">@line.LineTotal.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="4" style="text-align:right;font-weight:600;">Subtotal:</td>
                                        <td style="text-align:right;font-weight:600;">@selectedOrder.SubTotal.ToString("N2")</td>
                                    </tr>
                                    <tr>
                                        <td colspan="4" style="text-align:right;font-weight:600;">Tax:</td>
                                        <td style="text-align:right;">@selectedOrder.TaxAmount.ToString("N2")</td>
                                    </tr>
                                </tfoot>
                            </table>

                            <div class="total-banner">
                                <span class="total-label">Total</span>
                                <span class="total-value">@selectedOrder.DocTotal.ToString("N2")</span>
                            </div>
                        }
                    </div>
                    <div class="drawer-footer">
                        <MudButton Class="btn-secondary-action" OnClick="() => selectedOrder = null">Close</MudButton>
                    </div>
                </div>
            }

            <!-- ━━━ Create Order Modal ━━━ -->
            @if (showCreateModal)
            {
                <div class="create-modal-overlay" @onclick="() => showCreateModal = false">
                    <div class="create-modal" @onclick:stopPropagation="true">
                        <div class="create-modal-header">
                            <h5><i class="bi bi-plus-circle"></i> New Sales Order</h5>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="btn-close-modal"
                                           OnClick="() => showCreateModal = false" />
                        </div>
                        <div class="create-modal-body">
                            <div class="form-grid">
                                <div class="form-field">
                                    <label>Customer Code *</label>
                                    <input type="text" @bind="newOrder.CardCode" placeholder="e.g., C001" />
                                </div>
                                <div class="form-field">
                                    <label>Customer Name</label>
                                    <input type="text" @bind="newOrder.CardName" />
                                </div>
                                <div class="form-field">
                                    <label>Delivery Date</label>
                                    <MudDatePicker @bind-Date="newOrder.DeliveryDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   DateFormat="dd.MM.yyyy" Editable="true" />
                                </div>
                                <div class="form-field">
                                    <label>Currency</label>
                                    <select @bind="newOrder.Currency">
                                        <option value="USD">USD</option>
                                        <option value="ZIG">ZIG</option>
                                    </select>
                                </div>
                                <div class="form-field full">
                                    <label>Comments</label>
                                    <textarea @bind="newOrder.Comments" rows="2" placeholder="Optional comments"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="create-modal-footer">
                            <MudButton Class="btn-secondary-action" OnClick="() => showCreateModal = false">Cancel</MudButton>
                            <MudButton Class="btn-create" OnClick="CreateOrder" Disabled="@isCreating">
                                @if (isCreating)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                <span>Create Order</span>
                            </MudButton>
                        </div>
                    </div>
                </div>
            }

@code {
    private MudTable<SalesOrderDto>? _table;
    private List<SalesOrderDto>? orders;
    private SalesOrderDto? selectedOrder;
    private bool isLoading = true;
    private bool isCreating = false;
    private bool showCreateModal = false;
    private string? errorMessage;
    private int? convertingOrderId;

    // Filters
    private string? orderNumberFilter;
    private string? customerFilter;
    private string? statusFilter;
    private DateTime? fromDate;
    private DateTime? toDate;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalPages = 1;
    private int totalCount = 0;

    // New order
    private CreateSalesOrderRequest newOrder = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private void PageChanged(int i)
    {
        _table.NavigateTo(i - 1);
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            SalesOrderStatus? status = null;
            if (!string.IsNullOrEmpty(statusFilter) && int.TryParse(statusFilter, out var statusInt))
            {
                status = (SalesOrderStatus)statusInt;
            }

            var response = await SalesOrderService.GetSalesOrdersAsync(currentPage, pageSize, status, customerFilter, fromDate,
            toDate);
            if (response != null)
            {
                orders = response.Orders;
                totalCount = response.TotalCount;
                totalPages = response.TotalPages;
            }
            else
            {
                errorMessage = "Failed to load sales orders.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilter() => await LoadOrders();

    private async Task ClearFilter()
    {
        orderNumberFilter = null;
        customerFilter = null;
        statusFilter = null;
        fromDate = null;
        toDate = null;
        currentPage = 1;
        await LoadOrders();
    }

    private async Task OnPageChanged(int page)
    {
        await GoToPage(page);
    }

    private async Task GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            await LoadOrders();
        }
    }

    private void ViewOrder(SalesOrderDto order)
    {
        selectedOrder = order;
    }

    private async Task ApproveOrder(int id)
    {
        var result = await SalesOrderService.ApproveAsync(id);
        if (result != null)
        {
            await LoadOrders();
        }
    }

    private async Task ConvertToInvoice(SalesOrderDto order)
    {
        var result = await DialogService.ShowMessageBoxAsync(
        "Convert to Invoice",
        $"Are you sure you want to convert order {order.OrderNumber} for {order.CardName ?? order.CardCode} (Total: {order.Currency} {order.DocTotal:N2}) into an invoice?",
        yesText: "Convert",
        cancelText: "Cancel");

        if (result != true) return;

        convertingOrderId = order.Id;
        StateHasChanged();

        try
        {
            var invoice = await SalesOrderService.ConvertToInvoiceAsync(order.Id);
            if (invoice != null)
            {
                Snackbar.Add($"Order {order.OrderNumber} converted to Invoice #{invoice.DocNum} successfully!", Severity.Success);
                await LoadOrders();
            }
            else
            {
                Snackbar.Add("Failed to convert sales order to invoice. Please try again.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error converting order: {ex.Message}", Severity.Error);
        }
        finally
        {
            convertingOrderId = null;
            StateHasChanged();
        }
    }

    private async Task DeleteOrder(int id)
    {
        var success = await SalesOrderService.DeleteSalesOrderAsync(id);
        if (success)
        {
            await LoadOrders();
        }
    }

    private async Task CreateOrder()
    {
        if (string.IsNullOrEmpty(newOrder.CardCode))
        {
            return;
        }

        isCreating = true;
        try
        {
            var result = await SalesOrderService.CreateSalesOrderAsync(newOrder);
            if (result != null)
            {
                showCreateModal = false;
                newOrder = new();
                await LoadOrders();
            }
        }
        finally
        {
            isCreating = false;
        }
    }

    private string GetStatusCssClass(SalesOrderStatus status) => status switch
    {
        SalesOrderStatus.Draft => "draft",
        SalesOrderStatus.Pending => "pending",
        SalesOrderStatus.Approved => "approved",
        SalesOrderStatus.PartiallyFulfilled => "partial",
        SalesOrderStatus.Fulfilled => "fulfilled",
        SalesOrderStatus.Invoiced => "invoiced",
        SalesOrderStatus.Cancelled => "cancelled",
        SalesOrderStatus.OnHold => "on-hold",
        _ => "draft"
    };

    private async Task OnPageSizeChanged()
    {
        currentPage = 1;
        await LoadOrders();
    }
}