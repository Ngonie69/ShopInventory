@page "/sales-orders"
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@attribute [Authorize(Roles = "Admin,Cashier,SalesRep")]
@inject ISalesOrderService SalesOrderService
@inject IBusinessPartnerService BusinessPartnerService
@inject IMasterDataCacheService CacheService
@inject IPriceService PriceService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<SalesOrders> Logger
@inject IAppSettingsProvider AppSettings
@inject IAuditService AuditService
@rendermode InteractiveServer

<PageTitle>Sales Orders - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .so-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Header ──────────────────────────────────────── */
    .so-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .so-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .so-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .so-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .so-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .btn-so-gradient {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 2px 8px rgba(102, 126, 234, .25);
        cursor: pointer;
    }

    .btn-so-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .4);
        color: #fff;
    }

    /* ── Stat Cards ───────────────────────────────────── */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .stat-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1rem 1.15rem;
        display: flex;
        align-items: center;
        gap: .85rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        transition: transform .15s, box-shadow .15s;
    }

    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 0, 0, .06);
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        flex-shrink: 0;
    }

    .stat-icon.total {
        background: #ede9fe;
        color: #7c3aed;
    }

    .stat-icon.pending {
        background: #fef3c7;
        color: #d97706;
    }

    .stat-icon.approved {
        background: #d1fae5;
        color: #059669;
    }

    .stat-icon.fulfilled {
        background: #dbeafe;
        color: #2563eb;
    }

    .stat-info .stat-value {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1.1;
        font-family: 'Space Grotesk', monospace;
    }

    .stat-info .stat-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
    }

    /* ── Filter Bar ──────────────────────────────────── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        align-items: flex-end;
        padding: 1rem 1.25rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .filter-bar .filter-field {
        flex: 1;
        min-width: 140px;
    }

    .filter-bar .filter-field label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .3rem;
    }

    .filter-bar .filter-field input,
    .filter-bar .filter-field select {
        width: 100%;
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        background: #fff;
        transition: all .15s;
    }

    .filter-bar .filter-field input:focus,
    .filter-bar .filter-field select:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .filter-actions-row {
        display: flex;
        gap: .5rem;
        align-items: flex-end;
    }

    .btn-search {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-search:hover {
        opacity: .92;
        transform: translateY(-1px);
    }

    .btn-clear {
        background: #fff;
        color: #6b7280;
        border: 1px solid #d1d5db;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-clear:hover {
        background: #f3f4f6;
    }

    /* ── Table ───────────────────────────────────────── */
    .so-table-wrap {
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #fff;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .so-table-header {
        padding: .85rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
    }

    .so-table-header h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .92rem;
    }

    .so-count-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #374151;
    }

    /* ── Status Badges ───────────────────────────────── */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .73rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-badge.draft {
        background: #f3f4f6;
        color: #6b7280;
    }

    .status-badge.pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-badge.approved {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.partial {
        background: #e0e7ff;
        color: #3730a3;
    }

    .status-badge.fulfilled {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-badge.invoiced {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.cancelled {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-badge.on-hold {
        background: #374151;
        color: #fff;
    }

    /* ── Cell Styles ─────────────────────────────────── */
    .doc-number {
        font-weight: 700;
        color: #667eea;
        font-family: 'Space Grotesk', monospace;
        font-size: .88rem;
    }

    .customer-info .name {
        font-weight: 600;
        font-size: .85rem;
        color: #1a1a2e;
    }

    .customer-info .code {
        font-size: .75rem;
        color: #9ca3af;
        font-family: 'Space Grotesk', monospace;
    }

    .amount-cell {
        font-weight: 700;
        color: #1a1a2e;
        font-family: 'Space Grotesk', monospace;
        font-size: .88rem;
    }

    /* ── Action Buttons ──────────────────────────────── */
    .action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .85rem;
    }

    .action-btn:hover {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }

    .action-btn.view:hover {
        background: #ede9fe;
        color: #667eea;
        border-color: #c4b5fd;
    }

    .action-btn.approve:hover {
        background: #d1fae5;
        color: #059669;
        border-color: #6ee7b7;
    }

    .action-btn.invoice:hover {
        background: #dbeafe;
        color: #2563eb;
        border-color: #93c5fd;
    }

    .action-btn.delete:hover {
        background: #fee2e2;
        color: #dc2626;
        border-color: #fca5a5;
    }

    .sync-dot {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .78rem;
        font-weight: 600;
    }

    .sync-dot i {
        font-size: .7rem;
    }

    .sync-dot.synced {
        color: #059669;
    }

    .sync-dot.unsynced {
        color: #d97706;
    }

    /* ── Drawer ──────────────────────────────────────── */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        z-index: 9998;
        animation: fadeIn .2s ease;
    }

    .detail-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(640px, 95vw);
        height: 100vh;
        background: #fff;
        z-index: 9999;
        box-shadow: -8px 0 30px rgba(0, 0, 0, .12);
        display: flex;
        flex-direction: column;
        animation: slideInRight .25s ease;
    }

    .drawer-header {
        padding: 1.15rem 1.5rem;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }

    .drawer-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .drawer-header .btn-close-drawer {
        background: rgba(255, 255, 255, .15);
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s;
        font-size: 1rem;
    }

    .drawer-header .btn-close-drawer:hover {
        background: rgba(255, 255, 255, .25);
    }

    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .drawer-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
        margin-bottom: 1.25rem;
    }

    .detail-item .detail-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
        margin-bottom: .15rem;
    }

    .detail-item .detail-value {
        font-size: .92rem;
        font-weight: 600;
        color: #1a1a2e;
    }

    .detail-section-title {
        font-weight: 600;
        color: #1a1a2e;
        font-size: .9rem;
        margin-bottom: .75rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    /* ── Lines Table ─────────────────────────────────── */
    .lines-table {
        width: 100%;
        font-size: .85rem;
        border-collapse: separate;
        border-spacing: 0;
    }

    .lines-table th {
        background: #f8fafc;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6b7280;
        font-weight: 600;
        padding: .6rem .75rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .lines-table td {
        padding: .55rem .75rem;
        border-bottom: 1px solid #f3f4f6;
        color: #374151;
    }

    .lines-table tr:last-child td {
        border-bottom: none;
    }

    .lines-table tfoot td {
        border-top: 2px solid #e5e7eb;
        background: #f8fafc;
    }

    /* Total Banner */
    .total-banner {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.25rem;
    }

    .total-banner .total-label {
        font-size: .9rem;
        font-weight: 500;
    }

    .total-banner .total-value {
        font-size: 1.4rem;
        font-weight: 700;
    }

    /* ── Create Modal ────────────────────────────────── */
    .create-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .5);
        z-index: 10000;
        display: flex;
        justify-content: center;
        align-items: center;
        animation: fadeIn .2s ease;
        padding: 1rem;
    }

    .create-modal {
        background: #fff;
        border-radius: 14px;
        width: min(780px, 95vw);
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
        animation: scaleIn .25s ease;
    }

    .create-modal-header {
        padding: 1.15rem 1.5rem;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .create-modal-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1rem;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .create-modal-header .btn-close-modal {
        background: #f3f4f6;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #6b7280;
        transition: all .15s;
        font-size: .9rem;
    }

    .create-modal-header .btn-close-modal:hover {
        background: #e5e7eb;
        color: #374151;
    }

    .create-modal-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .create-modal-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    .form-field {
        display: flex;
        flex-direction: column;
    }

    .form-field.full {
        grid-column: span 2;
    }

    .form-field label {
        font-size: .75rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: .25rem;
    }

    .form-field input,
    .form-field select,
    .form-field textarea {
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        transition: all .15s;
    }

    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .btn-create {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-create:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
    }

    .btn-create:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    .btn-secondary-action {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .15s;
    }

    .btn-secondary-action:hover {
        background: #f9fafb;
    }

    /* ── Empty / Loading ─────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 1.8rem;
        color: #9ca3af;
    }

    .empty-state h6 {
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
    }

    .empty-state p {
        color: #9ca3af;
        font-size: .88rem;
    }

    .loading-state {
        text-align: center;
        padding: 3rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    /* ── Alert ───────────────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    /* ── Animations ──────────────────────────────────── */
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }

        to {
            transform: translateX(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@media (max-width:768px) {
        .so-header {
            flex-direction: column;
        }

        .filter-bar {
            flex-direction: column;
        }

        .stat-row {
            grid-template-columns: 1fr 1fr;
        }

        .detail-grid,
        .form-grid {
            grid-template-columns: 1fr;
        }

        .form-field.full {
            grid-column: span 1;
        }
    }
</style>

<div class="so-page">
    <div class="container-fluid">

        <!-- ━━━ Header ━━━ -->
        <div class="so-header">
            <div class="so-header-left">
                <div class="so-header-icon"><i class="bi bi-cart-check"></i></div>
                <div>
                    <h2>Sales Orders</h2>
                    <p>Track order status and fulfillment</p>
                </div>
            </div>
            <AuthorizeView Roles="Admin,Cashier">
                <Authorized>
                    <MudButton Class="btn-so-gradient" Href="/sales-orders/create">
                        <i class="bi bi-plus-lg"></i> New Sales Order
                    </MudButton>
                </Authorized>
            </AuthorizeView>
        </div>

        <!-- ━━━ Alerts ━━━ -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner error-alert">
                <i class="bi bi-exclamation-octagon-fill"></i>
                <div style="flex:1;">@errorMessage</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Style="background:none;border:none;color:inherit;opacity:.45;cursor:pointer;font-size:1rem;"
                               OnClick="() => errorMessage = null" />
            </div>
        }

        <!-- ━━━ Stat Cards ━━━ -->
        @if (orders?.Any() == true)
        {
            <div class="stat-row">
                <div class="stat-card">
                    <div class="stat-icon total"><i class="bi bi-cart-check"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@totalCount</div>
                        <div class="stat-label">Total Orders</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon pending"><i class="bi bi-clock-history"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@orders.Count(o => o.Status == SalesOrderStatus.Pending)</div>
                        <div class="stat-label">Pending</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon approved"><i class="bi bi-check-circle"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@orders.Count(o => o.Status == SalesOrderStatus.Approved)</div>
                        <div class="stat-label">Approved</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon fulfilled"><i class="bi bi-truck"></i></div>
                    <div class="stat-info">
                        <div class="stat-value">@orders.Count(o => o.Status == SalesOrderStatus.Fulfilled || o.Status ==
                                                                                                                                                                                                                                                        SalesOrderStatus.Invoiced)</div>
                            <div class="stat-label">Fulfilled</div>
                        </div>
                    </div>
                </div>
            }

            <!-- ━━━ Filter Bar ━━━ -->
            <div class="filter-bar">
                <div class="filter-field">
                    <label>Order Number</label>
                    <input type="text" @bind="orderNumberFilter" placeholder="e.g., SO-001" />
                </div>
                <div class="filter-field">
                    <label>Customer</label>
                    <input type="text" @bind="customerFilter" placeholder="Customer code" />
                </div>
                <div class="filter-field">
                    <label>Status</label>
                    <select @bind="statusFilter">
                        <option value="">All Statuses</option>
                        @foreach (SalesOrderStatus status in Enum.GetValues(typeof(SalesOrderStatus)))
                        {
                            <option value="@(((int)status).ToString())">@status</option>
                        }
                    </select>
                </div>
                <div class="filter-field">
                    <label>From Date</label>
                    <MudDatePicker @bind-Date="fromDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   DateFormat="@AppSettings.DateFormat" Editable="true" />
                </div>
                <div class="filter-field">
                    <label>To Date</label>
                    <MudDatePicker @bind-Date="toDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   DateFormat="@AppSettings.DateFormat" Editable="true" />
                </div>
                <div class="filter-actions-row">
                    <MudButton Class="btn-search" OnClick="ApplyFilter">
                        <i class="bi bi-search"></i> Search
                    </MudButton>
                    <MudButton Class="btn-clear" OnClick="ClearFilter">
                        <i class="bi bi-x-circle"></i> Clear
                    </MudButton>
                </div>
            </div>

            <!-- ━━━ Content ━━━ -->
            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner-border" style="color:#667eea;width:2.5rem;height:2.5rem;" role="status"></div>
                    <p style="margin-top:.75rem;color:#6b7280;font-weight:500;">Loading sales orders...</p>
                </div>
            }
            else if (orders?.Any() == true)
            {
                <div class="so-table-wrap">
                    <div class="so-table-header">
                        <h6><i class="bi bi-table"></i> Sales Orders</h6>
                        <span class="so-count-badge">@totalCount total</span>
                    </div>
                    <MudTable @ref="@_table" Items="@orders" RowsPerPage="@_pageSize" Hover="true" Striped="true" Dense="true"
                              Breakpoint="Breakpoint.Sm" Loading="@isLoading" LoadingProgressColor="Color.Primary" T="SalesOrderDto"
                              Elevation="0" Style="background:transparent;">
                        <HeaderContent>
                            <MudTh>Doc Entry</MudTh>
                            <MudTh>Doc #</MudTh>
                            <MudTh>Customer</MudTh>
                            <MudTh>Order Date</MudTh>
                            <MudTh>Delivery</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Currency</MudTh>
                            <MudTh Style="text-align:right">Total</MudTh>
                            <MudTh>Synced</MudTh>
                            <MudTh Style="width:150px">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Doc Entry"><span
                                style="font-size:.85rem;color:#6b7280;">@(context.SAPDocEntry?.ToString() ??
                                                                                                                            context.Id.ToString())</span></MudTd>
                                <MudTd DataLabel="Doc #"><span class="doc-number">@(context.SAPDocNum?.ToString() ??
                                                                                                                                        context.OrderNumber)</span></MudTd>
                                    <MudTd DataLabel="Customer">
                                        <div class="customer-info">
                                            <span class="name">@context.CardName</span>
                                            <span class="code">@context.CardCode</span>
                                        </div>
                                    </MudTd>
                                    <MudTd DataLabel="Order Date"><span
                                        style="font-size:.85rem;color:#374151;">@context.OrderDate.ToString("dd MMM yyyy")</span>
                                    </MudTd>
                                    <MudTd DataLabel="Delivery"><span
                                        style="font-size:.85rem;color:#374151;">@(context.DeliveryDate?.ToString("dd MMM yyyy") ??
                                                                                                                                                                                                                                                                                                                                        "—")</span></MudTd>
                                        <MudTd DataLabel="Status">
                                            <span class="status-badge @GetStatusCssClass(context.Status)">@context.StatusName</span>
                                            @if (context.IsMobileOrder)
                                            {
                                                <span
                                                    style="display:inline-flex; align-items:center; gap:.2rem; background:#dbeafe; color:#1e40af; font-size:.68rem; font-weight:600; padding:.1rem .4rem; border-radius:5px; margin-left:.3rem;"><i
                                                    class="bi bi-phone"></i> Mobile</span>
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Currency"><span style="font-size:.85rem;color:#6b7280;">@context.Currency</span>
                                            </MudTd>
                                            <MudTd DataLabel="Total" Style="text-align:right">
                                                <span class="amount-cell">@context.DocTotal.ToString("N2")</span>
                                            </MudTd>
                                            <MudTd DataLabel="Synced">
                                                @if (context.IsSynced)
                                                {
                                                    <span class="sync-dot synced"><i class="bi bi-circle-fill"></i> Synced</span>
                                                }
                                                else
                                                {
                                                    <span class="sync-dot unsynced"><i class="bi bi-circle-fill"></i> Pending</span>
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Actions">
                                                <MudStack Row="true" Spacing="1">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                                                   Variant="Variant.Outlined" Color="Color.Primary" Title="View Details"
                                                                   OnClick="async () => await ViewOrder(context)" />
                                                    @if ((context.Status == SalesOrderStatus.Draft || context.Status ==
                                                                                                                                                                                                                                                                                                                                                                                        SalesOrderStatus.Pending) && !context.IsSynced)
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                       Variant="Variant.Outlined" Color="Color.Warning" Title="Edit"
                                                                       OnClick="() => NavigateToEdit(context.Id)" />
                                                    }
                                                    @if (context.Status == SalesOrderStatus.Approved && context.InvoiceId == null)
                                                    {
                                                        <MudIconButton
                                                        Icon="@(convertingOrderId == context.Id ? Icons.Material.Filled.HourglassTop : Icons.Material.Filled.Receipt)"
                                                        Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                                        Title="Convert to Invoice" Disabled="@(convertingOrderId == context.Id)"
                                                        OnClick="() => ConvertToInvoice(context)" />
                                                    }
                                                    @if (!context.IsSynced)
                                                    {
                                                        @if (context.Status == SalesOrderStatus.Pending)
                                                        {
                                                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                                                                           Variant="Variant.Outlined" Color="Color.Success" Title="Approve"
                                                                           OnClick="() => ApproveOrder(context.Id)" />
                                                        }
                                                        @if (context.Status == SalesOrderStatus.Draft || context.Status ==
                                                                                                                                                                                                                                                                                                                                                                                                                                                                    SalesOrderStatus.Cancelled)
                                                        {
                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                           Variant="Variant.Outlined" Color="Color.Error" Title="Delete"
                                                                           OnClick="() => DeleteOrder(context.Id)" />
                                                        }
                                                    }
                                                </MudStack>
                                            </MudTd>
                                        </RowTemplate>
                                        <PagerContent>
                                            <div class="pager-row">
                                                <div class="page-size-wrap">
                                                    <span>Show</span>
                                                    <select @bind="_pageSize">
                                                        <option value="10">10</option>
                                                        <option value="25">25</option>
                                                        <option value="50">50</option>
                                                        <option value="100">100</option>
                                                    </select>
                                                    <span>per page</span>
                                                </div>
                                                <MudPagination SelectedChanged="PageChanged"
                                                               Count="@((_table.GetFilteredItemsCount() + _table.RowsPerPage - 1) / _table.RowsPerPage)"
                                                               Class="pa-4" />
                                            </div>
                                        </PagerContent>
                                    </MudTable>
                                </div>
                            }
        else
                            {
                                <div class="empty-state">
                                    <div class="empty-icon"><i class="bi bi-cart-x"></i></div>
                                    <h6>No sales orders found</h6>
                                    <p>Create a new order or adjust your filters to find existing ones.</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- ━━━ View Order Drawer ━━━ -->
                    @if (selectedOrder != null)
                    {
                        <div class="modal-backdrop-custom" @onclick="() => selectedOrder = null"></div>
                        <div class="detail-drawer">
                            <div class="drawer-header">
                                <h5><i class="bi bi-cart-check me-2"></i>Sales Order: @selectedOrder.OrderNumber</h5>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Class="btn-close-drawer"
                                               OnClick="() => selectedOrder = null" />
                            </div>
                            <div class="drawer-body">
                                <div class="detail-grid">
                                    <div class="detail-item">
                                        <div class="detail-label">Customer</div>
                                        <div class="detail-value">@selectedOrder.CardCode — @selectedOrder.CardName</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label">Order Date</div>
                                        <div class="detail-value">@selectedOrder.OrderDate.ToString("dd MMM yyyy")</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label">Delivery Date</div>
                                        <div class="detail-value">@(selectedOrder.DeliveryDate?.ToString("dd MMM yyyy") ?? "Not set")</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label">Status</div>
                                        <div class="detail-value"><span
                                            class="status-badge @GetStatusCssClass(selectedOrder.Status)">@selectedOrder.StatusName</span>
                                        </div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label">Currency</div>
                                        <div class="detail-value">@selectedOrder.Currency</div>
                                    </div>
                                    <div class="detail-item">
                                        <div class="detail-label">Created By</div>
                                        <div class="detail-value">@selectedOrder.CreatedByUserName</div>
                                    </div>
                                </div>

                                @if (selectedOrder.Lines?.Any() == true)
                                {
                                    <div class="detail-section-title"><i class="bi bi-list-ul"></i> Order Lines</div>
                                    <table class="lines-table">
                                        <thead>
                                            <tr>
                                                <th>Item</th>
                                                <th>Description</th>
                                                <th style="text-align:right">Qty</th>
                                                <th style="text-align:right">Unit Price</th>
                                                <th style="text-align:right">Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var line in selectedOrder.Lines)
                                            {
                                                <tr>
                                                    <td><span style="font-weight:600;color:#667eea;">@line.ItemCode</span></td>
                                                    <td>@line.ItemDescription</td>
                                                    <td style="text-align:right;font-weight:600;">@line.Quantity</td>
                                                    <td style="text-align:right;">@line.UnitPrice.ToString("N2")</td>
                                                    <td style="text-align:right;font-weight:600;">@line.LineTotal.ToString("N2")</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <td colspan="4" style="text-align:right;font-weight:600;">Subtotal:</td>
                                                <td style="text-align:right;font-weight:600;">@selectedOrder.SubTotal.ToString("N2")</td>
                                            </tr>
                                            <tr>
                                                <td colspan="4" style="text-align:right;font-weight:600;">Tax:</td>
                                                <td style="text-align:right;">@selectedOrder.TaxAmount.ToString("N2")</td>
                                            </tr>
                                        </tfoot>
                                    </table>

                                    <div class="total-banner">
                                        <span class="total-label">Total</span>
                                        <span class="total-value">@selectedOrder.DocTotal.ToString("N2")</span>
                                    </div>
                                }
                            </div>
                            <div class="drawer-footer">
                                @if ((selectedOrder.Status == SalesOrderStatus.Draft || selectedOrder.Status == SalesOrderStatus.Pending) &&
                                                                                                                                                                                                                        !selectedOrder.IsSynced)
                                {
                                    <MudButton Class="btn-so-gradient" Style="font-size:.82rem; padding:.45rem 1rem;"
                                               OnClick="() => NavigateToEdit(selectedOrder.Id)">
                                        <i class="bi bi-pencil-square me-1"></i> Edit
                                    </MudButton>
                                }
                                @if (selectedOrder.Status == SalesOrderStatus.Approved && !selectedOrder.IsSynced)
                                {
                                    <MudButton Class="btn-so-gradient"
                                               Style="font-size:.82rem; padding:.45rem 1rem; background:linear-gradient(135deg,#059669,#047857);"
                                               Disabled="@isPostingToSAP" OnClick="() => PostOrderToSAP(selectedOrder.Id)">
                                        @if (isPostingToSAP)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        <i class="bi bi-cloud-upload me-1"></i> Post to SAP
                                    </MudButton>
                                }
                                <MudButton Class="btn-secondary-action" OnClick="() => selectedOrder = null">Close</MudButton>
                            </div>
                        </div>
                    }

                    <!-- ━━━ Create Order Modal ━━━ -->
                    @if (showCreateModal)
                    {
                        <div class="create-modal-overlay" @onclick="CloseCreateModal">
                            <div class="create-modal" @onclick:stopPropagation="true">
                                <div class="create-modal-header">
                                    <h5><i class="bi bi-plus-circle"></i> New Sales Order</h5>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Class="btn-close-modal" OnClick="CloseCreateModal" />
                                </div>
                                <div class="create-modal-body">

                                    <!-- Customer Section -->
                                    <div style="margin-bottom:1.25rem;">
                                        <label
                                            style="display:block; font-size:.72rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.5px; margin-bottom:.35rem;">
                                            Customer <span style="color:#ef4444;">*</span>
                                        </label>
                                        @if (isLoadingBPs)
                                        {
                                            <div class="d-flex align-items-center gap-2" style="padding:.4rem 0;">
                                                <div class="spinner-border spinner-border-sm text-primary"></div>
                                                <span style="color:#6b7280; font-size:.85rem;">Loading customers…</span>
                                            </div>
                                        }
                                        else if (selectedBusinessPartner != null)
                                        {
                                            <div style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:10px; padding:.75rem 1rem;">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div>
                                                        <div style="font-weight:700; color:#065f46;">
                                                            <i class="bi bi-check-circle-fill me-1" style="color:#059669;"></i>
                                                            @selectedBusinessPartner.CardCode
                                                        </div>
                                                        <div style="font-size:.85rem; color:#065f46; opacity:.8;">@selectedBusinessPartner.CardName
                                                        </div>
                                                        @if (!string.IsNullOrEmpty(selectedBusinessPartner.Phone1))
                                                        {
                                                            <div style="font-size:.82rem; color:#065f46; opacity:.7; margin-top:.25rem;">
                                                                <i class="bi bi-telephone me-1"></i>@selectedBusinessPartner.Phone1
                                                            </div>
                                                        }
                                                        @if (customerPriceListNum.HasValue)
                                                        {
                                                            <div style="font-size:.82rem; color:#065f46; opacity:.7; margin-top:.25rem;">
                                                                <i class="bi bi-tags me-1"></i>Price List #@customerPriceListNum
                                                                @if (isLoadingCustomerPrices)
                                                                {
                                                                    <span class="spinner-border spinner-border-sm ms-1"></span>
                                                                }
                                                                else
                                                                {
                                                                    <span
                                                                        style="background:#d1fae5; color:#065f46; font-size:.7rem; padding:.1rem .4rem; border-radius:4px; font-weight:600; margin-left:.25rem;">
                                                                        @customerPriceListPrices.Count items
                                                                    </span>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                    <button type="button"
                                                            style="background:#fef2f2; border:1px solid #fecaca; color:#dc2626; width:28px; height:28px; border-radius:7px; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:.8rem;"
                                                            @onclick="ClearSelectedBP">
                                                        <i class="bi bi-x"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="position-relative">
                                                <input type="text"
                                                       style="width:100%; padding:.5rem .75rem; border:1px solid #d1d5db; border-radius:8px; font-size:.88rem; color:#374151;"
                                                       @bind="bpSearchTerm" @bind:event="oninput" @onfocus="() => showBPDropdown = true"
                                                       @onblur="OnBPSearchBlur" placeholder="Search by code or name…" autocomplete="off" />
                                                @if (showBPDropdown && filteredBusinessPartners.Any())
                                                {
                                                    <div class="dropdown-autocomplete" @onmousedown:preventDefault>
                                                        @foreach (var bp in filteredBusinessPartners.Take(15))
                                                        {
                                                            <div class="dropdown-item" @onmousedown="() => SelectBusinessPartner(bp)">
                                                                <strong>@bp.CardCode</strong> — <span style="color:#6b7280;">@bp.CardName</span>
                                                            </div>
                                                        }
                                                        @if (filteredBusinessPartners.Count() > 15)
                                                        {
                                                            <div class="dropdown-item" style="color:#9ca3af; text-align:center; font-size:.82rem;">
                                                                <i class="bi bi-info-circle me-1"></i>
                                                                @filteredBusinessPartners.Count() total — type more to filter
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else if (showBPDropdown && !string.IsNullOrWhiteSpace(bpSearchTerm) &&
                                                !filteredBusinessPartners.Any())
                                                {
                                                    <div class="dropdown-autocomplete" style="padding:1rem; text-align:center; color:#9ca3af;">
                                                        <i class="bi bi-search me-1"></i>No customers found
                                                    </div>
                                                }
                                            </div>
                                        }
                                        @if (createValidationErrors.ContainsKey("Customer"))
                                        {
                                            <div style="color:#ef4444; font-size:.78rem; margin-top:.2rem;">@createValidationErrors["Customer"]
                                            </div>
                                        }
                                    </div>

                                    <!-- Details Grid -->
                                    <div class="form-grid" style="margin-bottom:1.25rem;">
                                        <div class="form-field">
                                            <label>Delivery Date</label>
                                            <MudDatePicker @bind-Date="newOrder.DeliveryDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                           DateFormat="@AppSettings.DateFormat" Editable="true" />
                                        </div>
                                        <div class="form-field">
                                            <label>Currency</label>
                                            <select @bind="newOrder.Currency">
                                                <option value="USD">USD — US Dollar</option>
                                                <option value="ZIG">ZIG — Zimbabwe Gold</option>
                                            </select>
                                        </div>
                                        <div class="form-field">
                                            <label>Customer Reference</label>
                                            <input type="text" @bind="newOrder.CustomerRefNo" placeholder="PO / Reference number" />
                                        </div>
                                        <div class="form-field">
                                            <label>Warehouse</label>
                                            <select @bind="newOrder.WarehouseCode">
                                                <option value="">— Default —</option>
                                                @foreach (var wh in cachedWarehouses)
                                                {
                                                    <option value="@wh.WarehouseCode">@wh.WarehouseCode</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-field full">
                                            <label>Comments</label>
                                            <textarea @bind="newOrder.Comments" rows="2" placeholder="Optional comments"></textarea>
                                        </div>
                                    </div>

                                    <!-- Line Items Section -->
                                    <div style="border-top:1px solid #e5e7eb; padding-top:1rem;">
                                        <div class="d-flex justify-content-between align-items-center" style="margin-bottom:.75rem;">
                                            <span style="font-weight:600; font-size:.92rem; color:#1a1a2e;">
                                                <i class="bi bi-list-ul me-1" style="color:#667eea;"></i>Order Lines
                                            </span>
                                            <button type="button" class="btn-so-gradient" style="padding:.35rem .85rem; font-size:.8rem;"
                                                    @onclick="AddOrderLine">
                                                <i class="bi bi-plus-lg"></i> Add Line
                                            </button>
                                        </div>

                                        @if (isLoadingMasterData)
                                        {
                                            <div style="text-align:center; padding:1.5rem;">
                                                <div class="spinner-border spinner-border-sm text-primary"></div>
                                                <span style="color:#6b7280; font-size:.85rem; margin-left:.5rem;">Loading products…</span>
                                            </div>
                                        }
                                        else if (newOrder.Lines.Any())
                                        {
                                            @for (int i = 0; i < newOrder.Lines.Count; i++)
                                            {
                                                var index = i;
                                                var line = newOrder.Lines[index];
                                                var lineState = GetLineState(index);
                                                var lineErrors = GetLineValidationErrors(index);

                                                <div
                                                    style="background:#f8fafc; border:1px solid #e5e7eb; border-radius:10px; padding:.85rem; margin-bottom:.65rem; position:relative;">
                                                    <!-- Line Header -->
                                                    <div class="d-flex justify-content-between align-items-center" style="margin-bottom:.6rem;">
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span
                                                                style="background:linear-gradient(135deg,#667eea,#764ba2); color:#fff; width:24px; height:24px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:600; font-size:.75rem;">@(index
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        + 1)</span>
                                            @if (!string.IsNullOrEmpty(line.ItemDescription))
                                            {
                                                <span style="font-weight:600; font-size:.85rem; color:#1a1a2e;">@line.ItemCode</span>
                                                <span style="color:#d1d5db;">—</span>
                                                <span style="color:#6b7280; font-size:.82rem;">@TruncateName(line.ItemDescription,
                                                                                                                                                                                                                                                                                                                                                                                                                                        30)</span>
                                                }
                            else
                                                {
                                                    <span style="color:#9ca3af; font-size:.82rem;">New Line Item</span>
                                                }
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span
                                                style="font-weight:700; color:#059669; font-size:.92rem;">@CalculateLineTotal(line).ToString("N2")</span>
                                                <button type="button"
                                                        style="background:#fef2f2; border:1px solid #fecaca; color:#dc2626; width:24px; height:24px; border-radius:6px; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:.75rem;"
                                                        @onclick="() => RemoveOrderLine(index)">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Item Code + Description -->
                                        <div class="row g-2 mb-2">
                                            <div class="col-5">
                                                <label
                                                    style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Item
                                                    Code <span style="color:#ef4444;">*</span></label>
                                                    <div class="position-relative">
                                                        <input type="text"
                                                               style="width:100%; padding:.4rem .6rem; border:1px solid @(lineErrors.ContainsKey("ItemCode") ? "#ef4444" : "#d1d5db"); border-radius:7px; font-size:.85rem;"
                                                               value="@line.ItemCode" @oninput="(e) => OnItemCodeInput(index, e.Value?.ToString())"
                                                               @onkeydown="(e) => OnItemCodeKeyDown(index, e)"
                                                               @onfocus="() => OnItemCodeFocus(index)" @onblur="() => OnItemCodeBlur(index)"
                                                               placeholder="Search item…" autocomplete="off" />
                                                        @if (lineState.ShowProductDropdown && lineState.FilteredProducts.Any())
                                                        {
                                                            <div class="dropdown-autocomplete" @onmousedown:preventDefault>
                                                                @foreach (var product in lineState.FilteredProducts.Take(10))
                                                                {
                                                                    var isSelected = lineState.SuggestedProduct?.ItemCode == product.ItemCode;
                                                                    var displayPrice = GetPriceForItem(product.ItemCode, product.Price);
                                                                    <div class="dropdown-item @(isSelected ? "selected" : "")"
                                                                         @onmousedown="async () => await SelectProduct(index, product)">
                                                                        <div class="d-flex justify-content-between align-items-center">
                                                                            <div>
                                                                                <div style="font-weight:600; font-size:.82rem;">@product.ItemCode</div>
                                                                                <small
                                                                                    style="@(isSelected ? "color:rgba(255,255,255,.7);" : "color:#6b7280;")">@TruncateName(product.ItemName,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            25)</small>
                                                                                </div>
                                                                                <span
                                                                                    style="font-size:.75rem; font-weight:600; padding:.1rem .4rem; border-radius:4px; @(isSelected ? "background:rgba(255,255,255,.2); color:#fff;" : "background:#dbeafe; color:#1e40af;")">
                                                                                    @displayPrice.ToString("N2")
                                                                                </span>
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                    @if (lineState.FilteredProducts.Count > 10)
                                                                    {
                                                                        <div class="dropdown-item"
                                                                             style="color:#9ca3af; text-align:center; font-size:.78rem;">
                                                                            +@(lineState.FilteredProducts.Count - 10) more…
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                    <div class="col-7">
                                                        <label
                                                        style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Description</label>
                                                        @if (!string.IsNullOrEmpty(line.ItemDescription))
                                                        {
                                                            <div
                                                                style="background:#f0f9ff; border:1px solid #bae6fd; border-radius:7px; padding:.4rem .6rem; font-size:.82rem; color:#0c4a6e;">
                                                                <i class="bi bi-box-seam me-1"
                                                                   style="color:#667eea;"></i>@TruncateName(line.ItemDescription, 35)
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <input type="text"
                                                                   style="width:100%; padding:.4rem .6rem; border:1px solid #d1d5db; border-radius:7px; font-size:.85rem; background:#f3f4f6; cursor:default;"
                                                                   placeholder="Select an item" readonly />
                                                        }
                                                    </div>
                                                </div>

                                                <!-- Quantity + Price + Warehouse -->
                                                <div class="row g-2">
                                                    <div class="col-3">
                                                        <label
                                                            style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Qty
                                                            <span style="color:#ef4444;">*</span></label>
                                                            <input type="number"
                                                                   style="width:100%; padding:.4rem .6rem; border:1px solid @(lineErrors.ContainsKey("Quantity") ? "#ef4444" : "#d1d5db"); border-radius:7px; font-size:.85rem;"
                                                                   value="@line.Quantity" @onchange="(e) => OnQuantityChange(index, e.Value?.ToString())"
                                                                   min="0.001" step="0.001" placeholder="0" />
                                                        </div>
                                                        <div class="col-3">
                                                            <label
                                                                style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Unit
                                                                Price</label>
                                                                <input type="text"
                                                                       style="width:100%; padding:.4rem .6rem; border:1px solid #d1d5db; border-radius:7px; font-size:.85rem; background:#f3f4f6; cursor:default;"
                                                                       value="@line.UnitPrice.ToString("N2")" readonly />
                                                            </div>
                                                            <div class="col-3">
                                                                <label
                                                                    style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Discount
                                                                    %</label>
                                                                    <input type="number"
                                                                           style="width:100%; padding:.4rem .6rem; border:1px solid #d1d5db; border-radius:7px; font-size:.85rem;"
                                                                           @bind="line.DiscountPercent" min="0" max="100" step="0.01" />
                                                                </div>
                                                                <div class="col-3">
                                                                    <label
                                                                    style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Warehouse</label>
                                                                    <select
                                                                        style="width:100%; padding:.4rem .6rem; border:1px solid #d1d5db; border-radius:7px; font-size:.85rem;"
                                                                        @bind="line.WarehouseCode">
                                                                        <option value="">Default</option>
                                                                        @foreach (var wh in cachedWarehouses)
                                                                        {
                                                                            <option value="@wh.WarehouseCode">@wh.WarehouseCode</option>
                                                                        }
                                                                    </select>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }

                                                    <!-- Add another line -->
                                                    <div style="text-align:center; margin-top:.5rem;">
                                                        <button type="button"
                                                                style="background:none; border:1px dashed #d1d5db; color:#6b7280; padding:.4rem 1rem; border-radius:8px; font-size:.82rem; cursor:pointer;"
                                                                @onclick="AddOrderLine">
                                                            <i class="bi bi-plus-lg me-1"></i>Add Another Line
                                                        </button>
                                                    </div>
                                                }
                else
                                                {
                                                    <div
                                                        style="text-align:center; padding:2rem 1rem; background:#f9fafb; border-radius:10px; border:2px dashed #e5e7eb;">
                                                        <div style="font-size:1.5rem; color:#9ca3af; margin-bottom:.5rem;"><i class="bi bi-inbox"></i></div>
                                                        <p style="color:#6b7280; font-size:.85rem; margin-bottom:.25rem;">No order lines yet</p>
                                                        <p style="color:#9ca3af; font-size:.78rem; margin-bottom:.75rem;">Add products to build the sales
                                                            order</p>
                                                            <button type="button" class="btn-so-gradient" style="padding:.4rem 1rem; font-size:.82rem;"
                                                                    @onclick="AddOrderLine">
                                                                <i class="bi bi-plus-lg"></i> Add First Line
                                                            </button>
                                                        </div>
                                                    }
                                                    @if (createValidationErrors.ContainsKey("Lines"))
                                                    {
                                                        <div style="color:#ef4444; font-size:.78rem; margin-top:.4rem;">@createValidationErrors["Lines"]</div>
                                                    }
                                                </div>

                                                <!-- Order Summary -->
                                                @if (newOrder.Lines.Any())
                                                {
                                                    <div
                                                        style="background:linear-gradient(135deg,#667eea,#764ba2); border-radius:10px; padding:.85rem 1.15rem; margin-top:1rem; color:#fff;">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <div>
                                                                <div style="font-size:.78rem; opacity:.8;">@newOrder.Lines.Count line(s) · @newOrder.Currency
                                                                </div>
                                                                <div style="font-size:.85rem; font-weight:500;">Subtotal</div>
                                                            </div>
                                                            <div style="font-size:1.3rem; font-weight:700;">@CalculateOrderTotal().ToString("N2")</div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                            <div class="create-modal-footer">
                                                <MudButton Class="btn-secondary-action" OnClick="CloseCreateModal">Cancel</MudButton>
                                                <MudButton Class="btn-create" OnClick="CreateOrder" Disabled="@isCreating">
                                                    @if (isCreating)
                                                    {
                                                        <span class="spinner-border spinner-border-sm"></span>
                                                    }
                                                    <span>Create Order</span>
                                                </MudButton>
                                            </div>
                                        </div>
                                    </div>
                                }

@code {
    private MudTable<SalesOrderDto>? _table;
    private int _pageSize = 10;
    private List<SalesOrderDto>? orders;
    private SalesOrderDto? selectedOrder;
    private bool isLoading = true;
    private bool isCreating = false;
    private bool showCreateModal = false;
    private string? errorMessage;
    private int? convertingOrderId;
    private bool isPostingToSAP = false;

    // Filters
    private string? orderNumberFilter;
    private string? customerFilter;
    private string? statusFilter;
    private string? sourceFilter;
    private DateTime? fromDate;
    private DateTime? toDate;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10000;
    private int totalPages = 1;
    private int totalCount = 0;

    // New order
    private CreateSalesOrderRequest newOrder = new();

    // Business Partner autocomplete state
    private List<BusinessPartnerDto> allBusinessPartners = new();
    private BusinessPartnerDto? selectedBusinessPartner;
    private string? bpSearchTerm;
    private bool showBPDropdown = false;
    private bool isLoadingBPs = true;

    // Master data
    private bool isLoadingMasterData = true;
    private List<ProductDto> cachedProducts = new();
    private List<WarehouseDto> cachedWarehouses = new();

    // Customer price list
    private Dictionary<string, decimal> customerPriceListPrices = new();
    private int? customerPriceListNum;
    private bool isLoadingCustomerPrices = false;

    // Line item autocomplete state
    private Dictionary<int, LineState> lineStates = new();

    // Validation
    private Dictionary<string, string> createValidationErrors = new();
    private Dictionary<int, Dictionary<string, string>> lineValidationErrors = new();

    private class LineState
    {
        public string SearchTerm { get; set; } = string.Empty;
        public bool ShowProductDropdown { get; set; } = false;
        public List<ProductDto> FilteredProducts { get; set; } = new();
        public ProductDto? SuggestedProduct { get; set; } = null;
        public string SuggestionSuffix { get; set; } = string.Empty;
    }

    private IEnumerable<BusinessPartnerDto> filteredBusinessPartners
    {
        get
        {
            if (string.IsNullOrWhiteSpace(bpSearchTerm))
                return allBusinessPartners.Take(50);

            var search = bpSearchTerm.ToLowerInvariant();
            return allBusinessPartners.Where(bp =>
            (bp.CardCode?.ToLowerInvariant().Contains(search) ?? false) ||
            (bp.CardName?.ToLowerInvariant().Contains(search) ?? false));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Default date range to current month so SAP queries are always date-filtered
        fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        toDate = DateTime.Today;
        await LoadOrders();
        await AuditService.LogAsync(AuditActions.ViewSalesOrders, "SalesOrder", null);
    }

    private void PageChanged(int i)
    {
        _table?.NavigateTo(i - 1);
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            SalesOrderStatus? status = null;
            if (!string.IsNullOrEmpty(statusFilter) && int.TryParse(statusFilter, out var statusInt))
            {
                status = (SalesOrderStatus)statusInt;
            }

            // Only filter by source when explicitly selected; null = fetch from SAP
            SalesOrderSource? source = null;
            if (!string.IsNullOrEmpty(sourceFilter) && int.TryParse(sourceFilter, out var sourceInt))
            {
                source = (SalesOrderSource)sourceInt;
            }

            var response = await SalesOrderService.GetSalesOrdersAsync(currentPage, pageSize, status, customerFilter, fromDate,
            toDate, source);
            if (response != null)
            {
                orders = response.Orders;
                totalCount = response.TotalCount;
                totalPages = response.TotalPages;
            }
            else
            {
                errorMessage = "Failed to load sales orders.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilter()
    {
        currentPage = 1;
        await LoadOrders();
    }

    private async Task ClearFilter()
    {
        orderNumberFilter = null;
        customerFilter = null;
        statusFilter = null;
        fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        toDate = DateTime.Today;
        currentPage = 1;
        await LoadOrders();
    }

    private async Task OnPageChanged(int page)
    {
        await GoToPage(page);
    }

    private async Task GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            await LoadOrders();
        }
    }

    private async Task ViewOrder(SalesOrderDto order)
    {
        // Show drawer immediately with list data (header info)
        selectedOrder = order;
        StateHasChanged();

        // Fetch the full order with lines from the API
        try
        {
            var fullOrder = await SalesOrderService.GetSalesOrderByIdAsync(order.Id);
            if (fullOrder != null)
            {
                selectedOrder = fullOrder;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to fetch full order details for {OrderId}", order.Id);
        }
    }

    private void NavigateToEdit(int id)
    {
        NavigationManager.NavigateTo($"/sales-orders/edit/{id}");
    }

    private async Task ApproveOrder(int id)
    {
        var result = await SalesOrderService.ApproveAsync(id);
        if (result != null)
        {
            await AuditService.LogAsync(AuditActions.ApproveSalesOrder, "SalesOrder", id.ToString());
            await LoadOrders();
        }
    }

    private async Task PostOrderToSAP(int id)
    {
        isPostingToSAP = true;
        StateHasChanged();

        try
        {
            var result = await SalesOrderService.PostToSAPAsync(id);
            if (result != null)
            {
                Snackbar.Add($"Order {result.OrderNumber} posted to SAP successfully! (Doc #{result.SAPDocNum})", Severity.Success);
                await AuditService.LogAsync(AuditActions.PostSalesOrderToSAP, "SalesOrder", id.ToString(), $"SAP Doc #{result.SAPDocNum}", true);
                selectedOrder = null;
                await LoadOrders();
            }
            else
            {
                Snackbar.Add("Failed to post order to SAP. Please try again.", Severity.Error);
            }
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"SAP posting failed: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error posting to SAP: {ex.Message}", Severity.Error);
        }
        finally
        {
            isPostingToSAP = false;
            StateHasChanged();
        }
    }

    private async Task ConvertToInvoice(SalesOrderDto order)
    {
        var result = await DialogService.ShowMessageBoxAsync(
        "Convert to Invoice",
        $"Are you sure you want to convert order {order.OrderNumber} for {order.CardName ?? order.CardCode} (Total: {order.Currency} {order.DocTotal:N2}) into an invoice?",
        yesText: "Convert",
        cancelText: "Cancel");

        if (result != true) return;

        convertingOrderId = order.Id;
        StateHasChanged();

        try
        {
            var invoice = await SalesOrderService.ConvertToInvoiceAsync(order.Id);
            if (invoice != null)
            {
                Snackbar.Add($"Order {order.OrderNumber} converted to Invoice #{invoice.DocNum} successfully!", Severity.Success);
                await AuditService.LogAsync(AuditActions.ConvertOrderToInvoice, "SalesOrder", order.Id.ToString(), $"Converted to Invoice #{invoice.DocNum}", true);
                await LoadOrders();
            }
            else
            {
                Snackbar.Add("Failed to convert sales order to invoice. Please try again.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error converting order: {ex.Message}", Severity.Error);
        }
        finally
        {
            convertingOrderId = null;
            StateHasChanged();
        }
    }

    private async Task DeleteOrder(int id)
    {
        var success = await SalesOrderService.DeleteSalesOrderAsync(id);
        if (success)
        {
            await AuditService.LogAsync(AuditActions.DeleteSalesOrder, "SalesOrder", id.ToString());
            await LoadOrders();
        }
    }

    // ── Create Modal Logic ──────────────────────────────

    private async Task OpenCreateModal()
    {
        showCreateModal = true;
        newOrder = new CreateSalesOrderRequest();
        selectedBusinessPartner = null;
        bpSearchTerm = null;
        showBPDropdown = false;
        customerPriceListPrices.Clear();
        customerPriceListNum = null;
        lineStates.Clear();
        createValidationErrors.Clear();
        lineValidationErrors.Clear();

        // Load master data if not already loaded
        if (allBusinessPartners.Count == 0 || cachedProducts.Count == 0)
        {
            await LoadMasterDataForCreate();
        }
        else
        {
            isLoadingBPs = false;
            isLoadingMasterData = false;
        }
    }

    private void CloseCreateModal()
    {
        showCreateModal = false;
    }

    private async Task LoadMasterDataForCreate()
    {
        isLoadingBPs = true;
        isLoadingMasterData = true;

        try
        {
            allBusinessPartners = await CacheService.GetBusinessPartnersAsync();
            isLoadingBPs = false;
            StateHasChanged();

            cachedWarehouses = await CacheService.GetWarehousesAsync();
            cachedProducts = await CacheService.GetProductsAsync();
            isLoadingMasterData = false;

            Logger.LogInformation("Loaded create modal data: {BPCount} customers, {ProductCount} products, {WHCount} warehouses",
            allBusinessPartners.Count, cachedProducts.Count, cachedWarehouses.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading master data for create modal");
            errorMessage = "Failed to load master data. Please try again.";
        }
        finally
        {
            isLoadingBPs = false;
            isLoadingMasterData = false;
        }
    }

    // ── Business Partner Selection ──────────────────────

    private async Task SelectBusinessPartnerAsync(BusinessPartnerDto bp)
    {
        selectedBusinessPartner = bp;
        newOrder.CardCode = bp.CardCode ?? string.Empty;
        newOrder.CardName = bp.CardName;
        bpSearchTerm = bp.DisplayName;
        showBPDropdown = false;

        if (!string.IsNullOrEmpty(bp.Currency))
        {
            newOrder.Currency = bp.Currency;
        }

        createValidationErrors.Remove("Customer");

        if (bp.PriceListNum.HasValue && bp.PriceListNum.Value > 0)
        {
            await LoadCustomerPriceList(bp.PriceListNum.Value);
        }
        else
        {
            customerPriceListPrices.Clear();
            customerPriceListNum = null;
        }
    }

    private void SelectBusinessPartner(BusinessPartnerDto bp)
    {
        _ = SelectBusinessPartnerAsync(bp);
    }

    private void ClearSelectedBP()
    {
        selectedBusinessPartner = null;
        newOrder.CardCode = string.Empty;
        newOrder.CardName = null;
        bpSearchTerm = null;
        customerPriceListPrices.Clear();
        customerPriceListNum = null;
    }

    private async Task LoadCustomerPriceList(int priceListNum)
    {
        isLoadingCustomerPrices = true;
        StateHasChanged();

        try
        {
            var response = await PriceService.GetPricesByPriceListAsync(priceListNum);
            if (response?.Prices != null && response.Prices.Any())
            {
                customerPriceListPrices.Clear();
                foreach (var price in response.Prices)
                {
                    if (!string.IsNullOrEmpty(price.ItemCode))
                    {
                        customerPriceListPrices[price.ItemCode] = price.Price;
                    }
                }
                customerPriceListNum = priceListNum;
            }
            else
            {
                customerPriceListPrices.Clear();
                customerPriceListNum = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading customer price list {PriceListNum}", priceListNum);
            customerPriceListPrices.Clear();
            customerPriceListNum = null;
        }
        finally
        {
            isLoadingCustomerPrices = false;
            StateHasChanged();
        }
    }

    private decimal GetPriceForItem(string? itemCode, decimal defaultPrice)
    {
        if (string.IsNullOrEmpty(itemCode)) return defaultPrice;
        return customerPriceListPrices.TryGetValue(itemCode, out var customerPrice) ? customerPrice : defaultPrice;
    }

    private async Task OnBPSearchBlur()
    {
        await Task.Delay(200);
        showBPDropdown = false;
    }

    // ── Line Item Management ────────────────────────────

    private void AddOrderLine()
    {
        newOrder.Lines.Add(new CreateSalesOrderLineRequest
        {
            Quantity = 1,
            WarehouseCode = newOrder.WarehouseCode ?? ""
        });
    }

    private void RemoveOrderLine(int index)
    {
        if (index >= 0 && index < newOrder.Lines.Count)
        {
            newOrder.Lines.RemoveAt(index);
            lineStates.Remove(index);
            lineValidationErrors.Remove(index);

            // Re-index states
            var oldStates = new Dictionary<int, LineState>(lineStates);
            var oldErrors = new Dictionary<int, Dictionary<string, string>>(lineValidationErrors);
            lineStates.Clear();
            lineValidationErrors.Clear();

            for (int i = 0; i < newOrder.Lines.Count; i++)
            {
                var oldIndex = i >= index ? i + 1 : i;
                if (oldStates.TryGetValue(oldIndex, out var state))
                    lineStates[i] = state;
                if (oldErrors.TryGetValue(oldIndex, out var errors))
                    lineValidationErrors[i] = errors;
            }
        }
    }

    private LineState GetLineState(int index)
    {
        if (!lineStates.ContainsKey(index))
            lineStates[index] = new LineState();
        return lineStates[index];
    }

    private Dictionary<string, string> GetLineValidationErrors(int index)
    {
        return lineValidationErrors.TryGetValue(index, out var errors) ? errors : new Dictionary<string, string>();
    }

    // ── Product Autocomplete ────────────────────────────

    private void OnItemCodeInput(int index, string? value)
    {
        var line = newOrder.Lines[index];
        line.ItemCode = value ?? string.Empty;

        var state = GetLineState(index);
        state.SearchTerm = value ?? string.Empty;
        state.SuggestedProduct = null;
        state.SuggestionSuffix = string.Empty;

        if (lineValidationErrors.TryGetValue(index, out var errors))
            errors.Remove("ItemCode");

        if (string.IsNullOrWhiteSpace(value))
        {
            state.FilteredProducts = new List<ProductDto>();
            state.ShowProductDropdown = false;
            return;
        }

        var searchLower = value.ToLowerInvariant();
        var searchUpper = value.ToUpperInvariant();

        state.FilteredProducts = cachedProducts.Where(p =>
        (p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false) ||
        (p.ItemCode?.ToLowerInvariant().Contains(searchLower) ?? false) ||
        (p.ItemName?.ToLowerInvariant().Contains(searchLower) ?? false) ||
        (p.BarCode?.ToLowerInvariant().Contains(searchLower) ?? false))
        .OrderByDescending(p => p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false)
        .ThenBy(p => p.ItemCode)
        .ToList();

        var exactMatch = state.FilteredProducts.FirstOrDefault(p =>
        p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false);

        if (exactMatch != null && !string.IsNullOrEmpty(exactMatch.ItemCode))
        {
            state.SuggestedProduct = exactMatch;
            state.SuggestionSuffix = exactMatch.ItemCode.Substring(value.Length);
        }

        state.ShowProductDropdown = state.FilteredProducts.Any();
        StateHasChanged();
    }

    private async Task OnItemCodeKeyDown(int index, KeyboardEventArgs e)
    {
        var state = GetLineState(index);

        if ((e.Key == "Tab" || e.Key == "ArrowRight") && state.SuggestedProduct != null)
        {
            if (e.Key == "Tab" || !string.IsNullOrEmpty(state.SuggestionSuffix))
                await SelectProduct(index, state.SuggestedProduct);
        }
        else if (e.Key == "ArrowDown" && state.ShowProductDropdown && state.FilteredProducts.Any())
        {
            var currentIndex = state.SuggestedProduct != null ? state.FilteredProducts.IndexOf(state.SuggestedProduct) : -1;
            var nextIndex = Math.Min(currentIndex + 1, state.FilteredProducts.Count - 1);
            state.SuggestedProduct = state.FilteredProducts[nextIndex];
            StateHasChanged();
        }
        else if (e.Key == "ArrowUp" && state.ShowProductDropdown && state.FilteredProducts.Any())
        {
            var currentIndex = state.SuggestedProduct != null ? state.FilteredProducts.IndexOf(state.SuggestedProduct) :
            state.FilteredProducts.Count;
            var prevIndex = Math.Max(currentIndex - 1, 0);
            state.SuggestedProduct = state.FilteredProducts[prevIndex];
            StateHasChanged();
        }
        else if (e.Key == "Enter" && state.SuggestedProduct != null)
        {
            await SelectProduct(index, state.SuggestedProduct);
        }
        else if (e.Key == "Escape")
        {
            state.ShowProductDropdown = false;
            state.SuggestedProduct = null;
            state.SuggestionSuffix = string.Empty;
            StateHasChanged();
        }
    }

    private void OnItemCodeFocus(int index)
    {
        var state = GetLineState(index);
        if (!string.IsNullOrEmpty(state.SearchTerm) || cachedProducts.Any())
        {
            state.ShowProductDropdown = true;
            if (string.IsNullOrEmpty(state.SearchTerm))
                state.FilteredProducts = cachedProducts.Take(15).ToList();
        }
    }

    private async Task OnItemCodeBlur(int index)
    {
        await Task.Delay(200);
        var state = GetLineState(index);
        state.ShowProductDropdown = false;
        state.SuggestionSuffix = string.Empty;
        StateHasChanged();
    }

    private async Task SelectProduct(int index, ProductDto product)
    {
        var line = newOrder.Lines[index];
        line.ItemCode = product.ItemCode ?? string.Empty;
        line.ItemDescription = product.ItemName ?? string.Empty;
        line.UnitPrice = GetPriceForItem(product.ItemCode, product.Price);

        // If price is still 0, fetch from the price API
        if (line.UnitPrice == 0 && !string.IsNullOrEmpty(product.ItemCode))
        {
            try
            {
                var priceInfo = await PriceService.GetPriceByItemCodeAsync(product.ItemCode);
                if (priceInfo != null)
                {
                    var currency = newOrder.Currency ?? "USD";
                    line.UnitPrice = currency.Equals("USD", StringComparison.OrdinalIgnoreCase)
                    ? priceInfo.UsdPrice ?? 0
                    : priceInfo.ZigPrice ?? priceInfo.UsdPrice ?? 0;
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to fetch price for item {ItemCode}", product.ItemCode);
            }
        }

        line.WarehouseCode = !string.IsNullOrEmpty(newOrder.WarehouseCode) ? newOrder.WarehouseCode : (product.DefaultWarehouse
        ?? "01");

        var state = GetLineState(index);
        state.ShowProductDropdown = false;
        state.SearchTerm = product.ItemCode ?? string.Empty;
        state.SuggestedProduct = null;
        state.SuggestionSuffix = string.Empty;

        if (lineValidationErrors.TryGetValue(index, out var errors))
            errors.Remove("ItemCode");

        StateHasChanged();
    }

    private void OnQuantityChange(int index, string? value)
    {
        var line = newOrder.Lines[index];
        if (decimal.TryParse(value, out var quantity))
        {
            line.Quantity = quantity < 0 ? 0 : quantity;
        }
        else
        {
            line.Quantity = 0;
        }

        if (lineValidationErrors.TryGetValue(index, out var errors))
            errors.Remove("Quantity");

        StateHasChanged();
    }

    // ── Calculations ────────────────────────────────────

    private decimal CalculateLineTotal(CreateSalesOrderLineRequest line)
    {
        var subtotal = line.Quantity * line.UnitPrice;
        return line.DiscountPercent > 0 ? subtotal * (1 - line.DiscountPercent / 100) : subtotal;
    }

    private decimal CalculateOrderTotal()
    {
        return newOrder.Lines.Sum(l => CalculateLineTotal(l));
    }

    private string TruncateName(string? name, int maxLength)
    {
        return name?.Length > maxLength ? name[..maxLength] + "…" : name ?? "";
    }

    // ── Validation & Submit ─────────────────────────────

    private bool ValidateCreateForm()
    {
        createValidationErrors.Clear();
        lineValidationErrors.Clear();

        if (selectedBusinessPartner == null || string.IsNullOrEmpty(newOrder.CardCode))
            createValidationErrors["Customer"] = "Please select a customer";

        if (!newOrder.Lines.Any())
            createValidationErrors["Lines"] = "At least one line item is required";

        for (int i = 0; i < newOrder.Lines.Count; i++)
        {
            var line = newOrder.Lines[i];
            var errors = new Dictionary<string, string>();

            if (string.IsNullOrEmpty(line.ItemCode))
                errors["ItemCode"] = "Item code is required";
            if (line.Quantity <= 0)
                errors["Quantity"] = "Quantity must be greater than 0";

            if (errors.Any())
                lineValidationErrors[i] = errors;
        }

        return !createValidationErrors.Any() && !lineValidationErrors.Any();
    }

    private async Task CreateOrder()
    {
        if (!ValidateCreateForm()) return;

        isCreating = true;
        try
        {
            var result = await SalesOrderService.CreateSalesOrderAsync(newOrder);
            if (result != null)
            {
                showCreateModal = false;
                Snackbar.Add($"Sales order {result.OrderNumber} created successfully!", Severity.Success);
                await LoadOrders();
            }
            else
            {
                Snackbar.Add("Failed to create sales order. Please try again.", Severity.Error);
            }
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Failed to create order: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating order: {ex.Message}", Severity.Error);
        }
        finally
        {
            isCreating = false;
        }
    }

    private string GetStatusCssClass(SalesOrderStatus status) => status switch
    {
        SalesOrderStatus.Draft => "draft",
        SalesOrderStatus.Pending => "pending",
        SalesOrderStatus.Approved => "approved",
        SalesOrderStatus.PartiallyFulfilled => "partial",
        SalesOrderStatus.Fulfilled => "fulfilled",
        SalesOrderStatus.Invoiced => "invoiced",
        SalesOrderStatus.Cancelled => "cancelled",
        SalesOrderStatus.OnHold => "on-hold",
        _ => "draft"
    };

    private async Task OnPageSizeChanged()
    {
        currentPage = 1;
        await LoadOrders();
    }
}