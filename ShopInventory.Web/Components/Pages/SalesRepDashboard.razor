@using Microsoft.AspNetCore.Components

<style>
    .srd-page {
        min-height: 100vh;
        padding: 1.5rem;
    }

    .srd-hero {
        position: relative;
        overflow: hidden;
        margin-bottom: 1.5rem;
        padding: 1.75rem;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 1.25rem;
        background:
            radial-gradient(circle at top right, rgba(15, 118, 110, 0.18), transparent 32%),
            linear-gradient(135deg, rgba(248, 250, 252, 0.98), rgba(255, 255, 255, 0.95));
        box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
    }

    .srd-hero::after {
        content: "";
        position: absolute;
        inset: auto -4rem -5rem auto;
        width: 14rem;
        height: 14rem;
        border-radius: 999px;
        background: rgba(14, 165, 233, 0.08);
        filter: blur(8px);
        pointer-events: none;
    }

    .srd-hero-content {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .srd-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        margin-bottom: 0.9rem;
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        background: rgba(15, 118, 110, 0.12);
        color: #0f766e;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .srd-badge::before {
        content: "";
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 999px;
        background: currentColor;
        box-shadow: 0 0 0 0.3rem rgba(15, 118, 110, 0.16);
    }

    .srd-hero h2 {
        margin: 0 0 0.55rem;
        color: #0f172a;
        font-size: clamp(2rem, 3vw, 2.55rem);
        font-weight: 700;
        letter-spacing: -0.04em;
    }

    .srd-hero p {
        max-width: 48rem;
        margin: 0;
        color: #475569;
        font-size: 1rem;
        line-height: 1.7;
    }

    .srd-hero-actions {
        display: flex;
        gap: 0.85rem;
        flex-wrap: wrap;
        align-self: center;
    }

    .srd-hero-link {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.8rem 1.1rem;
        border-radius: 0.95rem;
        text-decoration: none;
        font-weight: 600;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .srd-hero-link:hover {
        transform: translateY(-2px);
    }

    .srd-hero-link-primary {
        background: linear-gradient(135deg, #0f766e, #0f9d8a);
        color: #f8fafc;
        box-shadow: 0 14px 26px rgba(15, 118, 110, 0.22);
    }

    .srd-hero-link-secondary {
        border: 1px solid rgba(15, 23, 42, 0.1);
        background: rgba(255, 255, 255, 0.78);
        color: #0f172a;
        box-shadow: 0 10px 20px rgba(15, 23, 42, 0.06);
    }

    .srd-module {
        display: block;
        height: 100%;
        padding: 1.35rem;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 1.1rem;
        text-decoration: none;
        transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
        box-shadow: 0 16px 35px rgba(15, 23, 42, 0.07);
    }

    .srd-module:hover {
        transform: translateY(-4px);
        border-color: rgba(15, 118, 110, 0.26);
        box-shadow: 0 20px 38px rgba(15, 23, 42, 0.1);
    }

    .srd-module-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .srd-module-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 3rem;
        height: 3rem;
        border-radius: 0.95rem;
        font-size: 1.2rem;
    }

    .srd-module-tag {
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .srd-module h3 {
        margin: 0 0 0.55rem;
        color: #0f172a;
        font-size: 1.1rem;
        font-weight: 700;
    }

    .srd-module p {
        margin: 0 0 1rem;
        color: #475569;
        line-height: 1.65;
    }

    .srd-module-link {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: #0f172a;
        font-weight: 600;
    }

    .srd-accent-orders {
        background: linear-gradient(180deg, rgba(224, 242, 254, 0.72), rgba(255, 255, 255, 0.98));
    }

    .srd-accent-orders .srd-module-icon,
    .srd-accent-orders .srd-module-tag {
        background: rgba(3, 105, 161, 0.12);
        color: #0369a1;
    }

    .srd-accent-drafts {
        background: linear-gradient(180deg, rgba(236, 253, 245, 0.78), rgba(255, 255, 255, 0.98));
    }

    .srd-accent-drafts .srd-module-icon,
    .srd-accent-drafts .srd-module-tag {
        background: rgba(5, 150, 105, 0.13);
        color: #047857;
    }

    .srd-accent-poddash {
        background: linear-gradient(180deg, rgba(240, 249, 255, 0.76), rgba(255, 255, 255, 0.98));
    }

    .srd-accent-poddash .srd-module-icon,
    .srd-accent-poddash .srd-module-tag {
        background: rgba(14, 165, 233, 0.12);
        color: #0284c7;
    }

    .srd-accent-delivery {
        background: linear-gradient(180deg, rgba(254, 249, 195, 0.56), rgba(255, 255, 255, 0.98));
    }

    .srd-accent-delivery .srd-module-icon,
    .srd-accent-delivery .srd-module-tag {
        background: rgba(202, 138, 4, 0.13);
        color: #a16207;
    }

    .srd-accent-report {
        background: linear-gradient(180deg, rgba(255, 241, 242, 0.7), rgba(255, 255, 255, 0.98));
    }

    .srd-accent-report .srd-module-icon,
    .srd-accent-report .srd-module-tag {
        background: rgba(225, 29, 72, 0.1);
        color: #be123c;
    }

    .srd-panel {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 1.1rem;
        box-shadow: 0 16px 32px rgba(15, 23, 42, 0.06);
    }

    .srd-panel .card-body {
        padding: 1.25rem;
    }

    .srd-step-list {
        display: grid;
        gap: 0.9rem;
    }

    .srd-step {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.9rem;
        align-items: start;
        padding: 0.95rem 1rem;
        border-radius: 0.95rem;
        background: #f8fafc;
        border: 1px solid rgba(148, 163, 184, 0.22);
    }

    .srd-step-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        background: #0f172a;
        color: #f8fafc;
        font-weight: 700;
        font-size: 0.9rem;
    }

    .srd-step h4 {
        margin: 0 0 0.25rem;
        color: #0f172a;
        font-size: 0.98rem;
        font-weight: 700;
    }

    .srd-step p,
    .srd-access-list li,
    .srd-panel-note {
        margin: 0;
        color: #475569;
        line-height: 1.6;
    }

    .srd-access-list {
        display: grid;
        gap: 0.8rem;
        padding-left: 1.15rem;
        margin: 0 0 1rem;
    }

    .srd-boundary {
        padding: 0.95rem 1rem;
        border-radius: 0.95rem;
        background: rgba(15, 118, 110, 0.08);
        border: 1px solid rgba(15, 118, 110, 0.14);
        color: #134e4a;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .srd-page {
            padding: 1rem;
        }

        .srd-hero {
            padding: 1.3rem;
        }

        .srd-hero h2 {
            font-size: 1.8rem;
        }

        .srd-hero-actions,
        .srd-hero-link {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="container-fluid fade-in staff-dashboard staff-shell srd-page">
    <div class="srd-hero">
        <div class="srd-hero-content">
            <div>
                <div class="srd-badge">Sales workspace</div>
                <h2>Welcome back, @DisplayName</h2>
                <p>
                    This dashboard is tailored for sales reps. It keeps your sales-order and delivery follow-up tools in
                    one place
                    and intentionally removes cashier, invoicing, payments, and transfer workflows.
                </p>
            </div>

            <div class="srd-hero-actions">
                <a class="srd-hero-link srd-hero-link-primary" href="/sales-orders">
                    <i class="bi bi-cart-check"></i>
                    Open Sales Orders
                </a>
                <a class="srd-hero-link srd-hero-link-secondary" href="/mobile-drafts">
                    <i class="bi bi-phone"></i>
                    Review Mobile Drafts
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        @foreach (var module in Modules)
        {
            <div class="col-xl-4 col-md-6">
                <a class="srd-module @module.AccentClass" href="@module.Href">
                    <div class="srd-module-head">
                        <span class="srd-module-icon">
                            <i class="@module.IconClass"></i>
                        </span>
                        <span class="srd-module-tag">@module.Tag</span>
                    </div>
                    <h3>@module.Title</h3>
                    <p>@module.Description</p>
                    <span class="srd-module-link">
                        Open module
                        <i class="bi bi-arrow-right"></i>
                    </span>
                </a>
            </div>
        }
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card dashboard-panel srd-panel h-100">
                <div class="card-header dashboard-panel-header">
                    <h5 class="mb-0 d-flex align-items-center gap-2">
                        <i class="bi bi-list-check"></i>
                        Recommended Workflow
                    </h5>
                </div>
                <div class="card-body">
                    <div class="srd-step-list">
                        <div class="srd-step">
                            <span class="srd-step-number">1</span>
                            <div>
                                <h4>Review incoming customer orders</h4>
                                <p>Use Sales Orders to track status, update order details, and keep customer demand
                                    moving.</p>
                                </div>
                            </div>
                            <div class="srd-step">
                                <span class="srd-step-number">2</span>
                                <div>
                                    <h4>Process mobile-submitted drafts</h4>
                                    <p>Open Mobile Drafts to validate field submissions and continue the sales workflow
                                        without stepping into cashier tasks.</p>
                                    </div>
                                </div>
                                <div class="srd-step">
                                    <span class="srd-step-number">3</span>
                                    <div>
                                        <h4>Close the delivery loop</h4>
                                        <p>Use the POD tools to upload proof of delivery, monitor upload activity, and chase
                                            outstanding documents.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

@code {
    [Parameter] public string Username { get; set; } = string.Empty;

    private string DisplayName => string.IsNullOrWhiteSpace(Username) ? "Sales Rep" : Username;

    private static readonly IReadOnlyList<DashboardModule> Modules = new[]
    {
        new DashboardModule(
            "Sales Orders",
            "Review order status, open customer orders, and continue order updates without crossing into invoicing.",
            "/sales-orders",
            "bi bi-cart-check",
            "srd-accent-orders",
            "Order flow"),
        new DashboardModule(
            "Mobile Drafts",
            "Pick up orders captured in the field and move them forward from a controlled sales workflow.",
            "/mobile-drafts",
            "bi bi-phone",
            "srd-accent-drafts",
            "Field sales"),
        new DashboardModule(
            "POD Dashboard",
            "See your proof-of-delivery activity at a glance and monitor upload momentum.",
            "/pod-dashboard",
            "bi bi-speedometer2",
            "srd-accent-poddash",
            "Upload activity"),
        new DashboardModule(
            "Proof of Delivery",
            "Upload and manage POD attachments for completed deliveries.",
            "/pods",
            "bi bi-clipboard-check",
            "srd-accent-delivery",
            "Delivery proof"),
        new DashboardModule(
            "POD Upload Report",
            "Track uploaded versus pending delivery evidence so follow-up stays visible.",
            "/pod-report",
            "bi bi-clipboard-data",
            "srd-accent-report",
            "Status view")
    };

    private sealed record DashboardModule(
        string Title,
        string Description,
        string Href,
        string IconClass,
        string AccentClass,
        string Tag);
}