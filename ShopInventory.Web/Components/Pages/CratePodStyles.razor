<style>
    .crpod-page {
        max-width: 1320px;
        margin: 0 auto;
        padding-bottom: 2rem;
    }

    .crpod-hero {
        background: linear-gradient(135deg, #0f766e 0%, #0f766e 35%, #155e75 100%);
        border-radius: 18px;
        padding: 1.5rem 1.75rem;
        color: #fff;
        margin-bottom: 1.1rem;
        box-shadow: 0 18px 40px rgba(15, 118, 110, 0.16);
    }

    .crpod-hero-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .crpod-hero-title {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin: 0;
        font-size: 1.6rem;
        font-weight: 700;
    }

    .crpod-hero-icon {
        width: 46px;
        height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.16);
        font-size: 1.25rem;
    }

    .crpod-hero-subtitle {
        margin: .35rem 0 0;
        font-size: .92rem;
        opacity: .9;
        max-width: 820px;
    }

    .crpod-hero-actions {
        display: flex;
        align-items: center;
        gap: .6rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .crpod-stat-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: .42rem .85rem;
        font-size: .8rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .crpod-stat-pill-neutral {
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
    }

    .crpod-stat-pill-warning {
        background: rgba(245, 158, 11, 0.22);
        color: #fde68a;
    }

    .crpod-stat-pill-success {
        background: rgba(34, 197, 94, 0.22);
        color: #bbf7d0;
    }

    .crpod-refresh-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 10px;
        background: transparent;
        color: #fff;
        font-weight: 600;
        padding: .7rem 1rem;
        transition: background .15s ease, border-color .15s ease;
    }

    .crpod-refresh-btn:hover:not(:disabled) {
        background: rgba(255, 255, 255, 0.12);
    }

    .crpod-refresh-btn:disabled {
        opacity: .65;
        cursor: not-allowed;
    }

    .crpod-mode-toggle {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .crpod-mode-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        padding: .7rem 1rem;
        border-radius: 12px;
        border: 1px solid #dbe4ea;
        background: #fff;
        color: #335266;
        font-size: .88rem;
        font-weight: 600;
        text-decoration: none;
        transition: all .15s ease;
    }

    .crpod-mode-btn:hover {
        border-color: #0f766e;
        color: #0f766e;
    }

    .crpod-mode-active {
        background: linear-gradient(135deg, #0f766e, #155e75);
        color: #fff;
        border-color: transparent;
    }

    .crpod-status-banner {
        display: flex;
        align-items: center;
        gap: .75rem;
        border-radius: 14px;
        padding: .9rem 1rem;
        margin-bottom: 1rem;
        font-weight: 500;
    }

    .crpod-status-success {
        background: #ecfdf5;
        color: #047857;
        border: 1px solid #a7f3d0;
    }

    .crpod-status-error {
        background: #fef2f2;
        color: #b91c1c;
        border: 1px solid #fecaca;
    }

    .crpod-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .crpod-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.2rem;
        border-bottom: 1px solid #eef2f7;
        background: linear-gradient(180deg, #fcfefe 0%, #f8fafc 100%);
    }

    .crpod-card-body {
        padding: 1.2rem;
    }

    .crpod-card-title {
        margin: 0;
        color: #0f172a;
        font-size: 1.05rem;
        font-weight: 700;
    }

    .crpod-card-note {
        margin: .25rem 0 0;
        color: #64748b;
        font-size: .86rem;
    }

    .crpod-header-count {
        font-size: .8rem;
        font-weight: 600;
        color: #64748b;
        background: #f1f5f9;
        border-radius: 999px;
        padding: .35rem .8rem;
        white-space: nowrap;
    }

    .crpod-readonly-state {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.2rem;
    }

    .crpod-readonly-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ecfeff;
        color: #0f766e;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .crpod-label {
        display: block;
        margin-bottom: .35rem;
        color: #475569;
        font-size: .78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .crpod-input {
        border-radius: 12px;
        border-color: #dbe4ea;
        min-height: 44px;
        box-shadow: none;
    }

    .crpod-input:focus {
        border-color: #0f766e;
        box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.12);
    }

    .crpod-help {
        font-size: .75rem;
        color: #64748b;
        margin-top: .35rem;
    }

    .crpod-bulk-alert {
        border-radius: 14px;
        border: 1px solid #bfdbfe;
        background: #eff6ff;
        color: #1d4ed8;
        padding: .9rem 1rem;
        font-size: .84rem;
    }

    .crpod-bulk-guide {
        border: 1px solid #dbe4ea;
        border-radius: 16px;
        background: #f8fafc;
        padding: 1rem;
    }

    .crpod-bulk-guide-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: .9rem;
    }

    .crpod-bulk-guide-title {
        margin: 0;
        font-size: .98rem;
        font-weight: 700;
        color: #0f172a;
    }

    .crpod-bulk-guide-copy {
        margin: .3rem 0 0;
        color: #64748b;
        font-size: .84rem;
    }

    .crpod-bulk-guide-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: .8rem;
    }

    .crpod-bulk-guide-card {
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        background: #fff;
        padding: .9rem;
    }

    .crpod-guide-chips {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .crpod-guide-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: .4rem .75rem;
        border-radius: 999px;
        background: #ecfeff;
        color: #155e75;
        font-size: .78rem;
        font-weight: 700;
    }

    .crpod-bulk-code {
        margin: 0;
        border-radius: 12px;
        background: #0f172a;
        color: #e2e8f0;
        padding: .9rem 1rem;
        font-size: .8rem;
        line-height: 1.7;
        overflow-x: auto;
        white-space: pre;
    }

    .crpod-inline-pill {
        min-height: 44px;
        border-radius: 12px;
        border: 1px solid #dbe4ea;
        background: #f8fafc;
        color: #0f172a;
        display: inline-flex;
        align-items: center;
        gap: .55rem;
        padding: .7rem .85rem;
        font-size: .85rem;
        font-weight: 600;
        width: 100%;
    }

    .crpod-bulk-qty {
        min-width: 120px;
    }

    .crpod-invoice-badge,
    .crpod-warning-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .35rem;
        padding: .35rem .7rem;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .crpod-invoice-badge {
        background: #ecfeff;
        color: #155e75;
    }

    .crpod-warning-badge {
        background: #fff7ed;
        color: #c2410c;
    }

    .crpod-bulk-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 0 0;
        flex-wrap: wrap;
    }

    .crpod-bulk-summary {
        color: #64748b;
        font-size: .85rem;
        font-weight: 600;
    }

    .crpod-bulk-actions {
        display: flex;
        align-items: center;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .crpod-inline-alert {
        display: flex;
        align-items: center;
        gap: .55rem;
        min-height: 44px;
        border-radius: 12px;
        padding: .7rem .85rem;
        font-size: .83rem;
    }

    .crpod-inline-alert-info {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
    }

    .crpod-inline-alert-success {
        background: #ecfdf5;
        color: #047857;
        border: 1px solid #a7f3d0;
    }

    .crpod-file-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        margin-top: 1rem;
    }

    .crpod-file-chip {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        max-width: 100%;
        padding: .45rem .8rem;
        border-radius: 999px;
        background: #ecfeff;
        color: #155e75;
        font-size: .8rem;
        font-weight: 600;
    }

    .crpod-file-chip-size {
        color: #64748b;
        font-weight: 500;
    }

    .crpod-card-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 1rem;
    }

    .crpod-primary-btn,
    .crpod-row-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
    }

    .crpod-primary-btn {
        padding: .8rem 1.15rem;
        background: linear-gradient(135deg, #0f766e, #155e75);
        color: #fff;
        min-width: 240px;
        box-shadow: 0 10px 24px rgba(15, 118, 110, 0.18);
    }

    .crpod-primary-btn:hover:not(:disabled),
    .crpod-row-btn:hover:not(:disabled) {
        transform: translateY(-1px);
    }

    .crpod-primary-btn:disabled,
    .crpod-row-btn:disabled {
        opacity: .6;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .crpod-detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: .9rem;
    }

    .crpod-detail-item {
        background: #f8fafc;
        border: 1px solid #eef2f7;
        border-radius: 14px;
        padding: .9rem 1rem;
        display: flex;
        flex-direction: column;
        gap: .2rem;
    }

    .crpod-detail-label {
        font-size: .74rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #64748b;
    }

    .crpod-detail-value {
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
    }

    .crpod-detail-sub {
        font-size: .8rem;
        color: #64748b;
    }

    .crpod-detail-note {
        margin-top: 1rem;
        padding: .9rem 1rem;
        border-radius: 14px;
        background: #fffbeb;
        border: 1px solid #fde68a;
    }

    .crpod-detail-note p {
        margin: .35rem 0 0;
        color: #78350f;
        font-size: .88rem;
    }

    .crpod-filter-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        padding: 1rem 1.2rem;
        border-bottom: 1px solid #eef2f7;
        background: #fbfdff;
        flex-wrap: wrap;
    }

    .crpod-filter-bar-history {
        align-items: stretch;
    }

    .crpod-filter-search {
        display: flex;
        align-items: center;
        gap: .6rem;
        min-width: min(100%, 340px);
        flex: 1 1 260px;
        padding: 0 .85rem;
        border: 1px solid #dbe4ea;
        border-radius: 12px;
        background: #fff;
    }

    .crpod-filter-search i {
        color: #94a3b8;
    }

    .crpod-filter-search .crpod-input {
        border: none;
        background: transparent;
        padding-left: 0;
        padding-right: 0;
    }

    .crpod-filter-search .crpod-input:focus {
        box-shadow: none;
    }

    .crpod-filter-select {
        max-width: 220px;
    }

    .crpod-tab-bar {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .crpod-tab {
        border: 1px solid #dbe4ea;
        border-radius: 999px;
        background: #fff;
        color: #475569;
        font-size: .82rem;
        font-weight: 600;
        padding: .5rem .9rem;
        transition: all .15s ease;
    }

    .crpod-tab:hover {
        border-color: #0f766e;
        color: #0f766e;
    }

    .crpod-tab-active {
        background: #0f766e;
        color: #fff;
        border-color: #0f766e;
    }

    .crpod-table-wrap {
        overflow: hidden;
    }

    .crpod-table {
        margin: 0;
    }

    .crpod-table thead th {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        color: #64748b;
        font-size: .74rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
        padding: .8rem 1rem;
    }

    .crpod-table tbody td {
        padding: .85rem 1rem;
        border-bottom: 1px solid #eef2f7;
        font-size: .88rem;
        vertical-align: middle;
    }

    .crpod-row-selected td {
        background: rgba(20, 184, 166, 0.08);
    }

    .crpod-table-primary {
        font-weight: 600;
        color: #0f172a;
    }

    .crpod-table-sub,
    .crpod-table-note {
        font-size: .78rem;
        color: #64748b;
        margin-top: .15rem;
    }

    .crpod-table-note {
        color: #475569;
        white-space: normal;
    }

    .crpod-status-badge,
    .crpod-role-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: .35rem .75rem;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .crpod-status-pending {
        background: #fff7ed;
        color: #c2410c;
    }

    .crpod-status-success {
        background: #ecfdf5;
        color: #047857;
    }

    .crpod-status-danger {
        background: #fef2f2;
        color: #b91c1c;
    }

    .crpod-role-driver {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .crpod-role-merch {
        background: #fdf2f8;
        color: #be185d;
    }

    .crpod-row-btn {
        background: #f1f5f9;
        color: #0f172a;
        padding: .55rem .85rem;
        min-width: 110px;
    }

    .crpod-row-btn-active {
        background: #0f766e;
        color: #fff;
    }

    .crpod-attachments {
        display: flex;
        flex-direction: column;
        gap: .6rem;
    }

    .crpod-attachment-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        border: 1px solid #dbe4ea;
        border-radius: 12px;
        padding: .7rem .8rem;
        background: #fff;
    }

    .crpod-attachment-meta {
        min-width: 0;
        flex: 1 1 auto;
    }

    .crpod-attachment-actions {
        display: flex;
        gap: .45rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .crpod-attachment-action,
    .crpod-secondary-btn,
    .crpod-danger-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        border-radius: 10px;
        font-size: .8rem;
        font-weight: 600;
        padding: .55rem .8rem;
        border: 1px solid #dbe4ea;
        background: #fff;
        color: #0f172a;
        transition: transform .15s ease, border-color .15s ease, background .15s ease;
    }

    .crpod-attachment-action:hover,
    .crpod-secondary-btn:hover,
    .crpod-danger-btn:hover {
        transform: translateY(-1px);
    }

    .crpod-attachment-action-view {
        color: #155e75;
        border-color: rgba(21, 94, 117, 0.2);
        background: rgba(236, 254, 255, 0.8);
    }

    .crpod-attachment-action-download {
        color: #1d4ed8;
        border-color: rgba(37, 99, 235, 0.18);
        background: rgba(239, 246, 255, 0.8);
    }

    .crpod-attachment-action-delete,
    .crpod-danger-btn {
        color: #b91c1c;
        border-color: rgba(220, 38, 38, 0.18);
        background: rgba(254, 242, 242, 0.9);
    }

    .crpod-attachment-btn {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        max-width: 100%;
        border: 1px solid #dbe4ea;
        background: #fff;
        color: #155e75;
        padding: .45rem .7rem;
        border-radius: 10px;
        font-size: .78rem;
        font-weight: 600;
    }

    .crpod-attachment-btn span {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .crpod-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.68);
        z-index: 1100;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .crpod-modal {
        width: min(640px, calc(100vw - 1.5rem));
        max-height: calc(100vh - 2rem);
        display: flex;
        flex-direction: column;
        background: #fff;
        border-radius: 18px;
        border: 1px solid #dbe4ea;
        box-shadow: 0 22px 50px rgba(15, 23, 42, 0.28);
        overflow: hidden;
    }

    .crpod-modal-large {
        width: min(1080px, calc(100vw - 1.5rem));
    }

    .crpod-modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.1rem;
        border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
    }

    .crpod-modal-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
    }

    .crpod-modal-close {
        width: 38px;
        height: 38px;
        border-radius: 999px;
        border: 1px solid #dbe4ea;
        background: #fff;
        color: #475569;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .crpod-modal-body {
        padding: 1rem 1.1rem;
        overflow: auto;
        max-height: min(72vh, 720px);
    }

    .crpod-modal-state,
    .crpod-delete-copy {
        color: #475569;
        font-size: .92rem;
        margin: 0;
    }

    .crpod-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        padding: 1rem 1.1rem;
        border-top: 1px solid #e2e8f0;
        background: #f8fafc;
    }

    .crpod-viewer-frame {
        width: 100%;
        min-height: min(68vh, 700px);
        border: none;
        border-radius: 12px;
        background: #0f172a;
    }

    .crpod-viewer-image {
        width: 100%;
        max-height: min(68vh, 700px);
        object-fit: contain;
        border-radius: 12px;
        background: #0f172a;
    }

    .crpod-secondary-btn {
        color: #0f172a;
        background: #fff;
    }

    .crpod-empty-state {
        padding: 2.5rem 1.2rem;
        text-align: center;
        color: #64748b;
        font-size: .92rem;
    }

    @@media (max-width: 991.98px) {

        .crpod-hero,
        .crpod-card-header,
        .crpod-card-body,
        .crpod-filter-bar {
            padding-left: 1rem;
            padding-right: 1rem;
        }

        .crpod-hero-actions,
        .crpod-card-header {
            justify-content: flex-start;
        }

        .crpod-filter-select {
            max-width: none;
            width: 100%;
        }
    }

    @@media (max-width: 767.98px) {
        .crpod-hero {
            padding: 1rem;
            border-radius: 16px;
        }

        .crpod-hero-title {
            font-size: 1.2rem;
            align-items: flex-start;
        }

        .crpod-hero-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .crpod-hero-actions,
        .crpod-refresh-btn,
        .crpod-primary-btn,
        .crpod-mode-btn,
        .crpod-tab,
        .crpod-row-btn {
            width: 100%;
        }

        .crpod-card-header,
        .crpod-filter-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .crpod-header-count {
            text-align: center;
        }

        .crpod-card-actions {
            justify-content: stretch;
        }

        .crpod-bulk-guide-header {
            flex-direction: column;
