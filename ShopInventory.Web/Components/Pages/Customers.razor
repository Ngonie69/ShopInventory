@page "/customers"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IBusinessPartnerService BusinessPartnerService
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject IAppSettingsProvider AppSettings
@inject IAuditService AuditService
@rendermode InteractiveServer

<PageTitle>Customers - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .cust-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Header ──────────────────────────────────────── */
    .cust-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .cust-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .cust-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .cust-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .cust-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .cust-header-actions {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .btn-cust-outline {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .45rem 1.1rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-cust-outline:hover {
        background: #f9fafb;
        border-color: #9ca3af;
    }

    .btn-cust-outline:disabled {
        opacity: .5;
        cursor: not-allowed;
    }

    .btn-cust-outline.active {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border-color: transparent;
        box-shadow: 0 2px 8px rgba(102, 126, 234, .25);
    }

    .sync-hint {
        font-size: .78rem;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    /* ── Stat Cards ──────────────────────────────────── */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: .85rem;
        border: 1px solid #e5e7eb;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        transition: all .25s ease;
    }

    .stat-card:hover {
        box-shadow: 0 4px 14px rgba(0, 0, 0, .08);
        transform: translateY(-2px);
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .stat-icon.purple {
        background: #ede9fe;
        color: #7c3aed;
    }

    .stat-icon.blue {
        background: #dbeafe;
        color: #2563eb;
    }

    .stat-icon.green {
        background: #d1fae5;
        color: #059669;
    }

    .stat-icon.amber {
        background: #fef3c7;
        color: #d97706;
    }

    .stat-info .stat-value {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1.2;
    }

    .stat-info .stat-label {
        font-size: .78rem;
        color: #6b7280;
        font-weight: 500;
    }

    /* ── Filter Bar ──────────────────────────────────── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        align-items: flex-end;
        padding: 1rem 1.25rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
    }

    .filter-bar .filter-field {
        flex: 1;
        min-width: 200px;
    }

    .filter-bar .filter-field label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .3rem;
    }

    .filter-bar .filter-field input {
        width: 100%;
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        background: #fff;
        transition: all .15s;
    }

    .filter-bar .filter-field input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    .filter-actions-row {
        display: flex;
        gap: .5rem;
        align-items: flex-end;
    }

    .btn-search {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-search:hover {
        opacity: .92;
        transform: translateY(-1px);
    }

    .btn-clear {
        background: #fff;
        color: #6b7280;
        border: 1px solid #d1d5db;
        padding: .5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-clear:hover {
        background: #f3f4f6;
    }

    /* ── Type Toggle ─────────────────────────────────── */
    .type-toggle {
        display: flex;
        gap: 0;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #d1d5db;
    }

    .type-toggle button {
        padding: .4rem 1rem;
        border: none;
        background: #fff;
        color: #6b7280;
        font-weight: 600;
        font-size: .82rem;
        cursor: pointer;
        transition: all .15s;
    }

    .type-toggle button:not(:last-child) {
        border-right: 1px solid #e5e7eb;
    }

    .type-toggle button:hover {
        background: #f3f4f6;
    }

    .type-toggle button.active {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
    }

    /* ── Table ───────────────────────────────────────── */
    .cust-table-wrap {
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #fff;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        margin-bottom: 1.25rem;
    }

    .cust-table-header {
        padding: .85rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
    }

    .cust-table-header h6 {
        margin: 0;
        font-weight: 600;
        color: #1a1a2e;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .92rem;
    }

    .cust-count-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #374151;
    }

    /* Quick filter within table */
    .table-quick-filter {
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .85rem;
        color: #374151;
        min-width: 220px;
        transition: all .15s;
    }

    .table-quick-filter:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    /* ── Status & Type Badges ────────────────────────── */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .73rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-badge.active {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.inactive {
        background: #f3f4f6;
        color: #6b7280;
    }

    .type-badge {
        display: inline-flex;
        align-items: center;
        gap: .2rem;
        padding: .15rem .55rem;
        border-radius: 6px;
        font-size: .75rem;
        font-weight: 600;
    }

    .type-badge.customer {
        background: #dbeafe;
        color: #1e40af;
    }

    .type-badge.supplier {
        background: #d1fae5;
        color: #065f46;
    }

    .type-badge.lead {
        background: #e0e7ff;
        color: #3730a3;
    }

    /* ── Contact Info ────────────────────────────────── */
    .contact-cell {
        font-size: .85rem;
    }

    .contact-cell a {
        color: #667eea;
        text-decoration: none;
        font-weight: 500;
    }

    .contact-cell a:hover {
        text-decoration: underline;
    }

    .contact-cell .phone {
        font-size: .78rem;
        color: #9ca3af;
    }

    /* ── Balance Cell ────────────────────────────────── */
    .balance-positive {
        color: #dc2626;
        font-weight: 700;
        font-family: 'Space Grotesk', monospace;
    }

    .balance-zero {
        color: #059669;
        font-weight: 600;
        font-family: 'Space Grotesk', monospace;
    }

    /* ── Customer Code ───────────────────────────────── */
    .customer-code {
        font-weight: 700;
        color: #667eea;
        font-size: .88rem;
        font-family: 'Space Grotesk', monospace;
    }

    .customer-name {
        font-weight: 600;
        color: #1a1a2e;
        font-size: .88rem;
    }

    /* ── Action Buttons ──────────────────────────────── */
    .action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: .85rem;
    }

    .action-btn:hover {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }

    .action-btn.primary:hover {
        background: #ede9fe;
        color: #667eea;
        border-color: #c4b5fd;
    }

    .action-btn.info:hover {
        background: #dbeafe;
        color: #2563eb;
        border-color: #93c5fd;
    }

    /* ── Drawer Modal ────────────────────────────────── */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        z-index: 9998;
        animation: fadeIn .2s ease;
    }

    .detail-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(640px, 95vw);
        height: 100vh;
        background: #fff;
        z-index: 9999;
        box-shadow: -8px 0 30px rgba(0, 0, 0, .12);
        display: flex;
        flex-direction: column;
        animation: slideInRight .25s ease;
    }

    .drawer-header {
        padding: 1.15rem 1.5rem;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }

    .drawer-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .drawer-header .btn-close-drawer {
        background: rgba(255, 255, 255, .15);
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s;
        font-size: 1rem;
    }

    .drawer-header .btn-close-drawer:hover {
        background: rgba(255, 255, 255, .25);
    }

    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .drawer-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        flex-shrink: 0;
        flex-wrap: wrap;
    }

    .detail-section-title {
        font-weight: 600;
        color: #1a1a2e;
        font-size: .9rem;
        margin-bottom: .75rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
        margin-bottom: 1.25rem;
    }

    .detail-item .detail-label {
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #9ca3af;
        margin-bottom: .15rem;
    }

    .detail-item .detail-value {
        font-size: .92rem;
        font-weight: 600;
        color: #1a1a2e;
    }

    /* Statement date fields */
    .stmt-row {
        display: flex;
        gap: .75rem;
        align-items: flex-end;
        padding: .85rem 1rem;
        background: #f8fafc;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .stmt-row .stmt-field {
        flex: 1;
        min-width: 140px;
    }

    .stmt-row .stmt-field label {
        display: block;
        font-size: .72rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .25rem;
    }

    .stmt-row .stmt-field input {
        width: 100%;
        padding: .4rem .6rem;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: .85rem;
    }

    .stmt-row .stmt-field input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    /* Action buttons in drawer */
    .btn-drawer-primary {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .5rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-drawer-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
    }

    .btn-drawer-primary:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    .btn-drawer-warning {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border: none;
        color: #fff;
        padding: .5rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-drawer-warning:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(217, 119, 6, .3);
    }

    .btn-drawer-warning:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    .btn-drawer-secondary {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .5rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .btn-drawer-secondary:hover {
        background: #f9fafb;
    }

    /* ── Empty & Loading States ──────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 1.8rem;
        color: #9ca3af;
    }

    .empty-state h6 {
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
    }

    .empty-state p {
        color: #9ca3af;
        font-size: .88rem;
        margin-bottom: 1rem;
    }

    .loading-state {
        text-align: center;
        padding: 3rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    /* ── Alert ───────────────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        margin-bottom: 1rem;
        font-size: .88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .alert-banner.info-alert {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1e40af;
    }

    /* ── Animations ──────────────────────────────────── */
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }

        to {
            transform: translateX(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ── Responsive ──────────────────────────────────── */
    @@media (max-width:768px) {
        .stat-row {
            grid-template-columns: 1fr 1fr;
        }

        .cust-header {
            flex-direction: column;
        }

        .detail-grid {
            grid-template-columns: 1fr;
        }

        .stmt-row {
            flex-direction: column;
        }
    }
</style>

<div class="cust-page">
    <div class="container-fluid">

        <!-- ━━━ Header ━━━ -->
        <div class="cust-header">
            <div class="cust-header-left">
                <div class="cust-header-icon"><i class="bi bi-people-fill"></i></div>
                <div>
                    <h2>Customers</h2>
                    <p>Manage customers, suppliers & business partners</p>
                </div>
            </div>
            <div class="cust-header-actions">
                @if (lastSyncTime.HasValue)
                {
                    <span class="sync-hint">
                        <i class="bi bi-clock-history"></i> Synced @lastSyncTime.Value.ToLocalTime().ToString("g")
                    </span>
                }
                <MudButton Class="btn-cust-outline" OnClick="RefreshFromApi" Disabled="@isSyncing">
                    @if (isSyncing)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                        <span>Syncing...</span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-clockwise"></i>
                        <span>Refresh</span>
                    }
                </MudButton>
                <div class="type-toggle">
                    <MudButton Class="@(selectedType == "cCustomer" ? "active" : "")"
                               OnClick='() => FilterByType("cCustomer")'>
                        Customers</MudButton>
                        <MudButton Class="@(selectedType == "cSupplier" ? "active" : "")"
                                   OnClick='() => FilterByType("cSupplier")'>
                            Suppliers</MudButton>
                            <MudButton Class="@(selectedType == "" ? "active" : "")" OnClick='() => FilterByType("")'>All
                            </MudButton>
                        </div>
                    </div>
                </div>

                <!-- ━━━ Alerts ━━━ -->
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert-banner error-alert">
                        <i class="bi bi-exclamation-octagon-fill"></i>
                        <div style="flex:1;">@errorMessage</div>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Style="color:inherit;opacity:.45;font-size:1rem;"
                                       OnClick="() => errorMessage = null" />
                    </div>
                }

                <!-- ━━━ Stat Cards ━━━ -->
                @if (customers?.Any() == true)
                {
                    <div class="stat-row">
                        <div class="stat-card">
                            <div class="stat-icon purple"><i class="bi bi-people-fill"></i></div>
                            <div class="stat-info">
                                <div class="stat-value">@customers.Count(c => c.CardType == "cCustomer" || c.CardType == "C")</div>
                                <div class="stat-label">Customers</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon blue"><i class="bi bi-truck"></i></div>
                            <div class="stat-info">
                                <div class="stat-value">@customers.Count(c => c.CardType == "cSupplier" || c.CardType == "S")</div>
                                <div class="stat-label">Suppliers</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon green"><i class="bi bi-check-circle-fill"></i></div>
                            <div class="stat-info">
                                <div class="stat-value">@customers.Count(c => c.IsActive)</div>
                                <div class="stat-label">Active</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon amber"><i class="bi bi-cash-coin"></i></div>
                            <div class="stat-info">
                                <div class="stat-value">@customers.Where(c => c.Balance > 0).Sum(c => c.Balance ?? 0).ToString("N0")
                                </div>
                                <div class="stat-label">Total Outstanding</div>
                            </div>
                        </div>
                    </div>
                }

                <!-- ━━━ Filter Bar ━━━ -->
                <div class="filter-bar">
                    <div class="filter-field">
                        <label>Search</label>
                        <input type="text" @bind="searchTerm" @bind:event="oninput" @onkeyup="OnSearchKeyUp"
                               placeholder="Search by code, name, or email..." />
                    </div>
                    <div class="filter-actions-row">
                        <MudButton Class="btn-search" OnClick="SearchCustomers">
                            <i class="bi bi-search"></i> Search
                        </MudButton>
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <MudButton Class="btn-clear" OnClick="ClearSearch">
                                <i class="bi bi-x-circle"></i> Clear
                            </MudButton>
                        }
                    </div>
                </div>

                <!-- ━━━ Content ━━━ -->
                @if (isLoading)
                {
                    <div class="loading-state">
                        <div class="spinner-border" style="color:#667eea;width:2.5rem;height:2.5rem;" role="status"></div>
                        <p style="margin-top:.75rem;color:#6b7280;font-weight:500;">Loading customers...</p>
                    </div>
                }
                else if (customers?.Any() == true)
                {
                    <div class="cust-table-wrap">
                        <div class="cust-table-header">
                            <h6><i class="bi bi-table"></i> Business Partners</h6>
                            <div style="display:flex;align-items:center;gap:.75rem;">
                                <span class="cust-count-badge">@totalCount total</span>
                                <input type="text" class="table-quick-filter" @bind="_searchString" @bind:event="oninput"
                                       placeholder="Quick filter..." />
                            </div>
                        </div>
                        <MudTable @ref="@_table" Items="@customers" RowsPerPage="@_pageSize" Dense="true" Hover="true"
                                  Striped="true" Filter="new Func<BusinessPartnerDto, bool>(_quickFilter)"
                                  OnRowClick="@OnCustomerRowClicked" T="BusinessPartnerDto" Elevation="0" Style="background:transparent;">
                            <HeaderContent>
                                <MudTh>Code</MudTh>
                                <MudTh>Name</MudTh>
                                <MudTh>Type</MudTh>
                                <MudTh>Contact</MudTh>
                                <MudTh>Location</MudTh>
                                <MudTh>Currency</MudTh>
                                <MudTh Style="text-align:right">Balance</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh Style="width:80px">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Code"><span class="customer-code">@context.CardCode</span></MudTd>
                                <MudTd DataLabel="Name"><span class="customer-name">@context.CardName</span></MudTd>
                                <MudTd DataLabel="Type">
                                    <span class="type-badge @GetTypeClass(context.CardType)">@GetTypeLabel(context.CardType)</span>
                                </MudTd>
                                <MudTd DataLabel="Contact">
                                    <div class="contact-cell">
                                        @if (!string.IsNullOrEmpty(context.Email))
                                        {
                                            <a href="mailto:@context.Email">@context.Email</a>
                                        }
                                        @if (!string.IsNullOrEmpty(context.Phone1))
                                        {
                                            <div class="phone"><i class="bi bi-telephone me-1"></i>@context.Phone1</div>
                                        }
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="Location">
                                    @if (!string.IsNullOrEmpty(context.City) || !string.IsNullOrEmpty(context.Country))
                                    {
                                        <span style="font-size:.85rem;">@context.City @context.Country</span>
                                    }
                                    else
                                    {
                                        <span style="color:#d1d5db;">—</span>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Currency">
                                    <span
                                        style="font-size:.82rem;padding:.15rem .45rem;border-radius:4px;background:#f3f4f6;color:#374151;font-weight:600;">@(context.Currency
                                                                                                                                                                                                                                                                            ?? "USD")</span>
                                    </MudTd>
                                    <MudTd DataLabel="Balance" Style="text-align:right">
                                        <span class="@(context.Balance > 0 ? "balance-positive" : "balance-zero")">
                                            @((context.Balance ?? 0).ToString("N2"))
                                        </span>
                                    </MudTd>
                                    <MudTd DataLabel="Status">
                                        @if (context.IsActive)
                                        {
                                            <span class="status-badge active"><i class="bi bi-check-circle-fill"></i> Active</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge inactive">Inactive</span>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Actions">
                                        <div style="display:flex;gap:.3rem;">
                                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Class="action-btn primary"
                                                           OnClick="@(() => ViewCustomer(context))" title="View Details" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Receipt" Class="action-btn info"
                                                           OnClick="@(() => NavigateToInvoices(context.CardCode ?? string.Empty))"
                                                           title="View Invoices" />
                                        </div>
                                    </MudTd>
                                </RowTemplate>
                                <PagerContent>
                                    <div class="pager-row">
                                        <div class="page-size-wrap">
                                            <span>Show</span>
                                            <select @bind="_pageSize">
                                                <option value="10">10</option>
                                                <option value="25">25</option>
                                                <option value="50">50</option>
                                                <option value="100">100</option>
                                            </select>
                                            <span>per page</span>
                                        </div>
                                        <MudPagination SelectedChanged="PageChanged"
                                                       Count="@((_table.GetFilteredItemsCount() + _table.RowsPerPage - 1) / _table.RowsPerPage)"
                                                       Class="pa-4" />
                                    </div>
                                </PagerContent>
                            </MudTable>
                        </div>
                    }
        else
                    {
                        <div class="empty-state">
                            <div class="empty-icon"><i class="bi bi-people"></i></div>
                            <h6>No customers found</h6>
                            <p>Try adjusting your search criteria or click Refresh to sync from server.</p>
                            <MudButton Class="btn-search" OnClick="RefreshFromApi"><i class="bi bi-arrow-clockwise"></i> Refresh
                            </MudButton>
                        </div>
                    }
                </div>
            </div>

            <!-- ━━━ Customer Detail Drawer ━━━ -->
            @if (selectedCustomer != null)
            {
                <div class="modal-backdrop-custom" @onclick="() => selectedCustomer = null"></div>
                <div class="detail-drawer">
                    <div class="drawer-header">
                        <h5><i class="bi bi-person-badge"></i> @selectedCustomer.CardName</h5>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Class="btn-close-drawer"
                                       OnClick="() => selectedCustomer = null" />
                    </div>
                    <div class="drawer-body">
                        <!-- Statement Generator -->
                        <div class="stmt-row">
                            <div class="stmt-field">
                                <label>Statement From</label>
                                <MudDatePicker @bind-Date="statementFromDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                               DateFormat="@AppSettings.DateFormat" Editable="true" />
                            </div>
                            <div class="stmt-field">
                                <label>Statement To</label>
                                <MudDatePicker @bind-Date="statementToDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                               DateFormat="@AppSettings.DateFormat" Editable="true" />
                            </div>
                            <MudButton Class="btn-drawer-warning" Style="align-self:flex-end;"
                                       OnClick="() => GenerateStatement(selectedCustomer.CardCode ?? string.Empty)"
                                       Disabled="@isGeneratingStatement">
                                @if (isGeneratingStatement)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                    <span>Generating...</span>
                                }
                                else
                                {
                                    <i class="bi bi-file-pdf"></i>
                                    <span>Generate Statement</span>
                                }
                            </MudButton>
                        </div>

                        <!-- General Information -->
                        <div class="detail-section-title"><i class="bi bi-info-circle"></i> General Information</div>
                        <div class="detail-grid">
                            <div class="detail-item">
                                <div class="detail-label">Code</div>
                                <div class="detail-value" style="font-family:'Space Grotesk',monospace;color:#667eea;">
                                    @selectedCustomer.CardCode</div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-label">Name</div>
                                    <div class="detail-value">@selectedCustomer.CardName</div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-label">Type</div>
                                    <div class="detail-value">
                                        <span
                                        class="type-badge @GetTypeClass(selectedCustomer.CardType)">@GetTypeLabel(selectedCustomer.CardType)</span>
                                    </div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-label">Group Code</div>
                                    <div class="detail-value">@(selectedCustomer.GroupCode ?? "—")</div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-label">Status</div>
                                    <div class="detail-value">
                                        @if (selectedCustomer.IsActive)
                                        {
                                            <span class="status-badge active"><i class="bi bi-check-circle-fill"></i> Active</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge inactive">Inactive</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Contact Information -->
                            <div class="detail-section-title"><i class="bi bi-telephone"></i> Contact Information</div>
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <div class="detail-label">Email</div>
                                    <div class="detail-value">
                                        @if (!string.IsNullOrEmpty(selectedCustomer.Email))
                                        {
                                            <a href="mailto:@selectedCustomer.Email"
                                               style="color:#667eea;text-decoration:none;">@selectedCustomer.Email</a>
                                        }
                                        else
                                        {

                                            <span style="color:#d1d5db;">—</span>
                                        }
                                    </div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-label">Phone 1</div>
                                    <div class="detail-value">@(selectedCustomer.Phone1 ?? "—")</div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-label">Phone 2</div>
                                    <div class="detail-value">@(selectedCustomer.Phone2 ?? "—")</div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-label">Address</div>
                                    <div class="detail-value">@(selectedCustomer.Address ?? "—")</div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-label">City / Country</div>
                                    <div class="detail-value">@selectedCustomer.City @selectedCustomer.Country</div>
                                </div>
                            </div>

                            <!-- Financial Information -->
                            <div class="detail-section-title"><i class="bi bi-cash-coin"></i> Financial Information</div>
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <div class="detail-label">Currency</div>
                                    <div class="detail-value">@(selectedCustomer.Currency ?? "USD")</div>
                                </div>
                                <div class="detail-item">
                                    <div class="detail-label">Balance</div>
                                    <div class="detail-value">
                                        <span class="@(selectedCustomer.Balance > 0 ? "balance-positive" : "balance-zero")"
                                              style="font-size:1.1rem;">
                                            @((selectedCustomer.Balance ?? 0).ToString("N2"))
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="drawer-footer">
                            <MudButton Class="btn-drawer-primary" OnClick='() => NavigateToInvoices(selectedCustomer.CardCode ?? "")'>
                                <i class="bi bi-receipt"></i> View Invoices
                            </MudButton>
                            <MudButton Class="btn-drawer-secondary" OnClick="() => selectedCustomer = null">Close</MudButton>
                        </div>
                    </div>
                }

@code {
    private MudTable<BusinessPartnerDto> _table = null!;
    private int _pageSize = 10;
    private List<BusinessPartnerDto>? customers;
    private BusinessPartnerDto? selectedCustomer;
    private bool isLoading = true;
    private bool isGeneratingStatement = false;
    private bool isSyncing = false;
    private string? errorMessage;
    private string searchTerm = "";
    private string selectedType = "";
    private int totalCount = 0;
    private DateTime? statementFromDate = DateTime.Now.AddMonths(-3);
    private DateTime? statementToDate = DateTime.Now;
    private DateTime? lastSyncTime;
    private string _searchString = string.Empty;

    private Func<BusinessPartnerDto, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (x.CardCode?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (x.CardName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (x.Email?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (x.Phone1?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (x.City?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (x.Country?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        return false;
    };

    private void OnCustomerRowClicked(TableRowClickEventArgs<BusinessPartnerDto> args)
    {
        if (args.Item is not null)
            ViewCustomer(args.Item);
    }

    private void PageChanged(int i)
    {
        _table.NavigateTo(i - 1);
    }

    protected override async Task OnInitializedAsync()
    {
        _pageSize = AppSettings.PageSize;
        await LoadCustomers();
        lastSyncTime = await BusinessPartnerService.GetLastSyncTimeAsync();
        await AuditService.LogAsync(AuditActions.ViewCustomers, "Customer", null);
    }

    private async Task LoadCustomers()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            BusinessPartnerListResponse? response;

            if (!string.IsNullOrEmpty(searchTerm))
            {
                response = await BusinessPartnerService.SearchCachedBusinessPartnersAsync(searchTerm);
            }
            else
            {
                response = await BusinessPartnerService.GetCachedBusinessPartnersAsync();
            }

            if (response != null)
            {
                var filteredPartners = response.BusinessPartners;

                if (!string.IsNullOrEmpty(selectedType))
                {
                    filteredPartners = filteredPartners?.Where(p => p.CardType == selectedType).ToList();
                }

                customers = filteredPartners;
                totalCount = customers?.Count ?? 0;
            }
            else
            {
                errorMessage = "No cached data found. Click Refresh to sync from server.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshFromApi()
    {
        isSyncing = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var count = await BusinessPartnerService.SyncBusinessPartnersAsync();
            lastSyncTime = DateTime.UtcNow;
            await LoadCustomers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Sync failed: {ex.Message}";
        }
        finally
        {
            isSyncing = false;
        }
    }

    private async Task FilterByType(string type)
    {
        selectedType = type;
        await LoadCustomers();
    }

    private async Task SearchCustomers()
    {
        await LoadCustomers();
    }

    private async Task ClearSearch()
    {
        searchTerm = "";
        await LoadCustomers();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchCustomers();
        }
    }

    private void ViewCustomer(BusinessPartnerDto customer)
    {
        selectedCustomer = customer;
    }

    private void NavigateToInvoices(string cardCode)
    {
        selectedCustomer = null;
        NavigationManager.NavigateTo($"/invoices?customer={cardCode}");
    }

    private string GetTypeBadgeClass(string? type) => type switch
    {
        "C" or "cCustomer" => "bg-primary",
        "S" or "cSupplier" => "bg-success",
        "L" or "cLead" => "bg-info",
        _ => "bg-secondary"
    };

    private string GetTypeClass(string? type) => type switch
    {
        "C" or "cCustomer" => "customer",
        "S" or "cSupplier" => "supplier",
        "L" or "cLead" => "lead",
        _ => ""
    };

    private string GetTypeLabel(string? type) => type switch
    {
        "C" or "cCustomer" => "Customer",
        "S" or "cSupplier" => "Supplier",
        "L" or "cLead" => "Lead",
        _ => "Unknown"
    };

    private async Task GenerateStatement(string cardCode)
    {
        isGeneratingStatement = true;
        try
        {
            var fromDate = (statementFromDate ?? DateTime.Now.AddMonths(-3)).ToString("yyyy-MM-dd");
            var toDate = (statementToDate ?? DateTime.Now).ToString("yyyy-MM-dd");
            var response = await Http.GetAsync($"api/statement/generate/{cardCode}?fromDate={fromDate}&toDate={toDate}");
            if (response.IsSuccessStatusCode)
            {
                var fileBytes = await response.Content.ReadAsByteArrayAsync();
                var fileName = $"Statement_{cardCode}_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";

                var base64 = Convert.ToBase64String(fileBytes);
                await JS.InvokeVoidAsync("downloadFile", fileName, base64);
                await AuditService.LogAsync(AuditActions.GenerateStatement, "Customer", cardCode);
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to generate statement: {response.StatusCode} - {errorContent}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error generating statement: {ex.Message}";
        }
        finally
        {
            isGeneratingStatement = false;
        }
    }
}