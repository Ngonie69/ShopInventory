@page "/merchandiser-account"
@using MediatR
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using ShopInventory.Web.Features.UserManagement.Commands.CreateMerchandiserAccount
@using ShopInventory.Web.Models
@attribute [Authorize(Roles = "Admin,SalesRep")]
@inject IMediator Mediator
@inject IMasterDataCacheService MasterDataCache
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Create Merchandiser Account - Shop Inventory</PageTitle>

<div class="macc-page">
    <div class="macc-shell">
        <div class="macc-header">
            <div>
                <h1>Create Merchandiser Account</h1>
                <p>Sales reps can only create merchandiser accounts with assigned customer access.</p>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="macc-state-card">
                <div class="macc-spinner"></div>
                <span>Loading customers and warehouses...</span>
            </div>
        }
        else
        {
            <EditForm EditContext="@editContext" OnValidSubmit="CreateAccountAsync">
                <DataAnnotationsValidator />

                <div class="macc-grid">
                    <section class="macc-card">
                        <div class="macc-card-header">
                            <h2>Account Details</h2>
                            <span>Role is fixed to Merchandiser</span>
                        </div>

                        <div class="macc-field-grid">
                            <div class="macc-field">
                                <label for="username">Username</label>
                                <InputText id="username" class="macc-input" @bind-Value="form.Username" />
                                <ValidationMessage For="() => form.Username" />
                            </div>

                            <div class="macc-field">
                                <label for="email">Email</label>
                                <InputText id="email" class="macc-input" @bind-Value="form.Email" />
                                <ValidationMessage For="() => form.Email" />
                            </div>

                            <div class="macc-field">
                                <label for="firstName">First Name</label>
                                <InputText id="firstName" class="macc-input" @bind-Value="form.FirstName" />
                                <ValidationMessage For="() => form.FirstName" />
                            </div>

                            <div class="macc-field">
                                <label for="lastName">Last Name</label>
                                <InputText id="lastName" class="macc-input" @bind-Value="form.LastName" />
                                <ValidationMessage For="() => form.LastName" />
                            </div>

                            <div class="macc-field">
                                <label for="password">Password</label>
                                <InputText id="password" type="password" class="macc-input" @bind-Value="form.Password" />
                                <ValidationMessage For="() => form.Password" />
                            </div>

                            <div class="macc-field">
                                <label for="confirmPassword">Confirm Password</label>
                                <InputText id="confirmPassword" type="password" class="macc-input"
                                           @bind-Value="form.ConfirmPassword" />
                                <ValidationMessage For="() => form.ConfirmPassword" />
                            </div>
                        </div>

                        <div class="macc-field">
                            <label for="warehouse">Default Warehouse</label>
                            <select id="warehouse" class="macc-input" @bind="selectedWarehouseCode">
                                <option value="">Select a warehouse</option>
                                @foreach (var warehouse in warehouses)
                                {
                                    <option value="@warehouse.WarehouseCode">@warehouse.WarehouseCode - @warehouse.WarehouseName
                                    </option>
                                }
                            </select>
                            <small>This warehouse will be attached to the merchandiser profile when selected.</small>
                        </div>
                    </section>

                    <section class="macc-card">
                        <div class="macc-card-header">
                            <h2>Assigned Customers</h2>
                            <span>@form.AssignedCustomerCodes.Count selected</span>
                        </div>

                        <div class="macc-field">
                            <label for="customerSearch">Search customers</label>
                            <input id="customerSearch" class="macc-input" @bind="customerSearchTerm" @bind:event="oninput"
                                   placeholder="Search by code or name" />
                        </div>

                        <ValidationMessage For="() => form.AssignedCustomerCodes" />

                        <div class="macc-customer-list">
                            @if (filteredCustomers.Any())
                            {
                                @foreach (var customer in filteredCustomers)
                                {
                                    var cardCode = customer.CardCode ?? string.Empty;
                                    var isSelected = form.AssignedCustomerCodes.Contains(cardCode);
                                    <label class="macc-customer-item">
                                        <input type="checkbox" checked="@isSelected"
                                               @onchange="args => ToggleCustomer(cardCode, args.Value as bool? == true)" />
                                        <span class="macc-customer-text">
                                            <strong>@cardCode</strong>
                                            <span>@customer.CardName</span>
                                        </span>
                                    </label>
                                }
                            }
                            else
                            {
                                <div class="macc-empty">No customers match the current search.</div>
                            }
                        </div>
                    </section>
                </div>

                <div class="macc-actions">
                    <button type="submit" class="macc-submit" disabled="@isSaving">
                        @(isSaving ? "Creating..." : "Create Merchandiser Account")
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>

<style>
    .macc-page {
        min-height: 100vh;
        padding: 1.5rem;
        background:
            radial-gradient(circle at top left, rgba(14, 165, 233, 0.10), transparent 28%),
            linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
    }

    .macc-shell {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .macc-header,
    .macc-card,
    .macc-state-card {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(148, 163, 184, 0.22);
        border-radius: 24px;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.10);
    }

    .macc-header {
        padding: 1.5rem 1.75rem;
    }

    .macc-header h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #0f172a;
    }

    .macc-header p {
        margin: .5rem 0 0;
        color: #475569;
    }

    .macc-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 1.25rem;
    }

    .macc-card {
        padding: 1.5rem;
    }

    .macc-card-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .macc-card-header h2 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 700;
        color: #0f172a;
    }

    .macc-card-header span,
    .macc-field small,
    .macc-empty {
        color: #64748b;
    }

    .macc-field-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .macc-field {
        display: flex;
        flex-direction: column;
        gap: .45rem;
        margin-bottom: 1rem;
    }

    .macc-field label {
        font-size: .92rem;
        font-weight: 600;
        color: #1e293b;
    }

    .macc-input {
        width: 100%;
        min-height: 44px;
        padding: .75rem .9rem;
        border-radius: 14px;
        border: 1px solid #cbd5e1;
        background: #fff;
        color: #0f172a;
    }

    .macc-input:focus {
        outline: none;
        border-color: #0ea5e9;
        box-shadow: 0 0 0 4px rgba(14, 165, 233, .14);
    }

    .macc-customer-list {
        max-height: 420px;
        overflow: auto;
        padding-right: .25rem;
        display: flex;
        flex-direction: column;
        gap: .65rem;
    }

    .macc-customer-item {
        display: flex;
        gap: .75rem;
        align-items: flex-start;
        padding: .85rem .9rem;
        border-radius: 16px;
        border: 1px solid #dbe4f0;
        background: #f8fafc;
        cursor: pointer;
    }

    .macc-customer-text {
        display: flex;
        flex-direction: column;
        gap: .2rem;
        color: #334155;
    }

    .macc-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 1rem;
    }

    .macc-submit {
        border: 0;
        border-radius: 999px;
        padding: .9rem 1.4rem;
        min-width: 240px;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(135deg, #0284c7, #0f766e);
        box-shadow: 0 16px 40px rgba(8, 47, 73, 0.22);
    }

    .macc-submit:disabled {
        opacity: .7;
        cursor: wait;
    }

    .macc-state-card {
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: .9rem;
        color: #334155;
    }

    .macc-spinner {
        width: 20px;
        height: 20px;
        border-radius: 999px;
        border: 3px solid rgba(14, 165, 233, .18);
        border-top-color: #0284c7;
        animation: macc-spin .8s linear infinite;
    }

    .validation-message {
        color: #b91c1c;
        font-size: .82rem;
    }

    :global(.dark-theme) .macc-page {
        background:
            radial-gradient(circle at top left, rgba(56, 189, 248, 0.14), transparent 28%),
            linear-gradient(180deg, #0f172a 0%, #111827 100%);
    }

    :global(.dark-theme) .macc-header,
    :global(.dark-theme) .macc-card,
    :global(.dark-theme) .macc-state-card {
        background: rgba(15, 23, 42, 0.92);
        border-color: rgba(148, 163, 184, 0.18);
        box-shadow: 0 24px 60px rgba(2, 6, 23, 0.35);
    }

    :global(.dark-theme) .macc-header h1,
    :global(.dark-theme) .macc-card-header h2,
    :global(.dark-theme) .macc-field label,
    :global(.dark-theme) .macc-customer-text {
        color: #e2e8f0;
    }

    :global(.dark-theme) .macc-header p,
    :global(.dark-theme) .macc-card-header span,
    :global(.dark-theme) .macc-field small,
    :global(.dark-theme) .macc-empty,
    :global(.dark-theme) .macc-state-card {
        color: #94a3b8;
    }

    :global(.dark-theme) .macc-input {
        background: #0f172a;
        border-color: #334155;
        color: #e2e8f0;
    }

    :global(.dark-theme) .macc-customer-item {
        background: rgba(15, 23, 42, 0.7);
        border-color: #334155;
    }

    @@media (max-width: 900px) {

        .macc-grid,
        .macc-field-grid {
            grid-template-columns: 1fr;
        }

        .macc-page {
            padding: 1rem;
        }
    }

    @@keyframes macc-spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

@code {
    private readonly CreateMerchandiserAccountFormModel form = new();
    private EditContext editContext = null!;
    private List<BusinessPartnerDto> customers = new();
    private List<WarehouseDto> warehouses = new();
    private string customerSearchTerm = string.Empty;
    private string selectedWarehouseCode = string.Empty;
    private bool isLoading = true;
    private bool isSaving;

    private IEnumerable<BusinessPartnerDto> filteredCustomers =>
        string.IsNullOrWhiteSpace(customerSearchTerm)
            ? customers.OrderBy(customer => customer.CardCode).Take(150)
            : customers.Where(customer =>
                    (customer.CardCode?.Contains(customerSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (customer.CardName?.Contains(customerSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
                .OrderBy(customer => customer.CardCode)
                .Take(150);

    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(form);

        try
        {
            var warehousesTask = MasterDataCache.GetWarehousesAsync();
            var customersTask = MasterDataCache.GetBusinessPartnersAsync();
            await Task.WhenAll(warehousesTask, customersTask);

            warehouses = await warehousesTask;
            customers = await customersTask;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load merchandiser setup data: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateAccountAsync()
    {
        isSaving = true;
        try
        {
            form.AssignedWarehouseCodes = string.IsNullOrWhiteSpace(selectedWarehouseCode)
                ? new List<string>()
                : new List<string> { selectedWarehouseCode };

            var result = await Mediator.Send(new CreateMerchandiserAccountCommand(form));
            if (result.IsError)
            {
                Snackbar.Add(result.FirstError.Description, Severity.Error);
                return;
            }

            Snackbar.Add($"Merchandiser account {result.Value} created successfully.", Severity.Success);

            form.Username = string.Empty;
            form.Email = string.Empty;
            form.Password = string.Empty;
            form.ConfirmPassword = string.Empty;
            form.FirstName = string.Empty;
            form.LastName = string.Empty;
            form.AssignedCustomerCodes.Clear();
            form.AssignedWarehouseCodes.Clear();
            selectedWarehouseCode = string.Empty;
            customerSearchTerm = string.Empty;
            editContext = new EditContext(form);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ToggleCustomer(string cardCode, bool isSelected)
    {
        if (isSelected)
        {
            if (!form.AssignedCustomerCodes.Contains(cardCode, StringComparer.OrdinalIgnoreCase))
            {
                form.AssignedCustomerCodes.Add(cardCode);
            }
        }
        else
        {
            form.AssignedCustomerCodes.RemoveAll(code => string.Equals(code, cardCode, StringComparison.OrdinalIgnoreCase));
        }

        editContext.NotifyFieldChanged(new FieldIdentifier(form, nameof(form.AssignedCustomerCodes)));
    }
}