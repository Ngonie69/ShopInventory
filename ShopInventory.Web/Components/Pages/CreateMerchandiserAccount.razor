@page "/merchandiser-account"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@attribute [Authorize(Roles = "Admin,SalesRep")]
@rendermode InteractiveServer

<PageTitle>Manage Merchandiser Accounts - Shop Inventory</PageTitle>

<div class="macc-page">
    <div class="macc-shell">
        <div class="macc-header">
            <div>
                <h1>Manage Merchandiser Accounts</h1>
                <p>Create merchandiser accounts, review existing profiles, and update assigned business partners.</p>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="macc-state-card">
                <div class="macc-spinner"></div>
                <span>Loading merchandiser accounts, customers, and warehouses...</span>
            </div>
        }
        else
        {
            <EditForm EditContext="@createEditContext" OnValidSubmit="CreateAccountAsync">
                <DataAnnotationsValidator />

                <div class="macc-grid">
                    <section class="macc-card">
                        <div class="macc-card-header">
                            <h2>Create Account</h2>
                            <span>Role is fixed to Merchandiser</span>
                        </div>

                        <div class="macc-field-grid">
                            <div class="macc-field">
                                <label for="username">Username</label>
                                <InputText id="username" class="macc-input" @bind-Value="createForm.Username" />
                                <ValidationMessage For="() => createForm.Username" />
                            </div>

                            <div class="macc-field">
                                <label for="email">Email</label>
                                <InputText id="email" class="macc-input" @bind-Value="createForm.Email" />
                                <ValidationMessage For="() => createForm.Email" />
                            </div>

                            <div class="macc-field">
                                <label for="firstName">First Name</label>
                                <InputText id="firstName" class="macc-input" @bind-Value="createForm.FirstName" />
                                <ValidationMessage For="() => createForm.FirstName" />
                            </div>

                            <div class="macc-field">
                                <label for="lastName">Last Name</label>
                                <InputText id="lastName" class="macc-input" @bind-Value="createForm.LastName" />
                                <ValidationMessage For="() => createForm.LastName" />
                            </div>

                            <div class="macc-field">
                                <label for="password">Password</label>
                                <InputText id="password" type="password" class="macc-input"
                                           @bind-Value="createForm.Password" />
                                <ValidationMessage For="() => createForm.Password" />
                            </div>

                            <div class="macc-field">
                                <label for="confirmPassword">Confirm Password</label>
                                <InputText id="confirmPassword" type="password" class="macc-input"
                                           @bind-Value="createForm.ConfirmPassword" />
                                <ValidationMessage For="() => createForm.ConfirmPassword" />
                            </div>
                        </div>

                        <div class="macc-field">
                            <label for="warehouse">Default Warehouse</label>
                            <select id="warehouse" class="macc-input" @bind="selectedWarehouseCode">
                                <option value="">Select a warehouse</option>
                                @foreach (var warehouse in warehouses)
                                {
                                    <option value="@warehouse.WarehouseCode">@warehouse.WarehouseCode - @warehouse.WarehouseName
                                    </option>
                                }
                            </select>
                            <small>This warehouse will be attached to the merchandiser profile when selected.</small>
                        </div>
                    </section>

                    <section class="macc-card">
                        <div class="macc-card-header">
                            <h2>Assigned Business Partners</h2>
                            <span>@createForm.AssignedCustomerCodes.Count selected</span>
                        </div>

                        <div class="macc-field">
                            <label for="customerSearch">Search customers</label>
                            <input id="customerSearch" class="macc-input" @bind="createCustomerSearchTerm"
                                   @bind:event="oninput" placeholder="Search by code or name" />
                        </div>

                        <ValidationMessage For="() => createForm.AssignedCustomerCodes" />

                        <div class="macc-customer-list">
                            @if (filteredCreateCustomers.Any())
                            {
                                @foreach (var customer in filteredCreateCustomers)
                                {
                                    var cardCode = customer.CardCode ?? string.Empty;
                                    var isSelected = createForm.AssignedCustomerCodes.Contains(cardCode,
                        StringComparer.OrdinalIgnoreCase);
                                    <label class="macc-customer-item">
                                        <input type="checkbox" checked="@isSelected"
                                               @onchange="args => ToggleCreateCustomer(cardCode, args.Value as bool? == true)" />
                                        <span class="macc-customer-text">
                                            <strong>@cardCode</strong>
                                            <span>@(customer.IsActive ? customer.CardName : $"{customer.CardName} (Inactive)")</span>
                                        </span>
                                    </label>
                                }
                            }
                            else
                            {
                                <div class="macc-empty">No customers match the current search.</div>
                            }
                        </div>
                    </section>
                </div>

                <div class="macc-actions macc-create-actions">
                    <button type="submit" class="macc-submit" disabled="@isCreating">
                        @(isCreating ? "Creating..." : "Create Merchandiser Account")
                    </button>
                </div>
            </EditForm>

            <section class="macc-card macc-account-section">
                <div class="macc-card-header">
                    <h2>Existing Merchandiser Accounts</h2>
                    <span>@filteredMerchandisers.Count() visible</span>
                </div>

                <div class="macc-field">
                    <label for="accountSearch">Search accounts</label>
                    <input id="accountSearch" class="macc-input" @bind="accountSearchTerm" @bind:event="oninput"
                           placeholder="Search by username, name, or email" />
                </div>

                <div class="macc-account-list">
                    @if (filteredMerchandisers.Any())
                    {
                        @foreach (var merchandiser in filteredMerchandisers)
                        {
                            var isEditing = editingMerchandiserId == merchandiser.Id;
                            var selectedCount = isEditing ? editingAssignedCustomerCodes.Count :
                merchandiser.AssignedCustomerCodes.Count;

                            <article class="macc-account-item">
                                <div class="macc-account-summary">
                                    <div class="macc-account-heading">
                                        <div>
                                            <h3>@merchandiser.Username</h3>
                                            <p>@GetMerchandiserSubtitle(merchandiser)</p>
                                        </div>
                                        <span class="macc-status @(merchandiser.IsActive ? "is-active" : "is-inactive")">
                                            @(merchandiser.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </div>

                                    <div class="macc-chip-group">
                                        <span class="macc-chip macc-chip-warehouse">
                                            @(string.IsNullOrWhiteSpace(merchandiser.AssignedWarehouseCode)
                                                ? "No warehouse"
                                                : $"Warehouse: {merchandiser.AssignedWarehouseCode}")
                                        </span>
                                        <span class="macc-chip macc-chip-count">@selectedCount BP assigned</span>
                                    </div>

                                    <div class="macc-bp-tags">
                                        @foreach (var code in GetPreviewCustomerCodes(merchandiser))
                                        {
                                            <span class="macc-bp-tag">@GetCustomerDisplayName(code)</span>
                                        }

                                        @if (merchandiser.AssignedCustomerCodes.Count > previewCustomerCodeLimit)
                                        {
                                            <span class="macc-bp-tag macc-bp-tag-muted">+@(merchandiser.AssignedCustomerCodes.Count -
                                                                                previewCustomerCodeLimit) more</span>
                                            }
                                        </div>

                                        <div class="macc-inline-actions">
                                            <button type="button" class="macc-secondary-button"
                                                    @onclick="() => BeginEditAssignedCustomers(merchandiser)">
                                                @(isEditing ? "Editing Assignments" : "Edit Assignments")
                                            </button>
                                        </div>
                                    </div>

                                    @if (isEditing)
                                    {
                                        <div class="macc-editor-shell">
                                            <div class="macc-card-header macc-editor-header">
                                                <h2>Update Merchandiser Assignments</h2>
                                                <span>@editingAssignedCustomerCodes.Count BP selected</span>
                                            </div>

                                            <div class="macc-field">
                                                <label for="editWarehouse">Assigned warehouse</label>
                                                <select id="editWarehouse" class="macc-input" @bind="editingWarehouseCode">
                                                    <option value="">No warehouse assigned</option>
                                                    @foreach (var warehouse in warehouses)
                                                    {
                                                        <option value="@warehouse.WarehouseCode">@warehouse.WarehouseCode -
                                                            @warehouse.WarehouseName</option>
                                                        }
                                                    </select>
                                                </div>

                                                <div class="macc-editor-grid">
                                                    <section class="macc-editor-column macc-editor-selection">
                                                        <div class="macc-card-header macc-editor-subheader">
                                                            <h3>Selected business partners</h3>
                                                            <span>Remove assignments directly from here</span>
                                                        </div>

                                                        @if (editingAssignedCustomerCodes.Any())
                                                        {
                                                            <div class="macc-selected-list">
                                                                @foreach (var selectedCode in GetEditingSelectedCustomerCodes())
                                                                {
                                                                    <div class="macc-selected-item">
                                                                        <div class="macc-selected-text">
                                                                            <strong>@selectedCode</strong>
                                                                            <span>@GetCustomerDisplayName(selectedCode)</span>
                                                                        </div>
                                                                        <button type="button" class="macc-selected-remove"
                                                                                @onclick="() => ToggleEditCustomer(selectedCode, false)">
                                                                            Remove
                                                                        </button>
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="macc-empty macc-selected-empty">No business partners selected yet.</div>
                                                        }
                                                    </section>

                                                    <section class="macc-editor-column">
                                                        <div class="macc-field">
                                                            <label for="editCustomerSearch">Search business partners</label>
                                                            <input id="editCustomerSearch" class="macc-input" @bind="editCustomerSearchTerm"
                                                                   @bind:event="oninput" placeholder="Search by code or name" />
                                                            <small>Selected business partners stay visible on the left while you search and add more here.</small>
                                                        </div>

                                                        <div class="macc-customer-list macc-editor-list">
                                                            @if (filteredEditCustomers.Any())
                                                            {
                                                                @foreach (var customer in filteredEditCustomers)
                                                                {
                                                                    var cardCode = customer.CardCode ?? string.Empty;
                                                                    var isSelected = editingAssignedCustomerCodes.Contains(cardCode);
                                                                    <label class="macc-customer-item">
                                                                        <input type="checkbox" checked="@isSelected"
                                                                               @onchange="args => ToggleEditCustomer(cardCode, args.Value as bool? == true)" />
                                                                        <span class="macc-customer-text">
                                                                            <strong>@cardCode</strong>
                                                                            <span>@(customer.IsActive ? customer.CardName : $"{customer.CardName} (Inactive)")</span>
                                                                        </span>
                                                                    </label>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <div class="macc-empty">No business partners match the current search.</div>
                                                            }
                                                        </div>
                                                    </section>
                                                </div>

                                                <div class="macc-actions macc-inline-actions">
                                                    <button type="button" class="macc-submit" disabled="@isUpdating"
                                                            @onclick="() => SaveAssignedCustomersAsync(merchandiser)">
                                                        @(isUpdating ? "Saving..." : "Save Assignments")
                                                    </button>
                                                    <button type="button" class="macc-secondary-button" disabled="@isUpdating"
                                                            @onclick="CancelEditAssignedCustomers">
                                                        Cancel
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </article>
                                }
                            }
                    else
                            {
                                <div class="macc-empty-state">
                                    <h3>No merchandiser accounts found</h3>
                                    <p>Try a different search or create the first merchandiser account above.</p>
                                </div>
                            }
                        </div>
                    </section>
                }
            </div>
        </div>

        <style>
            .macc-page {
                min-height: 100vh;
                padding: 1.5rem;
                background:
                    radial-gradient(circle at top left, rgba(14, 165, 233, 0.10), transparent 28%),
                    linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
            }

            .macc-shell {
                max-width: 1280px;
                margin: 0 auto;
                display: flex;
                flex-direction: column;
                gap: 1.25rem;
            }

            .macc-header,
            .macc-card,
            .macc-state-card {
                background: rgba(255, 255, 255, 0.92);
                border: 1px solid rgba(148, 163, 184, 0.22);
                border-radius: 24px;
                box-shadow: 0 24px 60px rgba(15, 23, 42, 0.10);
            }

            .macc-header {
                padding: 1.5rem 1.75rem;
            }

            .macc-header h1 {
                margin: 0;
                font-size: 2rem;
                font-weight: 700;
                color: #0f172a;
            }

            .macc-header p {
                margin: .5rem 0 0;
                color: #475569;
            }

            .macc-grid {
                display: grid;
                grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
                gap: 1.25rem;
            }

            .macc-card {
                padding: 1.5rem;
            }

            .macc-account-section {
                display: flex;
                flex-direction: column;
                gap: 1rem;
            }

            .macc-card-header {
                display: flex;
                align-items: baseline;
                justify-content: space-between;
                gap: 1rem;
                margin-bottom: 1rem;
            }

            .macc-card-header h2,
            .macc-account-heading h3,
            .macc-empty-state h3 {
                margin: 0;
                color: #0f172a;
            }

            .macc-card-header h2 {
                font-size: 1.1rem;
                font-weight: 700;
            }

            .macc-card-header span,
            .macc-field small,
            .macc-empty,
            .macc-account-heading p,
            .macc-empty-state p {
                color: #64748b;
            }

            .macc-field-grid {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 1rem;
            }

            .macc-field {
                display: flex;
                flex-direction: column;
                gap: .45rem;
                margin-bottom: 1rem;
            }

            .macc-field label {
                font-size: .92rem;
                font-weight: 600;
                color: #1e293b;
            }

            .macc-input {
                width: 100%;
                min-height: 44px;
                padding: .75rem .9rem;
                border-radius: 14px;
                border: 1px solid #cbd5e1;
                background: #fff;
                color: #0f172a;
            }

            .macc-input:focus {
                outline: none;
                border-color: #0ea5e9;
                box-shadow: 0 0 0 4px rgba(14, 165, 233, .14);
            }

            .macc-customer-list,
            .macc-account-list {
                display: flex;
                flex-direction: column;
                gap: .75rem;
            }

            .macc-customer-list {
                max-height: 420px;
                overflow: auto;
                padding-right: .25rem;
            }

            .macc-account-item,
            .macc-editor-shell {
                border-radius: 18px;
                border: 1px solid #dbe4f0;
                background: #f8fafc;
            }

            .macc-account-item {
                overflow: hidden;
            }

            .macc-account-summary,
            .macc-editor-shell {
                padding: 1rem 1.1rem;
            }

            .macc-account-heading {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 1rem;
            }

            .macc-account-heading h3 {
                font-size: 1rem;
                font-weight: 700;
            }

            .macc-account-heading p {
                margin: .3rem 0 0;
            }

            .macc-status {
                display: inline-flex;
                align-items: center;
                border-radius: 999px;
                padding: .3rem .7rem;
                font-size: .75rem;
                font-weight: 700;
            }

            .macc-status.is-active {
                background: rgba(16, 185, 129, 0.15);
                color: #047857;
            }

            .macc-status.is-inactive {
                background: rgba(248, 113, 113, 0.16);
                color: #b91c1c;
            }

            .macc-chip-group,
            .macc-bp-tags,
            .macc-inline-actions {
                display: flex;
                flex-wrap: wrap;
                gap: .6rem;
            }

            .macc-chip-group,
            .macc-bp-tags {
                margin-top: .9rem;
            }

            .macc-chip,
            .macc-bp-tag {
                display: inline-flex;
                align-items: center;
                border-radius: 999px;
                padding: .35rem .75rem;
                font-size: .78rem;
                font-weight: 600;
            }

            .macc-chip-warehouse {
                background: rgba(14, 165, 233, 0.12);
                color: #0369a1;
            }

            .macc-chip-count,
            .macc-bp-tag {
                background: rgba(148, 163, 184, 0.14);
                color: #334155;
            }

            .macc-bp-tag-muted {
                background: rgba(15, 23, 42, 0.08);
                color: #475569;
            }

            .macc-customer-item {
                display: flex;
                gap: .75rem;
                align-items: flex-start;
                padding: .85rem .9rem;
                border-radius: 16px;
                border: 1px solid #dbe4f0;
                background: #f8fafc;
                cursor: pointer;
            }

            .macc-customer-text {
                display: flex;
                flex-direction: column;
                gap: .2rem;
                color: #334155;
            }

            .macc-actions {
                display: flex;
                justify-content: flex-end;
                gap: .75rem;
                margin-top: 1rem;
            }

            .macc-create-actions {
                margin-top: 1.1rem;
            }

            .macc-inline-actions {
                margin-top: 1rem;
            }

            .macc-submit,
            .macc-secondary-button {
                border: 0;
                border-radius: 999px;
                padding: .9rem 1.4rem;
                min-width: 200px;
                font-weight: 700;
            }

            .macc-submit {
                color: #fff;
                background: linear-gradient(135deg, #0284c7, #0f766e);
                box-shadow: 0 16px 40px rgba(8, 47, 73, 0.22);
            }

            .macc-secondary-button {
                color: #0f172a;
                background: rgba(148, 163, 184, 0.18);
            }

            .macc-submit:disabled,
            .macc-secondary-button:disabled {
                opacity: .7;
                cursor: wait;
            }

            .macc-state-card,
            .macc-empty-state {
                padding: 1.5rem;
                display: flex;
                align-items: center;
                gap: .9rem;
                color: #334155;
            }

            .macc-empty-state {
                flex-direction: column;
                align-items: flex-start;
                border: 1px dashed #cbd5e1;
                border-radius: 18px;
                background: #f8fafc;
            }

            .macc-editor-shell {
                margin: 0 1rem 1rem;
                border-style: dashed;
                background: rgba(255, 255, 255, 0.72);
            }

            .macc-editor-header {
                margin-bottom: .75rem;
            }

            .macc-editor-list {
                max-height: 320px;
            }

            .macc-editor-grid {
                display: grid;
                grid-template-columns: minmax(260px, 320px) minmax(0, 1fr);
                gap: 1rem;
                align-items: start;
            }

            .macc-editor-column {
                min-width: 0;
            }

            .macc-editor-selection {
                padding: 1rem;
                border-radius: 18px;
                border: 1px solid #dbe4f0;
                background: rgba(248, 250, 252, 0.9);
            }

            .macc-editor-subheader {
                margin-bottom: .75rem;
            }

            .macc-editor-subheader h3 {
                margin: 0;
                color: #0f172a;
                font-size: 1rem;
                font-weight: 700;
            }

            .macc-selected-list {
                display: flex;
                flex-direction: column;
                gap: .75rem;
                max-height: 320px;
                overflow: auto;
                padding-right: .25rem;
            }

            .macc-selected-item {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: .75rem;
                padding: .8rem .85rem;
                border-radius: 16px;
                border: 1px solid #dbe4f0;
                background: #fff;
            }

            .macc-selected-text {
                display: flex;
                flex-direction: column;
                gap: .2rem;
                min-width: 0;
                color: #334155;
            }

            .macc-selected-text strong,
            .macc-selected-text span {
                overflow-wrap: anywhere;
            }

            .macc-selected-remove {
                flex-shrink: 0;
                border: 0;
                border-radius: 999px;
                padding: .45rem .8rem;
                font-size: .78rem;
                font-weight: 700;
                color: #b91c1c;
                background: rgba(248, 113, 113, 0.12);
            }

            .macc-selected-empty {
                padding: .85rem .2rem 0;
            }

            .macc-spinner {
                width: 20px;
                height: 20px;
                border-radius: 999px;
                border: 3px solid rgba(14, 165, 233, .18);
                border-top-color: #0284c7;
                animation: macc-spin .8s linear infinite;
            }

            .validation-message {
                color: #b91c1c;
                font-size: .82rem;
            }

            .dark-theme .macc-page {
                background:
                    radial-gradient(circle at top left, rgba(56, 189, 248, 0.14), transparent 28%),
                    linear-gradient(180deg, #0f172a 0%, #111827 100%);
            }

            .dark-theme .macc-header,
            .dark-theme .macc-card,
            .dark-theme .macc-state-card {
                background: rgba(15, 23, 42, 0.92);
                border-color: rgba(148, 163, 184, 0.18);
                box-shadow: 0 24px 60px rgba(2, 6, 23, 0.35);
            }

            .dark-theme .macc-account-item,
            .dark-theme .macc-customer-item,
            .dark-theme .macc-editor-shell,
            .dark-theme .macc-empty-state {
                background: rgba(15, 23, 42, 0.7);
                border-color: #334155;
            }

            .dark-theme .macc-editor-selection,
            .dark-theme .macc-selected-item {
                background: rgba(15, 23, 42, 0.82);
                border-color: #334155;
            }

            .dark-theme .macc-header h1,
            .dark-theme .macc-card-header h2,
            .dark-theme .macc-editor-subheader h3,
            .dark-theme .macc-account-heading h3,
            .dark-theme .macc-field label,
            .dark-theme .macc-customer-text,
            .dark-theme .macc-selected-text,
            .dark-theme .macc-empty-state h3,
            .dark-theme .macc-secondary-button {
                color: #e2e8f0;
            }

            .dark-theme .macc-header p,
            .dark-theme .macc-card-header span,
            .dark-theme .macc-field small,
            .dark-theme .macc-empty,
            .dark-theme .macc-state-card,
            .dark-theme .macc-account-heading p,
            .dark-theme .macc-empty-state p {
                color: #94a3b8;
            }

            .dark-theme .macc-input {
                background: #0f172a;
                border-color: #334155;
                color: #e2e8f0;
            }

            .dark-theme .macc-chip-warehouse {
                background: rgba(14, 165, 233, 0.18);
                color: #7dd3fc;
            }

            .dark-theme .macc-chip-count,
            .dark-theme .macc-bp-tag,
            .dark-theme .macc-bp-tag-muted,
            .dark-theme .macc-secondary-button {
                background: rgba(148, 163, 184, 0.16);
                color: #cbd5e1;
            }

            .dark-theme .macc-status.is-active {
                background: rgba(16, 185, 129, 0.18);
                color: #6ee7b7;
            }

            .dark-theme .macc-status.is-inactive {
                background: rgba(248, 113, 113, 0.18);
                color: #fca5a5;
            }

            .dark-theme .macc-selected-remove {
                color: #fca5a5;
                background: rgba(248, 113, 113, 0.18);
            }

            @@media (max-width: 900px) {

                .macc-grid,
                .macc-field-grid,
                .macc-editor-grid {
                    grid-template-columns: 1fr;
                }

