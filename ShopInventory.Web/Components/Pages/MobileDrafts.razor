                {
                    <img src="@purchaseOrderViewerDataUri" alt="@purchaseOrderViewerFileName" class="md-po-viewer-image" />
                }
                else if (purchaseOrderViewerMimeType == "application/pdf")
                {
                    <iframe src="@purchaseOrderViewerDataUri" class="md-po-viewer-pdf" title="@purchaseOrderViewerFileName"></iframe>
                }
            </div>
        </div>
    </div>
}

@code {
    private MudTable<SalesOrderDto> _table = null!;
    private int _pageSize = 10;
    private List<SalesOrderDto>? orders;
    private SalesOrderDto? selectedOrder;
    private readonly List<DocumentAttachmentDto> purchaseOrderAttachments = new();
    private bool isLoading = true;
    private bool isLoadingPurchaseOrderAttachments;
    private string? errorMessage;
    private string? purchaseOrderAttachmentError;
    private bool showPurchaseOrderViewer;
    private bool isLoadingPurchaseOrderViewer;
    private string? purchaseOrderViewerDataUri;
    private string? purchaseOrderViewerFileName;
    private string? purchaseOrderViewerMimeType;
    private DocumentAttachmentDto? purchaseOrderViewerAttachment;
    private readonly Dictionary<int, OrderActionType> orderActionStates = new();

    // Filters
    private string? customerFilter;
    private string? statusFilter;
    private DateTime? fromDate;
    private DateTime? toDate;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10000;
    private int totalPages = 1;
    private int totalCount = 0;

    private enum OrderActionType
    {
        View,
        Approve,
        PostToSap,
        ConvertToInvoice,
        Delete
    }

    protected override async Task OnInitializedAsync()
    {
        _pageSize = AppSettings.PageSize;
        await LoadOrders();
    }

    private void PageChanged(int i)
    {
        _table?.NavigateTo(i - 1);
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            SalesOrderStatus? status = null;
            if (!string.IsNullOrEmpty(statusFilter) && int.TryParse(statusFilter, out var statusInt))
            {
                status = (SalesOrderStatus)statusInt;
            }

            var response = await SalesOrderService.GetSalesOrdersAsync(currentPage, pageSize, status, customerFilter, fromDate, toDate, SalesOrderSource.Mobile);
            if (response != null)
            {
                orders = response.Orders;
                totalCount = response.TotalCount;
                totalPages = response.TotalPages;

                await PopulateMissingOrderPricesAsync(orders);
                await RefreshSelectedOrderAsync();
            }
            else
            {
                errorMessage = "Failed to load mobile draft orders.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilter() => await LoadOrders();

    private async Task ClearFilter()
    {
        customerFilter = null;
        statusFilter = null;
        fromDate = null;
        toDate = null;
        currentPage = 1;
        await LoadOrders();
    }

    private async Task ViewOrder(SalesOrderDto order)
    {
        if (!TryBeginOrderAction(order.Id, OrderActionType.View))
            return;

        await ClosePurchaseOrderViewer();
        selectedOrder = order;
        StateHasChanged();

        try
        {
            var detailOrder = await SalesOrderService.GetSalesOrderByIdAsync(order.Id) ?? order;
            if (!ReferenceEquals(detailOrder, order))
            {
                selectedOrder = detailOrder;
                StateHasChanged();
            }

            await LoadPurchaseOrderAttachmentsAsync(detailOrder);

            // If order lines have no prices (mobile drafts), fetch from SAP using the BP's price list
            if (OrderHasMissingPrices(detailOrder))
            {
                await PopulateOrderPricesAsync(detailOrder);
            }

            StateHasChanged();
        }
        finally
        {
            EndOrderAction(order.Id);
            StateHasChanged();
        }
    }

    private async Task ClearSelectedOrder()
    {
        await ClosePurchaseOrderViewer();
        selectedOrder = null;
        purchaseOrderAttachments.Clear();
        purchaseOrderAttachmentError = null;
        isLoadingPurchaseOrderAttachments = false;
    }

    private async Task LoadPurchaseOrderAttachmentsAsync(SalesOrderDto order)
    {
        purchaseOrderAttachments.Clear();
        purchaseOrderAttachmentError = null;

        var poReferenceNumber = GetPurchaseOrderReference(order);

        if (string.IsNullOrWhiteSpace(poReferenceNumber))
            return;

        isLoadingPurchaseOrderAttachments = true;

        try
        {
            var response = await PurchaseOrderService.GetDocumentsAsync(poReferenceNumber);
            if (response?.Attachments != null)
            {
                purchaseOrderAttachments.AddRange(response.Attachments);
            }
            else
            {
                purchaseOrderAttachmentError = "Failed to load uploaded purchase order files.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load physical purchase order attachments for mobile order {OrderId} and reference {PoReference}", order.Id, poReferenceNumber);
            purchaseOrderAttachmentError = "Failed to load uploaded purchase order files.";
        }
        finally
        {
            isLoadingPurchaseOrderAttachments = false;
        }
    }

    private static string? GetPurchaseOrderReference(SalesOrderDto order)
    {
        return !string.IsNullOrWhiteSpace(order.CustomerRefNo)
            ? order.CustomerRefNo
            : order.OrderNumber;
    }

    private static bool IsViewablePurchaseOrderAttachment(DocumentAttachmentDto attachment)
    {
        var mimeType = GetPurchaseOrderViewerMimeType(attachment);
        return mimeType != null && (mimeType.StartsWith("image/") || mimeType == "application/pdf");
    }

    private static string? GetPurchaseOrderViewerMimeType(DocumentAttachmentDto attachment)
    {
        if (!string.IsNullOrWhiteSpace(attachment.MimeType))
            return attachment.MimeType;

        return Path.GetExtension(attachment.FileName).ToLowerInvariant() switch
        {
            ".jpg" or ".jpeg" => "image/jpeg",
            ".png" => "image/png",
            ".webp" => "image/webp",
            ".gif" => "image/gif",
            ".bmp" => "image/bmp",
            ".pdf" => "application/pdf",
            _ => null
        };
    }

    private async Task ViewPurchaseOrderAttachment(DocumentAttachmentDto attachment)
    {
        var mimeType = GetPurchaseOrderViewerMimeType(attachment);

        if (mimeType == null)
            return;

        try
        {
            await RevokePurchaseOrderViewerDataUriAsync();

            purchaseOrderViewerAttachment = attachment;
            purchaseOrderViewerFileName = attachment.FileName;
            purchaseOrderViewerMimeType = mimeType;
            purchaseOrderViewerDataUri = null;
            showPurchaseOrderViewer = true;
            isLoadingPurchaseOrderViewer = true;
            StateHasChanged();

            purchaseOrderViewerDataUri = await JS.InvokeAsync<string>(
                "createAuthenticatedObjectUrl",
                $"/download/purchase-order/{attachment.Id}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to view physical purchase order attachment {AttachmentId}", attachment.Id);
            Snackbar.Add("Failed to load the purchase order attachment.", Severity.Error);
            showPurchaseOrderViewer = false;
        }
        finally
        {
            isLoadingPurchaseOrderViewer = false;
            StateHasChanged();
        }
    }

    private async Task DownloadPurchaseOrderAttachment(DocumentAttachmentDto attachment)
    {
        try
        {
            await JS.InvokeVoidAsync("downloadAuthenticatedFile", $"/download/purchase-order/{attachment.Id}", attachment.FileName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to download physical purchase order attachment {AttachmentId}", attachment.Id);
            Snackbar.Add("Failed to download the purchase order attachment.", Severity.Error);
        }
    }

    private async Task ClosePurchaseOrderViewer()
    {
        showPurchaseOrderViewer = false;
        await RevokePurchaseOrderViewerDataUriAsync();
        purchaseOrderViewerFileName = null;
        purchaseOrderViewerMimeType = null;
        purchaseOrderViewerAttachment = null;
    }

    private async Task RevokePurchaseOrderViewerDataUriAsync()
    {
        if (!string.IsNullOrWhiteSpace(purchaseOrderViewerDataUri))
        {
            await JS.InvokeVoidAsync("revokeObjectUrl", purchaseOrderViewerDataUri);
            purchaseOrderViewerDataUri = null;
        }
    }

    private async Task RefreshSelectedOrderAsync()
    {
        if (selectedOrder == null)
            return;

        var refreshedOrder = orders?.FirstOrDefault(o => o.Id == selectedOrder.Id);
        if (refreshedOrder != null && (refreshedOrder.Lines?.Any() == true || selectedOrder.Lines?.Any() != true))
        {
            selectedOrder = refreshedOrder;
            return;
        }

        try
        {
            var fullOrder = await SalesOrderService.GetSalesOrderByIdAsync(selectedOrder.Id);
            if (fullOrder != null)
            {
                selectedOrder = fullOrder;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to refresh selected mobile order {OrderId}", selectedOrder.Id);
        }
    }

    private static bool OrderHasMissingPrices(SalesOrderDto order)
    {
        return order.Source == SalesOrderSource.Mobile
            && order.Lines?.Any() == true
            && order.Lines.Any(l => l.UnitPrice <= 0 || l.LineTotal <= 0);
    }

    private async Task PopulateMissingOrderPricesAsync(IEnumerable<SalesOrderDto> loadedOrders)
    {
        var missingPriceOrders = loadedOrders
            .Where(OrderHasMissingPrices)
            .ToList();

        if (missingPriceOrders.Count == 0)
            return;

        foreach (var order in missingPriceOrders)
        {
            await PopulateOrderPricesAsync(order);
        }

        StateHasChanged();
    }

    private async Task PopulateOrderPricesAsync(SalesOrderDto order)
    {
        try
        {
            var bpPrices = await PriceService.GetPricesByBusinessPartnerAsync(order.CardCode);
            if (bpPrices?.Prices == null || bpPrices.Prices.Count == 0)
                return;

            var priceMap = bpPrices.Prices
                .Where(p => p.ItemCode != null)
                .ToDictionary(p => p.ItemCode!, p => p.Price, StringComparer.OrdinalIgnoreCase);

            var pricesChanged = false;

            foreach (var line in order.Lines!)
            {
                if (priceMap.TryGetValue(line.ItemCode, out var price))
                {
                    if (line.UnitPrice != price)
                        pricesChanged = true;

                    line.UnitPrice = price;
                    var discountMultiplier = line.DiscountPercent > 0 ? (1 - line.DiscountPercent / 100m) : 1m;
                    line.LineTotal = Math.Round(line.Quantity * price * discountMultiplier, 2);
                }
            }

            order.SubTotal = order.Lines!.Sum(l => l.LineTotal);
            var taxRate = order.Lines!.FirstOrDefault()?.TaxPercent ?? 0m;
            order.TaxAmount = taxRate > 0 ? Math.Round(order.SubTotal * taxRate / 100m, 2) : 0m;
            var orderDiscountMultiplier = order.DiscountPercent > 0 ? (1 - order.DiscountPercent / 100m) : 1m;
            order.DocTotal = Math.Round((order.SubTotal + order.TaxAmount) * orderDiscountMultiplier, 2);

            if (!pricesChanged)
                return;

            var updateRequest = new CreateSalesOrderRequest
            {
                DeliveryDate = order.DeliveryDate,
                CardCode = order.CardCode,
                CardName = order.CardName,
                CustomerRefNo = order.CustomerRefNo,
                Comments = order.Comments,
                SalesPersonCode = order.SalesPersonCode,
                SalesPersonName = order.SalesPersonName,
                Currency = order.Currency,
                DiscountPercent = order.DiscountPercent,
                ShipToAddress = order.ShipToAddress,
                BillToAddress = order.BillToAddress,
                WarehouseCode = order.WarehouseCode,
                Source = order.Source,
                MerchandiserNotes = order.MerchandiserNotes,
                DeviceInfo = order.DeviceInfo,
                RowVersion = order.RowVersion,
                Lines = order.Lines.Select(line => new CreateSalesOrderLineRequest
                {
                    ItemCode = line.ItemCode,
                    ItemDescription = line.ItemDescription,
                    Quantity = line.Quantity,
                    UnitPrice = line.UnitPrice,
                    DiscountPercent = line.DiscountPercent,
                    TaxPercent = line.TaxPercent,
                    WarehouseCode = line.WarehouseCode,
                    UoMCode = line.UoMCode,
                    BatchNumber = line.BatchNumber
                }).ToList()
            };

            var updatedOrder = await SalesOrderService.UpdateSalesOrderAsync(order.Id, updateRequest);
            if (updatedOrder != null)
            {
                order.SubTotal = updatedOrder.SubTotal;
                order.TaxAmount = updatedOrder.TaxAmount;
                order.DiscountAmount = updatedOrder.DiscountAmount;
                order.DocTotal = updatedOrder.DocTotal;
                order.RowVersion = updatedOrder.RowVersion;
                order.Lines = updatedOrder.Lines;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to fetch BP prices for order {OrderId} ({CardCode})", order.Id, order.CardCode);
        }
    }

    private void NavigateToEdit(int id)
    {
        NavigationManager.NavigateTo($"/sales-orders/edit/{id}");
    }

    private bool TryBeginOrderAction(int id, OrderActionType action)
    {
        if (orderActionStates.ContainsKey(id))
            return false;

        orderActionStates[id] = action;
        return true;
    }

    private void EndOrderAction(int id)
    {
        orderActionStates.Remove(id);
    }

    private bool IsOrderActionBusy(int id) => orderActionStates.ContainsKey(id);

    private bool IsOrderActionBusy(int id, OrderActionType action)
        => orderActionStates.TryGetValue(id, out var currentAction) && currentAction == action;

    private static string FormatOrderLineCount(SalesOrderDto order)
    {
        var lineCount = order.Lines?.Count ?? 0;
        return $"{lineCount:N0} {(lineCount == 1 ? "line" : "lines")}";
    }

    private static string FormatOrderItemCount(SalesOrderDto order)
    {
        var itemCount = order.Lines?.Sum(line => line.Quantity) ?? 0m;
        return $"{QuantityDisplay.Format(itemCount)} {(itemCount == 1m ? "item" : "items")}";
    }

    private async Task ApproveOrder(int id)
    {
        if (!TryBeginOrderAction(id, OrderActionType.Approve))
            return;

        StateHasChanged();

        try
        {
            var result = await SalesOrderService.ApproveAsync(id);
            if (result != null)
            {
                var approvalMessage = result.IsSynced
                    ? result.SAPDocNum.HasValue
                        ? $"Order {result.OrderNumber} approved and posted to SAP successfully! (Doc #{result.SAPDocNum})"
                        : $"Order {result.OrderNumber} approved and posted to SAP successfully."
                    : $"Order {result.OrderNumber} approved successfully.";
                Snackbar.Add(approvalMessage, Severity.Success);
                selectedOrder = result;
                await LoadOrders();
            }
            else
            {
                Snackbar.Add("Failed to approve order. Please try again.", Severity.Error);
            }
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error approving order: {ex.Message}", Severity.Error);
        }
        finally
        {
            EndOrderAction(id);
            StateHasChanged();
        }
    }

    private async Task PostOrderToSAP(int id)
    {
        if (!TryBeginOrderAction(id, OrderActionType.PostToSap))
            return;

        StateHasChanged();

        try
        {
            var result = await SalesOrderService.PostToSAPAsync(id);
            if (result != null)
            {
                Snackbar.Add($"Order {result.OrderNumber} posted to SAP successfully! (Doc #{result.SAPDocNum})", Severity.Success);
                await ClearSelectedOrder();
                await LoadOrders();
            }
            else
            {
                Snackbar.Add("Failed to post order to SAP. Please try again.", Severity.Error);
            }
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"SAP posting failed: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error posting to SAP: {ex.Message}", Severity.Error);
        }
        finally
        {
            EndOrderAction(id);
            StateHasChanged();
        }
    }

    private async Task ConvertToInvoice(SalesOrderDto order)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "Convert to Invoice",
            $"Are you sure you want to convert order {order.OrderNumber} for {order.CardName ?? order.CardCode} (Total: {order.Currency} {order.DocTotal:N2}) into an invoice?",
            yesText: "Convert",
            cancelText: "Cancel");

        if (result != true) return;

        if (!TryBeginOrderAction(order.Id, OrderActionType.ConvertToInvoice))
            return;

        StateHasChanged();

        try
        {
            var invoice = await SalesOrderService.ConvertToInvoiceAsync(order.Id);
            if (invoice != null)
            {
                Snackbar.Add($"Order {order.OrderNumber} converted to Invoice #{invoice.DocNum} successfully!", Severity.Success);
                await LoadOrders();
            }
            else
            {
                Snackbar.Add("Failed to convert sales order to invoice. Please try again.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error converting order: {ex.Message}", Severity.Error);
        }
        finally
        {
            EndOrderAction(order.Id);
            StateHasChanged();
        }
    }

    private async Task DeleteOrder(int id)
    {
        if (!TryBeginOrderAction(id, OrderActionType.Delete))
            return;

        StateHasChanged();

        try
        {
            var success = await SalesOrderService.DeleteSalesOrderAsync(id);
            if (success)
            {
                Snackbar.Add("Order deleted successfully.", Severity.Success);
                await LoadOrders();
            }
            else
            {
                Snackbar.Add("Failed to delete order. Please try again.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting order: {ex.Message}", Severity.Error);
        }
        finally
        {
            EndOrderAction(id);
            StateHasChanged();
        }
    }

    private string GetStatusCssClass(SalesOrderStatus status) => status switch
    {
        SalesOrderStatus.Draft => "draft",
        SalesOrderStatus.Pending => "pending",
        SalesOrderStatus.Approved => "approved",
        SalesOrderStatus.PartiallyFulfilled => "partial",
        SalesOrderStatus.Fulfilled => "fulfilled",
        SalesOrderStatus.Cancelled => "cancelled",
        SalesOrderStatus.OnHold => "on-hold",
        _ => "draft"
    };
