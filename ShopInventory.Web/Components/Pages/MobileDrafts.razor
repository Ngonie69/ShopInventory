                        </MudButton>
                    </Authorized>
                </AuthorizeView>
            }
            <MudButton Class="btn-secondary-action" OnClick="ClearSelectedOrder">Close</MudButton>
        </div>
    </div>
}

@if (showPurchaseOrderViewer)
{
