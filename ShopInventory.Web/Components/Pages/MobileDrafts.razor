                        <i class="bi bi-x-lg"></i>
                    </MudButton>
                </div>
            </div>
            <div class="md-po-viewer-body">
                @if (isLoadingPurchaseOrderViewer)
                {
                    <div class="d-flex justify-content-center align-items-center h-100">
