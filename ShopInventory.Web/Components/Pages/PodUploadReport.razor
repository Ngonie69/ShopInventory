    }
    .podr-upload-btn:hover {
        background: linear-gradient(135deg, #283593, #5c6bc0);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 2px 6px rgba(26,35,126,0.3);
    }
    .podr-docnum {
        font-weight: 600;
        color: #1a237e;
        font-family: 'Space Grotesk', monospace;
    }
    .podr-customer {
        font-weight: 500;
        font-size: 0.88rem;
    }
    .podr-cardcode {
        font-size: 0.75rem;
