@code {
    private PodUploadStatusReport? report;
    private bool isLoading;
    private bool isExporting;
    private string? errorMessage;
    private DateTime? fromDate = DateTime.Today.AddDays(-30);
    private DateTime? toDate = DateTime.Today;
    private string filterMode = "all";
    private string? searchTerm;
    private int currentPage = 1;
    private const int pageSize = 25;

    private IEnumerable<PodUploadStatusItem> FilteredItems
    {
        get
        {
            if (report?.Items == null) return Enumerable.Empty<PodUploadStatusItem>();
            var items = report.Items.AsEnumerable();

            if (filterMode == "uploaded")
                items = items.Where(i => i.HasPod);
            else if (filterMode == "pending")
                items = items.Where(i => !i.HasPod);

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var term = searchTerm.Trim();
                items = items.Where(i =>
                    (i.CardName?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (i.CardCode?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    i.DocNum.ToString().Contains(term));
            }

            return items;
        }
    }

    private IEnumerable<PodUploadStatusItem> PagedItems =>
        FilteredItems.Skip((currentPage - 1) * pageSize).Take(pageSize);

    private int TotalFilteredPages => FilteredItems.Any()
        ? (int)Math.Ceiling((double)FilteredItems.Count() / pageSize) : 1;

    private int PageStart => Math.Max(1, currentPage - 2);
    private int PageEnd => Math.Min(TotalFilteredPages, PageStart + 4);

    private async Task LoadReport()
    {
        if (!fromDate.HasValue || !toDate.HasValue)
        {
            errorMessage = "Please select both From and To dates.";
            return;
        }

        isLoading = true;
        errorMessage = null;
        report = null;
        currentPage = 1;
        filterMode = "all";
        searchTerm = null;

        try
        {
            report = await PodService.GetPodUploadStatusAsync(fromDate.Value, toDate.Value);
            if (report == null)
                errorMessage = "Failed to load report. Please try again.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading report: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetFilter(string mode)
    {
        filterMode = mode;
        currentPage = 1;
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalFilteredPages)
            currentPage = page;
    }

    private void GoToUpload(int docNum)
    {
        Navigation.NavigateTo($"/pods?docNum={docNum}");
    }

    private void OnQuickSelectChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var days))
        {
            fromDate = DateTime.Today.AddDays(-days);
            toDate = DateTime.Today;
        }
    }

    private string FormatDate(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return "-";
        if (DateTime.TryParse(dateStr, out var dt))
            return dt.ToString("dd MMM yyyy");
        return dateStr;
    }

    private async Task ExportToExcel()
    {
        if (report == null) return;
        isExporting = true;
        StateHasChanged();
        try
        {
            var bytes = ExportService.ExportPodUploadStatusToExcel(report);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", $"POD_Upload_Report_{DateTime.Now:yyyyMMdd_HHmm}.xlsx", base64);
        }
        catch (Exception ex)
        {
            errorMessage = $"Export failed: {ex.Message}";
        }
        finally
        {
            isExporting = false;
            StateHasChanged();
        }
    }
}
