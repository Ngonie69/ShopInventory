@page "/pod-report"
@using Microsoft.AspNetCore.Authorization
@using ShopInventory.Web.Models
@using ShopInventory.Web.Services
@attribute [Authorize(Roles = "Admin,Cashier,PodOperator,Driver,SalesRep")]
@inject IPodService PodService
@inject IReportExportService ExportService
@inject IAppSettingsProvider AppSettings
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>POD Upload Report - Shop Inventory</PageTitle>

<div class="container-fluid fade-in staff-dashboard staff-shell">
    @* Hero Header *@
    <div class="podr-hero">
        <div class="podr-hero-content">
            <div>
                <h2 class="podr-hero-title">
                    <span class="podr-hero-icon">
                        <i class="bi bi-clipboard-data"></i>
                    </span>
                    POD Upload Report
                </h2>
                <p class="podr-hero-subtitle">Track which invoices have proof of delivery uploaded</p>
            </div>
            @if (report != null)
            {
                <div class="d-flex gap-2 align-items-center">
                    <span class="podr-stat-pill podr-pill-total">
                        <i class="bi bi-receipt me-1"></i>
                        @BaseFilteredCount invoices
                    </span>
                    <span class="podr-stat-pill podr-pill-uploaded">
                        <i class="bi bi-check-circle me-1"></i>
                        @BaseUploadedCount uploaded
                    </span>
                    <span class="podr-stat-pill podr-pill-pending">
                        <i class="bi bi-clock me-1"></i>
                        @BasePendingCount pending
                    </span>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ExportToExcel"
                               Disabled="@(isExporting || FilteredCount == 0)" Class="podr-export-btn">
                        @if (isExporting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                            <text>Exporting...</text>
                        }
                        else
                        {
                            <i class="bi bi-file-earmark-excel me-1"></i>
                            <text>Excel</text>
                        }
                    </MudButton>
                </div>
            }
        </div>
    </div>

    @* Date Filter *@
    <div class="podr-filter-card">
        <div class="podr-filter-header">
            <i class="bi bi-funnel"></i>
            <span>Report Filters</span>
        </div>
        <div class="podr-filter-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-semibold text-uppercase text-muted">From Date</label>
                    <MudDatePicker @bind-Date="fromDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   DateFormat="@AppSettings.DateFormat" Editable="true" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold text-uppercase text-muted">To Date</label>
                    <MudDatePicker @bind-Date="toDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   DateFormat="@AppSettings.DateFormat" Editable="true" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold text-uppercase text-muted">Quick Select</label>
                    <select class="form-select" @onchange="OnQuickSelectChanged" style="border-radius: 8px;">
                        <option value="7">Last 7 Days</option>
                        <option value="30" selected>Last 30 Days</option>
                        <option value="90">Last 90 Days</option>
                        <option value="180">Last 6 Months</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadReport"
                               Disabled="@isLoading" FullWidth="true" Class="podr-load-btn">
                        @if (isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                            <text>Loading...</text>
                        }
                        else
                        {
                            <i class="bi bi-lightning-charge me-1"></i>
                            <text>Load Report</text>
                        }
                    </MudButton>
                </div>
            </div>
            <div class="row g-3 align-items-end mt-1">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold text-uppercase text-muted">Invoice / Customer</label>
                    <input type="text" class="form-control" placeholder="Invoice #, customer, or card code"
                           @bind="searchTerm" @bind:event="oninput" @bind:after="OnAdvancedFiltersChanged" style="border-radius: 8px;" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold text-uppercase text-muted">Currency</label>
                    <select class="form-select" @bind="currencyFilter" @bind:after="OnAdvancedFiltersChanged" style="border-radius: 8px;">
                        <option value="all">All currencies</option>
                        @foreach (var currency in AvailableCurrencies)
                        {
                            <option value="@currency">@currency</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold text-uppercase text-muted">Uploaded By</label>
                    <select class="form-select" @bind="uploadedByFilter" @bind:after="OnAdvancedFiltersChanged" style="border-radius: 8px;">
                        <option value="all">Any uploader</option>
                        @foreach (var uploader in AvailableUploaders)
                        {
                            <option value="@uploader">@uploader</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold text-uppercase text-muted">Min Amount</label>
                    <input type="number" class="form-control" min="0" step="0.01" placeholder="0.00"
                           @bind="minAmount" @bind:after="OnAdvancedFiltersChanged" style="border-radius: 8px;" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold text-uppercase text-muted">Max Amount</label>
                    <input type="number" class="form-control" min="0" step="0.01" placeholder="0.00"
                           @bind="maxAmount" @bind:after="OnAdvancedFiltersChanged" style="border-radius: 8px;" />
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">@errorMessage</MudAlert>
    }

    @* Summary Stats *@
    @if (report != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="podr-stat-card podr-stat-total">
                    <div class="podr-stat-icon">
                        <i class="bi bi-receipt"></i>
                    </div>
                    <div>
                        <div class="podr-stat-label">Total Invoices</div>
                        <div class="podr-stat-value">@BaseFilteredCount</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="podr-stat-card podr-stat-uploaded">
                    <div class="podr-stat-icon">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <div>
                        <div class="podr-stat-label">POD Uploaded</div>
                        <div class="podr-stat-value">@BaseUploadedCount</div>
                    </div>
                    @if (BaseFilteredCount > 0)
                    {
                        <div class="podr-stat-pct">@((BaseUploadedCount * 100.0 / BaseFilteredCount).ToString("N1"))%</div>
                    }
                </div>
            </div>
            <div class="col-md-4">
                <div class="podr-stat-card podr-stat-pending">
                    <div class="podr-stat-icon">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                    <div>
                        <div class="podr-stat-label">Pending Upload</div>
                        <div class="podr-stat-value">@BasePendingCount</div>
                    </div>
                    @if (BaseFilteredCount > 0)
                    {
                        <div class="podr-stat-pct">@((BasePendingCount * 100.0 / BaseFilteredCount).ToString("N1"))%</div>
                    }
                </div>
            </div>
        </div>

        @* Progress Bar *@
        @if (BaseFilteredCount > 0)
        {
            var pct = BaseUploadedCount * 100.0 / BaseFilteredCount;
            <div class="podr-progress-card mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-semibold small">Upload Progress</span>
                    <span class="small text-muted">@BaseUploadedCount / @BaseFilteredCount</span>
                </div>
                <div class="progress" style="height: 10px; border-radius: 8px;">
                    <div class="progress-bar @(pct >= 100 ? "bg-success" : pct >= 50 ? "bg-primary" : "bg-warning")"
                         role="progressbar" style="width: @(pct.ToString("N1"))%; border-radius: 8px;"
                         aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                    </div>
                </div>
            </div>
        }

        @* Filter Tabs *@
        <div class="podr-tab-bar mb-3">
            <button class="podr-tab @(filterMode == "all" ? "podr-tab-active" : "")" @onclick='() => SetFilter("all")'>
                All (@BaseFilteredCount)
            </button>
            <button class="podr-tab @(filterMode == "uploaded" ? "podr-tab-active" : "")" @onclick='() => SetFilter("uploaded")'>
                <i class="bi bi-check-circle me-1"></i>Uploaded (@BaseUploadedCount)
            </button>
            <button class="podr-tab @(filterMode == "pending" ? "podr-tab-active" : "")" @onclick='() => SetFilter("pending")'>
                <i class="bi bi-clock me-1"></i>Pending (@BasePendingCount)
            </button>
            <div class="ms-auto d-flex align-items-center gap-2 flex-wrap">
                <span class="text-muted small">@FilteredCount matching invoices</span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ResetAdvancedFilters">Clear Filters</button>
            </div>
        </div>

        @* Data Table *@
        <div class="podr-table-card">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle podr-table">
                    <thead>
                        <tr>
                            <th>Invoice #</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th class="text-end">Amount</th>
                            <th class="text-center">POD Status</th>
                            <th>Uploaded</th>
                            <th class="text-center">Files</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (FilteredItems.Any())
                        {
                            @foreach (var item in PagedItems)
                            {
                                <tr class="@(!item.HasPod ? "podr-row-pending" : "")">
                                    <td>
                                        <span class="podr-docnum">@item.DocNum</span>
                                    </td>
                                    <td>
                                        <div class="podr-customer">@item.CardName</div>
                                        <div class="podr-cardcode">@item.CardCode</div>
                                    </td>
                                    <td>@FormatDate(item.DocDate)</td>
                                    <td class="text-end fw-semibold">
                                        @item.DocCurrency @item.DocTotal.ToString("N2")
                                    </td>
                                    <td class="text-center">
                                        @if (item.HasPod)
                                        {
                                            <span class="podr-badge podr-badge-uploaded">
                                                <i class="bi bi-check-circle-fill me-1"></i>Uploaded
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="podr-badge podr-badge-pending">
                                                <i class="bi bi-clock me-1"></i>Pending
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.HasPod && item.PodUploadedAt.HasValue)
                                        {
                                            <div class="small">@item.PodUploadedAt.Value.ToString("dd MMM yyyy HH:mm")</div>
                                            <div class="text-muted small">by @FormatPodUploadedByDisplay(item)</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">&mdash;</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (item.PodCount > 0)
                                        {
                                            <span class="badge bg-primary rounded-pill">@item.PodCount</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!item.HasPod)
                                        {
                                            <button class="btn btn-sm podr-upload-btn" @onclick="() => GoToUpload(item.DocNum)">
                                                <i class="bi bi-cloud-arrow-up me-1"></i>Upload
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox me-2"></i>No invoices match the current filters
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (TotalFilteredPages > 1)
            {
                <div class="podr-pagination">
                    <span class="text-muted small">Showing @PageStartItem&ndash;@PageEndItem of @FilteredCount</span>
                    <div class="d-flex gap-1">
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(EffectiveCurrentPage <= 1)" @onclick="() => GoToPage(1)">
                            <i class="bi bi-chevron-double-left"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(EffectiveCurrentPage <= 1)" @onclick="() => GoToPage(EffectiveCurrentPage - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        @for (int i = PageStart; i <= PageEnd; i++)
                        {
                            var pg = i;
                            <button class="btn btn-sm @(pg == EffectiveCurrentPage ? "btn-primary" : "btn-outline-secondary")" @onclick="() => GoToPage(pg)">
                                @pg
                            </button>
                        }
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(EffectiveCurrentPage >= TotalFilteredPages)" @onclick="() => GoToPage(EffectiveCurrentPage + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(EffectiveCurrentPage >= TotalFilteredPages)" @onclick="() => GoToPage(TotalFilteredPages)">
                            <i class="bi bi-chevron-double-right"></i>
                        </button>
                    </div>
                    <span class="text-muted small">Page @EffectiveCurrentPage of @TotalFilteredPages</span>
                </div>
            }
        </div>
    }
    else if (!isLoading && report == null)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-bar-chart-line" style="font-size: 3rem;"></i>
            <p class="mt-3">Select a date range and click <strong>Load Report</strong> to generate the POD upload status report.</p>
        </div>
    }
</div>

<style>
