        gap: 1rem;
        padding: 1.25rem;
        border-radius: 12px;
        color: #fff;
        min-height: 90px;
    }
    .podr-stat-total { background: linear-gradient(135deg, #1a237e, #3949ab); }
    .podr-stat-uploaded { background: linear-gradient(135deg, #1b5e20, #388e3c); }
    .podr-stat-pending { background: linear-gradient(135deg, #e65100, #f57c00); }
    .podr-stat-icon {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.2);
        border-radius: 12px;
        font-size: 1.35rem;
    }
    .podr-stat-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        opacity: 0.85;
    }
    .podr-stat-value {
        font-size: 1.75rem;
