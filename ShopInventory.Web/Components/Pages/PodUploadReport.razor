        color: #2e7d32;
    }
    .podr-badge-pending {
        background: #fff3e0;
        color: #e65100;
    }

    .podr-pagination {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        border-top: 1px solid var(--border-color, #e2e8f0);
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    /* Dark theme overrides */
    .dark-theme .podr-filter-card,
    .dark-theme .podr-progress-card,
    .dark-theme .podr-table-card {
        background: var(--card-bg, #1e293b);
        border-color: var(--border-color, #334155);
    }
    .dark-theme .podr-filter-header,
    .dark-theme .podr-table thead th {
        background: var(--card-header-bg, #1e293b);
    }
    .dark-theme .podr-tab {
        background: var(--card-bg, #1e293b);
        border-color: var(--border-color, #334155);
        color: var(--text-secondary, #94a3b8);
    }
    .dark-theme .podr-tab:hover { border-color: #7986cb; color: #7986cb; }
    .dark-theme .podr-tab-active { background: #3949ab; color: #fff !important; border-color: #3949ab; }
    .dark-theme .podr-docnum { color: #7986cb; }
    .dark-theme .podr-badge-uploaded { background: rgba(46,125,50,0.2); color: #81c784; }
    .dark-theme .podr-badge-pending { background: rgba(230,81,0,0.2); color: #ffb74d; }
    .dark-theme .podr-row-pending { background: rgba(255,152,0,0.05); }
</style>

@code {
    private PodUploadStatusReport? report;
    private bool isLoading;
    private bool isExporting;
    private string? errorMessage;
    private DateTime? fromDate = DateTime.Today.AddDays(-30);
    private DateTime? toDate = DateTime.Today;
    private string filterMode = "all";
    private string? searchTerm;
    private string currencyFilter = "all";
    private string uploadedByFilter = "all";
    private decimal? minAmount;
    private decimal? maxAmount;
    private int currentPage = 1;
    private const int pageSize = 25;

    private IEnumerable<string> AvailableCurrencies => report?.Items?
        .Select(i => i.DocCurrency?.Trim())
        .Where(currency => !string.IsNullOrWhiteSpace(currency))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(currency => currency)
        .Cast<string>()
        ?? Enumerable.Empty<string>();

    private IEnumerable<string> AvailableUploaders => report?.Items?
        .SelectMany(GetPodUploadedByUsers)
        .Select(uploader => uploader.Username.Trim())
        .Where(uploader => !string.IsNullOrWhiteSpace(uploader))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(uploader => uploader)
        ?? Enumerable.Empty<string>();

    private IEnumerable<PodUploadStatusItem> BaseFilteredItems
    {
        get
        {
            if (report?.Items == null)
                return Enumerable.Empty<PodUploadStatusItem>();

            var items = report.Items.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var term = searchTerm.Trim();
                items = items.Where(i =>
                    (i.CardName?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (i.CardCode?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    i.DocNum.ToString().Contains(term));
            }

            if (!string.Equals(currencyFilter, "all", StringComparison.OrdinalIgnoreCase))
            {
                items = items.Where(i => string.Equals(i.DocCurrency?.Trim(), currencyFilter, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.Equals(uploadedByFilter, "all", StringComparison.OrdinalIgnoreCase))
            {
                items = items.Where(i => GetPodUploadedByUsers(i)
                    .Any(uploader => string.Equals(uploader.Username.Trim(), uploadedByFilter, StringComparison.OrdinalIgnoreCase)));
            }

            if (minAmount.HasValue)
            {
                items = items.Where(i => i.DocTotal >= EffectiveMinAmount);
            }

            if (maxAmount.HasValue)
            {
                items = items.Where(i => i.DocTotal <= EffectiveMaxAmount);
            }

            return items;
        }
    }

    private IEnumerable<PodUploadStatusItem> FilteredItems
    {
        get
        {
            var items = BaseFilteredItems;

            if (filterMode == "uploaded")
                items = items.Where(i => i.HasPod);
            else if (filterMode == "pending")
                items = items.Where(i => !i.HasPod);

            return items;
        }
    }

    private int BaseFilteredCount => BaseFilteredItems.Count();
    private int BaseUploadedCount => BaseFilteredItems.Count(i => i.HasPod);
    private int BasePendingCount => BaseFilteredItems.Count(i => !i.HasPod);
    private int FilteredCount => FilteredItems.Count();
    private int EffectiveCurrentPage => Math.Clamp(currentPage, 1, TotalFilteredPages);
    private decimal EffectiveMinAmount => minAmount.HasValue && maxAmount.HasValue && minAmount.Value > maxAmount.Value
        ? maxAmount.Value
        : minAmount ?? 0m;
    private decimal EffectiveMaxAmount => minAmount.HasValue && maxAmount.HasValue && minAmount.Value > maxAmount.Value
        ? minAmount.Value
        : maxAmount ?? decimal.MaxValue;

    private IEnumerable<PodUploadStatusItem> PagedItems =>
        FilteredItems.Skip((EffectiveCurrentPage - 1) * pageSize).Take(pageSize);

    private int TotalFilteredPages => FilteredCount > 0
        ? (int)Math.Ceiling((double)FilteredCount / pageSize) : 1;

    private int PageStart => Math.Max(1, EffectiveCurrentPage - 2);
    private int PageEnd => Math.Min(TotalFilteredPages, PageStart + 4);
    private int PageStartItem => FilteredCount == 0 ? 0 : ((EffectiveCurrentPage - 1) * pageSize) + 1;
    private int PageEndItem => Math.Min(EffectiveCurrentPage * pageSize, FilteredCount);

    private async Task LoadReport()
    {
        if (!fromDate.HasValue || !toDate.HasValue)
        {
            errorMessage = "Please select both From and To dates.";
            return;
        }

        isLoading = true;
        errorMessage = null;
        report = null;
        currentPage = 1;

        try
        {
            report = await PodService.GetPodUploadStatusAsync(fromDate.Value, toDate.Value);
            NormalizeDynamicFilters();
            currentPage = EffectiveCurrentPage;
            if (report == null)
                errorMessage = "Failed to load report. Please try again.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading report: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetFilter(string mode)
    {
        filterMode = mode;
        currentPage = 1;
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalFilteredPages)
            currentPage = page;
    }

    private void GoToUpload(int docNum)
    {
        Navigation.NavigateTo($"/pods?docNum={docNum}");
    }

    private void OnQuickSelectChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var days))
        {
            fromDate = DateTime.Today.AddDays(-days);
            toDate = DateTime.Today;
        }
    }

    private void OnAdvancedFiltersChanged()
    {
        currentPage = 1;
    }

    private void ResetAdvancedFilters()
    {
        filterMode = "all";
        searchTerm = null;
        currencyFilter = "all";
        uploadedByFilter = "all";
        minAmount = null;
        maxAmount = null;
        currentPage = 1;
    }

    private void NormalizeDynamicFilters()
    {
        if (!string.Equals(currencyFilter, "all", StringComparison.OrdinalIgnoreCase)
            && !AvailableCurrencies.Contains(currencyFilter, StringComparer.OrdinalIgnoreCase))
        {
            currencyFilter = "all";
        }

        if (!string.Equals(uploadedByFilter, "all", StringComparison.OrdinalIgnoreCase)
            && !AvailableUploaders.Contains(uploadedByFilter, StringComparer.OrdinalIgnoreCase))
        {
            uploadedByFilter = "all";
        }
    }

    private static IReadOnlyList<PodUploadUserSummary> GetPodUploadedByUsers(PodUploadStatusItem item)
    {
        if (item.PodUploadedByUsers.Count > 0)
            return item.PodUploadedByUsers;

        if (!string.IsNullOrWhiteSpace(item.PodUploadedBy))
        {
            return
            [
                new PodUploadUserSummary
                {
                    Username = item.PodUploadedBy.Trim(),
                    FileCount = item.PodCount > 0 ? item.PodCount : 1,
                    LatestUploadedAt = item.PodUploadedAt
                }
            ];
        }

        return [];
    }

    private static string FormatPodUploadedByDisplay(PodUploadStatusItem item)
    {
        var uploaders = GetPodUploadedByUsers(item)
            .Select(uploader => uploader.Username.Trim())
            .Where(username => !string.IsNullOrWhiteSpace(username))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (uploaders.Count == 0)
            return string.IsNullOrWhiteSpace(item.PodUploadedBy) ? "Unknown uploader" : item.PodUploadedBy;

        return string.Join(", ", uploaders);
    }

    private string FormatDate(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return "-";
        if (DateTime.TryParse(dateStr, out var dt))
            return dt.ToString("dd MMM yyyy");
        return dateStr;
    }

    private async Task ExportToExcel()
    {
        if (report == null || FilteredCount == 0) return;
        isExporting = true;
        StateHasChanged();
        try
        {
            var exportReport = new PodUploadStatusReport
            {
                FromDate = report.FromDate,
                ToDate = report.ToDate,
                TotalInvoices = FilteredCount,
                UploadedCount = FilteredItems.Count(i => i.HasPod),
                PendingCount = FilteredItems.Count(i => !i.HasPod),
                Items = FilteredItems.ToList()
            };

            var bytes = ExportService.ExportPodUploadStatusToExcel(exportReport);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", $"POD_Upload_Report_{DateTime.Now:yyyyMMdd_HHmm}.xlsx", base64);
        }
        catch (Exception ex)
        {
            errorMessage = $"Export failed: {ex.Message}";
        }
        finally
        {
            isExporting = false;
            StateHasChanged();
        }
    }
}
