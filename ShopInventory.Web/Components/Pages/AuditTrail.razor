@page "/audit-trail"
@using ShopInventory.Web.Data
@using ShopInventory.Web.Services
@inject IAuditService AuditService
@inject AuthenticationStateProvider AuthStateProvider
@inject IAppSettingsProvider AppSettings
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<PageTitle>Audit Trail - Shop Inventory</PageTitle>

<div class="audit-page">
    <!-- Page Header -->
    <div class="audit-header">
        <div class="header-left">
            <div class="header-icon">
                <i class="bi bi-shield-check"></i>
            </div>
            <div>
                <h1 class="header-title">Audit Trail</h1>
                <p class="header-subtitle">Monitor system activity, user actions, and security events</p>
            </div>
        </div>
        <div class="header-actions">
            <button class="btn-audit btn-audit-outline" @onclick="RefreshLogs">
                <i class="bi bi-arrow-clockwise"></i>
                <span>Refresh</span>
            </button>
            <button class="btn-audit btn-audit-gradient" @onclick="ExportLogs">
                <i class="bi bi-download"></i>
                <span>Export CSV</span>
            </button>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon stat-icon-purple">
                <i class="bi bi-list-check"></i>
            </div>
            <div class="stat-content">
                <span class="stat-value">@totalCount.ToString("N0")</span>
                <span class="stat-label">Total Events</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon-blue">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-content">
                <span class="stat-value">@distinctUsers.Count</span>
                <span class="stat-label">Unique Users</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon-amber">
                <i class="bi bi-lightning"></i>
            </div>
            <div class="stat-content">
                <span class="stat-value">@distinctActions.Count</span>
                <span class="stat-label">Action Types</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon-red">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div class="stat-content">
                <span class="stat-value">@failedCount</span>
                <span class="stat-label">Failed Actions</span>
            </div>
        </div>
    </div>

    <!-- Filters Panel -->
    <div class="filter-panel">
        <div class="filter-header">
            <i class="bi bi-funnel"></i>
            <span>Filters</span>
        </div>
        <div class="filter-body">
            <div class="filter-row">
                <div class="filter-group">
                    <FlexibleDatePicker Label="From Date" @bind-Date="fromDate" />
                </div>
                <div class="filter-group">
                    <FlexibleDatePicker Label="To Date" @bind-Date="toDate" />
                </div>
                <div class="filter-group">
                    <label class="filter-label">User</label>
                    <select class="filter-select" @bind="selectedUser">
                        <option value="">All Users</option>
                        @foreach (var user in distinctUsers)
                        {
                            <option value="@user">@user</option>
                        }
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Action</label>
                    <select class="filter-select" @bind="selectedAction">
                        <option value="">All Actions</option>
                        @foreach (var action in distinctActions)
                        {
                            <option value="@action">@action</option>
                        }
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label">Per Page</label>
                    <select class="filter-select" @bind="pageSize" @bind:after="OnPageSizeChanged">
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="200">200</option>
                    </select>
                </div>
                <div class="filter-actions">
                    <button class="btn-audit btn-search" @onclick="ApplyFilters">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <button class="btn-audit btn-clear" @onclick="ClearFilters">
                        <i class="bi bi-x-lg"></i> Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading audit logs...</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert-banner alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@errorMessage</span>
            <button class="alert-close" @onclick="() => errorMessage = null">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }
    else
    {
        <!-- Search Bar + Logs Table -->
        <div class="table-container">
            <div class="table-toolbar">
                <div class="table-title">
                    <i class="bi bi-journal-text"></i>
                    <span>Activity Log</span>
                    <span class="record-count">@totalCount records</span>
                </div>
                <div class="search-box">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Quick search across all columns..." @bind="_searchString"
                           @bind:event="oninput" />
                </div>
            </div>

            @if (filteredLogs.Any())
            {
                <div class="audit-table-wrap">
                    <table class="audit-table">
                        <thead>
                            <tr>
                                <th class="col-timestamp">Timestamp</th>
                                <th class="col-user">User</th>
                                <th class="col-role">Role</th>
                                <th class="col-action">Action</th>
                                <th class="col-details">Details</th>
                                <th class="col-status">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in filteredLogs)
                            {
                                <tr class="@(log.IsSuccess ? "" : "row-failed")" @onclick="() => SelectLog(log)">
                                    <td class="col-timestamp" data-label="Timestamp">
                                        <div class="timestamp-cell">
                                            <span class="ts-date">@IAuditService.ToCAT(log.Timestamp).ToString("dd MMM yyyy")</span>
                                            <span class="ts-time">@IAuditService.ToCAT(log.Timestamp).ToString("HH:mm:ss")</span>
                                        </div>
                                    </td>
                                    <td class="col-user" data-label="User">
                                        <div class="user-cell">
                                            <div class="user-avatar">@GetInitials(log.Username)</div>
                                            <span class="user-name">@log.Username</span>
                                        </div>
                                    </td>
                                    <td class="col-role" data-label="Role">
                                        <span class="role-badge @GetRoleBadgeClass(log.UserRole)">@log.UserRole</span>
                                    </td>
                                    <td class="col-action" data-label="Action">
                                        <span class="action-badge @GetActionBadgeClass(log.Action)">@FormatAction(log.Action)</span>
                                    </td>
                                    <td class="col-details" data-label="Details">
                                        <div class="details-cell">
                                            @if (!string.IsNullOrEmpty(log.EntityType))
                                            {
                                                <span class="entity-tag">
                                                    @log.EntityType@(string.IsNullOrEmpty(log.EntityId) ? "" : $" #{log.EntityId}")
                                                </span>
                                            }
                                            @if (!string.IsNullOrEmpty(log.Details))
                                            {
                                                <span class="detail-text">@TruncateText(log.Details, 60)</span>
                                            }
                                            @if (!log.IsSuccess && !string.IsNullOrEmpty(log.ErrorMessage))
                                            {
                                                <span class="error-text">@TruncateText(log.ErrorMessage, 50)</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="col-status" data-label="Status">
                                        @if (log.IsSuccess)
                                        {
                                            <span class="status-badge status-success">
                                                <i class="bi bi-check-circle-fill"></i> OK
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-failed">
                                                <i class="bi bi-x-circle-fill"></i> Failed
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="table-footer">
                    <span class="page-info">
                        Showing @(((currentPage - 1) * pageSize) + 1)–@Math.Min(currentPage * pageSize, totalCount) of
                        @totalCount
                    </span>
                    <div class="pagination-controls">
                        <button class="page-btn" disabled="@(currentPage <= 1)" @onclick="() => GoToPage(1)">
                            <i class="bi bi-chevron-double-left"></i>
                        </button>
                        <button class="page-btn" disabled="@(currentPage <= 1)" @onclick="() => GoToPage(currentPage - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        @foreach (var p in GetPageNumbers())
                        {
                            <button class="page-btn @(p == currentPage ? "page-active" : "")"
                                    @onclick="() => GoToPage(p)">@p</button>
                        }
                        <button class="page-btn" disabled="@(currentPage >= totalPages)"
                                @onclick="() => GoToPage(currentPage + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                        <button class="page-btn" disabled="@(currentPage >= totalPages)" @onclick="() => GoToPage(totalPages)">
                            <i class="bi bi-chevron-double-right"></i>
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-journal-x"></i>
                    <h3>No audit logs found</h3>
                    <p>Try adjusting your filters or date range.</p>
                </div>
            }
        </div>
    }

    <!-- Detail Drawer -->
    @if (selectedLog != null)
    {
        <div class="drawer-backdrop" @onclick="CloseDrawer"></div>
        <div class="detail-drawer">
            <div class="drawer-header">
                <h3>Event Details</h3>
                <button class="drawer-close" @onclick="CloseDrawer">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="drawer-body">
                <div class="detail-grid">
                    <div class="detail-item">
                        <span class="detail-label">Timestamp</span>
                        <span class="detail-value">@IAuditService.ToCAT(selectedLog.Timestamp).ToString("dd MMM yyyy,      HH:mm:ss") CAT</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">User</span>
                        <span class="detail-value">@selectedLog.Username</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Role</span>
                        <span class="detail-value"><span
                            class="role-badge @GetRoleBadgeClass(selectedLog.UserRole)">@selectedLog.UserRole</span></span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Action</span>
                            <span class="detail-value"><span
                                class="action-badge @GetActionBadgeClass(selectedLog.Action)">@FormatAction(selectedLog.Action)</span></span>
                            </div>
                            @if (!string.IsNullOrEmpty(selectedLog.EntityType))
                            {
                                <div class="detail-item">
                                    <span class="detail-label">Entity</span>
                                    <span class="detail-value">@selectedLog.EntityType @(string.IsNullOrEmpty(selectedLog.EntityId) ? "" : $"#{selectedLog.EntityId}")</span>
                                </div>
                            }
                            <div class="detail-item">
                                <span class="detail-label">Status</span>
                                <span class="detail-value">
                                    @if (selectedLog.IsSuccess)
                                    {
                                        <span class="status-badge status-success"><i class="bi bi-check-circle-fill"></i> Success</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-failed"><i class="bi bi-x-circle-fill"></i> Failed</span>
                                    }
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(selectedLog.Details))
                            {
                                <div class="detail-item detail-full">
                                    <span class="detail-label">Details</span>
                                    <span class="detail-value detail-pre">@selectedLog.Details</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(selectedLog.ErrorMessage))
                            {
                                <div class="detail-item detail-full">
                                    <span class="detail-label">Error</span>
                                    <span class="detail-value error-text">@selectedLog.ErrorMessage</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(selectedLog.IpAddress))
                            {
                                <div class="detail-item">
                                    <span class="detail-label">IP Address</span>
                                    <span class="detail-value"
                                          style="font-family:'Space Grotesk',monospace;">@selectedLog.IpAddress</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(selectedLog.PageUrl))
                            {
                                <div class="detail-item">
                                    <span class="detail-label">Page URL</span>
                                    <span class="detail-value"
                                          style="font-family:'Space Grotesk',monospace;">@selectedLog.PageUrl</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <style>
            /* ===== Base ===== */
            .audit-page {
                padding: 1.5rem 2rem 3rem;
                max-width: 1440px;
                margin: 0 auto;
                animation: fadeIn .3s ease;
            }

            @@keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(8px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @@keyframes slideInRight {
                from {
                    transform: translateX(100%);
                }

                to {
                    transform: translateX(0);
                }
            }

            /* ===== Header ===== */
            .audit-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 1.5rem;
                flex-wrap: wrap;
                gap: 1rem;
            }

            .header-left {
                display: flex;
                align-items: center;
                gap: 1rem;
            }

            .header-icon {
                width: 48px;
                height: 48px;
                border-radius: 12px;
                background: linear-gradient(135deg, #667eea, #764ba2);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 1.25rem;
                flex-shrink: 0;
            }

            .header-title {
                font-size: 1.5rem;
                font-weight: 700;
                color: #1a1a2e;
                margin: 0;
                line-height: 1.2;
            }

            .header-subtitle {
                font-size: .82rem;
                color: #6b7280;
                margin: 2px 0 0;
            }

            .header-actions {
                display: flex;
                gap: .5rem;
            }

            /* ===== Buttons ===== */
            .btn-audit {
                display: inline-flex;
                align-items: center;
                gap: .4rem;
                padding: .5rem 1rem;
                border-radius: 8px;
                font-size: .82rem;
                font-weight: 600;
                cursor: pointer;
                border: none;
                transition: all .15s ease;
            }

            .btn-audit-gradient {
                background: linear-gradient(135deg, #667eea, #764ba2);
                color: white;
            }

            .btn-audit-gradient:hover {
                opacity: .9;
                transform: translateY(-1px);
            }

            .btn-audit-outline {
                background: white;
                color: #374151;
                border: 1px solid #d1d5db;
            }

            .btn-audit-outline:hover {
                background: #f9fafb;
                border-color: #9ca3af;
            }

            .btn-search {
                background: linear-gradient(135deg, #667eea, #764ba2);
                color: white;
            }

            .btn-search:hover {
                opacity: .9;
            }

            .btn-clear {
                background: white;
                color: #6b7280;
                border: 1px solid #d1d5db;
            }

            .btn-clear:hover {
                background: #f3f4f6;
            }

            /* ===== Stats ===== */
            .stats-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
                gap: 1rem;
                margin-bottom: 1.5rem;
            }

            .stat-card {
                background: white;
                border: 1px solid #e5e7eb;
                border-radius: 12px;
                padding: 1.1rem 1.25rem;
                display: flex;
                align-items: center;
                gap: 1rem;
                transition: box-shadow .2s ease, transform .2s ease;
            }

            .stat-card:hover {
                box-shadow: 0 4px 12px rgba(0, 0, 0, .06);
                transform: translateY(-2px);
            }

            .stat-icon {
                width: 42px;
                height: 42px;
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.15rem;
                flex-shrink: 0;
            }

            .stat-icon-purple {
                background: #ede9fe;
                color: #7c3aed;
            }

            .stat-icon-blue {
                background: #dbeafe;
                color: #2563eb;
            }

            .stat-icon-amber {
                background: #fef3c7;
                color: #d97706;
            }

            .stat-icon-red {
                background: #fee2e2;
                color: #dc2626;
            }

            .stat-content {
                display: flex;
                flex-direction: column;
            }

            .stat-value {
                font-size: 1.35rem;
                font-weight: 700;
                color: #1a1a2e;
                line-height: 1.2;
            }

            .stat-label {
                font-size: .72rem;
                font-weight: 500;
                color: #6b7280;
                text-transform: uppercase;
                letter-spacing: .5px;
            }

            /* ===== Filters ===== */
            .filter-panel {
                background: white;
                border: 1px solid #e5e7eb;
                border-radius: 12px;
                margin-bottom: 1.5rem;
                overflow: hidden;
            }

            .filter-header {
                padding: .75rem 1.25rem;
                background: #f8fafc;
                border-bottom: 1px solid #e5e7eb;
                font-weight: 600;
                font-size: .85rem;
                color: #374151;
                display: flex;
                align-items: center;
                gap: .5rem;
            }

            .filter-body {
                padding: 1.25rem;
            }

            .filter-row {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                align-items: flex-end;
            }

            .filter-group {
                flex: 1;
                min-width: 140px;
            }

            .filter-label {
                display: block;
                font-size: .75rem;
                font-weight: 600;
                color: #6b7280;
                text-transform: uppercase;
                letter-spacing: .4px;
                margin-bottom: .35rem;
            }

            .filter-select {
                width: 100%;
                padding: .5rem .75rem;
                border: 1px solid #d1d5db;
                border-radius: 8px;
                font-size: .85rem;
                color: #374151;
                background: white;
                transition: border-color .15s;
            }

            .filter-select:focus {
                outline: none;
                border-color: #667eea;
                box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
            }

            .filter-actions {
                display: flex;
                gap: .5rem;
                align-items: flex-end;
                padding-bottom: 1px;
            }

            /* ===== Loading ===== */
            .loading-state {
                text-align: center;
                padding: 4rem 1rem;
                color: #6b7280;
            }

            .spinner {
                width: 36px;
                height: 36px;
                border: 3px solid #e5e7eb;
                border-top-color: #667eea;
                border-radius: 50%;
                animation: spin .7s linear infinite;
                margin: 0 auto 1rem;
            }

            @@keyframes spin {
                to {
                    transform: rotate(360deg);
                }
            }

            /* ===== Alert Banner ===== */
            .alert-banner {
                display: flex;
                align-items: center;
                gap: .75rem;
                padding: .85rem 1.25rem;
                border-radius: 10px;
                font-size: .88rem;
                margin-bottom: 1.5rem;
                animation: fadeIn .3s ease;
            }

            .alert-error {
                background: #fef2f2;
                color: #991b1b;
                border: 1px solid #fecaca;
            }

            .alert-close {
                margin-left: auto;
                background: none;
                border: none;
                cursor: pointer;
                color: inherit;
                opacity: .6;
                font-size: .8rem;
            }

            .alert-close:hover {
                opacity: 1;
            }

            /* ===== Table Container ===== */
            .table-container {
                background: white;
                border: 1px solid #e5e7eb;
                border-radius: 12px;
                overflow: hidden;
            }

            .table-toolbar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 1rem 1.25rem;
                border-bottom: 1px solid #e5e7eb;
                gap: 1rem;
                flex-wrap: wrap;
            }

            .table-title {
                display: flex;
                align-items: center;
                gap: .5rem;
                font-weight: 600;
                font-size: .95rem;
                color: #1a1a2e;
            }

            .record-count {
                font-weight: 400;
                font-size: .78rem;
                color: #9ca3af;
                margin-left: .25rem;
            }

            .search-box {
                display: flex;
                align-items: center;
                gap: .5rem;
                background: #f9fafb;
                border: 1px solid #e5e7eb;
                border-radius: 8px;
                padding: .4rem .75rem;
                min-width: 260px;
                transition: border-color .15s;
            }

            .search-box:focus-within {
                border-color: #667eea;
                box-shadow: 0 0 0 3px rgba(102, 126, 234, .1);
            }

            .search-box i {
                color: #9ca3af;
                font-size: .85rem;
            }

            .search-box input {
                border: none;
                background: transparent;
                outline: none;
                font-size: .85rem;
                color: #374151;
                width: 100%;
            }

            /* ===== Audit Table ===== */
            .audit-table-wrap {
                overflow-x: auto;
            }

            .audit-table {
                width: 100%;
                border-collapse: collapse;
            }

            .audit-table thead th {
                background: #f8fafc;
                padding: .65rem 1rem;
                font-size: .72rem;
                font-weight: 600;
                color: #6b7280;
                text-transform: uppercase;
                letter-spacing: .5px;
                text-align: left;
                border-bottom: 1px solid #e5e7eb;
                white-space: nowrap;
            }

            .audit-table tbody tr {
                border-bottom: 1px solid #f3f4f6;
                cursor: pointer;
                transition: background .1s;
            }

            .audit-table tbody tr:hover {
                background: #f9fafb;
            }

            .audit-table tbody tr.row-failed {
                background: #fef2f2;
            }

            .audit-table tbody tr.row-failed:hover {
                background: #fee2e2;
            }

            .audit-table td {
                padding: .7rem 1rem;
                font-size: .85rem;
                color: #374151;
                vertical-align: middle;
            }

            .col-timestamp {
                width: 140px;
            }

            .col-user {
                width: 160px;
            }

            .col-role {
                width: 110px;
            }

            .col-action {
                width: 130px;
            }

            .col-status {
                width: 90px;
            }

            /* Timestamp Cell */
            .timestamp-cell {
                display: flex;
                flex-direction: column;
                gap: 1px;
            }

            .ts-date {
                font-size: .82rem;
                font-weight: 500;
                color: #374151;
            }

            .ts-time {
                font-size: .72rem;
                color: #9ca3af;
                font-family: 'Space Grotesk', monospace;
            }

            /* User Cell */
            .user-cell {
                display: flex;
                align-items: center;
                gap: .6rem;
            }

            .user-avatar {
                width: 30px;
                height: 30px;
                border-radius: 50%;
