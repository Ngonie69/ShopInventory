    private Color GetStatusColor(string? status)
    {
        return status?.ToLower() switch
        {
            "open" or "bost_open" => Color.Info,
            "closed" or "bost_close" => Color.Default,
            "approved" => Color.Success,
            "rejected" => Color.Error,
            "pending" => Color.Warning,
            _ => Color.Info
        };
    }

    private bool IsRequestConvertible(InventoryTransferRequestDto? request)
    {
        if (request == null) return false;

        // Check if the request is open (can be converted)
        var status = request.DocumentStatus?.ToLower();
        return status == null || status == "open" || status == "bost_open";
    }

    private async Task ConvertRequest(InventoryTransferRequestDto request)
    {
        if (request == null) return;

        isConverting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            Logger.LogInformation("Converting transfer request {DocEntry} to inventory transfer", request.DocEntry);

            var (success, message, transfer) = await TransferService.ConvertTransferRequestToTransferAsync(request.DocEntry);

            if (success)
            {
                successMessage = message;
                Logger.LogInformation("Transfer request {RequestDocEntry} converted to transfer {TransferDocEntry}",
                request.DocEntry, transfer?.DocEntry);

                // Close the modal
                CloseRequestModal();

                // Refresh the transfer requests list
                await LoadTransferRequestsAsync();

                // Switch to the transfers tab if desired
                // await SwitchTab("transfers");
            }
            else
            {
                errorMessage = message;
                Logger.LogWarning("Failed to convert transfer request: {Message}", message);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error converting transfer request {DocEntry}", request.DocEntry);
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isConverting = false;
            StateHasChanged();
        }
    }

    #endregion

