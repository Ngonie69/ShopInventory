@page "/inventory-transfers"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IInventoryTransferService TransferService
@inject IMasterDataCacheService CacheService
@inject ILogger<InventoryTransfers> Logger
@rendermode InteractiveServer

<style>
    .spin {
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.6);
        z-index: 9999;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: white;
    }

    .loading-overlay .spinner-border {
        width: 4rem;
        height: 4rem;
        border-width: 0.4em;
    }

    .loading-overlay p {
        margin-top: 1rem;
        font-size: 1.25rem;
        font-weight: 500;
    }
</style>

@if (isConverting)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light" role="status">
            <span class="visually-hidden">Converting...</span>
        </div>
        <p>Converting Transfer Request...</p>
        <small class="text-white-50">Please wait while the transfer is being created</small>
    </div>
}

<PageTitle>Inventory Transfers - Shop Inventory</PageTitle>

<div class="page-shell">
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="page-header-icon">
                <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" />
            </div>
            <div>
                <MudText Typo="Typo.h4" Class="fw-bold" Style="letter-spacing: -0.5px;">Inventory Transfers</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Manage stock movements between warehouses</MudText>
            </div>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       Href="/inventory-transfer/create" Style="border-radius: 12px; text-transform: none; font-weight: 600; padding: 8px 24px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                Create Transfer
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.NoteAdd"
                       Href="/transfer-request/create" Style="border-radius: 12px; text-transform: none; font-weight: 600; padding: 8px 24px;">
                Create Request
            </MudButton>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => successMessage = null">
            @successMessage
        </MudAlert>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => errorMessage = null">
            @errorMessage
        </MudAlert>
    }

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4"
             ActivePanelIndex="activeTabIndex" ActivePanelIndexChanged="OnTabIndexChanged">
        <MudTabPanel Text="Completed Transfers" Icon="@Icons.Material.Filled.SwapHoriz" BadgeColor="Color.Primary">
            <!-- Filter Card -->
            <div class="filter-panel">
                <div class="filter-panel-header">
                    <MudIcon Icon="@Icons.Material.Filled.Tune" />
                    <MudText Typo="Typo.subtitle2" Style="color: white; font-weight: 600;">Search & Filter</MudText>
                </div>
                <div class="filter-panel-body">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="3">
                            <MudText Typo="Typo.body2" Class="fw-semibold mb-1">Warehouse <span class="text-danger">*</span></MudText>
                            @if (isLoadingWarehouses)
                            {
                                <div class="d-flex align-items-center">
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Loading warehouses...</MudText>
                                </div>
                            }
                            else
                            {
                                <MudAutocomplete T="WarehouseDto" @bind-Value="selectedWarehouse" Label="Search warehouse..."
                                    SearchFunc="SearchWarehousesAsync"
                                    ToStringFunc="@(w => w == null ? string.Empty : $"{w.WarehouseCode} - {w.WarehouseName}")"
                                    Dense="true" Variant="Variant.Filled" Margin="Margin.Dense" ResetValueOnEmptyText="true"
                                    ShowProgressIndicator="true" MaxItems="20" DebounceInterval="150" Class="mt-0">
                                    <ItemTemplate>
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold">@context.WarehouseCode</span>
                                            <small class="text-muted">@context.WarehouseName</small>
                                        </div>
                                    </ItemTemplate>
                                    <NoItemsTemplate>
                                        <div class="p-2 text-muted">
                                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="me-1" />No warehouses found
                                        </div>
                                    </NoItemsTemplate>
                                </MudAutocomplete>
                            }
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <FlexibleDatePicker Label="From Date" @bind-Date="fromDate" Variant="Variant.Filled" />
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <FlexibleDatePicker Label="To Date" @bind-Date="toDate" Variant="Variant.Filled" />
                        </MudItem>
                        <MudItem xs="12" md="5" Class="d-flex align-items-end gap-2 filter-actions">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search"
                                OnClick="LoadTransfers" Disabled="@(selectedWarehouse == null || isLoading)">
                                @if (isLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                }
                                Search
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Clear"
                                OnClick="ClearFilter">Clear</MudButton>
                        </MudItem>
                    </MudGrid>
                </div>
            </div>

            @if (isLoading)
            {
                <div class="d-flex flex-column align-items-center py-5">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    <MudText Typo="Typo.body2" Class="mt-2" Color="Color.Secondary">Loading transfers...</MudText>
                </div>
            }
            else if (transfers?.Any() == true)
            {
                <MudTable Items="@transfers" Dense="true" Hover="true" Striped="true" Filter="new Func<InventoryTransferDto, bool>(_transferQuickFilter)" T="InventoryTransferDto">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">Transfers for @selectedWarehouse?.WarehouseCode</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="_transferSearchString" Placeholder="Search transfers..."
                            Adornment="Adornment.Start" Immediate="true"
                            AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>Doc Entry</MudTh>
                        <MudTh>Doc #</MudTh>
                        <MudTh>From Warehouse</MudTh>
                        <MudTh>To Warehouse</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Due Date</MudTh>
                        <MudTh>Items</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Doc Entry">@context.DocEntry</MudTd>
                        <MudTd DataLabel="Doc #"><strong>@context.DocNum</strong></MudTd>
                        <MudTd DataLabel="From Warehouse">
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.FromWarehouse</MudChip>
                        </MudTd>
                        <MudTd DataLabel="To Warehouse">
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">@context.ToWarehouse</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Date">@FormatDate(context.DocDate)</MudTd>
                        <MudTd DataLabel="Due Date">@FormatDate(context.DueDate)</MudTd>
                        <MudTd DataLabel="Items">
                            <MudChip T="string" Color="Color.Info" Size="Size.Small">@(context.Lines?.Count ?? 0) items</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Primary"
                                Size="Size.Small" OnClick="@(() => ViewTransfer(context))" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            }
            else if (selectedWarehouse != null && !isLoading)
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                    <p class="mt-3 text-muted">No inventory transfers found for warehouse <strong>@selectedWarehouse.WarehouseCode</strong>.</p>
                    <p class="text-muted small">Try adjusting your date range or selecting a different warehouse.</p>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh"
                        OnClick="LoadTransfers" Class="mt-2">Retry</MudButton>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
                    <p class="mt-3 text-muted">Select a warehouse and click <strong>Search</strong> to view inventory transfers.</p>
                </div>
            }
        </MudTabPanel>

        <MudTabPanel Text="Transfer Requests" Icon="@Icons.Material.Filled.Description"
                     BadgeData="@(transferRequestCount > 0 ? transferRequestCount.ToString() : null)"
                     BadgeColor="Color.Primary">
            <div class="d-flex justify-content-between align-items-center mb-3 mt-2">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Class="me-2" />Transfer Requests
                </MudText>
                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                        StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshTransferRequests"
                        Disabled="@isLoadingRequests">Refresh</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                        StartIcon="@Icons.Material.Filled.Add" Href="/transfer-request/create">New Request</MudButton>
                </div>
            </div>

            @if (isLoadingRequests)
            {
                <div class="d-flex flex-column align-items-center py-5">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    <MudText Typo="Typo.body2" Class="mt-2" Color="Color.Secondary">Loading transfer requests...</MudText>
                </div>
            }
            else if (transferRequests?.Any() == true)
            {
                <MudTable Items="@transferRequests" Dense="true" Hover="true" Striped="true" Filter="new Func<InventoryTransferRequestDto, bool>(_requestQuickFilter)" T="InventoryTransferRequestDto">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">Requests</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="_requestSearchString" Placeholder="Search requests..."
                            Adornment="Adornment.Start" Immediate="true"
                            AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>Doc #</MudTh>
                        <MudTh>From</MudTh>
                        <MudTh>To</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Requester</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Items</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Doc #"><strong>@context.DocNum</strong></MudTd>
                        <MudTd DataLabel="From">
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.FromWarehouse</MudChip>
                        </MudTd>
                        <MudTd DataLabel="To">
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">@context.ToWarehouse</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Date">@FormatDate(context.DocDate)</MudTd>
                        <MudTd DataLabel="Requester">@(context.RequesterName ?? "-")</MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Color="@GetStatusColor(context.DocumentStatus)" Size="Size.Small">
                                @(context.DocumentStatus ?? "Open")
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Items">
                            <MudChip T="string" Color="Color.Info" Size="Size.Small">@(context.Lines?.Count ?? 0)</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <div class="d-flex gap-1">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Primary"
                                    Size="Size.Small" OnClick="@(() => ViewTransferRequest(context))" />
                                @if (IsRequestConvertible(context))
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Success"
                                        Size="Size.Small" OnClick="@(() => ConvertRequest(context))"
                                        Disabled="@isConverting" />
                                }
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                    <p class="mt-3 text-muted">No transfer requests found</p>
                    <a href="/transfer-request/create" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i>Create First Request
                    </a>
                </div>
            }
        </MudTabPanel>
    </MudTabs>
</div>

<!-- Transfer Detail Modal -->
@if (selectedTransfer != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-arrow-left-right me-2"></i>Inventory Transfer #@selectedTransfer.DocNum</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="mb-2">
                                <small class="text-muted">From Warehouse</small><br />
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small">@selectedTransfer.FromWarehouse</MudChip>
                            </div>
                            <div class="mb-2">
                                <small class="text-muted">To Warehouse</small><br />
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">@selectedTransfer.ToWarehouse</MudChip>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-2">
                                <small class="text-muted">Date</small><br />
                                <strong>@FormatDate(selectedTransfer.DocDate)</strong>
                            </div>
                            <div class="mb-2">
                                <small class="text-muted">Due Date</small><br />
                                <strong>@FormatDate(selectedTransfer.DueDate)</strong>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(selectedTransfer.Comments))
                            {
                                <div class="mb-2">
                                    <small class="text-muted">Comments</small><br />
                                    @selectedTransfer.Comments
                                </div>
                            }
                        </div>
                    </div>

                    @if (selectedTransfer.Lines?.Any() == true)
                    {
                        <h6 class="mb-3"><i class="bi bi-list-ul me-1"></i>Transfer Lines</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Item Code</th>
                                        <th>Description</th>
                                        <th>From WH</th>
                                        <th>To WH</th>
                                        <th class="text-end">Quantity</th>
                                        <th>UoM</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var line in selectedTransfer.Lines)
                                    {
                                        <tr>
                                            <td>@line.LineNum</td>
                                            <td><code>@line.ItemCode</code></td>
                                            <td>@line.ItemDescription</td>
                                            <td>@line.FromWarehouseCode</td>
                                            <td>@line.ToWarehouseCode</td>
                                            <td class="text-end"><strong>@line.Quantity</strong></td>
                                            <td>@line.UoMCode</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="table-primary">
                                        <td colspan="5" class="text-end"><strong>Total Quantity:</strong></td>
                                        <td class="text-end"><strong>@selectedTransfer.Lines.Sum(l => l.Quantity)</strong></td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Transfer Request Detail Modal -->
@if (selectedTransferRequest != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-text me-2"></i>Transfer Request #@selectedTransferRequest.DocNum</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseRequestModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="mb-2">
                                <small class="text-muted">From Warehouse</small><br />
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small">@selectedTransferRequest.FromWarehouse</MudChip>
                            </div>
                            <div class="mb-2">
                                <small class="text-muted">To Warehouse</small><br />
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">@selectedTransferRequest.ToWarehouse</MudChip>
                            </div>
                            <div class="mb-2">
                                <small class="text-muted">Status</small><br />
                                <MudChip T="string" Color="@GetStatusColor(selectedTransferRequest.DocumentStatus)" Size="Size.Small">
                                    @(selectedTransferRequest.DocumentStatus ?? "Open")
                                </MudChip>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-2">
                                <small class="text-muted">Date</small><br />
                                <strong>@FormatDate(selectedTransferRequest.DocDate)</strong>
                            </div>
                            <div class="mb-2">
                                <small class="text-muted">Due Date</small><br />
                                <strong>@FormatDate(selectedTransferRequest.DueDate)</strong>
                            </div>
                            <div class="mb-2">
                                <small class="text-muted">Requester</small><br />
                                @(selectedTransferRequest.RequesterName ?? "-")
                            </div>
                            <div class="mb-2">
                                <small class="text-muted">Email</small><br />
                                @(selectedTransferRequest.RequesterEmail ?? "-")
                            </div>
                            @if (!string.IsNullOrWhiteSpace(selectedTransferRequest.Comments))
                            {
                                <div class="mb-2">
                                    <small class="text-muted">Comments</small><br />
                                    @selectedTransferRequest.Comments
                                </div>
                            }
                        </div>
                    </div>

                    @if (selectedTransferRequest.Lines?.Any() == true)
                    {
                        <h6 class="mb-3"><i class="bi bi-list-ul me-1"></i>Request Lines</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Item Code</th>
                                        <th>Description</th>
                                        <th>From WH</th>
                                        <th>To WH</th>
                                        <th class="text-end">Quantity</th>
                                        <th>UoM</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var line in selectedTransferRequest.Lines)
                                    {
                                        <tr>
                                            <td>@line.LineNum</td>
                                            <td><code>@line.ItemCode</code></td>
                                            <td>@line.ItemDescription</td>
                                            <td>@line.FromWarehouseCode</td>
                                            <td>@line.ToWarehouseCode</td>
                                            <td class="text-end"><strong>@line.Quantity</strong></td>
                                            <td>@line.UoMCode</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="table-primary">
                                        <td colspan="5" class="text-end"><strong>Total Quantity:</strong></td>
                                        <td class="text-end"><strong>@selectedTransferRequest.Lines.Sum(l => l.Quantity)</strong></td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    @if (IsRequestConvertible(selectedTransferRequest))
                    {
                        <button type="button" class="btn btn-success" @onclick="() => ConvertRequest(selectedTransferRequest)"
                            disabled="@isConverting">
                            @if (isConverting)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                                <span>Converting...</span>
                            }
                            else
                            {
                                <i class="bi bi-arrow-left-right me-1"></i>
                                <span>Convert to Transfer</span>
                            }
                        </button>
                    }
                    <button type="button" class="btn btn-secondary" @onclick="CloseRequestModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}
</div>

@code {
    // Tab state
    private int activeTabIndex = 0;

    // Completed transfers
    private List<InventoryTransferDto>? transfers;
    private InventoryTransferDto? selectedTransfer;
    private bool isLoading = false;
    private string? errorMessage;
    private string? successMessage;
    private int currentPage = 1;
    private int pageSize = 20;
    private bool hasMore = false;
    private int totalCount = 0;
    private int totalPages = 0;

    // Transfer requests
    private List<InventoryTransferRequestDto>? transferRequests;
    private InventoryTransferRequestDto? selectedTransferRequest;
    private bool isLoadingRequests = false;
    private bool isConverting = false;
    private int requestPage = 1;
    private bool hasMoreRequests = false;
    private int transferRequestCount = 0;

    // Warehouse search
    private bool isLoadingWarehouses = true;
    private List<WarehouseDto> cachedWarehouses = new();
    private WarehouseDto? selectedWarehouse;

    private DateTime? fromDate;
    private DateTime? toDate;

    // Quick filter search strings
    private string? _transferSearchString;
    private string? _requestSearchString;

    private bool _hasLoadedData = false;

    // Quick filter for completed transfers
    private Func<InventoryTransferDto, bool> _transferQuickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_transferSearchString))
            return true;
        if (x.DocNum.ToString().Contains(_transferSearchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.DocEntry.ToString().Contains(_transferSearchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.FromWarehouse?.Contains(_transferSearchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if (x.ToWarehouse?.Contains(_transferSearchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if (x.Comments?.Contains(_transferSearchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        return false;
    };

    // Quick filter for transfer requests
    private Func<InventoryTransferRequestDto, bool> _requestQuickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_requestSearchString))
            return true;
        if (x.DocNum.ToString().Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.FromWarehouse?.Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if (x.ToWarehouse?.Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if (x.RequesterName?.Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if (x.DocumentStatus?.Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        return false;
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasLoadedData)
        {
            Logger.LogInformation("InventoryTransfers page: OnAfterRenderAsync - firstRender, starting data load");
            _hasLoadedData = true;
            await LoadWarehousesAsync();
            await LoadTransferRequestsAsync(); // Load transfer requests to get count
            StateHasChanged();
        }
    }

    private async Task LoadWarehousesAsync()
    {
        Logger.LogInformation("InventoryTransfers page: LoadWarehousesAsync started");
        try
        {
            isLoadingWarehouses = true;
            Logger.LogDebug("InventoryTransfers page: Calling CacheService.GetWarehousesAsync()");
            cachedWarehouses = await CacheService.GetWarehousesAsync();
            Logger.LogInformation("InventoryTransfers page: Loaded {Count} warehouses", cachedWarehouses?.Count ?? 0);

            // Pre-select warehouse "01" if it exists
            if (cachedWarehouses != null)
            {
                var defaultWarehouse = cachedWarehouses.FirstOrDefault(w => w.WarehouseCode == "01");
                if (defaultWarehouse != null)
                {
                    selectedWarehouse = defaultWarehouse;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "InventoryTransfers page: Failed to load warehouses");
            errorMessage = $"Failed to load warehouses: {ex.Message}";
        }
        finally
        {
            isLoadingWarehouses = false;
            Logger.LogDebug("InventoryTransfers page: LoadWarehousesAsync completed");
        }
    }

    private async Task<IEnumerable<WarehouseDto>> SearchWarehousesAsync(string searchText, CancellationToken
    cancellationToken)
    {
        // Return all warehouses if search is empty
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return cachedWarehouses.Take(20);
        }

        // Filter warehouses based on search text
        return cachedWarehouses
        .Where(w =>
        (w.WarehouseCode?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (w.WarehouseName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false))
        .Take(20);
    }

    private string FormatDate(string? dateString)
    {
        if (string.IsNullOrEmpty(dateString))
            return "-";

        if (DateTime.TryParse(dateString, out var date))
        {
            return date.ToString("dd MMM yyyy");
        }

        return dateString;
    }

    private async Task LoadTransfers()
    {
        if (selectedWarehouse == null)
            return;

        isLoading = true;
        errorMessage = null;

        try
        {
            var warehouseCode = selectedWarehouse.WarehouseCode!;

            if (fromDate.HasValue && toDate.HasValue)
            {
                var response = await TransferService.GetTransfersByDateRangeAsync(warehouseCode, fromDate.Value, toDate.Value);
                transfers = response?.Transfers;
                totalCount = response?.Count ?? transfers?.Count ?? 0;
                hasMore = false;
                totalPages = 1;
            }
            else if (fromDate.HasValue)
            {
                var response = await TransferService.GetTransfersByDateAsync(warehouseCode, fromDate.Value);
                transfers = response?.Transfers;
                totalCount = response?.Count ?? transfers?.Count ?? 0;
                hasMore = false;
                totalPages = 1;
            }
            else
            {
                var response = await TransferService.GetPagedTransfersAsync(warehouseCode, currentPage, pageSize);
                if (response != null)
                {
                    transfers = response.Transfers;
                    hasMore = response.HasMore;
                    totalCount = response.Count;
                    totalPages = pageSize > 0 ? (int)Math.Ceiling((double)totalCount / pageSize) : 1;
                }
                else
                {
                    transfers = null;
                    errorMessage = "Failed to load transfers - no response from server. Check if the API is running.";
                }
            }
        }
        catch (TimeoutException ex)
        {
            Logger.LogWarning(ex, "Timeout loading transfers");
            errorMessage = "The request timed out while loading transfers. SAP may be responding slowly. Please try again.";
        }
        catch (HttpRequestException ex)
        {
            Logger.LogError(ex, "HTTP error loading transfers");
            errorMessage = $"Connection error while loading transfers: {ex.Message}";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading transfers");
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ClearFilter()
    {
        selectedWarehouse = null;
        fromDate = null;
        toDate = null;
        currentPage = 1;
        transfers = null;
        totalCount = 0;
        totalPages = 0;

        // Re-select default warehouse
        var defaultWarehouse = cachedWarehouses?.FirstOrDefault(w => w.WarehouseCode == "01");
        if (defaultWarehouse != null)
        {
            selectedWarehouse = defaultWarehouse;
        }
    }

