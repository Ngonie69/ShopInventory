@page "/inventory-transfers"
@using Microsoft.AspNetCore.Authorization
@using ShopInventory.Web.Services
@attribute [Authorize(Roles = "Admin,StockController,DepotController")]
@inject IInventoryTransferService TransferService
@inject IMasterDataCacheService CacheService
@inject ILogger<InventoryTransfers> Logger
@inject IAppSettingsProvider AppSettings
@inject IAuditService AuditService
@rendermode InteractiveServer

<PageTitle>Inventory Transfers - Shop Inventory</PageTitle>

<style>
    /* ── Page ────────────────────────────────────────── */
    .it-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* ── Header ──────────────────────────────────────── */
    .it-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .it-header-left {
        display: flex;
        align-items: center;
        gap: 0.85rem;
    }

    .it-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        box-shadow: 0 4px 14px rgba(37, 99, 235, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .it-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }

    .it-header p {
        color: #6b7280;
        margin: 0;
        font-size: 0.88rem;
    }

    .it-header-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .btn-gradient {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border: none;
        color: #fff;
        padding: 0.55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.88rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        box-shadow: 0 2px 8px rgba(37, 99, 235, .25);
    }

    .btn-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(37, 99, 235, .4);
        color: #fff;
    }

    .btn-outline-action {
        background: #fff;
        border: 1px solid #d1d5db;
        color: #374151;
        padding: 0.55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.88rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

    .btn-outline-action:hover {
        background: #f3f4f6;
        border-color: #9ca3af;
        color: #111827;
    }

    /* ── Stat Cards ──────────────────────────────────── */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.85rem;
        border: 1px solid #e5e7eb;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        transition: box-shadow .2s;
    }

    .stat-card:hover {
        box-shadow: 0 4px 14px rgba(0, 0, 0, .08);
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .stat-icon.blue {
        background: #dbeafe;
        color: #2563eb;
    }

    .stat-icon.green {
        background: #d1fae5;
        color: #059669;
    }

    .stat-icon.amber {
        background: #fef3c7;
        color: #d97706;
    }

    .stat-icon.purple {
        background: #ede9fe;
        color: #7c3aed;
    }

    .stat-info .stat-value {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1.2;
    }

    .stat-info .stat-label {
        font-size: 0.78rem;
        color: #6b7280;
        font-weight: 500;
    }

    /* ── Tabs ────────────────────────────────────────── */
    .it-tabs {
        display: flex;
        gap: 0;
        background: #fff;
        border-radius: 12px 12px 0 0;
        border: 1px solid #e5e7eb;
        border-bottom: none;
        overflow: hidden;
    }

    .it-tab {
        flex: 1;
        padding: 0.85rem 1.25rem;
        text-align: center;
        font-weight: 600;
        font-size: 0.9rem;
        color: #6b7280;
        background: #fafbfc;
        border: none;
        border-bottom: 3px solid transparent;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .it-tab:hover {
        background: #f3f4f6;
        color: #374151;
    }

    .it-tab.active {
        background: #fff;
        color: #2563eb;
        border-bottom-color: #2563eb;
    }

    .it-tab .tab-badge {
        background: #e5e7eb;
        color: #6b7280;
        padding: 0.1rem 0.5rem;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .it-tab.active .tab-badge {
        background: #dbeafe;
        color: #2563eb;
    }

    .it-tab-body {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-top: none;
        border-radius: 0 0 12px 12px;
        padding: 1.25rem;
        min-height: 300px;
    }

    /* ── Filter Bar ──────────────────────────────────── */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: flex-end;
        padding: 1rem 1.25rem;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        margin-bottom: 1.25rem;
    }

    .filter-bar .filter-field {
        flex: 1;
        min-width: 160px;
    }

    .filter-bar .filter-field label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.3rem;
    }

    .filter-bar .filter-actions-row {
        display: flex;
        gap: 0.5rem;
        align-items: flex-end;
    }

    .btn-search {
        background: #2563eb;
        color: #fff;
        border: none;
        padding: 0.5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
    }

    .btn-search:hover {
        background: #1d4ed8;
    }

    .btn-search:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .btn-clear {
        background: #fff;
        color: #6b7280;
        border: 1px solid #d1d5db;
        padding: 0.5rem 1.1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all .2s;
    }

    .btn-clear:hover {
        background: #f3f4f6;
    }

    /* ── Table ───────────────────────────────────────── */
    .it-table-wrapper {
        overflow-x: auto;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
    }

    .it-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 0.88rem;
    }

    .it-table thead th {
        background: #f8fafc;
        font-weight: 600;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6b7280;
        padding: 0.75rem 1rem;
        border-bottom: 2px solid #e5e7eb;
        white-space: nowrap;
    }

    .it-table tbody td {
        padding: 0.7rem 1rem;
        border-bottom: 1px solid #f3f4f6;
        color: #374151;
        vertical-align: middle;
    }

    .it-table tbody tr {
        transition: background .15s;
    }

    .it-table tbody tr:hover {
        background: #f8fafc;
    }

    .it-table tbody tr:last-child td {
        border-bottom: none;
    }

    /* ── Badges / Pills ──────────────────────────────── */
    .wh-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.2rem 0.6rem;
        border-radius: 6px;
        font-size: 0.78rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .wh-badge.from {
        background: #fef3c7;
        color: #92400e;
    }

    .wh-badge.to {
        background: #d1fae5;
        color: #065f46;
    }

    .wh-badge.info {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .status-badge.open {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-badge.closed {
        background: #e5e7eb;
        color: #4b5563;
    }

    .status-badge.approved {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.rejected {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-badge.pending {
        background: #fef3c7;
        color: #92400e;
    }

    .flow-arrow {
        color: #9ca3af;
        font-size: 0.85rem;
        margin: 0 0.25rem;
    }

    /* ── Action Buttons ──────────────────────────────── */
    .btn-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        background: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-size: 0.95rem;
        color: #2563eb;
    }

    .btn-icon:hover {
        background: #dbeafe;
        border-color: #93c5fd;
        color: #1d4ed8;
    }

    .btn-icon.convert-btn {
        color: #059669;
        border-color: #a7f3d0;
        background: #f0fdf4;
    }

    .btn-icon.convert-btn:hover {
        background: #d1fae5;
        border-color: #6ee7b7;
        color: #047857;
    }

    .btn-icon:disabled {
        opacity: 0.35;
        cursor: not-allowed;
    }

    /* ── Search within table ─────────────────────────── */
    .table-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .table-header h6 {
        font-weight: 600;
        color: #1a1a2e;
        margin: 0;
        font-size: 0.95rem;
    }

    .quick-search {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 0.35rem 0.75rem;
        width: 250px;
        max-width: 100%;
    }

    .quick-search i {
        color: #9ca3af;
        font-size: 0.85rem;
    }

    .quick-search input {
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.85rem;
        color: #374151;
        width: 100%;
    }

    .quick-search input::placeholder {
        color: #9ca3af;
    }

    /* ── Empty State ─────────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 1.8rem;
        color: #9ca3af;
    }

    .empty-state h6 {
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.35rem;
    }

    .empty-state p {
        color: #9ca3af;
        font-size: 0.88rem;
        margin-bottom: 1rem;
    }

    /* ── Alerts ──────────────────────────────────────── */
    .alert-banner {
        border-radius: 10px;
        padding: 0.75rem 1rem;
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
        margin-bottom: 1rem;
        font-size: 0.88rem;
        animation: slideDown .3s ease;
    }

    .alert-banner.success-alert {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .alert-banner.error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .alert-banner .alert-body {
        flex: 1;
    }

    .alert-banner .alert-close {
        background: none;
        border: none;
        color: inherit;
        opacity: 0.45;
        cursor: pointer;
        padding: 0.2rem;
        font-size: 1rem;
    }

    .alert-banner .alert-close:hover {
        opacity: 1;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ── Modal / Drawer ──────────────────────────────── */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .45);
        z-index: 9998;
        animation: fadeIn .2s ease;
    }

    .detail-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(560px, 95vw);
        height: 100vh;
        background: #fff;
        z-index: 9999;
        box-shadow: -8px 0 30px rgba(0, 0, 0, .12);
        display: flex;
        flex-direction: column;
        animation: slideInRight .25s ease;
    }

    .drawer-header {
        padding: 1.15rem 1.5rem;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }

    .drawer-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .drawer-header .btn-close-drawer {
        background: rgba(255, 255, 255, .15);
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s;
        font-size: 1rem;
    }

    .drawer-header .btn-close-drawer:hover {
        background: rgba(255, 255, 255, .25);
    }

    .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .drawer-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: 0.5rem;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .detail-item .detail-label {
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #9ca3af;
        margin-bottom: 0.2rem;
    }

    .detail-item .detail-value {
        font-size: 0.92rem;
        font-weight: 600;
        color: #1a1a2e;
    }

    .detail-section-title {
        font-weight: 600;
        color: #1a1a2e;
        font-size: 0.9rem;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }

        to {
            transform: translateX(0);
        }
    }

    /* ── Converting overlay ──────────────────────────── */
    .converting-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .55);
        z-index: 99999;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: #fff;
    }

    .converting-overlay .spinner-border {
        width: 3rem;
        height: 3rem;
    }

    .converting-overlay p {
        margin-top: 1rem;
        font-weight: 600;
        font-size: 1.1rem;
    }

    .converting-overlay small {
        color: rgba(255, 255, 255, .6);
    }

    /* ── Pager ───────────────────────────────────────── */
    .table-pager {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding: 0.75rem 0;
        font-size: 0.82rem;
        color: #6b7280;
    }

    .table-pager .pager-info {
        font-weight: 500;
    }

    .pager-buttons {
        display: flex;
        gap: 0.35rem;
    }

    .pager-buttons button {
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        padding: 0.3rem 0.65rem;
        border-radius: 6px;
        font-size: 0.82rem;
        cursor: pointer;
        transition: all .15s;
        font-weight: 500;
    }

    .pager-buttons button:hover:not(:disabled) {
        background: #f3f4f6;
        border-color: #9ca3af;
    }

    .pager-buttons button:disabled {
        opacity: 0.35;
        cursor: not-allowed;
    }

    /* ── Responsive ──────────────────────────────────── */
    @@media (max-width: 768px) {
        .stat-row {
            grid-template-columns: 1fr 1fr;
        }

        .detail-grid {
            grid-template-columns: 1fr;
        }

        .it-header {
            flex-direction: column;
        }
    }
</style>

@if (isConverting)
{
    <div class="converting-overlay">
        <div class="spinner-border text-light" role="status"></div>
        <p>Converting Transfer Request…</p>
        <small>Please wait while the transfer is being created</small>
    </div>
}

<div class="it-page">
    <div class="container-fluid">

        <!-- ━━━ Header ━━━ -->
        <div class="it-header">
            <div class="it-header-left">
                <div class="it-header-icon"><i class="bi bi-arrow-left-right"></i></div>
                <div>
                    <h2>Inventory Transfers</h2>
                    <p>Manage stock movements between warehouses</p>
                </div>
            </div>
            <div class="it-header-actions">
                <a href="/inventory-transfer/create" class="btn-gradient">
                    <i class="bi bi-plus-lg"></i> New Transfer
                </a>
                <a href="/transfer-request/create" class="btn-outline-action">
                    <i class="bi bi-file-earmark-plus"></i> New Request
                </a>
            </div>
        </div>

        <!-- Alerts -->
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert-banner success-alert">
                <i class="bi bi-check-circle-fill"></i>
                <div class="alert-body">@successMessage</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Class="alert-close" OnClick="() => successMessage = null"
                               Size="Size.Small" />
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-banner error-alert">
                <i class="bi bi-exclamation-octagon-fill"></i>
                <div class="alert-body">@errorMessage</div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Class="alert-close" OnClick="() => errorMessage = null"
                               Size="Size.Small" />
            </div>
        }

        <!-- ━━━ Stat Cards ━━━ -->
        <div class="stat-row">
            <div class="stat-card">
                <div class="stat-icon blue"><i class="bi bi-arrow-left-right"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@totalCount</div>
                    <div class="stat-label">Completed Transfers</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon amber"><i class="bi bi-file-earmark-text"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@transferRequestCount</div>
                    <div class="stat-label">Transfer Requests</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="bi bi-building"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@(selectedWarehouse?.WarehouseCode ?? "—")</div>
                    <div class="stat-label">Active Warehouse</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon purple"><i class="bi bi-calendar-range"></i></div>
                <div class="stat-info">
                    <div class="stat-value">@(fromDate.HasValue? fromDate.Value.ToString("dd MMM") : "All")</div>
                    <div class="stat-label">Date Filter</div>
                </div>
            </div>
        </div>

        <!-- ━━━ Tabs ━━━ -->
        <div class="it-tabs">
            <MudButton Class="@($"it-tab {(activeTabIndex == 0 ? "active" : "")}")" OnClick="() => SwitchTab(0)">
                <i class="bi bi-arrow-left-right"></i>
                Completed Transfers
                @if (totalCount > 0)
                {
                    <span class="tab-badge">@totalCount</span>
                }
            </MudButton>
            <MudButton Class="@($"it-tab {(activeTabIndex == 1 ? "active" : "")}")" OnClick="() => SwitchTab(1)">
                <i class="bi bi-file-earmark-text"></i>
                Transfer Requests
                @if (transferRequestCount > 0)
                {
                    <span class="tab-badge">@transferRequestCount</span>
                }
            </MudButton>
        </div>

        <div class="it-tab-body">
            @if (activeTabIndex == 0)
            {
                <!-- ══════ COMPLETED TRANSFERS TAB ══════ -->

                <!-- Filter Bar -->
                <div class="filter-bar">
                    <div class="filter-field" style="min-width:220px;">
                        <label>Warehouse <span class="text-danger">*</span></label>
                        @if (isLoadingWarehouses)
                        {
                            <div class="d-flex align-items-center gap-2" style="padding:0.4rem 0;">
                                <div class="spinner-border spinner-border-sm text-primary"></div>
                                <span class="text-muted" style="font-size:0.85rem;">Loading…</span>
                            </div>
                        }
                        else
                        {
                            <MudAutocomplete T="WarehouseDto" @bind-Value="selectedWarehouse" Label="Search warehouse…"
                                             SearchFunc="SearchWarehousesAsync"
                                             ToStringFunc="@(w => w == null ? string.Empty : $"{w.WarehouseCode} - {w.WarehouseName}")"
                                             Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense" ResetValueOnEmptyText="true"
                                             ShowProgressIndicator="true" MaxItems="20" DebounceInterval="150" Class="mt-0">
                                <ItemTemplate>
                                    <div class="d-flex flex-column py-1">
                                        <span class="fw-semibold" style="font-size:0.88rem;">@context.WarehouseCode</span>
                                        <small class="text-muted">@context.WarehouseName</small>
                                    </div>
                                </ItemTemplate>
                                <NoItemsTemplate>
                                    <div class="p-2 text-muted small"><i class="bi bi-info-circle me-1"></i>No warehouses found
                                    </div>
                                </NoItemsTemplate>
                            </MudAutocomplete>
                        }
                    </div>
                    <div class="filter-field" style="min-width:150px;">
                        <label>From Date</label>
                        <FlexibleDatePicker Label="From" @bind-Date="fromDate" Variant="Variant.Outlined" />
                    </div>
                    <div class="filter-field" style="min-width:150px;">
                        <label>To Date</label>
                        <FlexibleDatePicker Label="To" @bind-Date="toDate" Variant="Variant.Outlined" />
                    </div>
                    <div class="filter-actions-row">
                        <MudButton Class="btn-search" OnClick="LoadTransfers"
                                   Disabled="@(selectedWarehouse == null || isLoading)">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <i class="bi bi-search"></i>
                            }
                            Search
                        </MudButton>
                        <MudButton Class="btn-clear" OnClick="ClearFilter"><i class="bi bi-x-lg"></i> Clear</MudButton>
                    </div>
                </div>

                @if (isLoading)
                {
                    <div class="empty-state">
                        <div class="spinner-border text-primary" role="status" style="width:2.5rem;height:2.5rem;"></div>
                        <p class="mt-3 text-muted">Loading transfers…</p>
                    </div>
                }
                else if (transfers?.Any() == true)
                {
                    <MudTable @ref="@_transfersTable" Items="@transfers" RowsPerPage="@_pageSize" Hover="true" Dense="true"
                              Breakpoint="Breakpoint.Sm" LoadingProgressColor="Color.Info"
                              Filter="new Func<InventoryTransferDto, bool>(_transferQuickFilter)" Elevation="0"
                              Style="border: 1px solid #e5e7eb; border-radius: 10px;">
                        <ToolBarContent>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600; color:#1a1a2e;">
                                <i class="bi bi-list-ul me-1"></i> @transfers.Count transfer(s) for
                                @selectedWarehouse?.WarehouseCode
                            </MudText>
                            <MudSpacer />
                            <MudTextField @bind-Value="_transferSearchString" Placeholder="Quick filter…"
                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                                          Class="mt-0" Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>Doc #</MudTh>
                            <MudTh>Route</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh>Due Date</MudTh>
                            <MudTh>Items</MudTh>
                            <MudTh Style="width:60px;text-align:center;">View</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Doc #"><strong style="color:#2563eb;">#@context.DocNum</strong></MudTd>
                            <MudTd DataLabel="Route">
                                <span class="wh-badge from"><i class="bi bi-box-arrow-right"></i> @context.FromWarehouse</span>
                                <span class="flow-arrow"><i class="bi bi-arrow-right"></i></span>
                                <span class="wh-badge to"><i class="bi bi-box-arrow-in-right"></i> @context.ToWarehouse</span>
                            </MudTd>
                            <MudTd DataLabel="Date">@FormatDate(context.DocDate)</MudTd>
                            <MudTd DataLabel="Due Date">@FormatDate(context.DueDate)</MudTd>
                            <MudTd DataLabel="Items"><span class="wh-badge info">@(context.Lines?.Count ?? 0) items</span>
                            </MudTd>
                            <MudTd DataLabel="View" Style="text-align:center;">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary"
                                               OnClick="() => ViewTransfer(context)" />
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <div class="pager-row">
                                <div class="page-size-wrap">
                                    <span>Show</span>
                                    <select @bind="_pageSize">
                                        <option value="10">10</option>
                                        <option value="25">25</option>
                                        <option value="50">50</option>
                                        <option value="100">100</option>
                                    </select>
                                    <span>per page</span>
                                </div>
                                <MudPagination SelectedChanged="TransferPageChanged"
                                               Count="@((_transfersTable.GetFilteredItemsCount() + _transfersTable.RowsPerPage - 1) / _transfersTable.RowsPerPage)"
                                               Class="pa-4" />
                            </div>
                        </PagerContent>
                    </MudTable>
