                            <MudTd DataLabel="Route">
                                <span class="wh-badge from"><i class="bi bi-box-arrow-right"></i> @context.FromWarehouse</span>
                                <span class="flow-arrow"><i class="bi bi-arrow-right"></i></span>
                                <span class="wh-badge to"><i class="bi bi-box-arrow-in-right"></i> @context.ToWarehouse</span>
                            </MudTd>
                            <MudTd DataLabel="Date">@FormatDate(context.DocDate)</MudTd>
