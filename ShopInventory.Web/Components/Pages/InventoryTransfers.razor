@page "/inventory-transfers"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using System.Text
@using ShopInventory.Web.Services
@attribute [Authorize]
@inject IInventoryTransferService TransferService
@inject IApprovalProcessService ApprovalProcessService
@inject IMasterDataCacheService CacheService
@inject ILogger<InventoryTransfers> Logger
@inject IAppSettingsProvider AppSettings
@inject IAuditService AuditService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Inventory Transfers - Shop Inventory</PageTitle>

@* Styles live in wwwroot/css/inventory-transfers.css (linked from App.razor). *@

@if (isConverting || isRejecting)
{
    <div class="itx-busy">
        <div class="spinner-border text-light" role="status"></div>
        <p class="mb-0 fw-semibold">@(isRejecting ? "Rejecting transfer request…" : "Approving transfer request…")</p>
        <small class="text-white-50">Please wait while the approval decision is processed</small>
    </div>
}

<div class="itx">

    <!-- ── Header ─────────────────────────────────────────── -->
    <div class="itx-head">
        <div>
            <h1>Inventory Transfers</h1>
            <p>Manage stock movements between warehouses</p>
        </div>
        <div class="itx-head-actions">
            <a href="/transfer-request/create" class="itx-btn">
                <i class="bi bi-file-earmark-plus"></i> New Request
            </a>
            <AuthorizeView Roles="Admin">
                <a href="/inventory-transfer/create" class="itx-btn itx-btn-primary">
                    <i class="bi bi-plus-lg"></i> New Transfer
                </a>
            </AuthorizeView>
        </div>
    </div>

    <!-- ── Alerts ─────────────────────────────────────────── -->
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="itx-alert ok">
            <i class="bi bi-check-circle-fill"></i>
            <div class="itx-alert-body">@successMessage</div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => successMessage = null" />
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="itx-alert err">
            <i class="bi bi-exclamation-octagon-fill"></i>
            <div class="itx-alert-body">@errorMessage</div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => errorMessage = null" />
        </div>
    }

    <!-- ── Panel ──────────────────────────────────────────── -->
    <div class="itx-panel">

        <div class="itx-tabs">
            <button type="button" class="itx-tab @(activeTabIndex == 0 ? "active" : "")" @onclick="() => SwitchTab(0)">
                <i class="bi bi-arrow-left-right"></i>
                Completed Transfers
                @if (totalCount > 0)
                {
                    <span class="itx-tab-count">@totalCount</span>
                }
            </button>
            <button type="button" class="itx-tab @(activeTabIndex == 1 ? "active" : "")" @onclick="() => SwitchTab(1)">
                <i class="bi bi-file-earmark-text"></i>
                Transfer Requests
                @if (transferRequestCount > 0)
                {
                    <span class="itx-tab-count">@transferRequestCount</span>
                }
            </button>
        </div>

        @if (activeTabIndex == 0)
        {
            <!-- ══════ COMPLETED TRANSFERS ══════ -->
            <div class="itx-toolbar">
                <div class="itx-grow">
                    @if (isLoadingWarehouses)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <div class="spinner-border spinner-border-sm text-primary"></div>
                            <span class="itx-arrow">Loading warehouses…</span>
                        </div>
                    }
                    else
                    {
                        <MudAutocomplete T="WarehouseDto" @bind-Value="selectedWarehouse" Label="Warehouse"
                                         SearchFunc="SearchWarehousesAsync"
                                         ToStringFunc="@(w => w == null ? string.Empty : $"{w.WarehouseCode} - {w.WarehouseName}")"
                                         Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense" ResetValueOnEmptyText="true"
                                         ShowProgressIndicator="true" MaxItems="20" DebounceInterval="150" Class="mt-0">
                            <ItemTemplate>
                                <div class="d-flex flex-column py-1">
                                    <span class="fw-semibold" style="font-size:.85rem;">@context.WarehouseCode</span>
                                    <small class="text-muted">@context.WarehouseName</small>
                                </div>
                            </ItemTemplate>
                            <NoItemsTemplate>
                                <div class="p-2 text-muted small">No warehouses found</div>
                            </NoItemsTemplate>
                        </MudAutocomplete>
                    }
                </div>

                <div class="itx-field">
                    <FlexibleDatePicker Label="From" @bind-Date="fromDate" Variant="Variant.Outlined" />
                </div>
                <div class="itx-field">
                    <FlexibleDatePicker Label="To" @bind-Date="toDate" Variant="Variant.Outlined" />
                </div>

                <button type="button" class="itx-btn itx-btn-primary" @onclick="LoadTransfers"
                        disabled="@(selectedWarehouse == null || isLoading)">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    else
                    {
                        <i class="bi bi-search"></i>
                    }
                    Search
                </button>
                <button type="button" class="itx-btn" @onclick="ClearFilter">Clear</button>

                <div class="itx-spacer"></div>

                @if (transfers?.Any() == true)
                {
                    <div class="itx-field">
                        <MudTextField @bind-Value="_transferSearchString" Placeholder="Filter results…"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Clearable="true"
                                      Class="mt-0" />
                    </div>
                }
            </div>

            @if (isLoading)
            {
                <div class="itx-empty">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3 mb-0">Loading transfers…</p>
                </div>
            }
            else if (transfers?.Any() == true)
            {
                <div class="itx-meta">
                    @transfers.Count transfer(s) in @selectedWarehouse?.WarehouseCode
                </div>
                <div class="itx-body">
                    <MudTable @ref="@_transfersTable" Items="@transfers" RowsPerPage="@_pageSize" Hover="true" Dense="true"
                              Breakpoint="Breakpoint.Sm" LoadingProgressColor="Color.Info" Elevation="0"
                              Filter="new Func<InventoryTransferDto, bool>(_transferQuickFilter)">
                        <HeaderContent>
                            <MudTh>Doc #</MudTh>
                            <MudTh>Route</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh>Due Date</MudTh>
                            <MudTh>Items</MudTh>
                            <MudTh Style="width:60px;text-align:center;">View</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Doc #"><span class="itx-doc">#@context.DocNum</span></MudTd>
                            <MudTd DataLabel="Route">
                                <span class="itx-route">
                                    <span class="itx-wh src">@context.FromWarehouse</span>
                                    <i class="bi bi-arrow-right itx-arrow"></i>
                                    <span class="itx-wh dst">@context.ToWarehouse</span>
                                </span>
                            </MudTd>
                            <MudTd DataLabel="Date">@FormatDate(context.DocDate)</MudTd>
                            <MudTd DataLabel="Due Date">@FormatDate(context.DueDate)</MudTd>
                            <MudTd DataLabel="Items"><span class="itx-wh count">@(context.Lines?.Count ?? 0)</span></MudTd>
                            <MudTd DataLabel="View" Style="text-align:center;">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary"
                                               OnClick="() => ViewTransfer(context)" />
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <div class="itx-empty">
                                <i class="bi bi-funnel itx-empty-icon"></i>
                                <h6>No Matching Transfers</h6>
                                <p>No transfers match "@_transferSearchString".</p>
                            </div>
                        </NoRecordsContent>
                        <PagerContent>
                            <div class="pager-row">
                                <div class="page-size-wrap">
                                    <span>Show</span>
                                    <select @bind="_pageSize">
                                        <option value="10">10</option>
                                        <option value="25">25</option>
                                        <option value="50">50</option>
                                        <option value="100">100</option>
                                        <option value="200">200</option>
                                    </select>
                                    <span>per page</span>
                                </div>
                                <MudPagination SelectedChanged="TransferPageChanged"
                                               Count="@((_transfersTable.GetFilteredItemsCount() + _transfersTable.RowsPerPage - 1) / _transfersTable.RowsPerPage)"
                                               Class="pa-4" />
                            </div>
                        </PagerContent>
                    </MudTable>
                </div>
            }
            else if (selectedWarehouse != null)
            {
                <div class="itx-empty">
                    <i class="bi bi-inbox itx-empty-icon"></i>
                    <h6>No Transfers Found</h6>
                    <p>Nothing in <strong>@selectedWarehouse.WarehouseCode</strong> for this date range.</p>
                    <button type="button" class="itx-btn" @onclick="LoadTransfers">
                        <i class="bi bi-arrow-clockwise"></i> Retry
                    </button>
                </div>
            }
            else
            {
                <div class="itx-empty">
                    <i class="bi bi-search itx-empty-icon"></i>
                    <h6>Search Transfers</h6>
                    <p>Pick a warehouse, then hit Search.</p>
                </div>
            }
        }
        else
        {
            <!-- ══════ TRANSFER REQUESTS ══════ -->
            <div class="itx-toolbar">
                <div class="itx-grow">
                    <MudTextField @bind-Value="_requestSearchString" Placeholder="Search doc #, route, requester…"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Clearable="true"
                                  Class="mt-0" />
                </div>
                <div class="itx-field">
                    <MudSelect T="string" @bind-Value="_requestStatusFilter" Label="Status" Dense="true"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="mt-0">
                        @foreach (var status in RequestStatusOptions)
                        {
                            <MudSelectItem T="string" Value="@status">@status</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                <button type="button" class="itx-btn @(showRequestFilters || ExtraRequestFilterCount > 0 ? "is-on" : "")"
                        @onclick="() => showRequestFilters = !showRequestFilters">
                    <i class="bi bi-sliders"></i> Filters
                    @if (ExtraRequestFilterCount > 0)
                    {
                        <span class="itx-btn-count">@ExtraRequestFilterCount</span>
                    }
                </button>
                <button type="button" class="itx-btn" @onclick="RefreshTransferRequests" disabled="@isLoadingRequests">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>

            @if (showRequestFilters)
            {
                <div class="itx-filters">
                    <MudSelect T="string" @bind-Value="_requestFromWarehouseFilter" Label="From warehouse" Dense="true"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="mt-0">
                        @foreach (var warehouse in RequestFromWarehouseOptions)
                        {
                            <MudSelectItem T="string" Value="@warehouse">@warehouse</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="string" @bind-Value="_requestToWarehouseFilter" Label="To warehouse" Dense="true"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="mt-0">
                        @foreach (var warehouse in RequestToWarehouseOptions)
                        {
                            <MudSelectItem T="string" Value="@warehouse">@warehouse</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTextField @bind-Value="_requestRequesterFilter" Label="Requester" Placeholder="Name or email…"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Clearable="true"
                                  Class="mt-0" />
                    <FlexibleDatePicker Label="From date" @bind-Date="requestFromDate" Variant="Variant.Outlined" />
                    <FlexibleDatePicker Label="To date" @bind-Date="requestToDate" Variant="Variant.Outlined" />
                    <div class="itx-filters-foot">
                        <button type="button" class="itx-btn itx-btn-sm" @onclick="ClearRequestFilters"
                                disabled="@(!HasActiveRequestFilters)">
                            Clear all filters
                        </button>
                    </div>
                </div>
            }

            @if (isLoadingRequests)
            {
                <div class="itx-empty">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3 mb-0">Loading transfer requests…</p>
                </div>
            }
            else if (transferRequests?.Any() == true)
            {
                <div class="itx-meta">
                    @FilteredRequestCount request(s)
                    @if (HasActiveRequestFilters)
                    {
                        <span>— filtered from @transferRequestCount</span>
                    }
                </div>
                <div class="itx-body">
                    <MudTable @ref="@_requestsTable" Items="@transferRequests" RowsPerPage="@_pageSize" Hover="true"
                              Dense="true" Breakpoint="Breakpoint.Sm" LoadingProgressColor="Color.Info" Elevation="0"
                              Filter="new Func<InventoryTransferRequestDto, bool>(_requestQuickFilter)">
                        <HeaderContent>
                            <MudTh>Doc #</MudTh>
                            <MudTh>Route</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh>Requester</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Items</MudTh>
                            <MudTh Style="width:100px;text-align:center;">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Doc #"><span class="itx-doc">#@context.DocNum</span></MudTd>
                            <MudTd DataLabel="Route">
                                <span class="itx-route">
                                    <span class="itx-wh src">@context.FromWarehouse</span>
                                    <i class="bi bi-arrow-right itx-arrow"></i>
                                    <span class="itx-wh dst">@context.ToWarehouse</span>
                                </span>
                            </MudTd>
                            <MudTd DataLabel="Date">@FormatDate(context.DocDate)</MudTd>
                            <MudTd DataLabel="Requester">@(context.RequesterName ?? "—")</MudTd>
                            <MudTd DataLabel="Status">
                                <span class="itx-status @GetStatusCssClass(context.ApprovalStatus ?? context.DocumentStatus)">
                                    @GetApprovalDisplayStatus(context)
                                </span>
                            </MudTd>
                            <MudTd DataLabel="Items"><span class="itx-wh count">@(context.Lines?.Count ?? 0)</span></MudTd>
                            <MudTd DataLabel="Actions" Style="text-align:center;">
                                <div class="d-flex justify-content-center gap-1">
                                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                                   Color="Color.Primary" OnClick="() => ViewTransferRequest(context)" />
                                    @if (CanCurrentUserDecide(context))
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.FactCheck" Size="Size.Small"
                                                       Color="Color.Success" OnClick="() => ViewTransferRequest(context)"
                                                       Disabled="@(isConverting || isRejecting)" />
                                    }
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <div class="itx-empty">
                                <i class="bi bi-funnel itx-empty-icon"></i>
                                <h6>No Matching Requests</h6>
                                <p>No transfer requests match the current filters.</p>
                                <button type="button" class="itx-btn" @onclick="ClearRequestFilters"
                                        disabled="@(!HasActiveRequestFilters)">
                                    Clear filters
                                </button>
                            </div>
                        </NoRecordsContent>
                        <PagerContent>
                            <div class="pager-row">
                                <div class="page-size-wrap">
                                    <span>Show</span>
                                    <select @bind="_pageSize">
                                        <option value="10">10</option>
                                        <option value="25">25</option>
                                        <option value="50">50</option>
                                        <option value="100">100</option>
                                        <option value="200">200</option>
                                    </select>
                                    <span>per page</span>
                                </div>
                                <MudPagination SelectedChanged="RequestPageChanged"
                                               Count="@((_requestsTable.GetFilteredItemsCount() + _requestsTable.RowsPerPage - 1) / _requestsTable.RowsPerPage)"
                                               Class="pa-4" />
                            </div>
                        </PagerContent>
                    </MudTable>
                </div>
            }
            else
            {
                <div class="itx-empty">
                    <i class="bi bi-file-earmark-text itx-empty-icon"></i>
                    <h6>No Transfer Requests</h6>
                    <p>No transfer requests have been created yet.</p>
                    <a href="/transfer-request/create" class="itx-btn itx-btn-primary">
                        <i class="bi bi-plus-lg"></i> Create First Request
                    </a>
                </div>
            }
        }
    </div>
</div>

<!-- ── Transfer detail drawer ─────────────────────────────── -->
@if (selectedTransfer != null)
{
    <div class="itx-scrim" @onclick="CloseModal"></div>
    <div class="itx-drawer">
        <div class="itx-drawer-head">
            <h5><i class="bi bi-arrow-left-right me-2"></i>Transfer #@selectedTransfer.DocNum</h5>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CloseModal" />
        </div>
        <div class="itx-drawer-body">
            <div class="itx-route-card">
                <div class="leg src">
                    <div class="leg-label">Source</div>
                    <div class="leg-value">@selectedTransfer.FromWarehouse</div>
                </div>
                <i class="bi bi-arrow-right-circle-fill" style="font-size:1.35rem;color:var(--itx-accent);"></i>
                <div class="leg dst">
                    <div class="leg-label">Destination</div>
                    <div class="leg-value">@selectedTransfer.ToWarehouse</div>
                </div>
            </div>

            <div class="itx-grid">
                <div>
                    <div class="k">Doc Entry</div>
                    <div class="v">@selectedTransfer.DocEntry</div>
                </div>
                <div>
                    <div class="k">Doc Number</div>
                    <div class="v">#@selectedTransfer.DocNum</div>
                </div>
                <div>
                    <div class="k">Document Date</div>
                    <div class="v">@FormatDate(selectedTransfer.DocDate)</div>
                </div>
                <div>
                    <div class="k">Due Date</div>
                    <div class="v">@FormatDate(selectedTransfer.DueDate)</div>
                </div>
                @if (!string.IsNullOrWhiteSpace(selectedTransfer.Comments))
                {
                    <div class="span-2">
                        <div class="k">Comments</div>
                        <div class="v plain">@selectedTransfer.Comments</div>
                    </div>
                }
            </div>

            @if (selectedTransfer.Lines?.Any() == true)
            {
                <div class="itx-section">
                    <i class="bi bi-list-check"></i> Transfer Lines (@selectedTransfer.Lines.Count)
                </div>
                <div class="itx-lines-wrap">
                    <table class="itx-lines">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Item</th>
                                <th>From</th>
                                <th>To</th>
                                <th class="num">Qty</th>
                                <th>UoM</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in selectedTransfer.Lines)
                            {
                                <tr>
                                    <td>@line.LineNum</td>
                                    <td>
                                        <div class="fw-semibold">@line.ItemCode</div>
                                        <div class="muted">@line.ItemDescription</div>
                                    </td>
                                    <td><span class="itx-wh src">@line.FromWarehouseCode</span></td>
                                    <td><span class="itx-wh dst">@line.ToWarehouseCode</span></td>
                                    <td class="num">@QuantityDisplay.Format(line.Quantity, line.UoMCode)</td>
                                    <td class="muted">@line.UoMCode</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="num">Total</td>
                                <td class="num">@QuantityDisplay.Format(selectedTransfer.Lines.Sum(l => l.Quantity))</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
        <div class="itx-drawer-foot">
            <button type="button" class="itx-btn itx-btn-primary" disabled="@isPrinting"
                    @onclick="() => PrintTransferDocument(selectedTransfer)">
                <i class="bi bi-printer"></i> Print Transfer Document
            </button>
            <button type="button" class="itx-btn" @onclick="CloseModal">Close</button>
        </div>
    </div>
}

<!-- ── Transfer request detail drawer ─────────────────────── -->
@if (selectedTransferRequest != null)
{
    <div class="itx-scrim" @onclick="CloseRequestModal"></div>
    <div class="itx-drawer">
        <div class="itx-drawer-head">
            <h5><i class="bi bi-file-earmark-text me-2"></i>Transfer Request #@selectedTransferRequest.DocNum</h5>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CloseRequestModal" />
        </div>
        <div class="itx-drawer-body">
            <div class="itx-route-card">
                <div class="leg src">
                    <div class="leg-label">Source</div>
                    <div class="leg-value">@selectedTransferRequest.FromWarehouse</div>
                </div>
                <i class="bi bi-arrow-right-circle-fill" style="font-size:1.35rem;color:var(--itx-accent);"></i>
                <div class="leg dst">
                    <div class="leg-label">Destination</div>
                    <div class="leg-value">@selectedTransferRequest.ToWarehouse</div>
                </div>
            </div>

            <div class="itx-grid">
                <div>
                    <div class="k">Doc Number</div>
                    <div class="v">#@selectedTransferRequest.DocNum</div>
                </div>
                <div>
                    <div class="k">Status</div>
                    <div class="v">
                        <span class="itx-status @GetStatusCssClass(selectedTransferRequest.ApprovalStatus ?? selectedTransferRequest.DocumentStatus)">
                            @GetApprovalDisplayStatus(selectedTransferRequest)
                        </span>
                    </div>
                </div>
                <div>
                    <div class="k">Document Date</div>
                    <div class="v">@FormatDate(selectedTransferRequest.DocDate)</div>
                </div>
                <div>
                    <div class="k">Due Date</div>
                    <div class="v">@FormatDate(selectedTransferRequest.DueDate)</div>
                </div>
                <div>
                    <div class="k">Requester</div>
                    <div class="v">@(selectedTransferRequest.RequesterName ?? "—")</div>
                </div>
                <div>
                    <div class="k">Requested By Role</div>
                    <div class="v">@GetFriendlyRoleName(selectedTransferRequest.RequestedByRole)</div>
                </div>
                <div>
                    <div class="k">Approval Stage</div>
                    <div class="v">@GetApprovalStageLabel(selectedTransferRequest)</div>
                </div>
                <div>
                    <div class="k">Email</div>
                    <div class="v plain">@(selectedTransferRequest.RequesterEmail ?? "—")</div>
                </div>
                @if (!string.IsNullOrWhiteSpace(selectedTransferRequest.Comments))
                {
                    <div class="span-2">
                        <div class="k">Comments</div>
                        <div class="v plain">@selectedTransferRequest.Comments</div>
                    </div>
                }
            </div>

            @if (selectedTransferRequest.ApprovalStages.Count > 0)
            {
                <div class="itx-section">
                    <i class="bi bi-diagram-3"></i>
                    Approval Stages — @selectedTransferRequest.ApprovalTemplateName
                </div>
                <div class="mb-3">
                    @foreach (var stage in selectedTransferRequest.ApprovalStages)
                    {
                        <div class="itx-stage">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <div class="fw-bold">@stage.StageName</div>
                                    @if (!string.IsNullOrWhiteSpace(stage.Description))
                                    {
                                        <div class="muted small">@stage.Description</div>
                                    }
                                </div>
                                <span class="itx-status @GetStatusCssClass(stage.Status)">@GetFriendlyStatus(stage.Status)</span>
                            </div>
                            <div class="small mt-2" style="color:var(--itx-ink-2);">
                                Approvals: @stage.ApprovalCount/@stage.ApprovalsRequired &nbsp;|&nbsp;
                                Rejections: @stage.RejectionCount/@stage.RejectionsRequired
                            </div>
                            @if (stage.Decisions.Count > 0)
                            {
                                <div class="mt-2">
                                    @foreach (var decision in stage.Decisions.OrderByDescending(x => x.DecidedAtUtc))
                                    {
                                        <div class="small py-1">
                                            <strong>@decision.AuthorizerName</strong>
                                            <span class="itx-status @GetStatusCssClass(decision.Decision)">@GetFriendlyStatus(decision.Decision)</span>
                                            <span style="color:var(--itx-ink-2);">@decision.DecidedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                                            @if (!string.IsNullOrWhiteSpace(decision.Remarks))
                                            {
                                                <div class="fst-italic" style="color:var(--itx-ink-2);">@decision.Remarks</div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            @if (CanCurrentUserDecideStage(selectedTransferRequest, stage))
                            {
                                <div class="mt-3">
                                    <label class="form-label small fw-semibold">Remarks</label>
                                    <textarea class="form-control form-control-sm" rows="2"
                                              placeholder="Optional approval or rejection remarks"
                                              value="@GetDecisionRemarks(stage.StageId)"
                                              @oninput="e => SetDecisionRemarks(stage.StageId, e.Value?.ToString())"></textarea>
                                    <div class="d-flex gap-2 mt-2 flex-wrap">
                                        <button type="button" class="itx-btn itx-btn-sm itx-btn-primary"
                                                disabled="@(isConverting || isRejecting)"
                                                @onclick="() => ConvertRequest(selectedTransferRequest, stage.StageId, false)">
                                            <i class="bi bi-check-circle"></i> Approve
                                        </button>
                                        @if (WillCompleteApproval(selectedTransferRequest, stage))
                                        {
                                            <button type="button" class="itx-btn itx-btn-sm"
                                                    disabled="@(isConverting || isRejecting)"
                                                    @onclick="() => ConvertRequest(selectedTransferRequest, stage.StageId, true)">
                                                <i class="bi bi-box-arrow-in-down"></i> Approve &amp; Add
                                            </button>
                                        }
                                        <button type="button" class="itx-btn itx-btn-sm itx-btn-danger"
                                                disabled="@(isConverting || isRejecting)"
                                                @onclick="() => RejectRequest(selectedTransferRequest, stage.StageId)">
                                            <i class="bi bi-x-circle"></i> Reject
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                @if (CanCurrentUserGenerate(selectedTransferRequest))
                {
                    <div class="itx-alert ok d-flex justify-content-between align-items-center gap-3">
                        <span>All stages are approved. The SAP inventory transfer can now be generated.</span>
                        <button type="button" class="itx-btn itx-btn-sm itx-btn-primary" disabled="@isConverting"
                                @onclick="() => GenerateApprovedRequest(selectedTransferRequest)">
                            <i class="bi bi-box-arrow-in-down"></i> Add Transfer
                        </button>
                    </div>
                }
            }

            @if (selectedTransferRequest.Lines?.Any() == true)
            {
                <div class="itx-section">
                    <i class="bi bi-list-check"></i> Request Lines (@selectedTransferRequest.Lines.Count)
                </div>
                <div class="itx-lines-wrap">
                    <table class="itx-lines">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Item</th>
                                <th>From</th>
                                <th>To</th>
                                <th class="num">Qty</th>
                                <th>UoM</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in selectedTransferRequest.Lines)
                            {
                                <tr>
                                    <td>@line.LineNum</td>
                                    <td>
                                        <div class="fw-semibold">@line.ItemCode</div>
                                        <div class="muted">@line.ItemDescription</div>
                                    </td>
                                    <td><span class="itx-wh src">@line.FromWarehouseCode</span></td>
                                    <td><span class="itx-wh dst">@line.ToWarehouseCode</span></td>
                                    <td class="num">@QuantityDisplay.Format(line.Quantity, line.UoMCode)</td>
                                    <td class="muted">@line.UoMCode</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="num">Total</td>
                                <td class="num">@QuantityDisplay.Format(selectedTransferRequest.Lines.Sum(l => l.Quantity))</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
        <div class="itx-drawer-foot">
            @if (CanCurrentUserDecide(selectedTransferRequest) && selectedTransferRequest.ApprovalStages.Count == 0)
            {
                <button type="button" class="itx-btn itx-btn-primary"
                        disabled="@(isConverting || isRejecting)"
                        @onclick="() => ConvertRequest(selectedTransferRequest)">
                    <i class="bi bi-check-circle"></i> @GetApprovalActionLabel(selectedTransferRequest)
                </button>
                <button type="button" class="itx-btn itx-btn-danger"
                        disabled="@(isConverting || isRejecting)"
                        @onclick="() => RejectRequest(selectedTransferRequest)">
                    <i class="bi bi-x-circle"></i> Reject
                </button>
            }
            <button type="button" class="itx-btn" @onclick="CloseRequestModal">Close</button>
        </div>
    </div>
}

@code {
    // ── Tab state ───────────────────────────────────────
    private int activeTabIndex = 0;

    // ── MudTable refs ───────────────────────────────────
    private MudTable<InventoryTransferDto> _transfersTable = null!;
    private MudTable<InventoryTransferRequestDto> _requestsTable = null!;
    private int _pageSize = 10;

    // ── Completed transfers ─────────────────────────────
    private List<InventoryTransferDto>? transfers;
    private InventoryTransferDto? selectedTransfer;
    private bool isLoading = false;
    private bool isPrinting = false;
    private string? errorMessage;
    private string? successMessage;
    private int currentPage = 1;
    private int pageSize = 20;
    private bool hasMore = false;
    private int totalCount = 0;
    private int totalPages = 0;

    // ── Transfer requests ───────────────────────────────
    private List<InventoryTransferRequestDto>? transferRequests;
    private InventoryTransferRequestDto? selectedTransferRequest;
    private bool isLoadingRequests = false;
    private bool isConverting = false;
    private bool isRejecting = false;
    private Guid? currentUserId;
    private string? currentUserRole;
    private HashSet<string> assignedWarehouseCodes = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<Guid, string?> decisionRemarks = [];
    private const int transferRequestBatchSize = 100;
    private int transferRequestCount = 0;

    // ── Warehouse search ────────────────────────────────
    private bool isLoadingWarehouses = true;
    private List<WarehouseDto> cachedWarehouses = new();
    private WarehouseDto? selectedWarehouse;

    private DateTime? fromDate;
    private DateTime? toDate;

    // ── Quick filter ────────────────────────────────────
    private string? _transferSearchString;
    private string? _requestSearchString;
    private string? _requestFromWarehouseFilter;
    private string? _requestToWarehouseFilter;
    private string? _requestStatusFilter;
    private string? _requestRequesterFilter;
    private DateTime? requestFromDate;
    private DateTime? requestToDate;

    // Search + status stay in the toolbar; the rest live behind the "Filters" toggle.
    private bool showRequestFilters = false;

    private bool _hasLoadedData = false;

    // ── Filtered collections ────────────────────────────
    private IEnumerable<InventoryTransferDto> FilteredTransfers =>
    transfers?.Where(_transferQuickFilter) ?? Enumerable.Empty<InventoryTransferDto>();

    private IEnumerable<InventoryTransferRequestDto> FilteredRequests =>
    transferRequests?.Where(_requestQuickFilter) ?? Enumerable.Empty<InventoryTransferRequestDto>();

    private int FilteredRequestCount => FilteredRequests.Count();

    private bool HasActiveRequestFilters =>
        !string.IsNullOrWhiteSpace(_requestSearchString) ||
        !string.IsNullOrWhiteSpace(_requestFromWarehouseFilter) ||
        !string.IsNullOrWhiteSpace(_requestToWarehouseFilter) ||
        !string.IsNullOrWhiteSpace(_requestStatusFilter) ||
        !string.IsNullOrWhiteSpace(_requestRequesterFilter) ||
        requestFromDate.HasValue ||
        requestToDate.HasValue;

    // Only the filters hidden behind the toggle — search and status are always visible,
    // so counting them would double-report what the user can already see.
    private int ExtraRequestFilterCount =>
        (string.IsNullOrWhiteSpace(_requestFromWarehouseFilter) ? 0 : 1) +
        (string.IsNullOrWhiteSpace(_requestToWarehouseFilter) ? 0 : 1) +
        (string.IsNullOrWhiteSpace(_requestRequesterFilter) ? 0 : 1) +
        (requestFromDate.HasValue ? 1 : 0) +
        (requestToDate.HasValue ? 1 : 0);

    private IEnumerable<string> RequestFromWarehouseOptions =>
        transferRequests?
            .Select(x => x.FromWarehouse)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x) ?? Enumerable.Empty<string>();

    private IEnumerable<string> RequestToWarehouseOptions =>
        transferRequests?
            .Select(x => x.ToWarehouse)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x) ?? Enumerable.Empty<string>();

    private IEnumerable<string> RequestStatusOptions =>
        transferRequests?
            .Select(GetApprovalDisplayStatus)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x) ?? Enumerable.Empty<string>();

    // ── Quick filters ───────────────────────────────────
    private Func<InventoryTransferDto, bool> _transferQuickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_transferSearchString)) return true;
        if (x.DocNum.ToString().Contains(_transferSearchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.DocEntry.ToString().Contains(_transferSearchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.FromWarehouse?.Contains(_transferSearchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.ToWarehouse?.Contains(_transferSearchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.Comments?.Contains(_transferSearchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    };

    private Func<InventoryTransferRequestDto, bool> _requestQuickFilter => x =>
    {
        if (!MatchesFilterValue(x.FromWarehouse, _requestFromWarehouseFilter)) return false;
        if (!MatchesFilterValue(x.ToWarehouse, _requestToWarehouseFilter)) return false;

        if (!string.IsNullOrWhiteSpace(_requestStatusFilter) &&
            !string.Equals(GetApprovalDisplayStatus(x), _requestStatusFilter, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(_requestRequesterFilter) &&
            !(x.RequesterName?.Contains(_requestRequesterFilter, StringComparison.OrdinalIgnoreCase) == true ||
              x.RequesterEmail?.Contains(_requestRequesterFilter, StringComparison.OrdinalIgnoreCase) == true))
        {
            return false;
        }

        if (!MatchesDateRange(x.DocDate, requestFromDate, requestToDate)) return false;

        if (string.IsNullOrWhiteSpace(_requestSearchString)) return true;
        if (x.DocNum.ToString().Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.DocEntry.ToString().Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.FromWarehouse?.Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.ToWarehouse?.Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.RequesterName?.Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.RequesterEmail?.Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.DocumentStatus?.Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.ApprovalStatus?.Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (GetApprovalDisplayStatus(x).Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.Comments?.Contains(_requestSearchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    };

    // ── Lifecycle ───────────────────────────────────────
    protected override void OnInitialized()
    {
        _pageSize = AppSettings.PageSize;
        pageSize = AppSettings.PageSize;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasLoadedData)
        {
            _hasLoadedData = true;
            await LoadApprovalContextAsync();
            if (TryGetRequestedDocumentEntry(out var requestedDocEntry))
            {
                activeTabIndex = 1;
                await LoadTransferRequestsAsync();
                selectedTransferRequest = await TransferService.GetTransferRequestByDocEntryAsync(requestedDocEntry)
                    ?? transferRequests?.FirstOrDefault(request => request.DocEntry == requestedDocEntry);
            }
            // Only load warehouses on first render (fast, cached).
            // Transfer requests are deferred until the user switches to that tab.
            await LoadWarehousesAsync();
            await AuditService.LogAsync(AuditActions.ViewTransfers, "InventoryTransfer", null);
            StateHasChanged();
        }
    }

    private async Task LoadApprovalContextAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdValue = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        currentUserId = Guid.TryParse(userIdValue, out var parsedUserId) ? parsedUserId : null;
        currentUserRole = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
        assignedWarehouseCodes = authState.User.FindAll("warehouse")
            .Select(claim => claim.Value)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private bool TryGetRequestedDocumentEntry(out int docEntry)
    {
        docEntry = 0;
        var query = QueryHelpers.ParseQuery(Navigation.ToAbsoluteUri(Navigation.Uri).Query);
        return query.TryGetValue("requestDocEntry", out var value) && int.TryParse(value.FirstOrDefault(), out docEntry);
    }

    private async Task LoadWarehousesAsync()
    {
        try
        {
            isLoadingWarehouses = true;
            cachedWarehouses = await CacheService.GetWarehousesAsync();
            Logger.LogInformation("Loaded {Count} warehouses", cachedWarehouses?.Count ?? 0);
            if (cachedWarehouses != null)
            {
                var defaultWarehouse = cachedWarehouses.FirstOrDefault(w => w.WarehouseCode == "01");
                if (defaultWarehouse != null)
                    selectedWarehouse = defaultWarehouse;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load warehouses");
            errorMessage = $"Failed to load warehouses: {ex.Message}";
        }
        finally
        {
            isLoadingWarehouses = false;
        }
    }

    private async Task<IEnumerable<WarehouseDto>> SearchWarehousesAsync(string searchText, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(searchText))
            return cachedWarehouses.Take(20);

        return cachedWarehouses
        .Where(w =>
        (w.WarehouseCode?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (w.WarehouseName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false))
        .Take(20);
    }

    private string FormatDate(string? dateString)
    {
        if (string.IsNullOrEmpty(dateString)) return "—";
        return DateTime.TryParse(dateString, out var date) ? date.ToString("dd MMM yyyy") : dateString;
    }

    // ── Tab switching ───────────────────────────────────
    private async Task SwitchTab(int index)
    {
        activeTabIndex = index;
        if (index == 1 && transferRequests == null)
            await LoadTransferRequestsAsync();
    }

    // ── Load transfers ──────────────────────────────────
    private async Task LoadTransfers()
    {
        if (selectedWarehouse == null) return;

        isLoading = true;
        errorMessage = null;

        try
        {
            var warehouseCode = selectedWarehouse.WarehouseCode!;

            if (fromDate.HasValue && toDate.HasValue)
            {
                // Fetch ALL records for the date range; MudTable handles client-side pagination
                var response = await TransferService.GetTransfersByDateRangeAsync(warehouseCode, fromDate.Value, toDate.Value);
                transfers = response?.Transfers;
                totalCount = response?.Count ?? transfers?.Count ?? 0;
                hasMore = false;
                totalPages = 1;
            }
            else if (fromDate.HasValue)
            {
                var response = await TransferService.GetTransfersByDateAsync(warehouseCode, fromDate.Value);
                transfers = response?.Transfers;
                totalCount = response?.Count ?? transfers?.Count ?? 0;
                hasMore = false;
                totalPages = 1;
            }
            else
            {
                var response = await TransferService.GetPagedTransfersAsync(warehouseCode, currentPage, pageSize);
                if (response != null)
                {
                    transfers = response.Transfers;
                    hasMore = response.HasMore;
                    totalCount = response.TotalCount > 0 ? response.TotalCount : response.Count;
                    totalPages = response.TotalPages > 0 ? response.TotalPages : (pageSize > 0 ? (int)Math.Ceiling((double)totalCount /
pageSize) : 1);
                }
                else
                {
                    transfers = null;
                    errorMessage = "Failed to load transfers — no response from server.";
                }
            }
        }
        catch (TimeoutException ex)
        {
            Logger.LogWarning(ex, "Timeout loading transfers");
            errorMessage = "Request timed out. SAP may be responding slowly — please try again.";
        }
        catch (HttpRequestException ex)
        {
            Logger.LogError(ex, "HTTP error loading transfers");
            errorMessage = $"Connection error: {ex.Message}";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading transfers");
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ClearFilter()
    {
        selectedWarehouse = null;
        fromDate = null;
        toDate = null;
        currentPage = 1;
        transfers = null;
        totalCount = 0;
        totalPages = 0;

        var defaultWarehouse = cachedWarehouses?.FirstOrDefault(w => w.WarehouseCode == "01");
        if (defaultWarehouse != null)
            selectedWarehouse = defaultWarehouse;
    }

    private void ViewTransfer(InventoryTransferDto transfer) => selectedTransfer = transfer;
    private void CloseModal() => selectedTransfer = null;

    private async Task PrintTransferDocument(InventoryTransferDto? transfer)
    {
        if (transfer == null || isPrinting) return;

        isPrinting = true;
        errorMessage = null;

        try
        {
            await JS.InvokeVoidAsync("printReportHtml", BuildTransferDocumentHtml(transfer));
            await AuditService.LogAsync(AuditActions.ViewTransfers, "InventoryTransfer", transfer.DocEntry.ToString());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to print transfer document {DocEntry}", transfer.DocEntry);
            errorMessage = "Failed to print the transfer document.";
        }
        finally
        {
            isPrinting = false;
        }
    }

    private string BuildTransferDocumentHtml(InventoryTransferDto transfer)
    {
        var lines = transfer.Lines ?? new();
        var rows = new StringBuilder();

        foreach (var line in lines)
        {
            rows.Append($"<tr><td>{line.LineNum}</td>")
                .Append($"<td><strong>{Html(line.ItemCode)}</strong><br/><span class='muted'>{Html(line.ItemDescription)}</span></td>")
                .Append($"<td>{Html(line.FromWarehouseCode)}</td>")
                .Append($"<td>{Html(line.ToWarehouseCode)}</td>")
                .Append($"<td class='num'>{Html(QuantityDisplay.Format(line.Quantity, line.UoMCode))}</td>")
                .Append($"<td>{Html(line.UoMCode)}</td></tr>");
        }

        var totalQty = Html(QuantityDisplay.Format(lines.Sum(l => l.Quantity)));
        var comments = string.IsNullOrWhiteSpace(transfer.Comments)
            ? string.Empty
            : $"<div class='comments'><span class='k'>Comments</span>{Html(transfer.Comments)}</div>";
        var printedAt = IAuditService.ToCAT(DateTime.UtcNow).ToString("dd MMM yyyy HH:mm");

        return $$"""
            <!doctype html>
            <html>
            <head>
                <meta charset="utf-8">
                <title>Inventory Transfer #{{transfer.DocNum}}</title>
                <style>
                    @page { size: A4; margin: 14mm; }
                    body { font-family: Arial, Helvetica, sans-serif; color: #111827; font-size: 12px; margin: 0; }
                    h1 { font-size: 20px; margin: 0 0 2px; }
                    .head { display: flex; justify-content: space-between; align-items: flex-start;
                            border-bottom: 2px solid #111827; padding-bottom: 10px; margin-bottom: 16px; }
                    .company { font-size: 15px; font-weight: 700; }
                    .doc-no { font-size: 18px; font-weight: 700; text-align: right; }
                    .route { display: flex; align-items: center; gap: 16px; border: 1px solid #d1d5db;
                             padding: 12px; margin-bottom: 16px; }
                    .route .leg { flex: 1; text-align: center; }
                    .route .leg .code { font-size: 16px; font-weight: 700; }
                    .grid { display: flex; flex-wrap: wrap; gap: 10px 32px; margin-bottom: 16px; }
                    .k { display: block; font-size: 10px; text-transform: uppercase; letter-spacing: .5px; color: #6b7280; }
                    table { width: 100%; border-collapse: collapse; }
                    th, td { text-align: left; padding: 6px 8px; border-bottom: 1px solid #e5e7eb; vertical-align: top; }
                    th { background: #f3f4f6; border-bottom: 1px solid #9ca3af; font-size: 11px;
                         text-transform: uppercase; letter-spacing: .4px; }
                    .num { text-align: right; }
                    tfoot td { font-weight: 700; border-top: 2px solid #111827; border-bottom: none; }
                    .muted { color: #6b7280; }
                    .comments { border: 1px solid #d1d5db; padding: 10px; margin-bottom: 16px; }
                    .sigs { display: flex; gap: 32px; margin-top: 40px; }
                    .sig { flex: 1; border-top: 1px solid #111827; padding-top: 6px; font-size: 11px; }
                    .foot { margin-top: 24px; font-size: 10px; color: #6b7280; text-align: center; }
                </style>
            </head>
            <body>
                <div class="head">
                    <div>
                        <div class="company">{{Html(AppSettings.CompanyName)}}</div>
                        <h1>Inventory Transfer</h1>
                    </div>
                    <div class="doc-no">
                        #{{transfer.DocNum}}
                        <div class="muted" style="font-weight:400;font-size:11px;">Doc Entry {{transfer.DocEntry}}</div>
                    </div>
                </div>

                <div class="route">
                    <div class="leg">
                        <span class="k">Source</span>
                        <span class="code">{{Html(transfer.FromWarehouse)}}</span>
                    </div>
                    <div style="font-size:18px;">&rarr;</div>
                    <div class="leg">
                        <span class="k">Destination</span>
                        <span class="code">{{Html(transfer.ToWarehouse)}}</span>
                    </div>
                </div>

                <div class="grid">
                    <div><span class="k">Document Date</span>{{Html(FormatDate(transfer.DocDate))}}</div>
                    <div><span class="k">Due Date</span>{{Html(FormatDate(transfer.DueDate))}}</div>
                    <div><span class="k">Total Lines</span>{{lines.Count}}</div>
                </div>

                {{comments}}

                <table>
                    <thead>
                        <tr><th>#</th><th>Item</th><th>From</th><th>To</th><th class="num">Qty</th><th>UoM</th></tr>
                    </thead>
                    <tbody>{{rows}}</tbody>
                    <tfoot>
                        <tr><td colspan="4" class="num">Total</td><td class="num">{{totalQty}}</td><td></td></tr>
                    </tfoot>
                </table>

                <div class="sigs">
                    <div class="sig">Issued by (name / signature / date)</div>
                    <div class="sig">Received by (name / signature / date)</div>
                </div>

                <div class="foot">Printed {{printedAt}} CAT</div>
            </body>
            </html>
            """;
    }

    private static string Html(string? value) => System.Net.WebUtility.HtmlEncode(value ?? string.Empty);

    private void TransferPageChanged(int i) => _transfersTable.NavigateTo(i - 1);
    private void RequestPageChanged(int i) => _requestsTable.NavigateTo(i - 1);

    private async Task PreviousPage()
    {
        if (currentPage > 1) { currentPage--; await LoadTransfers(); }
    }

    private async Task NextPage()
    {
        if (hasMore) { currentPage++; await LoadTransfers(); }
    }

    // ── Transfer Request Methods ────────────────────────
    private async Task LoadTransferRequestsAsync()
    {
        isLoadingRequests = true;
        try
        {
            var response = await TransferService.GetAllTransferRequestsAsync(transferRequestBatchSize);
            if (response?.TransferRequests != null)
            {
                transferRequests = response.TransferRequests;
                transferRequestCount = response.TransferRequests.Count;
            }
            else
            {
                transferRequests = new();
                transferRequestCount = 0;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load transfer requests");
        }
        finally
        {
            isLoadingRequests = false;
        }
    }

    private void ViewTransferRequest(InventoryTransferRequestDto request) => selectedTransferRequest = request;
    private void CloseRequestModal() => selectedTransferRequest = null;

    private async Task RefreshTransferRequests() => await LoadTransferRequestsAsync();

    private void ClearRequestFilters()
    {
        _requestSearchString = null;
        _requestFromWarehouseFilter = null;
        _requestToWarehouseFilter = null;
        _requestStatusFilter = null;
        _requestRequesterFilter = null;
        requestFromDate = null;
        requestToDate = null;
    }

    private string GetStatusCssClass(string? status) => status?.ToLower() switch
    {
        "open" or "bost_open" => "open",
        "closed" or "bost_close" => "closed",
        "approved" or "generated" or "generatedbyauthorizer" => "approved",
        "rejected" or "notapproved" or "cancelled" => "rejected",
        "pending" => "pending",
        _ => "open"
    };

    private string GetFriendlyStatus(string? status) => status?.ToLower() switch
    {
        "bost_open" or "open" => "Open",
        "bost_close" or "closed" => "Closed",
        "bost_delivered" => "Delivered",
        "bost_paid" => "Paid",
        "approved" => "Approved",
        "generated" => "Generated",
        "generatedbyauthorizer" => "Generated by Authorizer",
        "rejected" or "notapproved" => "Not Approved",
        "cancelled" => "Cancelled",
        "pending" => "Pending",
        _ => status ?? "Open"
    };

    private bool IsRequestConvertible(InventoryTransferRequestDto? request)
    {
        if (request == null) return false;
        var status = request.DocumentStatus?.ToLower();
        var approvalStatus = request.ApprovalStatus?.ToLower();
        return (status == null || status == "open" || status == "bost_open") &&
               (approvalStatus == null || approvalStatus == "pending");
    }

    private bool CanCurrentUserDecide(InventoryTransferRequestDto? request)
        => request is not null && request.ApprovalStages.Any(stage => CanCurrentUserDecideStage(request, stage));

    private bool CanCurrentUserDecideStage(InventoryTransferRequestDto? request, ApprovalStageProgressModel stage)
    {
        if (!IsRequestConvertible(request) || !string.Equals(stage.Status, "Pending", StringComparison.OrdinalIgnoreCase)) return false;
        if (!currentUserId.HasValue || string.IsNullOrWhiteSpace(currentUserRole)) return false;
        if (stage.Decisions.Any(x => x.AuthorizerUserId == currentUserId.Value)) return false;
        if (string.Equals(currentUserRole, "Admin", StringComparison.OrdinalIgnoreCase)) return true;
        return stage.AuthorizerUserIds.Contains(currentUserId.Value) ||
               stage.AuthorizerRoles.Contains(currentUserRole, StringComparer.OrdinalIgnoreCase);
    }

    private string GetApprovalDisplayStatus(InventoryTransferRequestDto request)
    {
        if (string.Equals(request.ApprovalStatus, "Pending", StringComparison.OrdinalIgnoreCase))
        {
            var pending = request.ApprovalStages.Where(x => x.Status == "Pending").Select(x => x.StageName).ToList();
            return pending.Count == 0 ? "Pending Approval" : $"Awaiting {string.Join(", ", pending)}";
        }
        return GetFriendlyStatus(request.ApprovalStatus ?? request.DocumentStatus);
    }

    private string GetApprovalStageLabel(InventoryTransferRequestDto request)
        => string.Equals(request.ApprovalStatus, "Pending", StringComparison.OrdinalIgnoreCase)
            ? request.ApprovalTemplateName ?? "Approval process"
            : GetFriendlyStatus(request.ApprovalStatus ?? request.DocumentStatus);

    private static bool WillCompleteApproval(InventoryTransferRequestDto request, ApprovalStageProgressModel stage)
        => stage.ApprovalCount + 1 >= stage.ApprovalsRequired &&
           request.ApprovalStages.All(x => x.StageId == stage.StageId || x.Status == "Approved");

    private bool CanCurrentUserGenerate(InventoryTransferRequestDto request)
        => string.Equals(request.ApprovalStatus, "Approved", StringComparison.OrdinalIgnoreCase) &&
           currentUserId.HasValue &&
           (string.Equals(currentUserRole, "Admin", StringComparison.OrdinalIgnoreCase) ||
            request.ApprovalStages.Any(stage => stage.AuthorizerUserIds.Contains(currentUserId.Value) ||
                                                stage.AuthorizerRoles.Contains(currentUserRole ?? string.Empty, StringComparer.OrdinalIgnoreCase)));

    private string GetApprovalActionLabel(InventoryTransferRequestDto request) => "Approve";

    private string? GetDecisionRemarks(Guid stageId)
        => decisionRemarks.TryGetValue(stageId, out var value) ? value : null;

    private void SetDecisionRemarks(Guid stageId, string? value) => decisionRemarks[stageId] = value;

    private static string GetFriendlyRoleName(string? role) => role switch
    {
        "StockController" => "Stock Officer",
        "DepotController" => "Depot Controller",
        "Admin" => "Administrator",
        null or "" => "Administrator review",
        _ => role
    };

    private static bool MatchesFilterValue(string? value, string? filter)
    {
        return string.IsNullOrWhiteSpace(filter) || string.Equals(value, filter, StringComparison.OrdinalIgnoreCase);
    }

    private static bool MatchesDateRange(string? value, DateTime? from, DateTime? to)
    {
        if (!from.HasValue && !to.HasValue)
        {
            return true;
        }

        if (!DateTime.TryParse(value, out var parsedDate))
        {
            return false;
        }

        var date = parsedDate.Date;

        if (from.HasValue && date < from.Value.Date)
        {
            return false;
        }

        if (to.HasValue && date > to.Value.Date)
        {
            return false;
        }

        return true;
    }

    private async Task ConvertRequest(InventoryTransferRequestDto request, Guid? stageId = null, bool generateDocument = false)
    {
        if (request == null) return;

        isConverting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var selectedStageId = stageId ?? request.ApprovalStages
                .FirstOrDefault(stage => CanCurrentUserDecideStage(request, stage))?.StageId;
            var (success, message, transfer) = selectedStageId.HasValue
                ? await ApprovalProcessService.SubmitDecisionAsync(
                    request.DocEntry, selectedStageId.Value, "Approved", GetDecisionRemarks(selectedStageId.Value), generateDocument)
                : await TransferService.ConvertTransferRequestToTransferAsync(request.DocEntry);

            if (success)
            {
                successMessage = message;
                CloseRequestModal();
                await LoadTransferRequestsAsync();
            }
            else
            {
                errorMessage = message;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error converting transfer request {DocEntry}", request.DocEntry);
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isConverting = false;
            StateHasChanged();
        }
    }

    private Task GenerateApprovedRequest(InventoryTransferRequestDto request)
    {
        var stage = request.ApprovalStages.FirstOrDefault(item =>
            string.Equals(currentUserRole, "Admin", StringComparison.OrdinalIgnoreCase) ||
            (currentUserId.HasValue && item.AuthorizerUserIds.Contains(currentUserId.Value)) ||
            item.AuthorizerRoles.Contains(currentUserRole ?? string.Empty, StringComparer.OrdinalIgnoreCase));
        return stage is null ? Task.CompletedTask : ConvertRequest(request, stage.StageId, true);
    }

    private async Task RejectRequest(InventoryTransferRequestDto request, Guid? stageId = null)
    {
        isRejecting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var selectedStageId = stageId ?? request.ApprovalStages
                .FirstOrDefault(stage => CanCurrentUserDecideStage(request, stage))?.StageId;
            bool success;
            string message;
            if (selectedStageId.HasValue)
            {
                var result = await ApprovalProcessService.SubmitDecisionAsync(
                    request.DocEntry, selectedStageId.Value, "NotApproved", GetDecisionRemarks(selectedStageId.Value));
                success = result.Success;
                message = result.Message;
            }
            else
            {
                (success, message) = await TransferService.CloseTransferRequestAsync(request.DocEntry);
            }
            if (success)
            {
                successMessage = message;
                CloseRequestModal();
                await LoadTransferRequestsAsync();
            }
            else
            {
                errorMessage = message;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error rejecting transfer request {DocEntry}", request.DocEntry);
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isRejecting = false;
            StateHasChanged();
        }
    }
}
