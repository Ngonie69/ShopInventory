@page "/credit-notes/create"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Cashier")]
@inject ICreditNoteService CreditNoteService
@inject IMasterDataCacheService CacheService
@inject IBusinessPartnerPricingService BusinessPartnerPricingService
@inject NavigationManager NavigationManager
@inject IAppSettingsProvider AppSettings
@using ShopInventory.Web.Data
@using ShopInventory.Web.Services
@inject ISnackbar Snackbar
@inject ILogger<CreateCreditNote> Logger
@inject IAuditService AuditService
@rendermode InteractiveServer

<PageTitle>Create Credit Note - Shop Inventory</PageTitle>

<style>
    /* Page */
    .ccn-page {
        background: #f0f2f5;
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* Breadcrumb */
    .ccn-breadcrumb {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .85rem;
        color: #6b7280;
        margin-bottom: 1.25rem;
    }

    .ccn-breadcrumb a {
        color: #667eea;
        text-decoration: none;
        font-weight: 500;
    }

    .ccn-breadcrumb a:hover {
        text-decoration: underline;
    }

    .ccn-breadcrumb .sep {
        color: #d1d5db;
    }

    /* Header */
    .ccn-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .ccn-header-left {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .ccn-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
        color: #fff;
        font-size: 1.4rem;
    }

    .ccn-header h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        letter-spacing: -.3px;
    }

    .ccn-header p {
        color: #6b7280;
        margin: 0;
        font-size: .88rem;
    }

    .ccn-header-actions {
        display: flex;
        gap: .5rem;
        align-items: center;
    }

    .btn-back {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .55rem 1.1rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .85rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: all .15s;
    }

    .btn-back:hover {
        background: #f9fafb;
        border-color: #9ca3af;
        color: #374151;
    }

    /* Form Card */
    .form-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, .04);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .form-card-title {
        font-weight: 600;
        font-size: .95rem;
        color: #1a1a2e;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    .form-field {
        display: flex;
        flex-direction: column;
    }

    .form-field.full {
        grid-column: span 2;
    }

    .form-field label {
        font-size: .75rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: .25rem;
    }

    .form-field input,
    .form-field select,
    .form-field textarea {
        padding: .5rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: .88rem;
        color: #374151;
        transition: all .15s;
    }

    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, .15);
    }

    /* Customer Selection */
    .dropdown-autocomplete {
        position: absolute;
        z-index: 100;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        max-height: 250px;
        overflow-y: auto;
        width: 100%;
        box-shadow: 0 8px 25px rgba(0, 0, 0, .12);
        margin-top: 2px;
    }

    .dropdown-item {
        padding: .5rem .75rem;
        cursor: pointer;
        font-size: .85rem;
        border-bottom: 1px solid #f3f4f6;
        transition: background .12s;
    }

    .dropdown-item:hover,
    .dropdown-item.selected {
        background: #f0f4ff;
    }

    .ccn-checkbox-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem 0;
        color: #374151;
    }

    .ccn-checkbox-input {
        width: 18px;
        height: 18px;
        margin: 0;
        accent-color: #667eea;
    }

    .ccn-checkbox-label {
        font-size: .88rem;
        font-weight: 600;
        text-transform: none;
        letter-spacing: 0;
        margin-bottom: 0;
        color: inherit;
    }

    /* Buttons */
    .btn-so-gradient {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 2px 8px rgba(102, 126, 234, .25);
        cursor: pointer;
    }

    .btn-so-gradient:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .4);
        color: #fff;
    }

    .btn-create {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        color: #fff;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-create:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(102, 126, 234, .3);
    }

    .btn-create:disabled {
        opacity: .5;
        cursor: not-allowed;
        transform: none;
    }

    .btn-secondary-action {
        background: #fff;
        color: #374151;
        border: 1px solid #d1d5db;
        padding: .55rem 1.35rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: .88rem;
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
    }

    .btn-secondary-action:hover {
        background: #f9fafb;
        border-color: #9ca3af;
    }

    /* Footer */
    .form-footer {
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        padding-top: 1rem;
    }

    /* Loading */
    .loading-state {
        text-align: center;
        padding: 3rem;
    }

    @@media (max-width: 768px) {
        .ccn-header {
            flex-direction: column;
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .form-field.full {
            grid-column: span 1;
        }

        .form-footer {
            flex-direction: column;
        }

        .btn-so-gradient,
        .btn-create,
        .btn-secondary-action {
            width: 100%;
            justify-content: center;
            text-align: center;
        }
    }
</style>

<div class="ccn-page">
    <div class="container-fluid">

        <div class="ccn-breadcrumb">
            <a href="/credit-notes">Credit Notes</a>
            <span class="sep">/</span>
            <span>Create New</span>
        </div>

        <div class="ccn-header">
            <div class="ccn-header-left">
                <div class="ccn-header-icon"><i class="bi bi-file-earmark-minus"></i></div>
                <div>
                    <h2>Create Credit Note</h2>
                    <p>Create a new customer credit note with line items</p>
                </div>
            </div>
            <div class="ccn-header-actions">
                <a href="/credit-notes" class="btn-back"><i class="bi bi-arrow-left"></i> Back</a>
            </div>
        </div>

        @if (!isMasterDataLoaded)
        {
            <div class="loading-state">
                <div class="spinner-border" style="color:#667eea;width:2.5rem;height:2.5rem;" role="status"></div>
                <p style="margin-top:.75rem;color:#6b7280;font-weight:500;">Loading master data...</p>
            </div>
        }
        else
        {
            <div class="form-card">
                <div class="form-card-title"><i class="bi bi-person-badge"></i> Customer</div>
                <div style="margin-bottom:1rem;">
                    <label
                        style="display:block; font-size:.72rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.5px; margin-bottom:.35rem;">
                        Customer <span style="color:#ef4444;">*</span>
                    </label>
                    @if (selectedBusinessPartner != null)
                    {
                        <div style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:10px; padding:.75rem 1rem;">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div style="font-weight:700; color:#065f46;">
                                        <i class="bi bi-check-circle-fill me-1" style="color:#059669;"></i>
                                        @selectedBusinessPartner.CardCode
                                    </div>
                                    <div style="font-size:.85rem; color:#065f46; opacity:.8;">@selectedBusinessPartner.CardName
                                    </div>
                                    @if (!string.IsNullOrEmpty(selectedBusinessPartner.Phone1))
                                    {
                                        <div style="font-size:.82rem; color:#065f46; opacity:.7; margin-top:.25rem;">
                                            <i class="bi bi-telephone me-1"></i>@selectedBusinessPartner.Phone1
                                        </div>
                                    }
                                    @if (customerPriceListNum.HasValue)
                                    {
                                        <div style="font-size:.82rem; color:#065f46; opacity:.7; margin-top:.25rem;">
                                            <i class="bi bi-tags me-1"></i>Price List #@customerPriceListNum
                                            @if (isLoadingCustomerPrices)
                                            {
                                                <span class="spinner-border spinner-border-sm ms-1"></span>
                                            }
                                            else
                                            {
                                                <span
                                                    style="background:#d1fae5; color:#065f46; font-size:.7rem; padding:.1rem .4rem; border-radius:4px; font-weight:600; margin-left:.25rem;">
                                                    @customerPriceListPrices.Count items
                                                </span>
                                            }
                                        </div>
                                    }
                                </div>
                                <button type="button"
                                        style="background:#fef2f2; border:1px solid #fecaca; color:#dc2626; width:28px; height:28px; border-radius:7px; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:.8rem;"
                                        @onclick="ClearSelectedBP">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="position-relative">
                            <input type="text"
                                   style="width:100%; padding:.5rem .75rem; border:1px solid #d1d5db; border-radius:8px; font-size:.88rem; color:#374151;"
                                   @bind="bpSearchTerm" @bind:event="oninput" @onfocus="() => showBPDropdown = true"
                                   @onblur="OnBPSearchBlur" placeholder="Search by code or name…" autocomplete="off" />
                            @if (showBPDropdown && filteredBusinessPartners.Any())
                            {
                                <div class="dropdown-autocomplete" @onmousedown:preventDefault>
                                    @foreach (var bp in filteredBusinessPartners.Take(15))
                                    {
                                        <div class="dropdown-item" @onmousedown="() => SelectBusinessPartner(bp)">
                                            <strong>@bp.CardCode</strong> — <span style="color:#6b7280;">@bp.CardName</span>
                                        </div>
                                    }
                                    @if (filteredBusinessPartners.Count() > 15)
                                    {
                                        <div class="dropdown-item" style="color:#9ca3af; text-align:center; font-size:.82rem;">
                                            <i class="bi bi-info-circle me-1"></i>
                                            @filteredBusinessPartners.Count() total — type more to filter
                                        </div>
                                    }
                                </div>
                            }
                            else if (showBPDropdown && !string.IsNullOrWhiteSpace(bpSearchTerm) &&
                    !filteredBusinessPartners.Any())
                            {
                                <div class="dropdown-autocomplete" style="padding:1rem; text-align:center; color:#9ca3af;">
                                    <i class="bi bi-search me-1"></i>No customers found
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="form-card">
                <div class="form-card-title"><i class="bi bi-info-circle"></i> Credit Note Details</div>
                <div class="form-grid">
                    <div class="form-field">
                        <label>Type</label>
                        <select @bind="newCreditNote.Type">
                            @foreach (CreditNoteType type in Enum.GetValues(typeof(CreditNoteType)))
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>
                    <div class="form-field">
                        <label>Currency</label>
                        <select @bind="newCreditNote.Currency">
                            <option value="USD">USD</option>
                            <option value="ZIG">ZIG</option>
                        </select>
                    </div>
                    <div class="form-field full">
                        <label>Reason <span style="color:#ef4444;">*</span></label>
                        <textarea @bind="newCreditNote.Reason" rows="2" placeholder="Reason for credit note"></textarea>
                    </div>
                    <div class="form-field">
                        <label>Options</label>
                        <div class="ccn-checkbox-row">
                            <input class="ccn-checkbox-input" type="checkbox" @bind="newCreditNote.RestockItems"
                                   id="restockCheck" />
                            <label for="restockCheck" class="ccn-checkbox-label">Restock Items</label>
                        </div>
                    </div>
                    <div class="form-field">
                        <label>Restock Warehouse</label>
                        <select @bind="newCreditNote.RestockWarehouseCode">
                            <option value="">— Select —</option>
                            @foreach (var wh in cachedWarehouses)
                            {
                                <option value="@wh.WarehouseCode">@wh.WarehouseCode</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="form-card">
                <div class="d-flex justify-content-between align-items-center" style="margin-bottom:.75rem;">
                    <span style="font-weight:600; font-size:.92rem; color:#1a1a2e;">
                        <i class="bi bi-list-ul me-1" style="color:#667eea;"></i>Credit Note Lines
                    </span>
                    <button type="button" class="btn-so-gradient" style="padding:.35rem .85rem; font-size:.8rem;"
                            @onclick="AddLine">
                        <i class="bi bi-plus-lg"></i> Add Line
                    </button>
                </div>

                @if (newCreditNote.Lines.Any())
                {
                    @for (int i = 0; i < newCreditNote.Lines.Count; i++)
                    {
                        var index = i;
                        var line = newCreditNote.Lines[index];
                        var lineState = GetCnLineState(index);

                        <div
                            style="background:#f8fafc; border:1px solid #e5e7eb; border-radius:10px; padding:.85rem; margin-bottom:.65rem; position:relative;">
                            <div class="d-flex justify-content-between align-items-center" style="margin-bottom:.6rem;">
                                <div class="d-flex align-items-center gap-2">
                                    <span
                                        style="background:linear-gradient(135deg,#667eea,#764ba2); color:#fff; width:24px; height:24px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:600; font-size:.75rem;">@(index
                                                                    + 1)</span>
                    @if (!string.IsNullOrEmpty(line.ItemDescription))
                    {
                        <span style="font-weight:600; font-size:.85rem; color:#1a1a2e;">@line.ItemCode</span>
                        <span style="color:#d1d5db;">—</span>
                        <span style="color:#6b7280; font-size:.82rem;">@TruncateText(line.ItemDescription, 30)</span>
                    }
                    else
                    {
                        <span style="color:#9ca3af; font-size:.82rem;">New Line Item</span>
                    }
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span
                    style="font-weight:700; color:#059669; font-size:.92rem;">@CalculateLineTotal(line).ToString("N2")</span>
                    <button type="button"
                            style="background:#fef2f2; border:1px solid #fecaca; color:#dc2626; width:24px; height:24px; border-radius:6px; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:.75rem;"
                            @onclick="() => RemoveLine(index)">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-5">
                    <label
                        style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Item
                        Code <span style="color:#ef4444;">*</span></label>
                        <div class="position-relative">
                            <input type="text"
                                   style="width:100%; padding:.4rem .6rem; border:1px solid @(showLineItemsError && string.IsNullOrWhiteSpace(line.ItemCode) ? "#ef4444" : "#d1d5db"); border-radius:7px; font-size:.85rem;"
                                   value="@line.ItemCode" @oninput="(e) => OnCnItemCodeInput(index, e.Value?.ToString())"
                                   @onfocus="() => OnCnItemCodeFocus(index)" @onblur="() => OnCnItemCodeBlur(index)"
                                   placeholder="Search item…" autocomplete="off" />
                            @if (lineState.ShowDropdown && lineState.FilteredProducts.Any())
                            {
                                <div class="dropdown-autocomplete" @onmousedown:preventDefault>
                                    @foreach (var product in lineState.FilteredProducts.Take(10))
                                    {
                                        var displayPrice = GetPriceForItem(product.ItemCode, product.Price);
                                        <div class="dropdown-item"
                                             @onmousedown="async () => await SelectCnProduct(index, product)">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <div style="font-weight:600; font-size:.82rem;">@product.ItemCode</div>
                                                    <small style="color:#6b7280;">@TruncateText(product.ItemName, 25)</small>
                                                </div>
                                                <span
                                                    style="font-size:.75rem; font-weight:600; padding:.1rem .4rem; border-radius:4px; background:#dbeafe; color:#1e40af;">
                                                    @displayPrice.ToString("N2")
                                                </span>
                                            </div>
                                        </div>
                                    }
                                    @if (lineState.FilteredProducts.Count > 10)
                                    {
                                        <div class="dropdown-item" style="color:#9ca3af; text-align:center; font-size:.78rem;">
                                            +@(lineState.FilteredProducts.Count - 10) more…
                                        </div>
                                    }
                                </div>
                            }
                            else if (lineState.ShowDropdown && !string.IsNullOrWhiteSpace(lineState.SearchTerm) &&
                !lineState.FilteredProducts.Any())
                            {
                                <div class="dropdown-autocomplete" style="padding:1rem; text-align:center; color:#9ca3af;">
                                    <i class="bi bi-search me-1"></i>No items found
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-7">
                        <label
                        style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Description</label>
                        @if (!string.IsNullOrEmpty(line.ItemDescription))
                        {
                            <div
                                style="background:#f0f9ff; border:1px solid #bae6fd; border-radius:7px; padding:.4rem .6rem; font-size:.82rem; color:#0c4a6e;">
                                <i class="bi bi-box-seam me-1"
                                   style="color:#667eea;"></i>@TruncateText(line.ItemDescription, 35)
                            </div>
                        }
                        else
                        {
                            <input type="text"
                                   style="width:100%; padding:.4rem .6rem; border:1px solid #d1d5db; border-radius:7px; font-size:.85rem; background:#f3f4f6; cursor:default;"
                                   placeholder="Select an item" readonly />
                        }
                    </div>
                </div>

                <div class="row g-2">
                    <div class="col-3">
                        <label
                            style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Qty
                            <span style="color:#ef4444;">*</span></label>
                            <input type="number"
                                   style="width:100%; padding:.4rem .6rem; border:1px solid @(showLineItemsError && line.Quantity <= 0 ? "#ef4444" : "#d1d5db"); border-radius:7px; font-size:.85rem;"
                                   @bind="line.Quantity" min="0.001" step="0.001" placeholder="0" />
                        </div>
                        <div class="col-3">
                            <label
                                style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Unit
                                Price</label>
                                <input type="number"
                                       style="width:100%; padding:.4rem .6rem; border:1px solid #d1d5db; border-radius:7px; font-size:.85rem;"
                                       @bind="line.UnitPrice" min="0" step="0.01" />
                            </div>
                            <div class="col-3">
                                <label
                                    style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Discount
                                    %</label>
                                    <input type="number"
                                           style="width:100%; padding:.4rem .6rem; border:1px solid #d1d5db; border-radius:7px; font-size:.85rem;"
                                           @bind="line.DiscountPercent" min="0" max="100" step="0.01" />
                                </div>
                                <div class="col-3">
                                    <label
                                        style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Tax
                                        %</label>
                                        <input type="number"
                                               style="width:100%; padding:.4rem .6rem; border:1px solid #d1d5db; border-radius:7px; font-size:.85rem;"
                                               @bind="line.TaxPercent" min="0" max="100" step="0.01" />
                                    </div>
                                    <div class="col-12">
                                        <label
                                        style="display:block; font-size:.68rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.4px; margin-bottom:.2rem;">Warehouse</label>
                                        <select
                                            style="width:100%; padding:.4rem .6rem; border:1px solid #d1d5db; border-radius:7px; font-size:.85rem;"
                                            @bind="line.WarehouseCode">
                                            <option value="">Default</option>
                                            @foreach (var wh in cachedWarehouses)
                                            {
                                                <option value="@wh.WarehouseCode">@wh.WarehouseCode</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>
                        }

                        <div style="text-align:center; margin-top:.5rem;">
                            <button type="button"
                                    style="background:none; border:1px dashed #d1d5db; color:#6b7280; padding:.4rem 1rem; border-radius:8px; font-size:.82rem; cursor:pointer;"
                                    @onclick="AddLine">
                                <i class="bi bi-plus-lg me-1"></i>Add Another Line
                            </button>
                        </div>
                    }
                else
                    {
                        <div
                            style="text-align:center; padding:2rem 1rem; background:#f9fafb; border-radius:10px; border:2px dashed #e5e7eb;">
                            <div style="font-size:1.5rem; color:#9ca3af; margin-bottom:.5rem;"><i class="bi bi-inbox"></i></div>
                            <p style="color:#6b7280; font-size:.85rem; margin-bottom:.25rem;">No credit note lines yet</p>
                            <p style="color:#9ca3af; font-size:.78rem; margin-bottom:.75rem;">Add products to build the credit note
                            </p>
                            <button type="button" class="btn-so-gradient" style="padding:.4rem 1rem; font-size:.82rem;"
                                    @onclick="AddLine">
                                <i class="bi bi-plus-lg"></i> Add First Line
                            </button>
                        </div>
                    }

                    @if (showLineItemsError)
                    {
                        <div style="color:#ef4444; font-size:.78rem; margin-top:.4rem;">At least one line item with a valid item
                            code and quantity is required.</div>
                        }

                        @if (newCreditNote.Lines.Any())
                        {
                            <div
                                style="background:linear-gradient(135deg,#667eea,#764ba2); border-radius:10px; padding:.85rem 1.15rem; margin-top:1rem; color:#fff;">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div style="font-size:.78rem; opacity:.8;">@newCreditNote.Lines.Count line(s) ·
                                            @newCreditNote.Currency</div>
                                            <div style="font-size:.85rem; font-weight:500;">Grand Total</div>
                                        </div>
                                        <div style="font-size:1.3rem; font-weight:700;">@CalculateGrandTotal().ToString("N2")</div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="form-footer">
                            <a href="/credit-notes" class="btn-secondary-action">Cancel</a>
                            <MudButton Class="btn-create" OnClick="CreateCreditNoteAsync" Disabled="@isCreating">
                                @if (isCreating)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                <span>Create Credit Note</span>
                            </MudButton>
                        </div>
                    }
                </div>
            </div>

@code {
    private CreateCreditNoteRequest newCreditNote = new();
    private bool isCreating = false;
    private bool showLineItemsError = false;
    private bool isMasterDataLoaded = false;

    private List<ProductDto> cachedProducts = new();
    private List<WarehouseDto> cachedWarehouses = new();
    private List<BusinessPartnerDto> allBusinessPartners = new();

    private BusinessPartnerDto? selectedBusinessPartner;
    private Dictionary<string, decimal> customerPriceListPrices = new();
    private int? customerPriceListNum;
    private bool isLoadingCustomerPrices = false;
    private string? bpSearchTerm;
    private bool showBPDropdown = false;

    private Dictionary<int, CnLineState> cnLineStates = new();

    private class CnLineState
    {
        public string SearchTerm { get; set; } = string.Empty;
        public bool ShowDropdown { get; set; } = false;
        public List<ProductDto> FilteredProducts { get; set; } = new();
    }

    private IEnumerable<BusinessPartnerDto> filteredBusinessPartners
    {
        get
        {
            if (string.IsNullOrWhiteSpace(bpSearchTerm))
            {
                return allBusinessPartners.Take(50);
            }

            var search = bpSearchTerm.ToLowerInvariant();
            return allBusinessPartners.Where(bp =>
                (bp.CardCode?.ToLowerInvariant().Contains(search) ?? false) ||
                (bp.CardName?.ToLowerInvariant().Contains(search) ?? false));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadMasterDataAsync();
    }

    private async Task LoadMasterDataAsync()
    {
        try
        {
            var productsTask = CacheService.GetProductsAsync();
            var warehousesTask = CacheService.GetWarehousesAsync();
            var bpTask = CacheService.GetBusinessPartnersAsync();
            await Task.WhenAll(productsTask, warehousesTask, bpTask);
            cachedProducts = await productsTask ?? new();
            cachedWarehouses = await warehousesTask ?? new();
            allBusinessPartners = await bpTask ?? new();
            isMasterDataLoaded = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading master data for credit note creation");
            isMasterDataLoaded = true;
        }
    }

    private async Task SelectBusinessPartnerAsync(BusinessPartnerDto bp)
    {
        selectedBusinessPartner = bp;
        newCreditNote.CardCode = bp.CardCode ?? string.Empty;
        newCreditNote.CardName = bp.CardName;
        showBPDropdown = false;

        await LoadBusinessPartnerPricesAsync(bp);
        UpdateExistingLinePrices();
    }

    private void SelectBusinessPartner(BusinessPartnerDto bp)
    {
        _ = SelectBusinessPartnerAsync(bp);
    }

    private void ClearSelectedBP()
    {
        selectedBusinessPartner = null;
        newCreditNote.CardCode = string.Empty;
        newCreditNote.CardName = null;
        bpSearchTerm = null;
        showBPDropdown = false;
        customerPriceListPrices.Clear();
        customerPriceListNum = null;
        UpdateExistingLinePrices();
    }

    private async Task OnBPSearchBlur()
    {
        await Task.Delay(200);
        showBPDropdown = false;
    }

    private CnLineState GetCnLineState(int index)
    {
        if (!cnLineStates.ContainsKey(index))
        {
            cnLineStates[index] = new CnLineState();
        }

        return cnLineStates[index];
    }

    private void UpdateExistingLinePrices()
    {
        foreach (var line in newCreditNote.Lines)
        {
            if (!string.IsNullOrWhiteSpace(line.ItemCode))
            {
                var product = cachedProducts.FirstOrDefault(p =>
                    string.Equals(p.ItemCode, line.ItemCode, StringComparison.OrdinalIgnoreCase));
                var defaultPrice = product?.Price ?? line.UnitPrice;
                line.UnitPrice = GetPriceForItem(line.ItemCode, defaultPrice);
            }
        }
    }

    private async Task LoadBusinessPartnerPricesAsync(BusinessPartnerDto bp)
    {
        isLoadingCustomerPrices = true;
        StateHasChanged();

        try
        {
            var lookup = await BusinessPartnerPricingService.LoadPriceLookupAsync(bp);
            customerPriceListPrices = lookup.Prices;
            customerPriceListNum = lookup.PriceListNum;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading credit note prices for {CardCode}", bp.CardCode);
            customerPriceListPrices.Clear();
            customerPriceListNum = null;
        }
        finally
        {
            isLoadingCustomerPrices = false;
            StateHasChanged();
        }
    }

    private decimal GetPriceForItem(string? itemCode, decimal defaultPrice)
    {
        if (string.IsNullOrEmpty(itemCode))
        {
            return defaultPrice;
        }

        return customerPriceListPrices.TryGetValue(itemCode, out var customerPrice)
            ? customerPrice
            : defaultPrice;
    }

    private void OnCnItemCodeInput(int index, string? value)
    {
        var line = newCreditNote.Lines[index];
        line.ItemCode = value ?? string.Empty;

        var state = GetCnLineState(index);
        state.SearchTerm = value ?? string.Empty;

        if (string.IsNullOrWhiteSpace(value))
        {
            state.FilteredProducts.Clear();
            state.ShowDropdown = false;
            line.ItemDescription = null;
            return;
        }

        var searchLower = value.ToLowerInvariant();
        var searchUpper = value.ToUpperInvariant();
        state.FilteredProducts = cachedProducts.Where(p =>
            (p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false) ||
            (p.ItemCode?.ToLowerInvariant().Contains(searchLower) ?? false) ||
            (p.ItemName?.ToLowerInvariant().Contains(searchLower) ?? false) ||
            (p.BarCode?.ToLowerInvariant().Contains(searchLower) ?? false))
            .OrderByDescending(p => p.ItemCode?.ToUpperInvariant().StartsWith(searchUpper) ?? false)
            .ThenBy(p => p.ItemCode)
            .ToList();

        state.ShowDropdown = true;
    }

    private void OnCnItemCodeFocus(int index)
    {
        var state = GetCnLineState(index);
        state.ShowDropdown = true;

        if (string.IsNullOrWhiteSpace(state.SearchTerm))
        {
            state.FilteredProducts = cachedProducts.Take(15).ToList();
        }
    }

    private async Task OnCnItemCodeBlur(int index)
    {
        await Task.Delay(200);
        var state = GetCnLineState(index);
        state.ShowDropdown = false;
    }

    private async Task SelectCnProduct(int index, ProductDto product)
    {
        var line = newCreditNote.Lines[index];
        line.ItemCode = product.ItemCode ?? string.Empty;
        line.ItemDescription = product.ItemName;
        line.UnitPrice = GetPriceForItem(product.ItemCode, product.Price);

        if (!string.IsNullOrEmpty(product.ItemCode))
        {
            try
            {
                line.UnitPrice = await BusinessPartnerPricingService.ResolveUnitPriceAsync(
                    product.ItemCode,
                    selectedBusinessPartner?.Currency ?? AppSettings.DefaultCurrency,
                    product.Price,
                    newCreditNote.CardCode,
                    customerPriceListNum,
                    customerPriceListPrices);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to resolve BP-aware credit note price for item {ItemCode}", product.ItemCode);
            }
        }

        if (string.IsNullOrEmpty(line.WarehouseCode))
        {
            line.WarehouseCode = string.IsNullOrEmpty(newCreditNote.RestockWarehouseCode)
                ? product.DefaultWarehouse
                : newCreditNote.RestockWarehouseCode;
        }

        var state = GetCnLineState(index);
        state.SearchTerm = line.ItemCode;
        state.ShowDropdown = false;
    }

    private void AddLine()
    {
        newCreditNote.Lines.Add(new CreateCreditNoteLineRequest
        {
            Quantity = 1,
            WarehouseCode = newCreditNote.RestockWarehouseCode ?? string.Empty
        });
        showLineItemsError = false;
    }

    private void RemoveLine(int index)
    {
        if (index >= 0 && index < newCreditNote.Lines.Count)
        {
            newCreditNote.Lines.RemoveAt(index);
            cnLineStates.Remove(index);

            var oldStates = new Dictionary<int, CnLineState>(cnLineStates);
            cnLineStates.Clear();

            for (int i = 0; i < newCreditNote.Lines.Count; i++)
            {
                var oldIndex = i >= index ? i + 1 : i;
                if (oldStates.TryGetValue(oldIndex, out var state))
                {
                    cnLineStates[i] = state;
                }
            }
        }
    }

    private decimal CalculateLineTotal(CreateCreditNoteLineRequest line)
    {
        var subtotal = line.Quantity * line.UnitPrice;
        var afterDiscount = subtotal * (1m - line.DiscountPercent / 100m);
        var tax = afterDiscount * (line.TaxPercent / 100m);
        return afterDiscount + tax;
    }

    private decimal CalculateGrandTotal()
    {
        return newCreditNote.Lines.Sum(l => CalculateLineTotal(l));
    }

    private async Task CreateCreditNoteAsync()
    {
        if (string.IsNullOrEmpty(newCreditNote.CardCode))
        {
            Snackbar.Add("Please select a customer.", Severity.Warning);
            return;
        }

        if (string.IsNullOrEmpty(newCreditNote.Reason))
        {
            Snackbar.Add("Please provide a reason for the credit note.", Severity.Warning);
            return;
        }

        if (newCreditNote.Lines.Count == 0 || !newCreditNote.Lines.Any(l => !string.IsNullOrWhiteSpace(l.ItemCode) && l.Quantity
> 0))
        {
            showLineItemsError = true;
            return;
        }

        showLineItemsError = false;
        isCreating = true;
        try
        {
            var result = await CreditNoteService.CreateCreditNoteAsync(newCreditNote);
            if (result != null)
            {
                Snackbar.Add($"Credit note {result.CreditNoteNumber} created successfully!", Severity.Success);
                await AuditService.LogAsync(AuditActions.CreateCreditNote, "CreditNote", result.CreditNoteNumber);
                NavigationManager.NavigateTo("/credit-notes");
            }
            else
            {
                Snackbar.Add("Failed to create credit note.", Severity.Error);
                await AuditService.LogAsync(AuditActions.CreateCreditNote, "CreditNote", newCreditNote.CardCode, null, false, "Failed to create credit note");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isCreating = false;
        }
    }

    private string TruncateText(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text))
        {
            return "—";
        }

        return text.Length <= maxLength ? text : text.Substring(0, maxLength) + "...";
    }
}