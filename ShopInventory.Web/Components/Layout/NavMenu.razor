@using MudBlazor

<style>
    /* ── Modern Sidebar Navigation ────────────────── */
    .nav-sidebar {
        display: flex;
        flex-direction: column;
        padding: 0.5rem 0.75rem 1rem;
        gap: 1px;
    }

    /* ── Section Labels ── */
    .nav-section-label {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: rgba(148, 163, 184, 0.55);
        padding: 1.25rem 0.75rem 0.4rem;
        margin: 0;
        user-select: none;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .nav-section-label:first-child {
        padding-top: 0.5rem;
    }

    .nav-section-label.admin-label {
        color: rgba(251, 191, 36, 0.55);
        border-top: 1px solid rgba(251, 191, 36, 0.1);
        margin-top: 0.5rem;
        padding-top: 1rem;
    }

    /* ── Nav Items ── */
    .snav-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.55rem 0.75rem;
        border-radius: 0.5rem;
        color: rgba(203, 213, 225, 0.85);
        text-decoration: none !important;
        font-size: 0.825rem;
        font-weight: 500;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        cursor: pointer;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin: 1px 0;
    }

    .snav-link:hover {
        background: rgba(255, 255, 255, 0.06);
        color: #f1f5f9;
        text-decoration: none !important;
    }

    .snav-link:hover .snav-icon {
        color: #a5b4fc;
        transform: scale(1.1);
    }

    /* Active state */
    .snav-link.active {
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(139, 92, 246, 0.15));
        color: #e0e7ff;
        font-weight: 600;
        box-shadow: inset 3px 0 0 0 #818cf8;
    }

    .snav-link.active .snav-icon {
        color: #a5b4fc;
    }

    /* Sub-items (Create actions) */
    .snav-link.sub-link {
        padding-left: 2.25rem;
        font-size: 0.785rem;
        color: rgba(203, 213, 225, 0.6);
    }

    .snav-link.sub-link .snav-icon .mud-icon-root {
        font-size: 0.95rem !important;
    }

    .snav-link.sub-link:hover {
        color: #e0e7ff;
    }

    .snav-link.sub-link.active {
        color: #c7d2fe;
        box-shadow: inset 3px 0 0 0 #6366f1;
        background: rgba(99, 102, 241, 0.12);
    }

    /* ── Icons ── */
    .snav-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.25rem;
        height: 1.25rem;
        flex-shrink: 0;
        color: rgba(148, 163, 184, 0.65);
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .snav-icon .mud-icon-root {
        font-size: 1.15rem !important;
        color: inherit !important;
    }

    /* ── Text ── */
    .snav-text {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* ── Bottom spacer ── */
    .nav-bottom-spacer {
        height: 2rem;
        flex-shrink: 0;
    }

    /* ── Focus visible for keyboard nav ── */
    .snav-link:focus-visible {
        outline: 2px solid #818cf8;
        outline-offset: -2px;
    }

    /* ── Mini Drawer (collapsed) state ── */
    .mud-drawer--closed .nav-sidebar {
        padding: 0.5rem 0.15rem 1rem;
    }

    .mud-drawer--closed .nav-section-label {
        opacity: 0;
        max-height: 0;
        padding-top: 0;
        padding-bottom: 0;
        margin: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .mud-drawer--closed .snav-link {
        justify-content: center;
        gap: 0;
        padding: 0.6rem 0;
        border-radius: 0.5rem;
    }

    .mud-drawer--closed .snav-link.sub-link {
        padding-left: 0;
    }

    .mud-drawer--closed .snav-text {
        opacity: 0;
        max-width: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .mud-drawer--closed .snav-link.active {
        box-shadow: none;
        background: rgba(99, 102, 241, 0.2);
    }

    /* Smooth transitions when drawer opens/closes */
    .nav-section-label {
        transition: opacity 0.15s ease, max-height 0.15s ease, padding 0.15s ease;
        max-height: 3rem;
    }

    .snav-text {
        transition: opacity 0.15s ease 0.05s, max-width 0.2s ease;
        max-width: 200px;
    }

    .nav-sidebar {
        transition: padding 0.2s ease;
    }

    /* ── Scrollbar ── */
    .nav-sidebar::-webkit-scrollbar {
        width: 3px;
    }

    .nav-sidebar::-webkit-scrollbar-track {
        background: transparent;
    }

    .nav-sidebar::-webkit-scrollbar-thumb {
        background: rgba(148, 163, 184, 0.2);
        border-radius: 10px;
    }

    .nav-sidebar::-webkit-scrollbar-thumb:hover {
        background: rgba(148, 163, 184, 0.35);
    }

    /* ── Responsive ── */
    @@media (max-width: 640px) {
        .nav-sidebar {
            padding: 0.5rem;
        }

        .nav-section-label {
            font-size: 0.6rem;
            padding: 1rem 0.5rem 0.35rem;
        }

        .snav-link {
            padding: 0.5rem 0.6rem;
            font-size: 0.8rem;
        }
    }
</style>

